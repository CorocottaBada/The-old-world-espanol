                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Mover y disparar, Disparos múltiples (1D3)</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Una miniatura armada con un cañón de granizo de hierro no sufre modificadores negativos por disparar a larga distancia, por usar la regla especial Disparos Múltiples (1D3), o mientras realiza una reacción a la carga de Aguantar y Disparar.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="de9c-e373-7553-3568" name="Disparos múltiples (X)" hidden="false" targetId="e607-71b1-5742-3ec4" type="rule"/>
                <infoLink id="7ceb-a61c-e8b7-8e76" name="Mover y disparar" hidden="false" targetId="2b49-fb72-106a-1e56" type="rule"/>
