                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Ataques adicionales (+2D3), Golpea último</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma tiene dos perfiles, que representan las diferentes formas en que puede ser usada en combate. Debes elegir qué perfil usará el portador al inicio de cada ronda de combate.</characteristic>
                  </characteristics>
                </profile>
