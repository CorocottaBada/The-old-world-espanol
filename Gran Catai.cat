      <rules>
        <rule id="b91a-0b19-12f1-0064" name="Catafractos de Catai" hidden="false">
          <description>Cuando una unidad en la que la mayoría de las miniaturas tienen esta regla especial realiza un movimiento de Avance (follow up pone en el inglés), la unidad cuenta como si hubiera cargado durante el siguiente turno.</description>
        </rule>
      </rules>
