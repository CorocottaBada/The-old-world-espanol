        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c088-0ab7-fd37-a7ab" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a2ed-72d2-b170-7d2f" name="Armadura de Jade de Beichai" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="df1a-9655-bdf7-c915" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a364-50ac-470b-4299" type="max"/>
          </constraints>
          <profiles>
            <profile id="988e-b878-c381-8170" name="Armadura de Jade de Beichai" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Jade de Beichai es una armadura de placas completa. Además, el portador de la Armadura de Jade tiene una salvación Especial de 5+ contra cualquier herida sufrida y gana la regla especial Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="984d-cf75-d128-2208" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="aeab-59d7-5f19-4a65" name="Talismanes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8714-1d15-d70c-eed5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a83b-7f0a-3eda-3b90" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e500-d02b-ba11-5763" name="Corona de Jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a1f0-5a2a-a78d-59be" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e18-8e5c-6cb6-3af1" type="max"/>
          </constraints>
          <profiles>
            <profile id="8b8f-19dd-3945-0c68" name="Corona de Jade" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">La Corona de Jade otorga a su portador una salvación especial de 4+ contra cualquier herida sufrida que haya sido causada por un Proyectil Mágico, un Vórtice Mágico o un hechizo de Asalto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0c40-7204-2d6f-96cb" name="Escudo de Nan-Gau" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="43bc-d537-c151-2144" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0cd5-f7f4-ea69-3c1d" type="max"/>
          </constraints>
          <profiles>
            <profile id="1c38-94e1-4a83-def7" name="Escudo de Nan-Gau" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Escudo de Nan-Gau es un escudo. Además, durante un turno en el que su portador fue cargado, el Escudo de Nan-Gau mejora el valor de armadura de su portador en 2 (hasta un máximo de 2+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2212-9df4-a9c0-28ab" name="Escudo (Shield)" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e62a-e587-f567-f177" name="Sello de Humo y Pólvora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="db09-544f-7af1-c59a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="26ca-8101-8e05-36cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f5e-aa81-cc27-9aa5" name="Sello de Humo y Pólvora" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que designe como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="399a-33e8-22ab-0957" name="Cristal de Kunlan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0844-b059-795f-854d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="94ac-bb29-2c57-9564" type="max"/>
          </constraints>
          <profiles>
            <profile id="8afa-a5e1-531e-60e6" name="Cristal de Kunlan" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Cristal de Kunlan otorga a su portador una salvación especial de 5+. Además, si se obtiene un 6 natural al realizar la salvación especial, cada modelo enemigo en contacto peana con peana con el portador sufre un impacto de Fuerza 3 con un PA de -. Estos ataques tienen la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="58c1-09c7-c06c-b778" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d1c6-9113-9f9b-60b8" name="Talismanes muy comunes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="635a-c83b-9eb3-6129" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e567-e836-af58-f29c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e59b-00cc-7219-261f" name="Plumas Bermellón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="751c-ddd2-3d0f-2f8c" type="max"/>
          </constraints>
          <profiles>
            <profile id="ded7-817d-f47c-11a8" name="Plumas Bermellón" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">0-1 por miniatura. Un solo uso. El portador de una Pluma Bermellón (pero no su montura) puede repetir cualquier tirada fallida para Impactar y/o para Herir realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f9df-c05f-d9b7-745b" name="Talismanes. Gran Catai. Infantería o caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f242-8ac5-c075-f335" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="12bc-4026-84e1-c42d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c891-be32-3460-6a3d" name="El Manto del Cielo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5601-69bc-a924-b2d2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5cd7-f577-97e4-9757" type="max"/>
          </constraints>
          <profiles>
            <profile id="181e-66d7-ac9c-d722" name="El Manto del Cielo" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. Puede llevarse con otra armadura. El portador del Manto del Cielo mejora su valor de armadura en 2 (hasta un máximo de 2+) contra ataques de disparo no mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e164-0db0-a499-094b" name="Estandartes mágicos. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="34cc-941e-3947-1ae5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="62fa-e130-927e-b2db" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5e98-df7c-d023-253f" name="Estandarte de Wei-Jin" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d37f-5144-05c5-b1b2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f03-3f64-3e8e-ff87" type="max"/>
          </constraints>
          <profiles>
            <profile id="f1b0-ad5f-db4f-b0a0" name="Estandarte de Wei-Jin" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de Wei-jin causa Miedo. Además, todas las unidades enemigas a 12&quot; o menos de la miniatura que porta el Estandarte de Wei-jin sufren un modificador de -1 a su atributo de Liderazgo al realizar un chequeo de Miedo, Pánico o Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d1e2-7677-b3be-22dc" name="Icono de la Furia Celestial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="aaaa-c0ec-3a33-6662" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca3e-d8f5-3ed6-ae63" type="max"/>
          </constraints>
          <profiles>
            <profile id="d1f0-bd64-99d1-f99c" name="Icono de la Furia Celestial" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, el portador de este estandarte puede intentar desatar su poder haciendo un chequeo de Liderazgo (utilizando su propio Liderazgo sin modificar). Si se supera este chequeo, las unidades enemigas no pueden utilizar la regla especial Volar (X) hasta tu siguiente subfase de Inicio del Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b180-cba3-415b-e6ab" name="Estandarte del Ojo de Dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="28c9-571a-a015-ae36" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="38dd-8621-b09e-4683" type="max"/>
          </constraints>
          <profiles>
            <profile id="537d-5abe-7bc2-934f" name="Estandarte del Ojo de Dragón" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando un Hechicero enemigo elige como objetivo de un hechizo a una unidad que porta el Estandarte del Ojo de Dragón, tira un 1D6. Con un 4+, el jugador controlador del Hechicero debe elegir otro objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0779-3468-607d-be54" name="Estandarte del Bastión" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="845b-22f5-595e-53f5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b5e6-71cd-2a70-e715" type="max"/>
          </constraints>
          <profiles>
            <profile id="aac6-1b9e-3163-26f7" name="Estandarte del Bastión" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte del Bastión gana la regla especial Muro de Escudos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e217-a180-dda1-0b99" name="Muro de escudos (Shieldwall)" hidden="false" targetId="8782-fdac-65da-b2f9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1f85-a2e7-2821-04b4" name="Estandarte de la Ira del Dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="29b6-b810-fbc4-c348" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4d81-53d6-6027-4817" type="max"/>
          </constraints>
          <profiles>
            <profile id="939a-8193-be6b-61dc" name="Estandarte de la Ira del Dragón" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de la Ira del Dragón gana las reglas especiales Ataques Flamígeros e Impactos por Carga (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d9a5-66fe-eab5-51f4" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="d62d-1a1f-80e5-8e60" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="357f-19e8-c3ac-dc20" name="El Estandarte de Jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="03b9-9085-30b5-64df" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="042b-b893-a41c-8c65" type="max"/>
          </constraints>
          <profiles>
            <profile id="cf75-d7f0-3a04-73bd" name="El Estandarte de Jade" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado de combate, una unidad que porte el Gran Estandarte de la Superioridad puede reclamar una bonificación adicional de +2 puntos al resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b238-7338-d827-3f71" name="El Sudario de Shiyama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7412-2879-65f3-ba5b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3084-863e-9fa8-11db" type="max"/>
          </constraints>
          <profiles>
            <profile id="d7e1-b4f8-84ca-8171" name="El Sudario de Shiyama" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Sudario de Shiyama gana la regla especial Miedo. Si ya tienen la regla especial Miedo, en su lugar ganan la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b344-c673-22ba-d653" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8e75-bb5b-f645-9a75" name="El Estandarte de Xen Wun" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ff2-3025-132e-84eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1bbc-ee33-6ce3-c361" type="max"/>
          </constraints>
          <profiles>
            <profile id="1db3-5013-b043-44bd" name="El Estandarte de Xen Wun" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Las unidades enemigas que deseen declarar una reacción a la carga de Aguantar y Disparar o Disparar y Huir contra una unidad que porte el Estandarte de Xen Wun deben primero superar un chequeo de Liderazgo. Si se supera este chequeo, pueden declarar una reacción a la carga de Aguantar y Disparar o Disparar y Huir. Si se falla este chequeo, deben Mantener la Posición.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8966-8c43-641d-f99e" name="Objetos hechizados. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9704-44d0-b39c-9f50" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="75f0-517f-03e9-94b2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9354-43de-c475-170e" name="Fragmento de las Fauces" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9c8e-b45c-ccc7-151b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0358-a4f5-8eec-2de3" type="max"/>
          </constraints>
          <profiles>
            <profile id="7fd0-b99c-a5d7-dfa3" name="Fragmento de las Fauces" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Si un Hechicero enemigo saca cualquier doble natural al hacer una tirada de Lanzamiento mientras esté a 18&quot; o menos del portador del Fragmento de las Fauces, el hechizo sufre una disfunción, independientemente del resultado de la tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="236c-e3f7-6ade-3a50" name="Máscara del Alquimista" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0a5b-1c87-91e9-f05d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5d42-1b89-a288-2a90" type="max"/>
          </constraints>
          <profiles>
            <profile id="7046-f066-756b-fdb7" name="Máscara del Alquimista" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de la Máscara del alquimista puede lanzar el hechizo Plaga de Óxido del saber del Elementalismo (ver página 327 del reglamento de Warhammer: the Old World) como un Hechizo Vinculado, con un Nivel de Energía de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c29b-b761-15da-7316" name="León Dorado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6cb7-546f-a3d4-e131" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8cb0-5d50-e1e3-5184" type="max"/>
          </constraints>
          <profiles>
            <profile id="be98-a549-498b-8b77" name="León Dorado" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del León Dorado y su unidad pueden repetir cualquier chequeo de Miedo, Pánico, Reagruparse o Terror fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5369-c97b-3822-9862" name="Anillo de Azabache" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="acaf-0fde-1e9b-a511" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8538-c712-6245-6421" type="max"/>
          </constraints>
          <profiles>
            <profile id="9bcf-3c74-8225-0558" name="Anillo de Azabache" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Anillo de Azabache puede lanzar el hechizo Espíritus Inquietos del Saber de la Nigromancia (ver página 333 del reglamento de Warhammer: the Old W orld) como un Hechizo Vinculado, con un Nivel de Energía 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1444-e748-e6ed-3590" name="Objetos hechizados muy comunes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1a99-298a-efca-25d8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bd36-cca7-680a-398d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ff48-a813-4b51-73d4" name="Linterna Espiritual" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cec3-2337-5823-1270" type="max"/>
          </constraints>
          <profiles>
            <profile id="7c05-4c19-99c7-0344" name="Linterna Espiritual" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un modelo que porte una Linterna Espiritual causa Terror. Además, una miniatura que porte una Linterna Espiritual puede repetir cualquier tirada para Herir de un 1 natural contra miniaturas enemigas que sean &apos;Demoníacos&apos; o &apos;No Muertos&apos;.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8f06-ecbe-7f74-2fe0" name="Terror (Terror)" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d001-c8a4-9d89-3bc5" name="Los Fuegos de Nan-Gau" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8abe-7f36-afa0-6bc1" type="max"/>
          </constraints>
          <profiles>
            <profile id="fd85-82cb-f54a-3178" name="Los Fuegos de Nan-Gau" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">0-1 por miniatura. Un solo uso. Los Fuegos de Nan-Gau es un arma de aliento con el siguiente perfil:</characteristic>
              </characteristics>
            </profile>
            <profile id="de7d-5a10-5473-c968" name="Los Fuegos de Nan-Gau" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">N/A</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Arma de Aliento, Ataques Flamígeros, Ataques Mágicos</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2d8b-2b95-d55f-8112" name="Arma de aliento (Breath weapon)" hidden="false" targetId="28ba-f733-cc16-d9e7" type="rule"/>
            <infoLink id="dfc8-10c4-76f4-65db" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="3a03-5556-e037-94da" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
