                <characteristic name="HA" typeId="983a-64b8-c41c-9267">3</characteristic>
                <characteristic name="HP" typeId="4915-ded6-bab4-124b">5</characteristic>
                <characteristic name="F" typeId="885a-9316-aa84-2715">3</characteristic>
                <characteristic name="R" typeId="35d9-aa07-76fc-5df8">-</characteristic>
                <characteristic name="H" typeId="57a0-b9e1-a78b-394e">-</characteristic>
