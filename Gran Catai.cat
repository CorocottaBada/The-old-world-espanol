              </costs>
            </selectionEntry>
            <selectionEntry id="a2d6-231b-d972-94ce" name="Centinela de Obsidiana" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6195-75e0-0aae-aeb3" type="max"/>
              </constraints>
              <profiles>
                <profile id="7f0f-f33f-7450-067a" name="Centinela de Obsidiana" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Obsidiana tiene la regla especial Resistencia a la Magia (-2). Además, cualquier Hechicero enemigo que desee lanzar un hechizo mientras esté a 12&quot; o menos de uno o más Centinelas de Obsidiana debe primero superar un chequeo de Liderazgo. Si se falla este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -3. Si se supera este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -1.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="b6ae-51e8-2478-0a93" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="303c-62e7-da86-65cd" name="Centinela de Granito" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b612-866e-c5bd-74bf" type="max"/>
              </constraints>
              <profiles>
                <profile id="4cd2-edbc-95f1-568b" name="Centinela de Granito" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Granito mejora su valor de armadura en 1. Además, un Centinela de Granito es inmune a la regla especial Heridas Múltiples (X). Si un Centinela de Granito sufre una herida no salvada de un ataque con esta regla especial, pierde una única Herida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="f652-4804-62d1-1460" name="Centinela de Piedra de disformidad" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a611-4b80-a111-082a" type="max"/>
              </constraints>
              <profiles>
                <profile id="1b3f-6ac1-95f0-ec2f" name="Centinela de Piedra de disformidad" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Piedra de Disformidad tiene la regla especial Ataques Mágicos. Además, mientras esté en contacto peana con peana con uno o más Centinelas de Piedra de Disformidad, las unidades enemigas sufren un modificador de -1 a su atributo de Resistencia (hasta un mínimo de 1).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="6e1c-c0a2-1cda-01d4" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
