        <selectionEntryGroup id="31f7-662e-f0a1-2782" name="Opciones" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="749c-7506-f830-7b90" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ad46-2a17-4aca-9fe6" type="max"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="7397-bcf0-fc50-9030" name="Centinela de Jade" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="90ac-9666-e4a7-325d" type="max"/>
              </constraints>
              <profiles>
                <profile id="8343-1419-74a4-735c" name="Centinela de Jade" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Jade conoce un único hechizo (elegido por su jugador controlador antes de desplegar los ejércitos) del Saber de la Magia de Batalla o del Saber de Elementalismo. Puede lanzar este hechizo como un Hechizo Vinculado con un Nivel de Energía 3.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="3a70-59d2-bdc1-a515" name="Centinela de Terracota" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="94a0-cc59-6769-a5af" type="max"/>
              </constraints>
              <profiles>
                <profile id="60a7-46d8-dbe8-75a7" name="Centinela de Terracota" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Terracota tiene la regla especial Regeneración (6+).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="8071-f583-b1a6-ec4c" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="fd1a-0460-d222-aaa4" name="Centinela de Obsidiana" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7aea-3bad-d8cb-1043" type="max"/>
              </constraints>
              <profiles>
                <profile id="6d1c-e36e-b727-2dd8" name="Centinela de Obsidiana" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Obsidiana tiene la regla especial Resistencia a la Magia (-2). Además, cualquier Hechicero enemigo que desee lanzar un hechizo mientras esté a 12&quot; o menos de uno o más Centinelas de Obsidiana debe primero superar un chequeo de Liderazgo. Si se falla este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -3. Si se supera este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -1.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="95d7-4037-9b5c-b335" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="f278-0420-0912-ebb3" name="Centinela de Granito" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df8e-b283-d465-a13c" type="max"/>
              </constraints>
              <profiles>
                <profile id="76ec-3389-69e6-6554" name="Centinela de Granito" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Granito mejora su valor de armadura en 1. Además, un Centinela de Granito es inmune a la regla especial Heridas Múltiples (X). Si un Centinela de Granito sufre una herida no salvada de un ataque con esta regla especial, pierde una única Herida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="6541-608c-5782-4d3b" name="Centinela de Piedra de disformidad" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6fe7-d33b-1705-bc2e" type="max"/>
              </constraints>
              <profiles>
                <profile id="df81-92bb-85ac-d22f" name="Centinela de Piedra de disformidad" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Piedra de Disformidad tiene la regla especial Ataques Mágicos. Además, mientras esté en contacto peana con peana con uno o más Centinelas de Piedra de Disformidad, las unidades enemigas sufren un modificador de -1 a su atributo de Resistencia (hasta un mínimo de 1).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="0477-aa74-7bca-7f45" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
