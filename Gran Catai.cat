          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="47ba-43e3-b750-7e21" name="Objetos arcanos. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
