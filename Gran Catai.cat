            <selectionEntry id="7f64-1664-bb6e-956c" name="Gran cañón" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d8c-be0e-0f0e-d9ef" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fc24-bfe6-5535-e203" type="min"/>
              </constraints>
              <profiles>
                <profile id="8486-b6bb-5415-296c" name="Gran cañón" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">48&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">10</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-3</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (3), Disparo de cañón, Aparatoso, Mover o disparar, Heridas múltiples (1D3+1), Impacto atronador</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma no utiliza la Habilidad de Proyectiles de su dotación. En su lugar, dispara usando la regla especial &apos;Disparo de Cañón&apos;. Esta arma utiliza la Tabla de Problemas de la Pólvora Negra.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="3c24-611a-31c2-e86f" name="Impacto atronador" hidden="false">
                  <description>Hasta tu siguiente subfase de Inicio de Turno, cualquier unidad (amiga o enemiga) que estuviera a 2D6&quot; o menos del punto de impacto cuando un gran cañón de Catai dispara sufre un modificador de -1 a su atributo de Movimiento y no puede usar la regla especial Zancada Veloz.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="04ee-e9c7-f03d-ba6f" name="Disparo de cañón" hidden="false" targetId="82ea-9e9a-631d-9bae" type="rule"/>
                <infoLink id="f0ee-57a2-842d-3877" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="b928-effb-d731-b48d" name="Mover o disparar" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="cc8e-b25e-7a88-9458" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
                <infoLink id="b0d9-3fdb-1cf4-c57d" name="Tabla de problemas de armas de pólvora" hidden="false" targetId="92b8-a4f7-bcd6-8b2c" type="rule"/>
                <infoLink id="8dbd-a189-2ba1-4296" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
              </infoLinks>
