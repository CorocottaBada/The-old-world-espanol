              <rules>
                <rule id="7e26-0569-6dda-5a67" name="Espíritus aullantes" hidden="false">
                  <description>Cualquier unidad que sufra una o más heridas no salvadas por esta arma debe hacer un chequeo de Pánico como si hubiera sufrido muchas bajas.</description>
