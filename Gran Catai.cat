    <selectionEntry id="725f-617b-f83d-32c1" name="Matriarca Suprema de Nan-Gau Guerreros jade" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="39aa-f9ac-e9df-d0b4" type="equalTo"/>
