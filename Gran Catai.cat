          <selectionEntries>
            <selectionEntry id="fcf8-ea14-c453-9bdc" name="Centinela de Jade" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d882-3994-4692-8ae2" type="max"/>
              </constraints>
              <profiles>
                <profile id="e7eb-f5d6-23a8-7553" name="Centinela de Jade" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Jade conoce un único hechizo (elegido por su jugador controlador antes de desplegar los ejércitos) del Saber de la Magia de Batalla o del Saber de Elementalismo. Puede lanzar este hechizo como un Hechizo Vinculado con un Nivel de Energía 3.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="47d2-041a-c868-4980" name="Centinela de Terracota" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f2e-6713-1658-b208" type="max"/>
              </constraints>
