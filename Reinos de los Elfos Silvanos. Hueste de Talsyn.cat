    <selectionEntry id="c5e9-81d8-3ed3-2ba9" name="Montaraces del Bosque Salvaje" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="e836-5d0b-a69c-612d" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="e836-5d0b-a69c-612d" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e836-5d0b-a69c-612d" type="max"/>
      </constraints>
      <rules>
        <rule id="f7e2-05fd-7ede-ea95" name="Guardianes del Bosque Salvaje" hidden="false">
          <description>Mientras está en contacto peana con peana con una miniatura enemiga que causa Miedo o Terror, una miniatura con esta regla especial obtiene un modificador +1 a su atributo de Ataques (hasta un máximo de 10) y a la regla especial Heridas múltiples (2).</description>
        </rule>
      </rules>
      <infoLinks>
