        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6cc1-53aa-4f48-06d9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2694-ea26-d87f-de99" name="Manto de Railarian" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="64a9-6237-c9fc-15eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ba49-29c0-8fd5-ce2e" type="max"/>
          </constraints>
          <profiles>
            <profile id="78f1-4c41-6162-af4c" name="Manto de Railarian" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Manto de Railarian es una armadura ligera. Además, mientras su portador se encuentra a 6” o menos de un elemento de escenografía de tipo Bosque, tiene una Salvación Especial de 4+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ca14-3d68-d6a4-bd5e" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="098e-1359-aec9-6259" name="Manto del renacer" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="74f6-47f8-8b87-cd68" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4804-ec4c-ae29-6469" type="max"/>
          </constraints>
          <profiles>
            <profile id="625d-daf9-2930-9398" name="Manto del renacer" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Manto del Renacer es una armadura ligera. Además, su portador obtiene la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e6ae-251d-7e65-d423" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
            <infoLink id="e96b-91d2-19c1-9804" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
