        <selectionEntry id="ea88-a369-49db-df5a" name="Arco de Loren" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="996d-3555-e6c8-ea32" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="067e-98a9-95c4-4401" type="max"/>
          </constraints>
          <profiles>
            <profile id="4dad-6145-f6a4-f7db" name="Arco de Loren" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">32&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco de Loren cuenta como un arco largo Asrai. En lugar de lo habitual, el portador del Arco de Loren puede realizar un número de ataques de disparo igual a su atributo de Ataques. Esta miniatura no sufre ningún modificador por realizar disparos múltiples.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8d6f-9d8d-dcbc-fa04" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="3f8f-78ec-74e8-f242" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d1b3-ca7b-1cef-61ce" name="Maldición de Asyendi" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="12db-c125-d4e7-6693" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="419f-6693-5627-3094" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb85-6396-3f5d-bef6" name="Maldición de Asyendi" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">32&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos, Disparo rápido.</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Maldición de Aseyendi cuenta como un arco largo Asrai. El portador de la Maldición de Asyendi puede repetir una única tirada fallida para Impactar realizada durante la fase de Disparo. Sin embargo, si la repetición tampoco impacta, el portador sufre un único impacto de Fuerza 3 con una PA de -.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8b69-74b1-e7a9-7c80" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="6b56-e339-5c6e-afda" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="4fd2-50a7-b449-8678" name="Disparo rápido (Quick shot)" hidden="false" targetId="ae60-f2dc-28d3-2489" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a7a5-44e8-367c-6a4f" name="Ira de Vaul" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9e19-77c6-2614-b66b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee3c-5724-2cd0-2575" type="max"/>
          </constraints>
          <profiles>
            <profile id="96cb-1a29-206f-2b61" name="Ira de Vaul" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">32&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques flamígeros, Ataques mágicos, Heridas múltiples (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Una vez por partida, a menos que el portador se haya movido durante la fase de Movimiento anterior, la Ira de Vaul puede dispararse como un lanzavirotes, utilizando la regla especial ‘Atravesar Filas‘ (ver página 223 del reglamento de Warhammer: the Old World).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="07b5-eaa5-f676-0165" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
            <infoLink id="de63-9c55-4c89-74b1" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="64ce-bb6b-a6f8-7e08" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="fbed-c31d-f161-861a" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8b85-4054-7fba-c0cb" name="La hoja de Daith" hidden="false" collective="false" import="true" type="upgrade">
