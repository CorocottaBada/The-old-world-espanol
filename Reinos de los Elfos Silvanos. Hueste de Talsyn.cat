      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b85a-976f-96c9-9417" type="max"/>
      </constraints>
      <rules>
        <rule id="2690-70a2-c1ab-84c3" name="Hijas de la eternidad" hidden="false">
          <description>Las miniaturas con esta regla especial tienen una Salvación Especial de 4+ contra cualquier herida sufrida.</description>
        </rule>
        <rule id="1de4-8a36-2cd4-938d" name="Aquelarre de Bosque Profundo" hidden="false">
          <description>Una unidad de Hermanas del Espino conoce un único hechizo generado aleatoriamente de los saberes de la Magia de Batalla o Elementalismo. Si lo deseas, este hechizo puede ser descartado y la unidad puede elegir el hechizo identificativo del Saber de Magia seleccionado. La unidad puede lanzar este hechizo como un Hechizo Vinculado:
Si la unidad incluye una Doncella del Espino, puede lanzar este Hechizo Vinculado con un Nivel de Energía 1.
Si incluye tanto una Doncella del Espino como un portaestandarte, puede lanzar este Hechizo Vinculado con un Nivel de Energía 2.
De lo contrario, la unidad puede lanzar este Hechizo Vinculado con un Nivel de Energía 0.</description>
        </rule>
      </rules>
