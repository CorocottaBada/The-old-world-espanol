                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">El Manto de Isha otorga a Orión una Salvación Especial de 5+. Además, durante cada una de tus subfases de Inicio de Turno, tira 1D6. Con un resultado de 5+, Orión recupera una única Herida perdida anteriormente durante la batalla.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
