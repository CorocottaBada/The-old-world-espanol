            <profile id="25b5-c5ee-5502-e526" name="Un corro de tánganos" hidden="false" typeId="e648-dafd-3c29-fef9" typeName="Duende y Hada">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">Solo Nobles Elfos Silvanos y Acechadores de Caminos. Una miniatura enemiga impactada por uno o más ataques de disparo realizados por el arco largo Asrai de esta miniatura sufre 1D3 impactos adicionales de Fuerza 2, cada uno con una PA de -. Estos impactos tienen la regla especial Perforacorazas (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="da02-76a5-9a58-7f4a" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
