              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Solo ‘Infantería’ o ‘caballería’. Un personaje que adopta el Aspecto del Oso aumenta sus atributos de Fuerza y Resistencia en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
