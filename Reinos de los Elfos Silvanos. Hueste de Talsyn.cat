          <profiles>
            <profile id="5c37-ab76-cefe-a304" name="Aspecto del sabueso" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un personaje que adopta el Aspecto del Sabueso, y cualquier unidad a la que se haya unido, puede repetir cualquier tirada para Impactar natural de 1 durante la fase de Combate.</characteristic>
