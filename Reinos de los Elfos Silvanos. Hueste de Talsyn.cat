            <profile id="bd62-dc27-c9bc-b323" name="Favor de Orión" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un Solo Uso. El portador del Favor de Orión puede repetir cualquier tirada para Impactar y/o para Herir fallida realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0aea-e6cb-838c-e590" name="Objetos hechizados. Elfos silvanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c479-038c-41ea-c08c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dc65-317e-3bcd-1289" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c391-55d0-2e5a-9273" name="Piedra espectral" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9aef-9402-5383-2e22" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8585-e7bc-666d-e3cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="cd8a-f9db-8218-e7bd" name="Piedra espectral" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">A menos que el portador de la Piedra Espectral esté huyendo, las unidades enemigas sufren un modificador de -1 a su atributo de Liderazgo (hasta un mínimo de 2) mientras están a 6” o menos del portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="11b6-da9a-d226-e299" name="Corona de Astas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9a70-1108-fe75-9d24" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="18cf-0b00-716b-fad8" type="max"/>
          </constraints>
          <profiles>
            <profile id="ee0b-ca0c-6c22-8392" name="Corona de Astas" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">La Corona de Astas otorga a su portador la regla especial Perforacorazas (1) e Impactos por Carga (1D3). Este Impacto por Carga tiene un atributo de Perforación de Armadura de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="28dc-f825-b3ae-3c27" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
            <infoLink id="5236-c4a1-3d74-4379" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0b4b-d484-ee86-ad3d" name="Piedra lunar de los caminos ocultos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="36cf-a3ed-68f6-c1a1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b69b-46c8-3b2a-014f" type="max"/>
          </constraints>
          <profiles>
            <profile id="a81f-ff5b-1d88-b4b1" name="Piedra lunar de los caminos ocultos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un Solo Uso. El portador de la Piedra Lunar de los Caminos Ocultos puede lanzar el hechizo Caminante Forestal del Saber de Athel Loren (ver página 80) como un Hechizo Vinculado con un Nivel de Energía de 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ecbf-8053-63c6-0b5f" name="Objetos hechizados muy comunes. Elfos silvanos. Arco largo Asrai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d2b6-6781-55f5-d23b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f68b-f4cd-d32a-fbc4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3fa4-c0b7-c9f1-d2c7" name="Flecha lluvia de muerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ebac-2c8d-aa4c-ec8b" type="max"/>
          </constraints>
          <profiles>
            <profile id="673e-0730-bfc2-488e" name="Flecha lluvia de muerte" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Solo miniaturas con arco largo Asrai. Se puede disparar una Flecha de Lluvia de Muerte de forma normal desde el arco largo Asrai del portador. Si la tirada para Impactar tiene éxito, coloque una Plantilla de Área Pequeña (3”) de modo que su orificio central quede directamente sobre el centro de la unidad objetivo. Cualquier miniatura cuya peana se encuentre debajo de la plantilla corre el riesgo de ser impactada y sufrir un único impacto de Fuerza 4 con una PA de -1 y la regla especial de Ataques Mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9df1-e1d7-388e-8169" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="13da-6ac9-af03-48df" name="Flecha de los lamentos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8dfc-d735-14d5-686e" type="max"/>
          </constraints>
          <profiles>
            <profile id="111e-92ee-7a47-3448" name="Flecha de los lamentos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Solo miniaturas los con arco largo Asrai. Se puede disparar una Flecha de los Lamentos de forma normal desde el arco largo Asrai del portador. Cualquier unidad que sufra una herida no salvada por este disparo debe hacer un chequeo de pánico como si hubiera sufrido muchas bajas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="469a-9b69-fed2-58bb" name="Flechas de punta contaminada" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cfe6-c528-428d-7e15" type="max"/>
          </constraints>
          <profiles>
            <profile id="1b52-bdb6-8113-c4c3" name="Flechas de punta contaminada" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Solo miniaturas con arco largo Asrai. Una Flecha de Punta Contaminada puede dispararse normalmente desde el arco largo Asrai del portador. Si una miniatura enemiga sufre una herida no salvada de una Flecha de Punta Contaminada, al comienzo de cada subfase de Inicio de Turno subsiguiente, esa miniatura debe realizar un chequeo de Resistencia. Si falla el chequeo, la miniatura sufre inmediatamente una única herida sin salvaciones por armadura o Regeneración permitidas (las salvaciones Especiales pueden intentarse como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f9cf-9b49-7cc6-2fbf" name="Objetos arcanos. Elfos silvanos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8df0-cb94-05b5-d608" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ae4-f04e-fedd-0945" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8e1c-cef7-b0da-7043" name="Vara de olmo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ab11-ad56-2f08-8ba4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5d40-eac5-dd2f-ea63" type="max"/>
          </constraints>
          <profiles>
            <profile id="cc42-2a5c-5d51-eeda" name="Vara de olmo" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, si se encuentra a 3” o menos de un elemento de escenografía de tipo Bosque, el portador de la Vara de Olmo puede repetir una Tirada de Lanzamiento fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="204f-2125-8824-e3e5" name="Bastón de roble" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8560-e885-9497-012e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1032-45bb-54b8-1d60" type="max"/>
          </constraints>
          <profiles>
            <profile id="7d8f-863b-dd7f-31a3" name="Bastón de roble" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Mientras que se encuentre a 3” o menos de un elemento de escenografía de tipo Bosque, el portador del Bastón de Roble aumenta su alcance de dispersión en 3”. Además, mientras se encuentre a 3” o menos de un elemento de escenografía de tipo Bosque, el portador puede tirar 1D6 adicional al hacer la Tirada de dispersión y descartar el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c8e0-9c11-0cde-8355" name="Orbe del Bosque Profundo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fe5c-ef58-0311-93d6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e7b-a89d-b2ec-aa91" type="max"/>
          </constraints>
          <profiles>
            <profile id="aec0-f626-65f3-7fab" name="Orbe del Bosque Profundo" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">A menos que el portador del Orbe del Bosque Profundo esté huyendo o participando en combate, puede usarla cuando un Hechicero enemigo que esté a 6” o menos de un elemento de escenografía de tipo Bosque lance un hechizo con éxito. Si lo hace, no se puede hacer ningún intento de dispersión y el hechizo se lanza normalmente. Una vez que el hechizo se ha resuelto, el Hechicero enemigo sufre inmediatamente 1D3 impactos de Fuerza 4, cada uno con una PA de -1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3ee8-4943-459a-d5b9" name="Orbe del solsticio de verano" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8c28-b3fb-508e-8b8a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="adbd-4037-527c-3bca" type="max"/>
          </constraints>
          <profiles>
            <profile id="11e5-4a9a-8b7e-0411" name="Orbe del solsticio de verano" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, el portador del Orbe del Solsticio de Verano puede repetir una Tirada de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5782-faa0-5405-afaf" name="Sello de la Reina hechicera" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="62b7-e1c8-a71c-b071" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f09c-825c-a172-f926" type="max"/>
          </constraints>
          <profiles>
            <profile id="5354-06a3-8c17-a6ed" name="Sello de la Reina hechicera" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un Solo Uso. El portador del Sello de la Reina Hechicera puede usarlo antes de realizar una Tirada de lanzamiento. Si lo hace, puede aplicar un modificador de +2 a esa tirada de Lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d35c-38c3-683a-279d" name="Colgante de Duramen" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6819-e4a9-6a48-3127" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f80c-2e64-bfd2-e7d2" type="max"/>
          </constraints>
          <profiles>
            <profile id="334e-2a92-0a56-442e" name="Colgante de Duramen" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Además de los Saberes de la Magia que normalmente pueden conocer, el portador de un Colgante de Duramen puede conocer hechizos del Saber de lo Salvaje (ver página 88).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f0fa-a9ee-69ea-6d3b" name="Estirpes nobles. Nobles. Corcel o Gran ciervo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="04ad-cf5a-dbc3-dc86" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fbcc-b6dd-3a80-d09e" name="Estirpe de jinetes salvajes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8609-561a-d67f-a288" type="max"/>
          </constraints>
          <profiles>
            <profile id="58af-62a4-744f-dd5f" name="Estirpe de jinetes salvajes" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Solo Nobles Elfos Silvanos. Un personaje que pertenece a la Estirpe de los Jinetes Salvajes debe estar montado en un Corcel Élfico o Gran Ciervo y solo puede llevar armadura ligera. Además, ganan las reglas especiales Contracarga, Furia, Carga Devastadora y Tatuajes Talismánicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b451-a19c-6c18-97ee" name="Tatuajes talismánicos" hidden="false" targetId="b840-235e-c02f-7276" type="rule"/>
            <infoLink id="df1c-a550-9f8c-274d" name="Carga devastadora" hidden="false" targetId="768a-7271-1e00-6be5" type="rule"/>
            <infoLink id="9f40-e2c7-5222-3358" name="Furia asesina" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
            <infoLink id="374b-d0ed-81fd-eb18" name="Contracarga" hidden="false" targetId="4ed0-6ae1-04ef-a764" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7d85-af3e-e475-3b16" name="Estirpes nobles. Magos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="369c-c932-e8c3-abaa" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ee29-d7e3-3b4e-e49a" name="Estirpe del tejedor de encantamientos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c77-332f-e580-b704" type="max"/>
          </constraints>
          <profiles>
            <profile id="b37e-2911-d687-3a56" name="Estirpe del tejedor de encantamientos" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Solo Magos Elfos Silvanos. Un personaje que pertenece a la Estirpe del Tejedor de Encantamientos obtiene una salvación especial de 5+ y gana la regla especial Espíritu del Bosque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d471-42fd-f99c-bd68" name="Espíritu del bosque" hidden="false" targetId="2168-1040-390a-2ca8" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="cee6-d8b9-ec59-8dd9" name="Estirpes nobles. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="71cd-cbbe-6bd5-6dec" type="max"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a831-08c2-ff70-c884" name="Estirpe eterna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf8a-bc62-ad74-9bbb" type="max"/>
          </constraints>
          <profiles>
            <profile id="d669-6e43-5d3d-c127" name="Estirpe eterna" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Solo ‘Infantería’. Un personaje que pertenece a la Estirpe Eterna, y cualquier unidad a la que se haya unido, puede repetir cualquier tirada para Impactar natural de 1 durante la fase de Combate. Además, un personaje que pertenece a la Estirpe Eterna, y cualquier unidad a la que se haya unido, puede repetir cualquier tirada para Herir fallida durante la fase de Combate mientras esté a 6” de un elemento de escenografía especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9fa0-41fd-45af-c7a4" name="Estirpe de exploradores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="334d-e092-8aca-594c" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b27-5ea7-3327-09be" name="Estirpe de exploradores" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Solo ‘Infantería’. Un personaje que pertenece a la Extirpe de Exploradores gana las reglas especiales Disparo Rápido y Exploradores.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1dc9-4d2e-7386-091a" name="Exploradores" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
            <infoLink id="3476-e231-1493-3f34" name="Disparo rápido" hidden="false" targetId="ae60-f2dc-28d3-2489" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3331-4ff7-62c1-ad09" name="Estirpes alter. Infantería o caballería" hidden="false" collective="false" import="true">
