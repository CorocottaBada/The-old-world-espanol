        <characteristic name="Reglas especiales" typeId="3dee-daab-e63d-5c37">Un arco largo Asrai con Flechas Certeras tiene las reglas especiales Ignora Cobertura y Disparo Rápido.</characteristic>
      </characteristics>
    </profile>
    <profile id="c576-15be-cc37-cf85" name="Espadillas arcanas" hidden="false" typeId="4f10-ed62-fdb5-b352" typeName="Flecha encantada">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="3dee-daab-e63d-5c37">Un arco largo Asrai con Espadillas Arcanas tiene una PA de -2.</characteristic>
      </characteristics>
    </profile>
    <profile id="b383-bd1c-7d98-530d" name="Arco largo Asrai" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">32&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Andanada</characteristic>
