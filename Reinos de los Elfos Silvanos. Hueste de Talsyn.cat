        </selectionEntry>
        <selectionEntry id="cb40-f283-7139-dfd1" name="Espadas de Loec" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9605-7bf3-9c10-2739" type="max"/>
