                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">18&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (1D3)</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza de Kurnous tiene dos perfiles, que representan cómo se usa esta arma en combate. La Lanza de Kurnous dispara como un lanzavirotes, utilizando la regla especial Atravesar Filas (ver página 223 del reglamento de Warhammer: the Old World).</characteristic>
                  </characteristics>
                </profile>
                <profile id="8cfc-116b-738f-750c" name="Lanza de Kurnous (combate)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (1D3)</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza de Kurnous tiene dos perfiles, que representan cómo se usa esta arma en combate. La Lanza de Kurnous dispara como un lanzavirotes, utilizando la regla especial Atravesar Filas (ver página 223 del reglamento de Warhammer: the Old World).</characteristic>
                  </characteristics>
                </profile>
