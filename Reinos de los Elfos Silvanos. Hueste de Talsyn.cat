            <selectionEntry id="5ec1-38e0-f093-4571" name="Cuerno de cacería salvaje" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ae5d-d361-369c-c945" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8573-1657-181e-5ba0" type="min"/>
              </constraints>
              <profiles>
                <profile id="3cb2-0bb5-16b3-6010" name="Cuerno de la cacería salvaje" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Una vez por partida, durante la subfase de Mando de su turno, Orión puede hacer sonar el Cuerno de la Cacería Salvaje. Si lo hace, hasta el final de este turno, las unidades amigas dentro del Aura de Mando de Orión ganan la regla especial Furia Asesina. Una unidad puede volverse Furiosa de esta manera incluso si ha perdido la Furia Asesina anteriormente durante la partida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="c616-c0d2-c3e2-e942" name="Furia asesina (Frenzy)" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
