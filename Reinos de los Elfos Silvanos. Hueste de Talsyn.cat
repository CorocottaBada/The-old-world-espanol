          </constraints>
          <profiles>
            <profile id="b41c-c7e3-017f-4629" name="El lamento de la Aldaboneras" hidden="false" typeId="e648-dafd-3c29-fef9" typeName="Duende y Hada">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">A menos que esta miniatura esté huyendo, las unidades enemigas que se encuentran a 6” o menos de esta miniatura sufren un modificador de -1 a su atributo de Liderazgo al realizar un chequeo de Miedo, Pánico o Terror (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4076-5095-3d61-0e1b" name="Los molestos geniecillos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e28-2e63-e4dc-d8e1" type="max"/>
          </constraints>
          <profiles>
            <profile id="4915-99b1-3b1d-b3e0" name="Los molestos geniecillos" hidden="false" typeId="e648-dafd-3c29-fef9" typeName="Duende y Hada">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">Mientras esta miniatura esté en un Desafío, su oponente en el desafío sufre un modificador de -1 en sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0f81-ffbe-b12d-fd22" name="La luz de las hadas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1347-dfec-c907-eba9" type="max"/>
          </constraints>
          <profiles>
            <profile id="296a-15dc-2481-85ea" name="La luz de las hadas" hidden="false" typeId="e648-dafd-3c29-fef9" typeName="Duende y Hada">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">Esta miniatura y cualquier unidad a la que se haya unido ganan la regla especial Ataques Mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ff5e-460d-acc8-622f" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
