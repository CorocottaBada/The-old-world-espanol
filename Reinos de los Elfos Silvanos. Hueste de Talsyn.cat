              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">Esta miniatura y cualquier unidad a la que se haya unido gana la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
