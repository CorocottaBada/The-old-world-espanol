      <selectionEntries>
        <selectionEntry id="4eb7-a324-adac-d8e2" name="Una plaga de trasgos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01f6-37a5-54b9-12e5" type="max"/>
          </constraints>
