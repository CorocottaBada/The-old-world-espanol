              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado de combate, una unidad que lleve el Estandarte de la Reina Eterna puede sumar una bonificación adicional de +1 al resultado de combate si está a 6” o menos de un elemento de escenografía de tipo Bosque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d391-9bc2-9f8b-0e05" name="Estandarte del Rey Cazador" hidden="false" collective="false" import="true" type="upgrade">
