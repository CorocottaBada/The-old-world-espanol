      <rules>
        <rule id="d08c-8143-67e3-a9e1" name="Destreza marcial" hidden="false">
          <description>Una unidad con esta regla especial puede realizar ataques de apoyo a su flanco o retaguardia, así como a su frontal.</description>
        </rule>
        <rule id="d042-db50-623b-2686" name="Parada" hidden="false">
          <description>Cuando lucha con un arma de mano y escudo, o lanza Asrai y escudo, esta unidad mejora su valor de armadura en 1.</description>
        </rule>
      </rules>
