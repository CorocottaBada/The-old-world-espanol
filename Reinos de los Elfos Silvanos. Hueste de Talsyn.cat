            <infoLink id="0810-bb91-85df-a91e" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
