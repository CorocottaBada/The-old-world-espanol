    <selectionEntry id="19e6-e1c5-ae40-b8ce" name="Araloth, señor de Talsyn" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1eee-56cb-280f-2224" type="max"/>
      </constraints>
      <rules>
        <rule id="aa39-54c9-66e4-3e49" name="El más audaz de los audaces" hidden="false">
          <description>Araloth ignora todos los modificadores negativos a su atributo de Liderazgo.</description>
        </rule>
        <rule id="11df-9298-a936-7d99" name="Favor de la Diosa" hidden="false">
          <description>Araloth tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</description>
        </rule>
        <rule id="3538-c487-aa7a-d517" name="Skaryn el Ladrón de ojos" hidden="false">
          <description>Durante la subfase de Mando de su turno, Araloth puede intentar enviar a Skaryn a atacar desde los cielos tirando 1D6. Con un resultado de 1-2, Skaryn permanece fuera del alcance del enemigo y no sucede nada. Con un resultado de 3+, Skaryn desciende de los cielos para atacar la marca de su amo. Designa a una única miniatura enemiga a 18” de Araloth. Esa miniatura sufre un único impacto de Fuerza 4 con una PA de -1. Si el objetivo sufre una herida no salvada, sus atributos de Habilidad de Armas e Iniciativa se reducen en 1D3 (hasta un mínimo de 1) durante el resto de la partida.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="1352-62e6-45cb-bfec" name="Evasivo (Evasive)" hidden="false" targetId="22e4-14de-b7b8-ba59" type="rule"/>
        <infoLink id="0821-1ffe-e3ac-1d1a" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
        <infoLink id="c207-f689-027a-092e" name="Grito de guerra (Rallying cry)" hidden="false" targetId="98aa-28c7-f0d9-c0d9" type="rule"/>
        <infoLink id="d20f-a2fa-cbdf-8aee" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
        <infoLink id="ab6d-5047-a516-5408" name="Tozudo (Stubborn)" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
        <infoLink id="76d6-1990-dc33-82a8" name="Infantería regular (Regular infantry)" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
      </infoLinks>
