      </constraints>
      <selectionEntries>
        <selectionEntry id="e26d-234c-7f88-b444" name="Capa de hojas danzantes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7489-caf6-46c1-de39" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de1b-5cd3-2d78-d991" type="max"/>
          </constraints>
          <profiles>
            <profile id="f920-75f7-4b7d-cdca" name="Capa de hojas danzantes" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa sea ‘infantería regular’ o ‘infantería pesada’. La Capa de Hojas Danzantes es una armadura ligera. Además, su portador obtiene las reglas especiales Volar (10) y Zancada Veloz. Sin embargo, el portador no puede unirse a una unidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fdf8-40fe-6368-2662" name="Zancada veloz (Swiftstride)" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
            <infoLink id="0b49-9d31-b4eb-702b" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
            <infoLink id="da70-e1fd-6660-87b7" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d1f7-5d34-3eb9-3a66" name="Armaduras mágicas. Elfos silvanos. Armadura" hidden="false" collective="false" import="true">
