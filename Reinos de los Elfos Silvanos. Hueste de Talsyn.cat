        </selectionEntry>
        <selectionEntry id="39f9-85a2-6037-d410" name="El asesinato de los duendes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b53e-7c69-25dc-aa54" type="max"/>
          </constraints>
          <profiles>
            <profile id="c33e-4566-3348-5161" name="El asesinato de los duendes" hidden="false" typeId="e648-dafd-3c29-fef9" typeName="Duende y Hada">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9506-bdca-d122-2b90">Cuando se elige el combate de esta miniatura durante la subfase 1 de la fase de Combate, una sola unidad enemiga con la que se enfrenta sufre 1D3 impactos de Fuerza 2, cada uno con una PA de -1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
