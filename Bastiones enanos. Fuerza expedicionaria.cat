          <profiles>
            <profile id="b0ad-0960-f5bd-b65f" name="Cercenagoblins" hidden="false" typeId="4d05-969a-c2da-d376" typeName="Modelo">
              <characteristics>
                <characteristic name="M" typeId="aaba-08f8-2596-fc9f">-</characteristic>
