    <selectionEntry id="6bf2-c47b-a064-0ace" name="Porteadores de escudo" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="a627-35f4-1b84-9597" name="Llevar en volandas" hidden="false">
          <description>Una miniatura con Porteadores de escudo no contiene solo una, sino cuatro miniaturas (el personaje y tres vasallos leales) que ocupa una sola base y actúan juntos como una sola entidad. Para representar esto, una miniatura con Porteadores de escudo tiene un perfil combinado y sigue la regla Perfil Combinado (Caballería). En todos los demás aspectos esta miniatura es infantería pesada.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="46fb-b70f-f0a3-4088" name="Infantería pesada (Heavy Infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
        <infoLink id="6180-2dfa-7710-94f8" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
        <infoLink id="8cfe-65ba-5a4d-1610" name="Firmeza" hidden="false" targetId="31c0-799b-f03c-f30f" type="rule"/>
        <infoLink id="4b0a-2ae0-24d1-858f" name="Armas de gromril" hidden="false" targetId="9093-d878-cce6-0cff" type="rule"/>
      </infoLinks>
      <selectionEntries>
        <selectionEntry id="5e45-95e2-16e6-3d1e" name="Porteadores de escudo" hidden="false" collective="false" import="true" type="upgrade">
