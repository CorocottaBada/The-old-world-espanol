          <selectionEntries>
            <selectionEntry id="6a3d-dbe6-76a9-0279" name="Carro de Bugman" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f705-b62b-4d0f-e227" type="max"/>
              </constraints>
              <profiles>
                <profile id="e833-736b-5f18-6b1f" name="Carro de Bugman" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Durante la subfase de Mando de tu turno, cualquier unidad Enana que no esté huyendo o trabada en un combate y que esté a 6” o menos de un Carro de Bugman amigo (que no esté huyendo o trabado en combate) gana un modificador de +1 a su atributo de Movimiento hasta el final del turno.
Ten en cuenta que este modificador no es acumulativo.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="27eb-40a9-2698-e518" name="Carro de mineros" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b7f8-57e2-424b-1928" type="max"/>
              </constraints>
              <profiles>
                <profile id="7a65-0d30-0cb8-8ba4" name="Carro de mineros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Cualquier unidad Enana que se encuentre a 3” o menos de un Carro de Mineros amigo que no esté huyendo o trabado en combate puede hacer una reacción de carga de Aguantar y Disparar y/o un ataque de disparo como si estuviera equipada con Cargas Explosivas (ver página 26 de Fuerzas de Fantasía). Además, cuando un Carro del Mineros pierde su última Herida por un ataque enemigo durante la fase de Combate, tira 1D6. Con una tirada de 4+, el Carro del Mineros explota y cada unidad (amiga o enemiga) en un radio de 3” sufre 1D6 impactos de Fuerza 3, cada uno con una PA de -1 y con la regla especial Ataques Flamígeros.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <costs>
        <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="1946-4fe3-24d3-9b52" name="Girocóptero" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="increment" field="c996-3479-e7ff-ea80" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="c996-3479-e7ff-ea80" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c996-3479-e7ff-ea80" type="max"/>
      </constraints>
      <rules>
        <rule id="dfa8-d916-401e-a441" name="Bomba aérea" hidden="false">
          <description>Una vez por partida, una unidad con esta regla especial puede realizar un ataque de Bomba Aérea contra una única unidad enemiga que no esté trabada en Combate. Para ello, esta unidad debe moverse (usando Volar) sobre la unidad que desea atacar durante la subfase de Resto de Movimientos. Una vez que se completa este movimiento, la unidad enemiga sufre 1D6 impactos de Fuerza 3 con una PA de -1 por cada girocóptero de esta unidad que se movió sobre ella. Sin embargo, por cada resultado natural de 1 obtenido al determinar el número de impactos, una bomba ha fallado y esta unidad sufre una única herida.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="461d-deb5-4801-3a02" name="Caballería monstruosa (Monstrous Cavalry)" hidden="false" targetId="cb5c-34dd-1260-a581" type="rule"/>
