      <rules>
        <rule id="c5f1-cf54-2bff-f320" name="Formación extendida" hidden="false">
          <description>Mientras está en formación de Hostigadores, cada miniatura en una unidad de Girocópteros Exploradores debe estar a 3” o menos de otra miniatura que pertenezca a la misma unidad, en lugar de la habitual 1”.</description>
        </rule>
        <rule id="8cda-d969-e64a-36bc" name="Golpear y huir" hidden="false">
          <description>En caso de ganar una ronda de combate, una unidad con esta regla especial puede optar por Retroceder en Buen Orden en lugar de hacer un movimiento de Presionar o Perseguir.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="5649-9fbc-7d18-10aa" name="Disparar y huir" hidden="false" targetId="2024-f1cc-061a-46ec" type="rule"/>
