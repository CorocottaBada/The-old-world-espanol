    <selectionEntryGroup id="8e4c-8621-b181-1c3b" name="Runas de ingenieros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1bd5-29f3-1e98-20db" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ed1a-aa29-eb30-6c5d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7864-d013-f827-2e9b" name="Runa de la firmeza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0b4-36ce-8fc4-c726" type="max"/>
          </constraints>
          <profiles>
            <profile id="8605-59b7-7769-078a" name="Runa de la firmeza" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Al calcular el Resultado del combate, una máquina de guerra inscrita con la Runa de la Firmeza puede reclamar una bonificación de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0c4e-fa47-0f09-d895" name="Runa de la recarga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a002-103d-dc83-ca62" type="max"/>
          </constraints>
          <profiles>
            <profile id="d37f-d9e2-c1df-e88e" name="Runa de la recarga" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Una máquina de guerra inscrita con una Runa de la Recarga puede disparar en cada turno, incluso si tuvo Mal Funcionamiento en su turno anterior.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="78a4-2858-e59c-28cb" name="Runa de la forja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3ea5-4a59-783c-f17a" type="max"/>
          </constraints>
          <profiles>
            <profile id="4c56-2fb5-7a59-3ac4" name="Runa de la forja" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Un solo uso. Una máquina de guerra inscrita con una Runa de la Forja puede usarla para repetir un único fallo en el Dado de artillería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2d30-8edb-2eb9-56cb" name="Runa incendiaria" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="48f6-146a-3ccd-57a4" type="max"/>
          </constraints>
          <profiles>
            <profile id="ade4-6148-b583-a372" name="Runa incendiaria" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Una máquina de guerra inscrita con una Runa Incendiaria obtiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="718a-d64a-36e6-9340" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3780-bb57-9eff-ef95" name="Runas de ingenieros. Lanzavirotes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4cdd-1b7d-ebb3-e927" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2668-f59f-a07a-6c00" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3bce-f2e9-ec14-b321" name="Runa empaladora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2634-56bd-aba3-192a" type="max"/>
          </constraints>
          <profiles>
            <profile id="6a4d-0854-ae9d-c363" name="Runa empaladora" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Sólo lanzavirotes. Un lanzavirotes inscrito con la Runa Empaladora tiene un modificador de + 1 a su atributo de Fuerza. Además, no se permite ninguna salvación por armadura contra heridas causadas por un lanzavirotes inscrito con la Runa de Empaladora (las salvaciones especiales y regeneración se pueden intentar de forma normal).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="684b-7a19-6bc0-ded8" name="Runas magistrales de armas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ec43-6f57-d2c7-5e07" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cade-aaf4-7dd1-109b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bdf4-f36b-27bd-58d6" name="Runa magistral de la destrucción" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5dfb-6dc9-af10-eabc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d8e-8cc8-c75b-db70" type="max"/>
          </constraints>
          <profiles>
            <profile id="0680-f731-c97a-ba61" name="Runa magistral de la destrucción" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Un arma inscrita con la Runa Magistral de la Destrucción obtiene la regla especial Heridas Múltiples (1D6).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="69f7-32d1-562d-954b" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="592b-3ccc-fa69-32f5" name="Runa magistral de Skalf Martillonegro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="310c-c63e-017b-c231" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a12-a1db-ab52-ea14" type="max"/>
          </constraints>
          <profiles>
            <profile id="ddde-3655-24c5-0128" name="Runa magistral de Skalf Martillonegro" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Al realizar una tirada para Herir con un arma inscrita con la Runa Magistral de Skalf Martillonegro, un resultado de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b731-fe99-b935-1292" name="Runa magistral de la ruina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a5af-55c4-982b-d4e4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6f0-e67c-535d-565f" type="max"/>
          </constraints>
          <profiles>
            <profile id="28a2-0d0d-89a7-a03d" name="Runa magistral de la ruina" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Cualquier arma mágica equipada por una miniatura enemiga que sufra una o más heridas no salvadas de un arma inscrita con la Runa Magistral de la Ruina se destruye y no se puede utilizar durante el resto del juego.
Ten en cuenta que incluso si su arma mágica es destruida se considera que la miniatura todavía está armada con un arma de mano.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8dbd-9ee0-6e73-1e51" name="Runa magistral de la rapidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d97b-b97c-6b1d-1447" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b023-2cd2-a4fe-ae28" type="max"/>
          </constraints>
          <profiles>
            <profile id="25d6-912a-ef99-50fa" name="Runa magistral de la rapidez" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">El portador de un arma inscrita con la Runa Magistral de la Rapidez gana la regla especial Golpea Primero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="40fd-3dfd-92e7-3a42" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="56a8-d57d-4a4d-6c94" name="Runa magistral matadragones" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2d9d-75e6-3585-83e9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9703-7723-e21f-b120" type="max"/>
          </constraints>
          <profiles>
            <profile id="2423-d600-9e50-981a" name="Runa magistral matadragones" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Al realizar una tirada para Herir contra un enemigo cuyo tipo de tropa es un “Coloso” con un arma inscrita con la Runa Magistral Matadragones, una tirada de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8d68-8f89-74db-a2c8" name="Runa magistral de Alarik el Loco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a248-8c42-5247-043f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7a1b-bd35-3559-cce4" type="max"/>
          </constraints>
          <profiles>
            <profile id="854f-714a-049a-333a" name="Runa magistral de Alarik el Loco" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">No se permite ninguna tirada de Salvación por Armadura contra heridas causadas por un arma inscrita con la Runa Magistral de Alarik El Loco (las salvaciones especiales o regeneración se pueden realizar de forma normal).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="db4f-0198-c82b-66e3" name="Runas magistrales de armas de ingenieros. Ballesta, Arcabuz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2604-e436-f735-acab" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2e16-3835-22a5-1d88" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c5d7-7fbc-3022-9f6c" name="Runa magistral de la matanza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8167-a032-384d-b016" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d487-5930-defe-778a" type="max"/>
          </constraints>
          <profiles>
            <profile id="36b5-3ab6-1309-9c63" name="Runa magistral de la matanza" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Al hacer una tirada para Herir contra un enemigo cuyo tipo de tropa es ‘coloso’ con un arma inscrita con esta runa, una tirada de 3+ siempre es un éxito, independientemente de la Resistencia del objetivo. Además, un arma inscrita con esta runa obtiene la regla especial Heridas Múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5ffc-1779-c1ec-3f56" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="79da-f1a1-6aa0-c7ec" name="Runa magistral de la perforación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d221-352b-15ad-323f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b05f-9386-1057-ef64" type="max"/>
          </constraints>
          <profiles>
            <profile id="fb00-2e41-a0ed-379b" name="Runa magistral de la perforación" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Un arma inscrita con esta runa tiene un modificador +1 a su atributo de Fuerza. Además, un arma inscrita con esta runa dispara como un Lanzavirotes, utilizando la regla especial ‘Atravesar Filas’ (véase la página 223 del reglamento de Warhammer: the Old World).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5e50-b2f5-8bc4-a95f" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="475f-2f32-b6d0-f28f" name="Runa magistral de llamas explosivas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c534-607a-1623-f402" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee9b-185b-a152-b3b4" type="max"/>
          </constraints>
          <profiles>
            <profile id="cfe1-87df-b9c7-98e9" name="Runa magistral de llamas explosivas" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Si la tirada para Impactar tiene éxito, un arma inscrita con esta runa provoca 2D3 impactos a la unidad enemiga objetivo, en lugar del único impacto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d498-4df4-c01f-e036" name="Runas magistrales de armas. Arma de mano" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b42d-7294-bb70-2da6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d6de-da15-ccca-517d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="11bc-9259-9b9d-1a85" name="Runa magistral del vuelo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3e5e-db70-21ad-c7ac" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3b76-4076-ee2b-dc84" type="max"/>
          </constraints>
          <profiles>
            <profile id="196c-18d8-94d3-c877" name="Runa magistral del vuelo" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Sólo armas de mano. Una vez por turno, durante la fase de Disparo, un arma inscrita con la Runa Magistral del Vuelo podrá ser arrojada con el siguiente perfil (que podrá ser modificado por runas adicionales).</characteristic>
              </characteristics>
            </profile>
            <profile id="c761-8f2d-fed4-aaa1" name="Runa magistral del vuelo" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12&quot;</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Ataques mágicos, Mover y disparar, Disparo rápido</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="53d1-d6af-749a-2b22" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="76dc-a431-b960-c1ec" name="Mover y disparar (Move &amp; shoot)" hidden="false" targetId="2b49-fb72-106a-1e56" type="rule"/>
            <infoLink id="7d26-b8d0-7814-21b7" name="Disparo rápido (Quick shot)" hidden="false" targetId="ae60-f2dc-28d3-2489" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="078b-5447-9495-df0b" name="Runas magistrales de estandartes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4fd0-909a-0144-c6ab" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8367-e162-4f3f-d70e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3533-7427-e3b0-1594" name="Runa magistral de la duda" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="34bb-cddc-26e0-d4cd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="361d-60dd-fe04-bca3" type="max"/>
          </constraints>
          <profiles>
            <profile id="7916-b0a1-cfd8-7b2d" name="Runa magistral de la duda" hidden="false" typeId="e12c-a08e-7890-b38f" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="248d-0541-d15b-b1fe">Una unidad enemiga que carga contra el arco frontal de una unidad que lleva un estandarte inscrito con la Runa Magistral de la Duda no cuenta que ha cargado para el propósito de elegir qué arma usar o cualquier regla especial que pueda tener.
Ten en cuenta que una unidad que porta esta runa todavía cuenta como que ha sido cargada por una unidad enemiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0069-f8d7-59a2-6401" name="Runa magistral de Stromni Barbaroja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4c64-d768-df16-0ffd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ed56-9fe3-2f6c-df44" type="max"/>
          </constraints>
          <profiles>
            <profile id="8bc1-4d50-85a8-de51" name="Runa magistral de Stromni Barbaroja" hidden="false" typeId="e12c-a08e-7890-b38f" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="248d-0541-d15b-b1fe"> Al calcular el resultado del combate, cualquier unidad amiga dentro del Aura de mando del portador del estandarte inscrito con la Runa Magistral de Stromni Barbaroja puede reclamar un bonificador adicional de +1 punto al resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3e22-5a0a-251e-3c9c" name="Runas magistrales de estandartes. Portaestandarte de batalla" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9dbd-8d82-76bc-3286" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="16da-52e0-5307-cc6f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6418-c2ae-90df-ad60" name="Runa magistral de Grungni" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1970-e215-25f3-0b76" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1937-f57b-6b8e-2edc" type="max"/>
          </constraints>
          <profiles>
            <profile id="e58f-36f9-fd9d-d0ab" name="Runa magistral de Grungni" hidden="false" typeId="e12c-a08e-7890-b38f" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="248d-0541-d15b-b1fe">Solo Portaestandarte de Batalla. Una unidad que lleva un estandarte inscrito con la Runa Magistral de Grungni tiene una Salvación Especial de 5+ contra todas las heridas sufridas. Además, mientras estén a 6” o menos de la miniatura que lleva este estandarte, las unidades amigas tienen una Salvación Especial de 6+ contra cualquier herida sufrida durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="01d1-f54a-3a70-44b5" name="Runas magistrales de ingenieros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2bb5-9203-7bf4-3f86" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a99a-17dd-8fc7-dbaf" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="748f-1874-d603-c659" name="Runa magistral del disfraz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b7f0-25c5-67e4-ee27" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="37a3-dbb4-1b61-dfda" type="max"/>
          </constraints>
          <profiles>
            <profile id="47c0-eab1-8fbe-0d86" name="Runa magistral del disfraz" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Una máquina de guerra inscrita con la Runa Magistral del Disfraz siempre se considera detrás de cobertura total.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5eb7-a304-555f-6619" name="Runas magistrales de ingenieros. Cañón" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1438-e9ea-e8f0-ef82" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dd97-6394-935c-0476" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b9f7-a8a8-45ba-9b5b" name="Runa magistral de la inmolación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9815-1828-7603-bd62" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c2c1-d914-97d0-6e7a" type="max"/>
          </constraints>
          <profiles>
            <profile id="6a67-d6db-8f55-87e7" name="Runa magistral de la inmolación" hidden="false" typeId="4367-42c8-72e1-ca8a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="93d8-f1ab-eede-14e2">Sólo cañones. Un solo uso. Si un cañón que tiene inscrita la Runa Magistral de la Inmolación pierde la última herida por un ataque enemigo durante la fase de Combate, su dotación lo podrá explotar. Por cada unidad enemiga en contacto peana con peana con esta miniatura sufre 1D6 impactos de Fuerza 5 con una PA de -2. El cañón es entonces retirado del juego como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3008-7208-f50e-f31f" name="Runas magistrales talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca49-989b-f9bb-c054" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bead-68f3-8564-6f0a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2183-2375-dc89-868c" name="Runa magistral del rencor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ce2-5478-c57e-233c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b4b4-edda-30ad-2bbb" type="max"/>
          </constraints>
          <profiles>
            <profile id="6107-b79b-aa15-714f" name="Runa magistral del rencor" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a385-9e64-fc78-8093" name="Runa magistral de la calma" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6ee7-16a0-17de-7e00" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="51a3-00bf-69b0-2c3f" type="max"/>
          </constraints>
          <profiles>
            <profile id="1ebf-3fed-d47b-73d2" name="Runa magistral de la calma" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">El portador de la Runa Magistral de la Calma puede lanzar el siguiente hechizo vinculado, con un Nivel de Energía 2.
Tipo: Maldición
Dificultad de Lanzamiento: 8+ / 11+
Alcance: Personal
Efecto: Si este hechizo vinculado se lanza con un resultado de lanzamiento de 8+, los magos enemigos que se encuentren a 18” o menos de esta miniatura y que intenten lanzar un hechizo deben aumentar la Dificultad de lanzamiento de ese hechizo en 2. Si el Hechizo Vinculado se lanza con un resultado de lanzamiento de 11+, los magos enemigos que estén a 36” o menos de esta miniatura cuando intenten lanzar un hechizo deben aumentar la Dificultad de Lanzamiento del hechizo en 2. Este hechizo dura hasta tu siguiente subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5225-e5cf-8d66-33a9" name="Runas magistrales talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c7dd-6494-8cfe-3c09" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c147-6a2f-7534-7fd6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="06d4-b54f-cec7-5f47" name="Runa magistral del equilibrio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d288-8b96-11e2-815f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1587-3a1c-d7d7-c29a" type="max"/>
          </constraints>
          <profiles>
            <profile id="3ba5-cad8-e3a1-065c" name="Runa magistral del equilibrio" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Solo Yunque Rúnico, Herrero Rúnico o Señor de las Runas. Una vez por turno, el portador de la Runa Magistral del Equilibrio puede usarla al intentar una dispersión arcana. Si lo hacen, tira 1D6 extra al intentar la tirada de dispersión y descarta el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5196-83be-f3ee-20c1" name="Runas talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0eff-d579-e048-f73f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cbdc-a7ce-b3f8-72eb" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8a5d-d70d-e849-f66b" name="Runa del pasadizo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9216-b12e-ada4-f756" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5920-1fe1-4352-cd9d" type="max"/>
          </constraints>
          <profiles>
            <profile id="c1e6-4ff8-993e-2768" name="Runa del pasadizo" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">El portador de una Runa del Pasadizo gana la regla especial Mover a Través de Cobertura. Cualquier unidad a la que el portador se una también gana la regla especial Mover a Través de Cobertura. Si el portador abandona la unidad por cualquier motivo, la unidad pierde esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cb57-43ab-09cc-2b5d" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5ab6-1d44-940b-ba41" name="Runa ígnea" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d48-b02d-14a3-7214" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3245-3862-05cd-c3e6" type="max"/>
          </constraints>
          <profiles>
            <profile id="7d5b-0118-0911-4186" name="Runa ígnea" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">El portador de una Runa Ígnea tiene una Salvación Especial de 3+ contra cualquier herida sufrida por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="65d9-5c5c-2831-1c6b" name="Runa de la suerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5883-039a-5a5c-f2bc" type="max"/>
          </constraints>
          <profiles>
            <profile id="2056-cde2-7748-7dd0" name="Runa de la suerte" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Un solo uso. El portador de una Runa de la Suerte puede repetir una única tirada fallida para Impactar o para Herir, o repetir una única tirada fallida de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1786-7156-a7b7-75a8" name="Runa de defensa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="93c2-aaee-624c-3272" type="max"/>
          </constraints>
          <profiles>
            <profile id="01d0-e7c4-b0b6-df11" name="Runa de defensa" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Un solo uso. Cada Runa de Defensa le da al portador una Salvación Especial de 2+ contra una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="92f8-36c8-6c56-c141" name="Runas talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aca2-8628-3711-7c8d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4e87-b63b-8cc2-c01e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="57d2-e9af-889b-7391" name="Runa rompehechizos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5601-5117-0767-d815" type="max"/>
          </constraints>
          <profiles>
            <profile id="5b6a-f44c-18a4-c7e6" name="Runa rompehechizos" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Solo Yunque Rúnico, Herreros Rúnicos Enanos o Señores de las Runas. Un solo uso. El portador de la Runa Rompehechizos podrá utilizarlo en lugar de un intento de dispersión. Si lo hacen, el hechizo se disipa automáticamente sin necesidad de realizar una tirada de Dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="253b-3759-24e8-124f" name="Tatuajes rúnicos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a3e0-e871-8445-250a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="334a-f997-2bb7-b7f2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8cab-e8c6-9927-ed4d" name="Runa de la batalla interminable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="af2b-9d88-ba93-6a59" type="max"/>
          </constraints>
          <profiles>
            <profile id="c378-d865-7ae3-e0a2" name="Runa de la batalla interminable" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Durante la fase de Combate de cualquier turno en el que una miniatura con este tatuaje rúnico carga, cada ataque que haga que cause una herida no salvada le permite realizar inmediatamente un ataque adicional.
Ten en cuenta que cualquier ataque adicional que cause heridas no salvadas y cualquier herida no salvada causada por la regla especial Impactos por Carga (X) no se beneficia de esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d46a-78bb-2da1-9c3d" name="Runa de los imprudentes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4047-ed49-cf07-248a" type="max"/>
          </constraints>
          <profiles>
            <profile id="0847-44e6-0763-3fd9" name="Runa de los imprudentes" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico obtiene la regla especial Furia Asesina y, durante la fase de Combate, tiene un modificador de +1 a sus tiradas para Impactar. Sin embargo, las miniaturas enemigas que elijan como objetivo a esta miniatura durante la fase de Combate también tienen un modificador de +1 en sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c91d-03fb-ec43-958a" name="Furia asesina" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="be0d-3258-6f2c-510a" name="Runa de lo odioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ea2a-e8a4-6575-1202" type="max"/>
          </constraints>
          <profiles>
            <profile id="77b1-f670-b6d8-ddfe" name="Runa de lo odioso" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico obtiene la regla especial Odio (todos los enemigos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c58e-5713-ed77-dd6f" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="15f1-f533-81e0-53fc" name="Runa del valor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a00e-6853-7cef-525d" type="max"/>
          </constraints>
          <profiles>
            <profile id="116c-ae58-9824-2142" name="Runa del valor" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico tiene un modificador de +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9a6c-81f5-d78b-d898" name="Runa de los intrépidos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="248d-8763-a6e0-301a" type="max"/>
          </constraints>
          <profiles>
            <profile id="9936-a019-0a57-7c63" name="Runa de los intrépidos" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico siempre debe lanzar y aceptar Desafíos (si es posible). Durante un Desafío, esta miniatura puede repetir cualquier tirada fallida para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="642e-e5b0-32cb-5a98" name="Runa de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f73c-00d8-4134-92bd" type="max"/>
          </constraints>
          <profiles>
            <profile id="c351-4c82-c644-b99c" name="Runa de la ira" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4100-ccb1-5d82-8e06" name="Runa de la furia ardiente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8459-dc6b-f701-9d14" type="max"/>
          </constraints>
          <profiles>
            <profile id="e1d1-54fb-0c8c-8589" name="Runa de la furia ardiente" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico tiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2896-22b9-36bd-0ea1" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
