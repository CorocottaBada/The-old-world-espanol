              <profiles>
                <profile id="1866-56ce-13c8-a737" name="Filo del dragón" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos. </characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo del Dragón está inscrita con una Runa de Furia y una Runa de Rencor, como se describe en la página 34 de Forces of Fantasy.</characteristic>
                  </characteristics>
                </profile>
                <profile id="a6f8-f18f-3d3b-f9fa" name="Runa de la furia" hidden="false" typeId="fa75-09bd-a059-fc90" typeName="Runa de arma">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="1425-29f3-2817-e87a">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
                  </characteristics>
                </profile>
                <profile id="0c42-bbf6-52ad-cff1" name="Runa magistral del rencor" hidden="false" typeId="a61d-1641-85bd-3452" typeName="Runa talismánica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="f2f6-001d-eac4-14d2">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="0eba-d442-a362-8410" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
                <infoLink id="cb81-3d5d-303f-f530" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
              </infoLinks>
