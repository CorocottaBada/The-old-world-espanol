        </selectionEntry>
        <selectionEntry id="5d63-e697-b856-f9aa" name="Runa del guerrero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="051a-a0ac-82c6-faff" type="max"/>
          </constraints>
          <profiles>
            <profile id="6b19-fc59-91c9-0dde" name="Runa del guerrero" hidden="false" typeId="be76-7536-41bc-21fc" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="54a7-1b30-1ca9-e298">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Habilidad de Armas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
