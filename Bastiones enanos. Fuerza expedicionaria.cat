          <profiles>
            <profile id="e5b7-23f7-40d9-6385" name="Porteadores de escudo" hidden="false" typeId="4d05-969a-c2da-d376" typeName="Modelo">
              <characteristics>
                <characteristic name="M" typeId="aaba-08f8-2596-fc9f">3</characteristic>
