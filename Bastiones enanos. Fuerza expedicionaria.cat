                <characteristic name="A" typeId="ce23-8368-434a-d0b1">3</characteristic>
                <characteristic name="L" typeId="9267-3e20-0bc5-9c1d">-</characteristic>
                <characteristic name="S" typeId="472f-789f-9d1f-641e"/>
                <characteristic name="Tipo de tropa" typeId="0c59-b5c0-8666-35bf">Infantería pesada</characteristic>
                <characteristic name="Reglas especiales" typeId="4d01-772d-4584-b98b">Llevar en volandas, Armas de Gromril, Odio (Orcos y Goblins), Firmeza</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4a9c-665b-26cd-99c7" name="Arma de mano (Hand Weapons)" hidden="false" targetId="de25-d2c8-c6d6-8278" type="profile"/>
