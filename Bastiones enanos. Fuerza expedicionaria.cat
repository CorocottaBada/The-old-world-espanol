  <sharedSelectionEntryGroups>
    <selectionEntryGroup id="7d4b-60eb-6f04-7b83" name="Runas de armaduras" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bb9f-eb46-4708-3298" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a752-3588-b50f-13b5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f24c-d451-fb82-5de2" name="Runa de piedra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="27ea-26ff-9996-d73d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7d59-2730-9309-3c36" name="Runa de piedra" hidden="false" typeId="1b9f-1ca5-7f7f-dcd3" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ddca-edf9-3da0-a790">Un solo uso. Por cada Runa de Piedra inscrita en la armadura, el portador puede repetir una única tirada de Salvación por Armadura fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3a6b-c4c6-3b51-fbb2" name="Runa de escudo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5ee4-ed43-6aa3-8a6f" type="max"/>
          </constraints>
          <profiles>
            <profile id="f3ce-080a-f1a7-f7b3" name="Runa de escudo" hidden="false" typeId="1b9f-1ca5-7f7f-dcd3" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ddca-edf9-3da0-a790">Una miniatura que lleva su armadura inscrita con una única Runa de Escudo tiene una Salvación Especial de 6+ contra todas las heridas sufridas. Por cada Runa de Escudo adicional, la Salvación Especial mejora en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="76f6-15bc-0b3c-b2e7" name="Runa de perseveración" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5335-441f-ae83-c432" type="max"/>
          </constraints>
          <profiles>
            <profile id="985f-4383-beb2-74c9" name="Runa de perseveración" hidden="false" typeId="1b9f-1ca5-7f7f-dcd3" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ddca-edf9-3da0-a790">Una miniatura que lleva su armadura inscrita con la Runa de Preservación es inmune a las reglas especiales Golpe Letal y Heridas Múltiples (X). Si el portador sufre heridas de un ataque con cualquiera de estas reglas especiales, pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7c17-eb37-ae3b-55d8" name="Runa de fortaleza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="57a8-4216-c806-41b2" type="max"/>
          </constraints>
          <profiles>
            <profile id="3868-232b-bfb8-d1bb" name="Runa de fortaleza" hidden="false" typeId="1b9f-1ca5-7f7f-dcd3" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ddca-edf9-3da0-a790">Por cada Runa de Fortaleza inscrita en la Armadura del portador tiene un modificador de +1 a su atributo de Resistencia (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f67f-ded7-b9fc-7f87" name="Runa de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8b6d-2346-c357-6001" type="max"/>
          </constraints>
          <profiles>
            <profile id="dc83-7542-bfc3-efb2" name="Runa de hierro" hidden="false" typeId="1b9f-1ca5-7f7f-dcd3" typeName="Runa de armadura">
              <characteristics>
