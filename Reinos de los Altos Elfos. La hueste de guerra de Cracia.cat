    <selectionEntryGroup id="d1b6-cc78-4b6d-496a" name="Armaduras mágicas. Altos elfos. Armadura. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5694-9881-95e3-abc1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4ebd-b482-2e1e-1e50" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b7bd-7ae3-39ed-e7ce" name="Armadura de las estrellas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6a9a-5973-7851-ae20" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b80-b710-24e3-6d67" type="max"/>
          </constraints>
          <profiles>
            <profile id="c5e6-ea21-8dca-392c" name="Armadura de las estrellas" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Sólo miniaturas cuyo tipo de tropa es «infantería» o «caballería». La Armadura de Estrellas es una armadura pesada. Además, su portador es inmune a la regla especial «Golpe Letal». Si el portador recibe un Golpe Letal, se le permiten las salvaciones de armadura y Regeneración como de costumbre. Si la herida no se salva, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b90e-106c-a544-9d36" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
