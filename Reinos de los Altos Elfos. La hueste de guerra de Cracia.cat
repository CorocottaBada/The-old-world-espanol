            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="295c-07ca-6a76-58b4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d91-73cc-8897-df1d" type="max"/>
          </constraints>
          <profiles>
            <profile id="f563-eff7-9515-73ff" name="Incienso sagrado" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que tome como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
