            <profile id="7945-6c33-c72f-f7ba" name="La espada blanca" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Cazamonstruos, Golpea último, Requiere ambas manos.</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo para Miniaturas de tipo &apos;infantería&apos; o &apos;carro&apos;.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c784-6499-5db5-70fc" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="8571-2656-e9c1-f5ae" name="Cazamonstruos (Monster slayer)" hidden="false" targetId="be83-b236-0aa9-0356" type="rule"/>
            <infoLink id="ee02-e267-02d0-8a21" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
            <infoLink id="467a-3772-2300-b739" name="Requiere ambas manos" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
