        <selectionEntry id="4001-75e1-8570-7111" name="Piedra de anulación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7498-86ed-3d56-bb24" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bb04-8753-3d26-bdde" type="max"/>
          </constraints>
          <profiles>
            <profile id="e778-4623-7dad-f148" name="Piedra de anulación" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Mientras estén dentro del Aura de Mando del portador, todos los Hechiceros (amigos o enemigos) sufren un penalizador de -1 en sus tiradas de lanzamiento y dispersión.
Además, durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar utilizar la Piedra de Anulación realizando un chequeo de liderazgo (usando su propio Liderazgo sin modificar). Si se supera esta prueba, este personaje no puede ser objetivo de ningún hechizo y es inmune a los efectos de cualquier hechizo hasta tu próxima subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9433-f246-128a-edfe" name="Capa de las barbas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ea3f-807d-6d09-fef1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7da4-6bdd-381d-cdc1" type="max"/>
          </constraints>
          <profiles>
            <profile id="3d7b-a457-6430-b9c1" name="Capa de las barbas" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de las Barbas provoca Terror. Sin embargo, el manto es tan desconcertante que otras miniaturas no pueden utilizar el Liderazgo de quien la porta.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="209f-a82a-c307-3b5a" name="Terror" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8c70-c810-949d-2738" name="Objetos hechizados muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1ada-bc1c-4e33-4180" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="29bc-959b-28c3-5897" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ade2-f266-1c0e-c41f" name="Semilla del renacimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f1e0-24cb-93da-4e9e" type="max"/>
          </constraints>
          <profiles>
            <profile id="eaa6-e230-a5b2-1a94" name="Semilla del renacimiento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">La Semilla del Renacimiento otorga a su portador la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7bc2-66ce-db13-4d4b" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a16e-d7a7-ce98-3612" name="Anillo de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e196-da92-2e76-3ec5" type="max"/>
          </constraints>
          <profiles>
            <profile id="64be-c7d9-041c-5e20" name="Anillo de la ira" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de un Anillo de la Ira puede lanzar el hechizo Mano de Martillo del Saber de la Magia de Batalla como hechizo Vinculado, con un Nivel de Energía 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="96c8-bf11-fbd3-a418" name="Objetos arcanos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7bdc-1a59-686d-205c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f1c9-ddb4-c283-1974" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b812-8ca9-c8ae-cbe7" name="Vara de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4aeb-5457-52d5-a310" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bdd5-5461-866b-b423" type="max"/>
          </constraints>
          <profiles>
            <profile id="d39c-7b9c-d075-cee8" name="Vara de plata" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador de la Vara de Plata conoce un hechizo más (elegido de la forma habitual) de lo normal para su Nivel de Magia.
Ten en cuenta que esto no aumenta el Nivel de Magia del hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7966-6e8a-cca4-81ba" name="Cristal de las Annuli" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="93b8-2387-c328-36ec" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="24a6-bbb0-610d-0c06" type="max"/>
          </constraints>
          <profiles>
            <profile id="4cc0-e5a7-bd9f-1663" name="Cristal de las Annuli" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, al lanzar con éxito un hechizo, el portador del Cristal de las Annulii puede optar por olvidar ese hechizo y generar otro(sin incluir los hechizos característicos) inmediatamente de la manera habitual.
Ten en cuenta que es posible que el Hechicero genere el hechizo que acaba de olvidar o uno olvidado en un turno anterior. Considéralo el destino.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7a1a-2198-2248-9053" name="Fragmentos de vórtice" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5d24-3937-a641-7492" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6f75-6ca6-cc39-9f9d" type="max"/>
          </constraints>
          <profiles>
            <profile id="1ffe-4b02-7a3a-dde8" name="Fragmentos de vórtice" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar este objeto en lugar de hacer un intento de dispersión. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirada de dispersión. Además, se dispersan todos los hechizos en juego, incluidos los hechizos lanzados por hechiceros amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="180e-1453-ebbb-c6af" name="El colgante del embaucador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="afe3-57f4-771e-c44a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e1d-574e-034f-c7e3" type="max"/>
          </constraints>
          <profiles>
            <profile id="65a2-6e9e-f3f0-662e" name="El colgante del embaucador" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar el Colgante del Embaucador cuando intente dispersar un hechizo. Si lo hace, tira 1D6 adicional al hacer la tirada de dispersión y descarta el resultado más bajo. Si el hechizo es dispersado, el hechicero que intentó lanzarlo no podrá intentar lanzar más hechizos durante el resto del turno en curso. Sin embargo, si se obtiene un doble 1 en cualquiera de los dos dados lanzados, el portador queda superado en el arte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="97b1-5d1f-c28e-38ce" name="Bastón de la solidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e627-0923-d672-8bae" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="daaa-2c67-da7f-799b" type="max"/>
          </constraints>
          <profiles>
            <profile id="14c8-e640-7de7-7fc4" name="Bastón de la solidez" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Una vez por partida, cuando el portador del Bastón de la Solidez tenga que tirar en la Tabla de Disfunción, puede elegir no hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1dd3-2b85-c0c4-befc" name="Gema del coraje" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f68e-ca49-99bb-0357" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="135e-5f1f-c06d-f4cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="5201-9b12-68b4-956b" name="Gema del coraje" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una Gema del coraje sólo puede ser adquirida por una miniatura de un Ejército de Infamia de la Hueste de guerra de Cracia. Un sólo uso. Una vez por partida, cuando se requiera hacer un chequeo de Liderazgo, el portador de una Gema del coraje (y su unidad) puede tirar 1D6 adicional y descartar el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5932-4e1a-6913-46f3" name="Objetos arcanos muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9bf-e578-30d6-6b47" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7e7d-e746-2e62-9a9f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="be90-6f96-9754-9e6e" name="Selllo de Asuryan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f9d0-ec4b-be7a-2a51" type="max"/>
          </constraints>
          <profiles>
            <profile id="bc9d-21f9-8ffc-64e5" name="Selllo de Asuryan" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Hechicero puede usar este objeto en lugar de intentar dispersar. Si lo hace, el hechizo se dispersa de forma automática sin necesidad de realizar una tirada de dispersión.
Ten en cuenta que una Fuerza irresistible no se puede dispersar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e40f-d18f-aad2-9731" name="Honores" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bc34-0872-b991-b7b6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b256-c71d-2eaf-4c30" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4cc1-ae9e-5fe7-7fa3" name="Acechante sombrío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f65f-1db5-4212-1c32" type="max"/>
          </constraints>
          <profiles>
            <profile id="5107-b709-16b3-21a5" name="Acechante sombrío" hidden="false" typeId="2a37-17bc-114f-a8ad" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e72f-8acd-9bb0-80c5">Un Personaje con el Honor Élfico Acechante Sombrío:
• No puede ir montado.
• Puede equiparse con un arco de Avelorn (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• No puede equiparse con armadura pesada o armadura completa.
• Tiene las reglas especiales Emboscador, Evasivo, Explorador, Disparar y Huir y Mover a Través de Cobertura</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="83b6-ed33-16fe-ec85" name="Emboscadores" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
            <infoLink id="d482-737e-3127-bea7" name="Evasivo" hidden="false" targetId="22e4-14de-b7b8-ba59" type="rule"/>
            <infoLink id="aefd-7560-ed2c-1b56" name="Disparar y huir" hidden="false" targetId="2024-f1cc-061a-46ec" type="rule"/>
            <infoLink id="814f-2f50-71ad-e6c4" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
            <infoLink id="02c6-fb8f-d877-dcf9" name="Exploradores" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="0842-7992-c114-7f90" name="Arco de Avelorn" hidden="false" collective="false" import="true" targetId="792d-3989-ac7d-c721" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="91d5-e00f-9dba-0ce9" name="Cazador de Cracia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dac3-593b-1b61-48cb" type="max"/>
          </constraints>
          <profiles>
            <profile id="9612-f572-4237-ec30" name="Cazador de Cracia" hidden="false" typeId="2a37-17bc-114f-a8ad" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e72f-8acd-9bb0-80c5">Un Personaje con el Honor Élfico Cazador de Cracia (pero no su montura):
• Solo puede montarse en un Carro de Leones Blancos (pero no se puede elegir ninguna otra opción de montura).
• Puede equiparse con un Hacha de Cracia (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales. 
• Tiene las reglas especiales Capa de León, Mover a Través de Cobertura y Tozudo</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="741a-34b6-79d9-4c1d" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
            <infoLink id="aa59-f460-388d-c99a" name="Capa de león" hidden="false" targetId="34b9-6525-592e-e73c" type="rule"/>
            <infoLink id="845a-dfc0-1609-a91a" name="Tozudo" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="1abf-24b1-b8a2-04df" name="Hacha de Cracia" hidden="false" collective="false" import="true" targetId="b1f0-8496-ce7f-5c0e" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0f93-21af-24a7-2320" name="Puro de corazón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9426-1abd-65a6-4f38" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b6e-b280-d168-e4e8" name="Puro de corazón" hidden="false" typeId="2a37-17bc-114f-a8ad" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e72f-8acd-9bb0-80c5">A menos que este Personaje esté huyendo, todas las unidades amigas dentro de su Aura de Mando pueden usar su Atributo de Liderazgo en lugar del suyo propio. Además, este Personaje y cualquier unidad a la que se una superan automáticamente cualquier Chequeo de Pánico que deba realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1383-a82c-9889-fbbd" name="Estandartes mágicos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f79-1b1e-2687-9257" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f019-d49a-d8b6-663a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="225d-5756-e92e-d309" name="Estandarte de protección arcana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e873-2933-c29c-8071" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3bc2-c16a-ccf8-9d75" type="max"/>
          </constraints>
          <profiles>
            <profile id="202d-9dca-4211-b2a9" name="Estandarte de protección arcana" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Protección Arcana obtiene la regla especial Resistencia a la magia (-3). Además, las unidades amigas a 6&quot; o menos de la miniatura que lleve este estandarte obtienen la regla especial Resistencia Mágica (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="27f2-0ba5-b1e0-8d0c" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="71a3-5fa6-665d-7cc0" name="Estandarte del león" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6d27-2978-2a92-edd3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a86c-3dc5-1958-d80d" type="max"/>
          </constraints>
          <profiles>
            <profile id="e1f5-6818-c948-b51f" name="Estandarte del león" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del León supera automáticamente cualquier chequeo de miedo o terror que deba realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a59e-f7ad-3600-5dae" name="Estandarte de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="687d-bbc0-3646-14bb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fa80-0e37-b3d1-110a" type="max"/>
          </constraints>
          <profiles>
            <profile id="e116-3c86-8858-5d07" name="Estandarte de batalla" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado del combate, una unidad que lleve el Estandarte de Batalla obtiene una bonificación adicional de +1D3 puntos en el resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d444-86da-3473-01d6" name="Estandarte de Ellyrion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d952-72f9-3407-29cf" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e9f2-cb62-a199-73eb" type="max"/>
          </constraints>
          <profiles>
            <profile id="766c-220d-0a7b-c4f1" name="Estandarte de Ellyrion" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Ellyrion obtiene la regla especial Mover a Través de Cobertura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7ba6-711b-b10f-dea7" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1ca1-b107-2d3a-4113" name="Estandarte de la resistencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="58bb-3bda-1560-e0bb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5ef5-3564-902c-0df5" type="max"/>
          </constraints>
          <profiles>
            <profile id="508f-2276-d993-3898" name="Estandarte de la resistencia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Resistencia tiene un modificador +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d562-61f7-9fab-af29" name="Estandarte de Lothern" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="67f9-738a-e6df-ecd7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="917c-4dbe-e47f-cd43" type="max"/>
          </constraints>
          <profiles>
            <profile id="aba2-7aa0-fb5f-1357" name="Estandarte de Lothern" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad que porta el Estandarte de Lothern está equipada con lanzas arrojadizas, la mitad de las miniaturas de la tercera fila o columna (es decir, la fila o columna directamente detrás de la que normalmente puede realizar ataques de apoyo), redondeando hacia arriba, pueden realizar ataques de apoyo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0c01-1a12-0bfe-10ba" name="Estandarte del equilibrio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7dc6-2f17-691b-10ef" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8fe2-fd4d-8ec2-1513" type="max"/>
          </constraints>
          <profiles>
            <profile id="cc28-8767-ccf8-bee1" name="Estandarte del equilibrio" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Mientras estén en contacto con una unidad que lleve el Estandarte del Equilibrio, las unidades enemigas no pueden repetir ninguna tirada para Impactar o para Herir. Sin embargo, la unidad que lleva el Estandarte del Equilibrio tampoco puede hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="59bb-1c00-4caa-4a1d" name="Estandarte de la confianza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b131-0493-8d64-9e7d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dcca-e84d-d913-c83e" type="max"/>
          </constraints>
          <profiles>
            <profile id="a17f-eaed-58c9-2696" name="Estandarte de la confianza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Confianza no sufre el modificador habitual de -1 a Impactar al realizar una reacción a la carga de Aguantar y Disparar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
