                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-4</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Cazamonstruos, Requiere ambas manos, Golpea último</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Hacha del leñador sólo puede ser adquirida por miniaturas en un Ejército de Infamia de la Hueste de guerra de Cracia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
