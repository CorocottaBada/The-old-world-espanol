        <selectionEntry id="ab8f-9405-45f3-7128" name="Arco de Ellyrion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3e3b-0bbf-24f3-f8c7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f79-7ddf-2549-72a2" type="max"/>
          </constraints>
          <profiles>
            <profile id="1e3f-ceba-7ab5-3ef3" name="Arco de Ellyrion" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco de Ellyrion cuenta como un Arco de Avelorn. El portador del Arco de Ellyrion puede realizar un número de disparos igual a su atributo de Ataques, en lugar del número habitual. Esta miniatura no sufre ningún penalizador por Disparos Múltiples.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0697-6e86-ca0e-d366" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6830-cbb6-575d-3f40" name="Perdición de enemigos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="33f4-30c9-2b14-f2f6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bf4f-24d4-974f-5981" type="max"/>
          </constraints>
          <profiles>
            <profile id="0a5d-5a36-f049-c917" name="Perdición de enemigos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cuando el portador de Perdición de Enemigos hace una tirada para Herir, un resultado de 4+ siempre es un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0d6f-6541-9ea9-1716" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="13e8-733f-facc-66ef" name="Arco del navegante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0d0e-b187-2e59-890a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8936-023b-0156-cc62" type="max"/>
          </constraints>
          <profiles>
            <profile id="e0c6-91a8-51d5-96f1" name="Arco del navegante" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">5</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Aparatoso, Heridas múltiples (1D3), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco del Navegante es un Arco de Avelorn. El Arco del Navegante dispara como un Lanzavirotes, usando la regla especial «Atravesar Filas» (ver página 223 del libro de reglas de Warhammer: el Viejo Mundo).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="753c-416c-9d8a-755d" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="b12a-26d8-9b30-d4d9" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
