      </characteristics>
    </profile>
    <profile id="b98b-41d7-0267-d087" name="Arco de Avelorn" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">30&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Andanada, Ataques mágicos, Perforacorazas (1)</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
      </characteristics>
    </profile>
    <profile id="180a-72cf-eca0-650f" name="Alabarda ceremonial" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">Combate</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F+1</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Ataques mágicos, Lucha con una fila extra, Perforacorazas (1), Requiere ambas manos</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Una miniatura que empuña una alabarda ceremonial no puede realizar un ataque de apoyo durante un turno en el que ha cargado.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
</catalogue>