        <selectionEntry id="dc3c-18c8-67ba-013d" name="General del ejército" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d98-6cd7-642a-039e" type="max"/>
          </constraints>
          <rules>
            <rule id="f0c8-427e-bb76-ec74" name="Cuerno de la manada" hidden="false">
              <description>Desde el inicio de la ronda 2 en adelante, si tu General está en el campo de batalla durante la subfase de Mando de su turno, puede intentar hacer sonar el Cuerno de la Manada haciendo un chequeo de Liderazgo. Si se supera el chequeo, puedes volver a tirar inmediatamente por cada unidad de Emboscadores del ejército que se mantenga en reserva y que no haya conseguido desplegar durante la subfase de Inicio de Turno de este turno.
Ten en cuenta que esta regla especial solo puede ser usada por un Caudillo o Beligor que ha sido elegido General del ejército.</description>
            </rule>
          </rules>
          <entryLinks>
            <entryLink id="574a-788b-e7dd-3705" name="General del ejército" hidden="false" collective="false" import="true" targetId="90e8-44cd-2f28-7f42" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
          </costs>
        </selectionEntry>
