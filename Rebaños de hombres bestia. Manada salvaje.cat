    <selectionEntryGroup id="d47e-2d93-7ea5-caa9" name="Estandartes mágicos. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4331-4bff-617b-d99b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4658-6768-0c5b-a518" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c846-8245-c94e-daa8" name="Estandarte de la vergüenza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6711-fca9-d7ca-d55f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="67e4-fd4c-9aae-472e" type="max"/>
          </constraints>
          <profiles>
            <profile id="7f93-89ce-c00e-8b34" name="Estandarte de la vergüenza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de la Vergüenza puede repetir su chequeo de Liderazgo cuando chequea para Furia Primitiva.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0d90-e10e-f755-58a0" name="Tótem herrumbroso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="06d8-d5ba-3b7d-e6b7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d332-a503-bc08-84fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="bf6d-4909-59a1-bbd6" name="Tótem herrumbroso" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cada miniatura (amiga o enemiga) que está a 6” o menos de la miniatura que porte el Tótem Herrumbroso sufre un modificador de -1 a sus tiradas de Salvación por Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a03b-b6d0-b1a8-d374" name="Tótem virulento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="928a-307d-3051-0d86" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f44f-a47e-51c8-7383" type="max"/>
          </constraints>
          <profiles>
            <profile id="43cc-7d39-8244-2c87" name="Tótem virulento" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tótem Virulento obtiene la regla especial Ataques Envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="57c3-c196-314a-43f6" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a8e1-a0b5-17ce-62a6" name="Estandarte de la perdición humana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4043-9996-31d3-8865" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="68c0-3593-f4a1-78c7" type="max"/>
          </constraints>
          <profiles>
            <profile id="d468-89a3-3104-8501" name="Estandarte de la perdición humana" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades enemigas que están a 6” o menos de la miniatura que porte el Estandarte de la Perdición Humana sufren un modificador de -1 a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6638-61c2-4fb5-3321" name="El Estandarte de la Carnicería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dd27-8a64-0ac7-19cd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e1e8-4192-f4bb-146c" type="max"/>
          </constraints>
          <profiles>
            <profile id="6048-8a6d-6a2e-bfa3" name="El Estandarte de la Carnicería" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad desea declarar una carga contra una unidad que porta el Estandarte de la Carnicería, debe primero superar un chequeo de Liderazgo. Si este chequeo se falla, la unidad no puede cargar. No se mueve y se considera que ha realizado una carga fallida. Si este chequeo se supera, la unidad puede cargar con normalidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0ff6-36af-80b9-55fe" name="Estandarte de la Luna Retorcida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d362-b8ae-12a8-7a99" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5616-a91f-bdb4-080d" type="max"/>
          </constraints>
          <profiles>
            <profile id="9301-c5bf-018b-6e9b" name="Estandarte de la Luna Retorcida" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Durante la subfase de Mando de su turno, si no están trabados en combate, el portador de este estandarte puede intentar desatar su poder realizando un chequeo de Liderazgo (usando su propio Liderazgo sin modificar). Si este chequeo se supera, hasta tu siguiente subfase de Inicio del Turno las unidades enemigas no pueden usar la regla especial Volar (X).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a6b2-a3b4-3b8d-ba90" name="El Estandarte de la Bestia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4def-720a-0638-c463" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7641-b8a5-266d-e480" type="max"/>
          </constraints>
          <profiles>
            <profile id="60d8-b61e-3557-761f" name="El Estandarte de la Bestia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de la Bestia aumenta su alcance de carga máximo posible en 3” y, cuando realiza una tirada de Carga, puede aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9829-c623-4563-7c66" name="El Tapiz Profanado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b2a6-71bb-e9f2-6c59" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e8b4-8626-fe19-da79" type="max"/>
          </constraints>
          <profiles>
            <profile id="7e63-d55a-dd70-0d0a" name="El Tapiz Profanado" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Tapiz Profanado obtiene la regla especial Odio (todos los enemigos). Sin embargo, todas las miniaturas enemigas Odian a la unidad que porta este estandarte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="09ec-4fd4-34c4-09ca" name="Odio (todos los enemigos) (Hatred)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9b81-a93c-3da8-ffe8" name="Armas mágicas. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a17e-1433-e1a7-232b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="41b6-2c51-8ea6-744a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="75d8-6b01-3fd6-29d7" name="Hacha de los hombres" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f9f4-847a-93c4-a63e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8133-77ec-8b16-270c" type="max"/>
          </constraints>
          <profiles>
            <profile id="6a13-a0ee-7233-b9ad" name="Hacha de los hombres" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Golpe letal, Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Si el portador del Hacha de los Hombres mata un personaje enemigo (incluidos campeones) en un desafío, obtiene la regla especial Terror para el resto de la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="914e-8b90-5cfd-ef1b" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
            <infoLink id="ed39-fed4-bd2c-43a0" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="52e2-a6de-dbae-0fa1" name="Lanza de caza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7720-f754-224c-0304" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b837-72dd-16e5-e3db" type="max"/>
          </constraints>
          <profiles>
            <profile id="14af-1db6-fad3-5b90" name="Lanza de caza" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">24&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">6</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Aparatoso, Ataques mágicos, Heridas múltiples (2), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza de Caza dispara como un lanzavirotes, usando la regla especial Atravesar Filas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8257-d1ea-2219-b169" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
