        <selectionEntry id="1dfc-e01e-0cdf-fda4" name="General del ejército" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="13ff-0352-9ed6-3c59" type="atLeast"/>
