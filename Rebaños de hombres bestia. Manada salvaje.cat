          </constraints>
          <profiles>
            <profile id="1d90-b657-2aa3-4a37" name="Runa de la bestia verdadera" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Miniaturas enemigas cuyo tipo de tropa sean ‘monstruo’ sufren un modificador de -1 a su atributo de Habilidad de Armas mientras estén a 6” o menos del portador de la Runa de la Bestia Verdadera.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8ecb-f30a-b444-e3be" name="Cáliz de la Lluvia Negra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d0ce-c622-8d9e-840a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1f0e-f867-59c1-2601" type="max"/>
          </constraints>
          <profiles>
            <profile id="b936-d65b-ee07-bd43" name="Cáliz de la Lluvia Negra" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, el portador del Cáliz de la Lluvia Negra puede beber de él. Hasta tu siguiente subfase de Inicio del Turno, el alcance de todas las armas de proyectiles enemigas se reduce a la mitad (redondeando fracciones hacia arriba) y las máquinas de guerra enemigas no pueden disparar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8ef8-3388-193b-f595" name="Cornucopia de Corpulencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="28a3-3c68-29a9-d4de" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca40-07d5-2cfd-1463" type="max"/>
          </constraints>
          <profiles>
            <profile id="9586-ff49-6911-7572" name="Cornucopia de Corpulencia" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cuando se elige el combate del portador durante el Paso 1.1 de cualquier subfase de Elegir Combate y Luchar, las miniaturas enemigas en contacto peana con peana con el portador de la Cornucopia de Corpulencia deben realizar un chequeo de Resistencia. Si este chequeo se falla, pierden una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
