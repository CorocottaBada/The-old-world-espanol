    <selectionEntry id="d72a-bb0a-3842-aa6c" name="Cayado de la manada" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0072-d36f-a66b-bc8f" type="max"/>
      </constraints>
      <profiles>
        <profile id="af12-4a7a-758f-beb4" name="Cayado de la manada" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
          <characteristics>
            <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Cuando esta miniatura es elegida para combatir durante el Paso 1.1 en cualquier subfase Elegir Combate y Luchar, debe elegir si usa el Cayado de la Manada ofensiva o defensivamente.
Ofensivamente, cuenta como un arma a dos manos. Defensivamente, cuenta como un arma de mano y otorga a su portador un Valor de Armadura de 5+.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink id="568d-882b-1f7a-96a6" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
        <infoLink id="2218-a8fb-3f6e-b20c" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
        <infoLink id="7dca-4549-fd34-d9be" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
        <infoLink id="ba47-ff48-c43a-af3b" name="Arma a dos manos" hidden="false" targetId="faa6-a3fc-7b87-4756" type="profile"/>
      </infoLinks>
      <costs>
