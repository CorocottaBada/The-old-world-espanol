          </constraints>
          <profiles>
            <profile id="89c8-3d55-a606-f961" name="Piel humana" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo Caudillos Hombres Bestia y Chamanes Hombres Bestia cuyo tipo de tropa es ‘infantería’. El portador de la Piel Humana obtiene las reglas especiales Exploradores y Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4d50-05b5-f556-fac4" name="Exploradores (Scouts)" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
            <infoLink id="bb35-b47c-e3e2-663f" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="59e0-ae6e-be17-c49c" name="Objetos hechizados. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b2d7-d14a-3432-5fa6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5789-8f6e-2964-b6d0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7310-3351-c86c-99d3" name="Piedra del resentimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6a04-8c8e-2851-52f9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f7c9-a59b-b98d-d8be" type="max"/>
          </constraints>
          <profiles>
            <profile id="0070-4ecc-9b31-93a1" name="Piedra del resentimiento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, este personaje puede usar la Piedra del Resentimiento. Hasta tu siguiente subfase de Inicio del Turno, todos los Hechiceros (amigos o enemigos) sufren un modificador de -2 a sus tiradas de Lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="485f-5cc6-8a2c-4769" name="Cuerno de la primera bestia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0aed-74dc-f1ae-973e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2004-6432-7442-37b1" type="max"/>
          </constraints>
          <profiles>
            <profile id="ea1d-f6c9-3081-91ef" name="Cuerno de la primera bestia" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Excepto si el portador del Cuerno de la Primera Bestia está huyendo, cualquier unidad amiga que esté a 18” o menos de esta miniatura puede usar su atributo de Liderazgo cuando chequean por Furia Primitiva.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8a8f-73fd-cc0f-9567" name="Azote de los Agobiados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="05c1-a6e3-9a43-0249" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c426-34ad-cbb4-349e" type="max"/>
          </constraints>
          <profiles>
            <profile id="abea-f98e-a730-96db" name="Azote de los Agobiados" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Azote de los Agobiados puede lanzar el hechizo Llamada de lo Salvaje del Saber de la Magia Primigenia como un Hechizo Vinculado, con un Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="623b-e8b2-2d72-6879" name="Tonada Cacofónica" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d662-24b2-edc7-8b3d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4cc2-8f30-14a4-fcdf" type="max"/>
          </constraints>
          <profiles>
            <profile id="b84c-36e5-1c97-84c0" name="Tonada Cacofónica" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Mientras su unidad esté a 18” o menos del portador de la Tonada Cacofónica, los músicos enemigos no pueden usar sus reglas de “¡Adelante hacia la Victoria!”, Ritmo Constante o Toque Rápido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="56a8-d6af-e7da-c2e3" name="Cuerno de la Gran Cacería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8226-fd85-2bb3-2025" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54dd-a1a9-e8bb-5cc7" type="max"/>
          </constraints>
          <profiles>
            <profile id="9ea4-7061-7a95-72e1" name="Cuerno de la Gran Cacería" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Una vez por turno, después de tirar para determinar si una unidad con la regla especial Emboscadores que actualmente se mantiene en reserva como refuerzo llega, y si el portador del Cuerno de la Gran Cacería está en el campo de batalla y no está huyendo, puedes aplicar un modificador de +1 o -1 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6b89-721e-888a-dbe6" name="Objetos arcanos. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c70f-e0a9-a574-bbe3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e933-cc86-b273-0ff1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b220-583b-7b3e-60de" name="Cáliz de la plaga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6fff-85e5-8704-1c3e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cc88-6d93-a3d3-1e7a" type="max"/>
          </constraints>
          <profiles>
            <profile id="5d3a-fbde-4e6d-0525" name="Cáliz de la plaga" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Si el portador del Cáliz de la Plaga obtiene cualquier resultado doble natural al realizar una tirada de Lanzamiento (sin incluir tiradas naturales de doble 1), el hechizo es lanzado con Fuerza Irresistible independientemente de su valor de lanzamiento o cualquier otro
modificador. Sin embargo, cada vez que el portador lanza con Fuerza
Irresistible, sufre un impacto de Fuerza 4 sin tirada de salvación por armadura (se permite Salvación Especial y Regeneración como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5e96-4fe4-342a-030d" name="Daga ritual" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="57e4-68e6-b970-6ca8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bea9-f62b-a475-64a6" type="max"/>
          </constraints>
          <profiles>
            <profile id="aeef-e215-e322-a2d0" name="Daga ritual" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La Daga Ritual solo puede ser usada por un Hechicero que se haya unido a una unidad. Antes de hacer una tirada de Lanzamiento, el portador de la Daga Ritual puede hacer un sacrificio. Una miniatura perteneciente a la unidad es retirada como baja inmediatamente. El portador puede entonces modificar su tirada de Lanzamiento añadiendo al resultado el atributo de Heridas de la miniatura sacrificada.
Ten en cuenta que esto es un modificador al resultado de la tirada no niega un resultado de doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b46c-2b45-5a72-8498" name="Fetiche del árbol de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b859-0f35-e7dd-838d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fcfb-a848-4085-fbcc" type="max"/>
          </constraints>
          <profiles>
            <profile id="b265-58ed-5000-590b" name="Fetiche del árbol de brujas" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Siempre que el portador del Fetiche del Árbol de Brujas lanza exitosamente un Proyectil Mágico, puede repetir cualquier tirada fallida para Herir.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f47b-8dbc-b043-5c7d" name="Corazón de Demonio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c092-1c4e-ff70-1eaf" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c5c0-5366-4d80-af3d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7e15-6e0d-d4e4-0e43" name="Corazón de Demonio" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Dispersión Mágica, el portador del Corazón de Demonio cuenta su Nivel de Mago como uno superior al del Mago cuyo hechizo está dispersando o, en el caso de Hechizos Vinculados, uno superior al Nivel de Hechicería de ese hechizo.
Ten en cuenta que esto se aplica incluso si significara que el portador cuenta su Nivel de Mago como inferior al que realmente es.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="24ff-b5c6-4d1f-9252" name="Objetos arcanos muy comunes. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="47f0-1b2e-a673-55fc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="86c3-3f86-0922-cbcc" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d0f8-dffb-d2fb-3366" name="Colmillo Sangriento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f883-cc5f-b1bf-0fee" type="max"/>
          </constraints>
          <profiles>
            <profile id="ca56-416f-3245-7461" name="Colmillo Sangriento" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Además de los Saberes de la Magia que normalmente puedan conocer, el portador de un Colmillo Sangriento puede conocer hechizos del Saber de la Magia Primigenia (ver página 92).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3ca8-ca4f-617e-96bc" name="Sangre del Entregador de Sombras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6b5d-108f-c809-8cae" type="max"/>
          </constraints>
          <profiles>
            <profile id="8fd7-0d17-d89b-dcd8" name="Sangre del Entregador de Sombras" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un sólo uso. Un Mago puede usar este objeto en lugar de realizar un intento de dispersión Mágica. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirada de Dispersión. Ten en cuenta que una invocación perfecta no puede ser dispersada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6bc5-624a-4034-03c6" name="Mutaciones del caos. Personajes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="89c5-bf59-aa35-94f9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="938e-b1d3-e511-fbfc" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e005-5bda-b40f-6095" name="Corona de cuernos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5c40-f69c-7238-f90f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6d75-a0b1-4fd1-5faf" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f2c-b25d-e163-d9c7" name="Corona de cuernos" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Sólo personajes. Este personaje y cualquier unidad a la que se haya unido obtienen la regla especial Tozudo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c54f-1d6e-cb2d-08c0" name="Tozudo (Stubborn)" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="34ee-5ed2-108f-2d35" name="Piel sombría" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c4fc-548b-5a45-0332" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9a59-2e18-eb0a-a9a4" type="max"/>
          </constraints>
          <profiles>
            <profile id="0c2e-67a0-e630-effb" name="Piel sombría" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Sólo personajes. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2783-c3d1-9146-9075" name="Mutaciones del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fee5-ed33-cf92-2533" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e5a3-6884-d5a6-3755" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f956-de2b-fb8d-62ba" name="Pellejo endurecido" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="18ed-3bce-4699-c492" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a9e9-8026-478f-6f56" type="max"/>
          </constraints>
          <profiles>
            <profile id="e3af-1569-e8a2-6980" name="Pellejo endurecido" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Solo miniaturas cuyo tipo de tropa es ‘infantería’. Esta miniatura obtiene la regla especial Pellejo Duro (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="19ba-d14f-ceb4-5ed4" name="Pellejo duro (X)" hidden="false" targetId="1dce-aa57-3693-62ae" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0045-181b-b542-0b2e" name="Mutaciones del caos. Caudillo hombre bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c857-4167-41d5-fb10" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4fb2-7501-edcf-56e5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="639e-731f-f168-6af5" name="Runa de la bestia ascendente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2301-80e9-53a8-b52b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1104-5802-0ece-bbde" type="max"/>
          </constraints>
          <profiles>
            <profile id="15a1-088f-6169-6b38" name="Runa de la bestia ascendente" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Solo Caudillos Hombres Bestia. Excepto si este personaje está huyendo, Rebaños de Bestigors, Gors y Ungors amigos obtienen un modificador de +1 a su atributo de Liderazgo mientras estén dentro del Aura de Mando de este personaje (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f19f-387e-18c2-62dc" name="Mutaciones del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0770-c3fe-b2f3-8032" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="86ba-20cd-5ceb-24d2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="452e-e470-e47c-a887" name="Monstruosidad muscular" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e0ce-bad8-f6dc-1570" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3675-fb5e-52ff-8f41" type="max"/>
          </constraints>
          <profiles>
            <profile id="0f30-d44e-bafb-8671" name="Monstruosidad muscular" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f888-e4a2-52aa-5234" name="Colmillos destripadores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1ac3-af85-0a16-d1ad" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2586-f0e7-a23b-eb50" type="max"/>
          </constraints>
          <profiles>
            <profile id="f281-c4e4-a0a6-e1e5" name="Colmillos destripadores" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Durante la fase de Combate, el atributo de Penetración de Armadura de cualquier arma utilizada por esta miniatura (pero no su montura) es mejorada en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a7db-48b5-1c5a-8e87" name="Diablo de múltiples extremidades" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="14b8-c9eb-1304-3f5a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e1f4-63e3-ea67-b90c" type="max"/>
          </constraints>
          <profiles>
            <profile id="6c2d-aa1a-ce0e-2e85" name="Diablo de múltiples extremidades" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Ataques. Sin embargo, este ataque extra debe hacerse utilizando un arma de mano ordinaria.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a29a-7c3a-c649-cbd3" name="Piel de babosa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ccab-9d48-2204-209e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5672-158e-2b36-90a5" type="max"/>
          </constraints>
          <profiles>
            <profile id="b695-ae30-1395-4eaf" name="Piel de babosa" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Cualquier miniatura enemiga que dirija sus ataques contra esta miniatura o cualquier unidad a la que se haya unido sufre un modificador de -1 a sus tiradas para Impactar durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a786-10a3-af7e-f629" name="Sentidos amplificados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8d82-d33c-6d70-d967" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="43de-4191-23d5-a4af" type="max"/>
          </constraints>
          <profiles>
            <profile id="3a08-32df-d2c2-30f7" name="Sentidos amplificados" hidden="false" typeId="f594-e67d-4cf0-518d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70c-1d1b-9f32-de9b">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
