                    <characteristic name="Tipo de tropa" typeId="0c59-b5c0-8666-35bf">Infantería regular</characteristic>
                    <characteristic name="Reglas especiales" typeId="4d01-772d-4584-b98b">Formación cerrada, Horda, Líder de la manada, Mover a través de cobertura, Furia primigenia, Zancada veloz, Partida de guerra</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="a7e9-ae5c-8066-2c1b" name="Líder de la manada" hidden="false">
                  <description>Las miniaturas con esta regla especial pueden ser incluidas como parte de una unidad de Mastines de Guerra Primigenios. Las miniaturas con esta regla especial deben posicionarse en la retaguardia de su unidad, formando su(s) fila(s) trasera(s). Cualquier Mastín de Guerra Primigenio que contenga la unidad debe ocupar siempre la(s) fila(s) delantera(s) de la unidad, adelantándose a cualquier miniatura con esta regla especial para llegar allí si es necesario (como cuando la unidad gira).</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="e5c5-82e5-88e2-9a82" name="Formación cerrada" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
                <infoLink id="a267-8434-4632-47db" name="Horda" hidden="false" targetId="358a-61a9-60e5-faec" type="rule"/>
                <infoLink id="db6e-61e3-58ba-f33b" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
