        <selectionEntry id="ed88-d323-da38-7f60" name="Runa de la bestia verdadera" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="115b-fb77-32eb-bde1" type="max"/>
