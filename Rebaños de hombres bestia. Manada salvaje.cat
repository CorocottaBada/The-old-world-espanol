    <selectionEntry id="3135-2870-f749-9e09" name="Manadas de guerra primigenias" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="6fe4-6eeb-7acd-2ed5" value="4.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="6fe4-6eeb-7acd-2ed5" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="69ef-3732-8ef5-2174" type="min"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6fe4-6eeb-7acd-2ed5" type="max"/>
      </constraints>
      <rules>
        <rule id="bfed-ae40-338d-98b9" name="Carga bestial" hidden="false">
          <description>Durante un turno en el que haya realizado un movimiento de carga de 3” o más, una miniatura con esta regla especial obtiene un modificador de +1 a su atributo de Fuerza.</description>
        </rule>
        <rule id="4bdd-b1ce-5a7d-1010" name="Unidad mixta" hidden="false">
          <description>Las miniaturas dentro de una Manada de Guerra Primigenia tienen diferentes atributos de
Habilidad de Armas y Resistencia. Antes de tirar Para Herir, los impactos causados por disparos enemigos deben dividirse tan equitativamente como sea posible entre Gors y Ungors. En combate, los modelos enemigos deben dirigir sus ataques contra las miniaturas en la fila de combate de esta unidad, como se describe en la página 147 del reglamento de Warhammer: the Old World.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4b20-a8c9-8a98-6209" name="Ira de sangre" hidden="false" targetId="5b9f-1a73-3189-31c2" type="rule"/>
