        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5bcb-99ec-6d4a-51e3" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="83d8-27a1-b2fa-4b39" name="Placas oscuras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8a16-1659-7b23-7dc0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="447b-c556-814e-aabe" type="max"/>
          </constraints>
          <profiles>
            <profile id="bced-0932-c236-ece7" name="Placas oscuras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Las Placas Oscuras son un conjunto de armadura completa. Además, su portador tiene una Salvación Especial de 3+ contra cualquier herida causada por un ataque que tenga la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b0de-0b54-bc34-b1a6" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="fa95-57f1-ad19-b286" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2e53-4a59-c88a-3e6a" name="Armaduras mágicas. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54cc-f75c-7cb2-7358" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e367-24e3-a8e4-5d99" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="90b2-58fc-f494-e573" name="Pellejo del caminante de sombras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ddb7-8fb0-6b60-3ab9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9ace-6a2f-f6a8-0a49" type="max"/>
          </constraints>
          <profiles>
            <profile id="0cbf-519d-f51a-5670" name="Pellejo del caminante de sombras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede combinarse con otra armadura. El portador del Pellejo de Caminante de Sombras mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador (y cualquier unidad a la que se haya unido) tienen Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e60e-f03c-e663-b569" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0ba1-daf9-2397-0219" name="La Piel de Sharggu" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1cbd-5016-cdd8-0799" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="400d-8392-4286-4a13" type="max"/>
          </constraints>
          <profiles>
            <profile id="9ada-3bba-694d-035d" name="La Piel de Sharggu" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a"/>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador de La Piel de Sharggu mejora su valor de armadura en 2 (hasta un máximo de 2+) contra ataques de proyectiles no mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a8c2-1e09-62c1-8968" name="Armaduras mágicas muy comunes. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="014d-5244-7038-451c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d251-5631-3572-daad" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d1d9-7b3e-acc0-365f" name="Armadura completa del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cd21-7f8a-aca8-7b29" type="max"/>
          </constraints>
          <profiles>
            <profile id="6bda-a8bd-b52f-c8d8" name="Armadura completa del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="abde-501e-c8e6-feac" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f220-b73c-64e3-e344" name="Armadura pesada del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="05bd-834b-a95e-e39c" type="max"/>
          </constraints>
          <profiles>
            <profile id="9a75-5566-84bb-2f4b" name="Armadura pesada del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="345f-8741-2ae9-b023" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="a7a9-3930-6d09-e4de" name="Toro-gors" hidden="false">
      <description>Los Impactos por Carga causados por una miniatura con esta regla especial tienen un atributo de Penetración de Armadura de -1.</description>
    </rule>
    <rule id="8929-2746-1ff6-429a" name="Saber de las Bestias" hidden="false">
      <description>Un Hechicero con la regla especial ‘Saber de las Bestias’ puede descartar uno de los hechizos generados al azar como es habitual. En su lugar puede seleccionar el hechizo identificativo del Saber de la Magia elegido o uno de los hechizos enumerados a continuación
Marea mortal:
Tipo: Proyectil Mágico
Dificultad de Lanzamiento: 9+
Alcance: 15”
Efecto: La unidad enemiga sufre 5D6 impactos de Fuerza 1, sin tirada de salvación por armadura (Salvación Especial y Regeneración se aplican como de costumbre).
Regresión:
Manto de Ghorok:
Tipo: Potenciación
Dificultad de Lanzamiento: 8+
Alcance: Lanzador
Efecto: Hasta el final de este turno, el lanzador obtiene un modificador de +1D6 a sus atributos de Fuerza y Ataques (hasta un máximo de 10). Sin embargo, si el resultado obtenido es un 6, el modificador se pierde y el lanzador pierde una Herida.
Tipo: Proyectil Mágico
Dificultad de Lanzamiento: 8+
Alcance: 15”
Efecto: La unidad enemiga debe hacer un chequeo de Liderazgo inmediatamente. Si se falla el chequeo, pierde un número de Heridas igual a la cantidad por la que se falló el chequeo.</description>
    </rule>
    <rule id="d730-6af4-cd77-84d5" name="Mirada de los dioses" hidden="false">
      <description>Durante la subfase de Mando de su turno, un personaje con esta regla especial puede elegir tirar en la Tabla de la Mirada de los Dioses:
Tabla de la Mirada de los Dioses
1D6 Resultado
1 Maldito por el Caos: Esta miniatura queda sujeto a la regla especial Estupidez durante el resto de la partida. Si ya tiene esta regla especial, sufre un modificador de -1 a su Liderazgo (hasta un mínimo de 2).
2 Rapidez antinatural: Hasta tu próxima subfase de Inicio de Turno, esta miniatura obtiene un modificador +1 a su atributo de Iniciativa (hasta un máximo de 10).
3 Piel férrea: Hasta tu próxima subfase de Inicio de Turno, esta miniatura obtiene un modificador de +1 a su atributo de Resistencia (hasta un máximo de 10).
4 Mutación homicida: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a su atributo de Habilidad de Armas (hasta un máximo de 10).
5 Furia oscura: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a su atributo de Ataques (hasta un máximo de 10).
6 Apoteosis: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a sus atributos de Fuerza y Liderazgo (hasta un máximo de 10).
Ten en cuenta que los beneficios otorgados por la Mirada de los Dioses solo se aplican al Campeón, no a su montura (si tiene una).</description>
    </rule>
    <rule id="825a-9c00-71ed-6872" name="Marca del caos Absoluto" hidden="false">
      <description>Las miniaturas con la Marca del Caos Absoluto pueden repetir cualquier chequeo fallido de Miedo, Pánico o Terror.</description>
    </rule>
    <rule id="5b9f-1a73-3189-31c2" name="Ira de sangre" hidden="false">
      <description>Si cuando se chequea para Furia Primitiva (ver página 79) esta unidad supera su chequeo de Liderazgo con cualquier tirada de doble natural, también obtendrá Furia Asesina. Una unidad puede obtener Furia Asesina a pesar de haberla perdido previamente en la batalla.</description>
    </rule>
    <rule id="1c3d-8a56-4adb-2058" name="Furia primitiva" hidden="false">
      <description>Cuando esta unidad es elegida para combatir durante el Paso 1.1 en cualquier subfase Elegir Combate y Luchar, debe hacer un chequeo de Liderazgo. Si supera el chequeo, la unidad queda sujeta a Furia Primitiva hasta el final de esta fase de Combate. Una unidad sujeta a Furia Primitiva puede repetir cualquier tirada para Impactar con resultado de 1 natural.</description>
    </rule>
    <rule id="95ac-44e3-4a86-7b2a" name="Desgarrador de enemigos" hidden="false">
      <description>Mientras esté sujeta a Furia Primitiva, un arma de mano blandida por una miniatura con esta regla especial tiene un atributo de Penetración de Armadura de -2.
Ten en cuenta que esta regla especial sólo se aplica a una única arma de mano no-mágica y no se aplica a la montura de la miniatura (si la tuviera). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, esta regla especial deja de tener efecto.</description>
    </rule>
    <rule id="b73d-40b2-bc53-254d" name="Cólera de la tormenta" hidden="false">
      <description>Una miniatura con esta regla especial tiene una Tirada de salvación especial de 5+ para cualquier herida sufrida a causa de hechizos de Proyectil mágico o Vórtice mágico. Además, si una miniatura con esta regla especial, o la unidad a la que pertenezca, sufre uno o más impactos por Llamada a la tormenta, (ver págica 74), se vuelve &quot;Encolerizada&quot;. Una miniatura &quot;Encolerizada&quot; tiene un modificador de +1 a sus atributos de Iniciativa y Ataques. Esta &quot;Encolerizada&quot; dura hasta su siguiente subfase de Inicio del Turno.</description>
    </rule>
    <rule id="9d6c-6e83-8201-fcaf" name="Colmillos afilados" hidden="false">
      <description>Durante el turno que ha cargado, el atributo de Penetración de Armadura de los colmillos de Tuskgors y Garragors (arma de mano) es mejorado en 1.
Ten en cuenta que esta regla especial solo se aplica a ataques realizados por un Tuskgor o un Garragor, no a un carro o su tripulación.</description>
    </rule>
    <rule id="afba-f1a5-36d3-81eb" name="Borrachos" hidden="false">
      <description>Durante la subfase de Inicio del Turno de cada uno de tus turnos, tira en la Tabla de Borrachos para cada unidad con esta regla especial que no se encuentre bajo Furia Asesina, no esté trabada en combate y que no esté huyendo:
Tabla de borrachos
1D6 Resultado
1 Inestable: Hasta su siguiente subfase de Inicio del Turno, la unidad está sujeta a la regla especial Movimientos Aleatorios y su atributo de Movimiento se convierte en 1D6+2.
2-5 Sobrio al fin: El alcohol no tiene efecto alguno sobre la unidad.
6 Borrachos Belicosos: Hasta su siguiente subfase de Inicio del Turno, la unidad está sujeta a la regla especial Furia Asesina (aunque la hubiese perdido previamente en la batalla).</description>
    </rule>
    <rule id="55f1-d54e-da5f-27da" name="Armas hechizadas" hidden="false">
      <description>Un arma de mano blandida por una miniatura con esta regla especial tiene la regla especial Ataques Mágicos y un atributo de Penetración de Armadura de -1.
Ten en cuenta que esta regla especial sólo se aplica a una única arma de mano no mágica y no se aplica a la montura de la miniatura (si la tuviera). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, esta regla especial deja de tener efecto.</description>
    </rule>
    <rule id="b0e5-c247-8b27-f411" name="Ansia de sangre" hidden="false">
      <description>Mientras tenga Furia Asesina, esta miniatura tiene un modificador de +2 a su atributo de Ataques (en vez del +1 habitual). Sin embargo, tan desesperada es la necesidad de carne fresca de esta miniatura que solo tira un único 1D6 cuando hace una tirada de Persecución (en vez del 2D6 habitual).</description>
    </rule>
    <rule id="efd6-e370-3128-715c" name="Hechicería ancestral" hidden="false">
      <description>Además de los Saberes de la Magia que normalmente conocen, los Chamanes Hombres Bestia dentro de un ejército de Manada Salvaje pueden conocer hechizos del Saber de la Magia Primigenia (ver página 82).</description>
    </rule>
    <rule id="1753-899b-6bec-1886" name="Cónclave oscuro" hidden="false">
      <description>Los Chamanes Hombres Bestia dentro de un ejército de Manada Salvaje pueden extraer poder de Magos cercanos cuando intentan lanzar un hechizo o cuando intentan una Dispersión Mágica. Para hacerlo, un Chamán del Rebaño o Gran Chamán del Rebaño puede aplicar un modificador de +1 a su tirada de Lanzamiento o Dispersión si hay uno o más Hechiceros amigos dentro de su Aura de Mando. Sin embargo, si obtiene un doble natural al realizar la tirada, algo ha salido terriblemente mal. Tira inmediatamente en la tabla de Disfunción Mágica pero aplica el resultado al Chamán del Rebaño o Gran Chamán del Rebaño que hizo el intento y a cada Hechicero amigo dentro de su Aura de Mando.</description>
    </rule>
    <rule id="9c82-a900-a7e0-6676" name="Dones de los Dioses oscuros" hidden="false">
      <description>Las miniaturas de Personaje en este ejército pueden gastar 25 puntos adicionales en objetos mágicos y 25 puntos adicionales en Mutaciones del Caos.</description>
    </rule>
    <rule id="44e0-5649-4c7d-9189" name="Partidas de guerra errantes" hidden="false">
      <description>Dentro de un ejército de Manada Salvaje, cualquier número de Rebaños de Gors, Rebaños de Ungors, Manadas de Guerra Primigenias y Rebaños de Centigors pueden tener la regla especial Emboscadores por +1 punto por miniatura. Cualquier número de Caudillos Hombres Bestia y Caudillos Centigor pueden tener la regla especial Emboscadores al coste de +10 puntos por miniatura.
Además, 0-1 Rebaño de Gors, Rebaño de Ungors o Rebaño de Centigors cada 1.000 puntos con una Potencia de Unidad de 10 o menos puede obtener la regla especial Emboscadores sin coste adicional.</description>
    </rule>
  </sharedRules>
</catalogue>