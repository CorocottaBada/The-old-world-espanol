<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue id="978c-27ff-8913-ff4b" name="Rebaños de hombres bestia. Manada salvaje" revision="3" battleScribeVersion="2.03" authorName="Corocotta Bada" authorContact="Corocotta10@gmail.com" authorUrl="https://eljabalipisador.com/" library="false" gameSystemId="dfdc-8d68-90f9-7f0e" gameSystemRevision="35" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
