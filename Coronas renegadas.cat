        <selectionEntry id="8d08-865f-031e-a763" name="El diestro errante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="76e9-2c39-07ae-529e" type="max"/>
          </constraints>
          <profiles>
            <profile id="953e-3e14-6772-1da4" name="El diestro errante" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un personaje con el Origen Infame de diestro errante:
- Tiene un modificador de +2 a su atributo de Habilidad de Armas.
- Obtiene la regla especial Finta y esquiva.
- No puede llevar ningún arma con la regla especial Golpea último.
- Puede llevar un arma de mano adicional +3 puntos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="9be0-17c6-686e-9d55" name="Finta y esquiva" hidden="false">
              <description>Una vez por partida, cuando un modelo enemigo dirija sus ataques contra un modelo con esta regla especial, puedes hacer que el modelo enemigo repita las tiradas exitosas para Impactar.</description>
            </rule>
          </rules>
          <selectionEntries>
            <selectionEntry id="919b-da49-64e3-e74f" name="Arma de mano adicional" hidden="false" collective="false" import="true" type="upgrade">
