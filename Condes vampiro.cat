          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fed8-674f-718a-e5d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2f51-a689-5a76-872b" type="max"/>
          </constraints>
          <profiles>
            <profile id="802c-c847-3db6-d43b" name="Capa de niebla y sombras" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Nigromantes cuyo tipo de tropa sea solo ‘infantería’. El portador de la Capa de Niebla y Sombras obtiene la regla especial Etéreo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ec89-5eab-b80d-9bf3" name="Etéreo (Ethereal)" hidden="false" targetId="54d1-564f-87ea-3799" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c30d-af7e-c91c-580e" name="Objetos arcanos. Condes vampiro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2986-5750-76ff-b5ff" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f5ce-4bbd-c8ab-7569" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="85bb-56a4-5d1e-15a5" name="Cetro de Noirot" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2a10-00fa-3f7c-95bd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8e17-6b55-d1d1-c102" type="max"/>
          </constraints>
          <profiles>
            <profile id="e2cc-127f-3c02-5b8d" name="Cetro de Noirot" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Cetro de Noirot puede intentar resucitar a los caídos usando la regla especial Invocación de Nehek dos veces durante su subfase de Mando (en lugar de una sola vez). Tira un 1D6 cada vez que se usa el cetro. En una tirada de 1, el portador pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e0c0-3849-242c-d723" name="Báculo de cráneo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f7b3-ccef-cb74-6b89" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3601-443a-9377-d540" type="max"/>
          </constraints>
          <profiles>
            <profile id="5501-51bc-4302-3d1f" name="Báculo de cráneo" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Báculo de Cráneo aumenta su alcance de Dispersión en 3” y, al intentar una Dispersión Arcana, puede aplicar un modificador +1 a su Tirada de dispersión.
Ten en cuenta que esto es un modificador del resultado de una tirada, no niega una tirada de un doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9df3-bc2a-338a-71d6" name="Objetos arcanos muy comunes. Condes vampiro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8eca-e99c-4473-8bcc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1d3a-0b05-870b-1451" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2b17-6c38-a50e-b063" name="Familiar hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0f42-6864-35c2-49eb" type="max"/>
          </constraints>
          <profiles>
            <profile id="74cd-360a-3a9e-cc08" name="Familiar hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por Hechicero. El propietario de un Familiar Hechicero conoce un hechizo más (elegido como de costumbre) de lo normal para su Nivel de Hechicería.
Ten en cuenta que esto no aumenta el nivel del Hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
