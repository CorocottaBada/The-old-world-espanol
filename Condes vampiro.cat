              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Solo miniaturas de tipo de tropa ‘infantería’. Este vampiro obtiene la regla Volar (10), pero no puede unirse a una unidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1f97-8423-545a-a5c6" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
