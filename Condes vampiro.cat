    <selectionEntry id="9333-a0f8-a94e-86f4" name="Carruaje negro" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="2.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="91ac-7e5f-c461-e1d0" type="max"/>
      </constraints>
      <rules>
        <rule id="6bf9-4fa7-5672-228d" name="Carruaje espectral" hidden="false">
          <description>Un Carruaje negro no es totalmente corpóreo. Para representar esto, un Carruaje Negro puede convertirse en “Incorpóreo” durante la subfase de Orden de tu turno, y permanecerá Incorpóreo hasta tu próxima subfase de Inicio de Turno. Mientras que sea Incorpóreo, un Carruaje Negro:
Pierde la regla especial Impactos por Carga (1D6+2).
Obtiene las reglas especiales Etéreo y Volar (10).</description>
        </rule>
      </rules>
      <infoLinks>
