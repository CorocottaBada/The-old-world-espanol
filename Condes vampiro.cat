          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d55d-b1db-afdb-af89" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="108f-8b04-90ee-defb" type="max"/>
          </constraints>
          <profiles>
            <profile id="728b-88bf-6bd2-10a9" name="Maestro de la magia negra" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Este Poder Vampírico solo puede ser adquirido por un Conde Vampiro que sea un Hechicero de Nivel 2, o por un Vampiro que sea un Hechicero de Nivel 1. Este vampiro aumenta su Nivel de Hechicería en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7093-2950-16d4-6bf7" name="Armas mágicas. Condes vampiro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d77-b29c-9964-d81f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9673-4fda-204b-295e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5172-f2e8-1477-7b9d" name="Bebedora de sangre" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4718-679c-4f1c-566b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c7a-8806-9833-41d5" type="max"/>
          </constraints>
          <profiles>
            <profile id="e19b-b6a1-7993-e29d" name="Bebedora de sangre" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Si el portador de la Bebedora de sangre causa una o más heridas no salvadas durante la fase de Combate, recupera una única herida perdida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6e68-ed93-dbbf-5e68" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6143-abee-b6ae-ee32" name="Espada de los reyes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="db36-81e7-8387-47d1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="51fb-681d-059c-bd62" type="max"/>
          </constraints>
          <profiles>
            <profile id="d88f-b949-c44c-8db3" name="Espada de los reyes" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpe letal</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de la Espada de los Reyes asesta un Golpe Letal si saca un 5 o 6 natural al hacer una tirada para Herir, en lugar del 6 habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a378-c74c-f74e-4746" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="d24c-2960-d6fe-3ac9" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="87f2-4509-2790-1437" name="Espada del frío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8139-d6cf-f425-076d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="427e-eeea-4311-c017" type="max"/>
          </constraints>
          <profiles>
            <profile id="cdef-2dc1-df0b-5072" name="Espada del frío" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpe letal</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier miniatura enemiga que sufra una o más heridas no salvadas por la Espada del Frío debe realizar inmediatamente un chequeo de Resistencia Si este chequeo falla, ganan la regla especial Pegar último y deben reducir su atributo de Iniciativa a 1 durante el resto de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="eed4-4c79-1b06-04b6" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="9e03-4b60-7350-3c7d" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d82e-ec34-1834-cb02" name="Armas mágicas. Condes vampiro. Caballería o Monstruo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d71-5606-60b1-4bd4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="131e-510e-e2a3-3895" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9314-b9e7-14a6-2b97" name="Lanza siniestra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a3cc-dc3d-187a-f985" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d73-a55f-ce16-78b8" type="max"/>
          </constraints>
          <profiles>
            <profile id="532a-16ab-2386-ac59" name="Lanza siniestra" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Perforacorazas (1)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Solo miniaturas cuyo tipo de tropa sea ‘caballería’ o ‘monstruo’. La Lanza Siniestra solo se puede usar durante un turno en el que el portador haya cargado. En los turnos posteriores (o si el portador no cargó) la miniatura debe usar su arma de mano en su lugar. El portador de la Lanza Siniestra puede repetir cualquier tirada fallida para Impactar realizada mientras la usa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="890b-a4a7-c56f-01dc" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="7d5f-cd4f-397c-25b1" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ad82-ac47-3cb1-dda4" name="Armaduras mágicas. Condes vampiro. Permite magos. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4eab-b974-198f-8c92" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d8a-54f1-eff8-a38b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9de7-fbe7-23c6-0845" name="La cota desolladora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f57-925a-2969-9ab3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="946f-a6c7-9af7-e821" type="max"/>
          </constraints>
          <profiles>
            <profile id="bc34-7e04-eb86-c10f" name="La cota desolladora" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Cota Desolladora es una armadura pesada que puede ser usada por un Hechicero sin penalización. Además, su portador tiene una Salvación Especial de 6+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="74cc-b673-2a6e-5b35" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f7c5-700a-4007-a6bc" name="Armaduras mágicas. Condes vampiro. Infantería o Caballería. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="adb8-dabd-6e43-b895" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7bba-c8d9-05e8-b7ff" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4312-a5be-ba3e-5cd5" name="La armadura maldita" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1d82-5b5d-1c1e-47a2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0321-f0df-c3c8-9c96" type="max"/>
          </constraints>
          <profiles>
            <profile id="d2f1-5fe2-edd3-0f9b" name="La armadura maldita" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa sea ‘infantería’ o ‘caballería’. La Armadura Maldita es una armadura completa. Además, su portador tiene un modificador +1 a su atributo de Resistencia, pero sufre un modificador de -1 a sus Atributos de Habilidad de Armas e Iniciativa (hasta un mínimo de 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5370-7ebc-f1f6-37c0" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ebde-cc70-5de2-7014" name="Talismanes. Condes vampiro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c274-e755-0758-6c0f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d704-4f67-2a34-8c52" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1320-8e67-eaf8-a8eb" name="Anillo Von Carstein" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f244-b6be-84c6-93fd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fdf3-77f4-c98c-95d7" type="max"/>
          </constraints>
          <profiles>
            <profile id="6632-1a8f-0d2e-22f2" name="Anillo Von Carstein" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo Vampiros. Un solo uso. Cuando el portador del Anillo Von Carstein pierda su última Herida, tira 1D6. Con un resultado de 2+, la Herida no se pierde.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="72fb-ab4f-c0e5-b5ec" name="Corona de los condenados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ec2e-3e01-c518-395f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bf35-fcd5-9311-a5da" type="max"/>
          </constraints>
          <profiles>
            <profile id="7354-58fb-1deb-18d2" name="Corona de los condenados" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">La Corona de los Condenados otorga a su portador una Salvación Especial de 4+ contra cualquier herida sufrida. Sin embargo, debido a los lamentos de los espíritus atrapados dentro de la corona, su portador también está sujeto a la regla especial de Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c507-722d-62da-033c" name="Estupidez (Stupidity)" hidden="false" targetId="e78e-de09-5640-bcda" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f250-ee09-48ab-2521" name="Estandartes mágicos. Condes vampiro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca8a-b1fb-3f58-ede6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c9b-b184-e7c9-7cc4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e879-9210-15bf-f55d" name="Estandarte de Drakenhof" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1068-3af0-a233-cd75" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f971-9b43-f872-13c5" type="max"/>
          </constraints>
          <profiles>
            <profile id="55a7-6558-f26e-5b61" name="Estandarte de Drakenhof" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad que lleva el Estandarte de Drakenhof tiene la regla especial Regeneración (X+), mejora el valor de armadura de su salvación de Regeneración en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="44cd-f696-848a-8278" name="Regeneración (X+) (Regeneration)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="50ab-55c5-f832-af21" name="Estandarte del vigor infernal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b1c3-4855-18b4-2a99" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6336-340d-8300-3847" type="max"/>
          </constraints>
          <profiles>
            <profile id="60f0-d102-cbbd-e8eb" name="Estandarte del vigor infernal" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de Vigor Infernal obtiene la regla especial Movimiento de Reserva.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2994-2470-1123-863b" name="Movimiento de reserva (Reserve movement)" hidden="false" targetId="fd0d-c7a1-619d-b8d4" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fbca-7dbd-bbbf-d01e" name="Estandarte de los lamentos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="09db-5d4a-7130-91d1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d5e4-16f1-32fe-0b75" type="max"/>
          </constraints>
          <profiles>
            <profile id="10d7-7d48-ccae-460e" name="Estandarte de los lamentos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando una unidad enemiga realiza un chequeo de Liderazgo debido al Miedo causado por una unidad que lleva el Estandarte Aullante, debe tirar 1D6 extra y descartar el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fadd-a1ad-231b-7720" name="Estandartes mágicos. Condes vampiro. Portaestandarte de batalla Señor tumulario" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e4e7-9d2e-5733-0116" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ab79-5d18-c504-1037" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9d26-5094-45b0-e3c6" name="Estandarte de los túmulos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0569-5897-71ab-0e63" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7624-fc4d-6cad-db0d" type="max"/>
          </constraints>
          <profiles>
            <profile id="d8de-8d65-d565-1feb" name="Estandarte de los túmulos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Solo Portaestandarte de Batalla Señor Tumulario. Durante la fase de Combate, cuando una unidad que lleva el Estandarte de los Túmulos realiza una tirada para Impactar, una tirada de 3+ siempre es un éxito, independientemente de la Habilidad de Armas del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d742-3dc7-5dbe-d6ee" name="Objetos hechizados. Condes vampiro. Nigromante y Tumulario" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fd3c-b25f-c215-8e90" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f15f-6e05-d57f-64cf" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c1df-f20f-2444-8f4a" name="Yelmo de mando" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f8cc-96bc-4410-f6bc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e5ce-6b9a-4b2b-b270" type="max"/>
          </constraints>
          <profiles>
            <profile id="7ede-2721-3692-7251" name="Yelmo de mando" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo Nigromantes y Tumularios. Durante la subfase de Mando de tu turno, este personaje puede intentar mejorar la sensibilidad de los que le rodean haciendo un chequeo de Liderazgo (usando su propio Liderazgo). Si lo supera, hasta la siguiente subfase de Inicio de Turno, este personaje y cualquier unidad a la que se haya unido ganan un modificador +1D3 a su atributo de Habilidad de Armas (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="dd5b-d0e0-37b1-9011" name="Objetos hechizados. Condes vampiro. Nigromante" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a1ed-e3aa-5dde-83f3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="97f5-d2d6-974d-e2a1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7287-6383-d5f4-eb17" name="Mano de polvo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5545-0ab6-0926-7ef4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5154-2d67-ad21-c31a" type="max"/>
          </constraints>
          <profiles>
            <profile id="bad7-fff1-35f9-e408" name="Mano de polvo" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo Nigromantes. Esta miniatura puede lanzar el siguiente Hechizo Vinculado, con un Nivel de Poder de 2. Tira 1D6 cada vez que se use la Mano del Polvo. Con una tirada de 1, se desmorona hasta convertirse en polvo y no se puede volver a usar:
Tipo: Asalto
Dificultad de Lanzamiento: 9+
Alcance: Combate
Efecto: La unidad objetivo sufre 2D6 Impactos de Fuerza 5, cada uno con una PA de -1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="36d9-1cc0-a942-9379" name="Objetos hechizados. Condes vampiro. Nigromante. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bd37-66f7-2d5a-54bf" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e990-56c5-155b-5b87" type="min"/>
      </constraints>
      <selectionEntries>
