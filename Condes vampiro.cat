        <selectionEntry id="35a2-e07e-2787-d59b" name="Portaestandarte de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="f52c-48ed-0fee-3164" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="77c3-554e-ffc7-ae56" type="equalTo"/>
              </conditions>
