        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="09f3-b2a1-0539-1f89" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="56e9-fc0a-5244-6116" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6e0e-13e1-3d23-b651" name="Maldición del resucitado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ecef-22bb-de0b-e638" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f87c-d2ad-d472-ef9a" type="max"/>
          </constraints>
          <profiles>
            <profile id="3eeb-7833-5ad7-bee9" name="Maldición del resucitado" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Este Vampiro tiene un modificador +1 a su atributo de Heridas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="938c-f2ba-6ece-36bd" name="Señor de la noche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="605b-fae6-2ba5-c727" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="118c-4a58-c79e-85c4" type="max"/>
          </constraints>
          <profiles>
            <profile id="eb20-725c-255a-101f" name="Señor de la noche" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Durante la subfase de Mando de tu turno, este Vampiro puede intentar resucitar a las criaturas caídas de la noche haciendo un chequeo de Liderazgo (usando su propio Liderazgo). Si se supera este chequeo, una sola unidad amiga de murciélagos vampiro, enjambres de murciélagos o lobos espectrales que esté a 12” o menos de esta miniatura recupera 1D6 heridas perdidas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4865-3f95-294b-6f76" name="Horror sobrenatural" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3704-7ddb-f622-339a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5e45-3c27-98d3-1f89" type="max"/>
          </constraints>
          <profiles>
            <profile id="4e92-2226-d5d5-24d4" name="Horror sobrenatural" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Este vampiro obtiene la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1a27-6238-9ca4-8c13" name="Terror (Terror)" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8074-72a1-db53-67f0" name="Acólito oscuro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3c58-4d4c-cfea-7eee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="58a9-220b-1913-b253" type="max"/>
          </constraints>
          <profiles>
            <profile id="a1a5-edc5-e824-6509" name="Acólito oscuro" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Este vampiro obtiene la regla especial Invocación de Nehek (como se describe en la página 62). A los efectos del uso de esta regla especial, esta miniatura cuenta como un Hechicero de nivel 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="6feb-f22a-2c35-bbc4" name="Invocación de Nehek" hidden="false">
              <description>Durante la subfase de Mando de tu turno, si no está en combate, este personaje puede intentar resucitar a los caídos (ver página 28) haciendo un chequeo de Liderazgo (usando su propio Liderazgo). Si se supera este chequeo, una única unidad amiga que tenga la regla especial No Muerto Nigromántico y esté a 12” o menos de este personaje recupera un número determinado a continuación de Heridas perdidas. Sin embargo, reparar mágicamente grandes bestias No muertas es mucho más difícil que resucitar zombis de la tierra. Por lo tanto, el número de heridas que se recuperan depende del tipo de tropa de la unidad y del nivel de hechicería de este personaje:
Si el tipo de tropa de la unidad es ‘infantería regular’ o ‘infantería pesada’, recupera un número de Heridas igual al Nivel de Hechicería de este personaje +1D3.
Si el tipo de tropa de la unidad es ‘enjambres’, ‘caballería ligera’ o ‘bestias de guerra’, recupera un número de Heridas igual al Nivel de Hechicería de este personaje +1.
Si el tipo de tropa de la unidad es ‘infantería monstruosa’, ‘caballería pesada’, ‘caballería monstruosa’ o ‘carro ligero’, recupera un número de heridas igual al Nivel de Hechicería de este personaje.
Si el tipo de tropa de la unidad es ‘carro pesado’, ‘criatura monstruosa’, ‘coloso’ o ‘máquina de guerra’, recupera una única herida.</description>
            </rule>
          </rules>
          <entryLinks>
            <entryLink id="def2-d056-e99d-63b0" name="Hechicero" hidden="false" collective="false" import="true" targetId="d4f5-0a9d-86db-72a9" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f8a2-4748-16bd-d8c6" name="Fascinación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="df0a-e066-a435-b861" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7ecc-75e3-9ac5-5d45" type="max"/>
          </constraints>
          <profiles>
            <profile id="1622-26e6-b615-e0f2" name="Fascinación" hidden="false" typeId="fb45-0ad8-09a7-4434" typeName="Poder vampírico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c727-19ff-c6ed-5cc6">Las unidades enemigas deben hacer un chequeo de Liderazgo antes de realizar cualquier tirada para Impactar contra este Vampiro durante la fase de Combate. Si lo falla, solo las tiradas naturales de 6 lograrán impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
