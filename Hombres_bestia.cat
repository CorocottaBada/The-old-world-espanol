              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="d8c0-578f-6428-e262" name="Marca de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="71e5-470c-dc01-6699" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="0e45-175e-2094-e6d2" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9301-dbbb-056e-a707" type="max"/>
              </constraints>
              <rules>
                <rule id="e83e-b11c-56c2-4e94" name="Marca de Tzeentch (Mark of Tzeentch)" hidden="false">
                  <description>Las miniaturas con la Marca de Tzeentch tienen las reglas especiales Ataques Flamígeros y Resistencia Mágica (+1). Adicionalmente, si un Hechicero con la Marca de Tzeentch se une a una unidad con la Marca de Tzeentch con una Fuerza de Unidad de 10 o más, obtendrán un bonificador de +1 a cualquier tirada de Lanzamiento de Hechizos. Si abandonara esa unidad o si la Fuerza de Unidad de dicha unidad bajara de 10, este bonificador se pierde.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="7e4d-2b11-dab8-5cef" name="Marca de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="71e5-470c-dc01-6699" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="0e45-175e-2094-e6d2" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ad1-d3f6-fc95-1431" type="max"/>
              </constraints>
              <rules>
                <rule id="9490-2532-f386-5f77" name="Marca de Nurgle (Mark of Nurgle)" hidden="false">
                  <description>Cualquier miniaturas enemiga que dirija un ataque a una miniatura con la Marca de Nurgle durante la Fase de Combate, deberá repetir cualquier tirada natural de 6 para Impactar.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="b185-7cce-899c-2ca7" name="Marca de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="71e5-470c-dc01-6699" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="0e45-175e-2094-e6d2" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1988-7fd3-e6ec-b5f7" type="max"/>
              </constraints>
              <rules>
                <rule id="2809-5370-7563-7ce8" name="Marca de Slaanesh (Mark of Slaanesh)" hidden="false">
                  <description>Las miniaturas con la Marca de Slaanesh tienen +1 a la Iniciativa durante la primera ronda de cualquier combate. Adicionalmente, si la mayoría de miniaturas en esa unidad tienen la Marca de Slaanesh, esa unidad supera automáticamente cualquier chequeo de Pánico que estén obligados a realizar.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="b897-ecb2-e22c-fb74" name="Marca de Khorne" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="71e5-470c-dc01-6699" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="0e45-175e-2094-e6d2" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="27c1-5e96-4301-8c35" type="max"/>
              </constraints>
              <rules>
                <rule id="de10-fffc-8b12-8494" name="Marca de Khorne (Mark of Khorne)" hidden="false">
                  <description>Miniaturas con la Marca de Khorne tienen la regla especial Frenesí.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
