      <profiles>
        <profile id="af97-3adb-06b7-9fea" name="Cayado de la manada" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
          <characteristics>
            <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Cuando esta miniatura es elegida para combatir durante el Paso 1.1 en cualquier subfase Elegir Combate y Luchar, debe elegir si usa el Cayado de la Manada ofensiva o defensivamente.
Ofensivamente, cuenta como un arma a dos manos. Defensivamente, cuenta como un arma de mano y otorga a su portador un Valor de Armadura de 5+.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink id="dc77-5a03-0e19-3803" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
        <infoLink id="c6fc-423f-aab0-0e56" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
        <infoLink id="7be1-3dbb-3afa-2197" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
        <infoLink id="82b0-999c-2cc9-0d1a" name="Arma a dos manos" hidden="false" targetId="faa6-a3fc-7b87-4756" type="profile"/>
      </infoLinks>
      <costs>
        <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
      </costs>
