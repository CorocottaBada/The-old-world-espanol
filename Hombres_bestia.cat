              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques adicionales (+1D6), Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cada vez que se obtiene un 6 natural en la tirada para los Ataques Adicionales (+1D6) de la regla especial, el portador de El Mazo Negro sufre un modificador de -1 a su atributo de Habilidad de Armas (hasta un mínimo de 1), durante el resto de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
