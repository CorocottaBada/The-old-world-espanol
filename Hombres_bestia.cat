              <profiles>
                <profile id="58b2-54bb-05ac-cb3a" name="Ataque a distancia" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-36&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4 (8)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-3)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Heridas múltiples (1D3+1).</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial “Bombardeo” y una plantilla de área de 3”. Si se obtiene un resultado de ‘Problemas’ en el dado de Artillería, esta miniatura pierde una Herida (en vez de tirar en la tabla de Problemas). La regla especial Heridas Múltiples (1D3+1) solo se aplica a una sola miniatura cuya peana se encuentre debajo del orificio central de la plantilla de área</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="1a5c-19ad-9b4b-ee7a" name="Bombardeo (Bombardment)" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
