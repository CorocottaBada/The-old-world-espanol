    <selectionEntry id="dcfb-f49a-a597-8f26" name="Escuerzo alado" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="e1b0-dbfb-1949-e0c5" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3dc5-4a98-da25-c560" type="max"/>
      </constraints>
      <rules>
        <rule id="ff5d-4d9d-607d-cbbb" name="Aura de locura (Maddening aura)" hidden="false">
          <description>Durante la subfase de Mando de su turno, cualquier unidad enemiga que esté a 8” o menos de esta miniatura, incluyendo unidades que estén huyendo o trabadas en combate, tiene que hacer un chequeo de Liderazgo. Si falla el chequeo, la unidad sufre 1D3 impactos de Fuerza 3, sin salvación por armadura ni Regeneración (se pueden intentar las Salvaciones Especiales de manera normal).</description>
        </rule>
        <rule id="c7fa-3edf-350e-46b2" name="Salpicadura de sangre corrupta (Spurting bile blood)" hidden="false">
          <description>Por cada Herida que pierda esta miniatura durante la fase de Combate, la unidad atacante enemiga sufre un impacto de Fuerza 4, con un PA de -1.</description>
        </rule>
      </rules>
