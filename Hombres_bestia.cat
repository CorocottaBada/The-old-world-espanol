            <profile id="664e-545d-cfcf-17c1" name="Piel sombría" hidden="false" typeId="83e7-7715-920c-134d" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ddcc-b7c0-da12-27c0">Sólo personajes. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
