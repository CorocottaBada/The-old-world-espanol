                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Aparatoso, Ataques mágicos, Heridas múltiples (2), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza de Caza dispara como un lanzavirotes, usando la regla especial Atravesar Filas.</characteristic>
