    <selectionEntry id="36fc-b19a-c372-fe6a" name="Cigor" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="e1b0-dbfb-1949-e0c5" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="15ca-9755-79f9-304e" type="max"/>
      </constraints>
      <rules>
        <rule id="bbb0-29da-5ed3-f858" name="Devorador de almas" hidden="false">
          <description>Cualquier Hechicero enemigo que desee lanzar un hechizo y esté a 12” o menos de uno o más Cigors deberá primero superar un chequeo de Liderazgo. Si lo falla, el Hechicero ha perdido el nervio y, si falla el lanzamiento del hechizo (es decir, si el resultado del lanzamiento es menor que la dificultad de lanzamiento del hechizo) se producirá una disfunción mágica y el jugador activo inmediatamente lanza en la tabla de Disfunción para ver qué destino le espera al desafortunado Hechicero. Si supera el chequeo, el Hechicero puede continuar con su intento de lanzamiento como de costumbre.</description>
        </rule>
        <rule id="2469-3d15-65e2-7427" name="Visión ultraterrena" hidden="false">
          <description>Durante la fase de Combate, un Cigor puede repetir cualquier tirada fallida Para Impactar realizada contra Hechiceros enemigos, miniaturas o unidades enemigas equipadas con cualquier objeto mágico, o miniaturas o unidades enemigas con Salvación Especial o Regeneración.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="5338-3df0-c246-1e3a" name="Coloso" hidden="false" targetId="7e87-1008-0eda-9b33" type="rule"/>
        <infoLink id="96a9-f49f-025f-d13f" name="Formación Cerrada (Close Order)" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
