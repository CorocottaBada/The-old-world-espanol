    <selectionEntry id="e82e-aa92-7ab4-105f" name="Cayado de la manada" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bfa3-539f-0c16-2f0e" type="max"/>
