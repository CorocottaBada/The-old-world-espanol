                <profile id="1bb3-8f31-7171-5fed" name="Cráneo del señor unicornio" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Ghorros tiene una Salvación Especial de 6+ contra cualquier herida sufrida que fuera causada por un ataque enemigo no mágico y una Salvación Especial de 5+ contra cualquier herida sufrida que fuera causada por un ataque enemigo Mágico.</characteristic>
                  </characteristics>
                </profile>
