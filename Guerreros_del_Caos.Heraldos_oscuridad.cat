                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a960-0f8c-2437-2531" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="c48e-17b6-0a30-4328" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
