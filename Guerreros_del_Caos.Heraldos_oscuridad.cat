              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a"/>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador de La Piel de Sharggu mejora su valor de armadura en 2 (hasta un máximo de 2+) contra ataques de proyectiles no mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
