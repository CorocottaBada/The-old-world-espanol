      </constraints>
      <selectionEntries>
        <selectionEntry id="250f-3e08-8516-393b" name="Armadura carmesí de Dargan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ea10-6976-ec03-3775" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0e7-4fee-4375-cdda" type="max"/>
          </constraints>
          <profiles>
            <profile id="b138-d0c1-4daa-5fa8" name="Armadura carmesí de Dargan" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. La Armadura Carmesí de Dargan es una armadura pesada. Además, el portador es inmune a la regla especial de Heridas Múltiples (X). Si el portador sufre una herida no salvada por un ataque con esta regla especial, pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8f23-c066-6442-47bc" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2f46-12d3-127f-c9e6" name="Coraza demoníaca" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c491-d666-33a3-7854" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cbac-4203-9fd4-07dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="c697-d1d9-87d4-264d" name="Coraza demoníaca" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Sólo miniaturas cuyo tipo de tropa es «infantería» o «caballería es una armadura completa. Además, su portador mejora sus atributos de Resistencia e Iniciativa en 1.</characteristic>
