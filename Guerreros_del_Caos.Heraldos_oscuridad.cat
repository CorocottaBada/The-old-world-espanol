          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6159-d7a4-29eb-dcee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4971-1960-aebf-02aa" type="max"/>
          </constraints>
          <profiles>
            <profile id="a7c0-2de1-4e11-2b47" name="Piel sombría" hidden="false" typeId="d4c3-ba7f-f165-c66a" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c52d-71e4-a1e8-5fee">Sólo personajes. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
