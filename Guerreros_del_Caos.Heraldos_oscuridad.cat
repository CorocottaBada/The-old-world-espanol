            <profile id="92c2-3991-b7d1-9bd4" name="Archa temible de obsidiana" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Perforacorazas (1), Golpe letal, Requiere ambas manos, Golpea último</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Archa temible de obsidiana sólo puede ser adquirida por Miniaturas en un Ejército de Infamia de Heraldos de la Oscuridad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7f1e-63ba-8d13-e976" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
