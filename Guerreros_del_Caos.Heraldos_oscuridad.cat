      <selectionEntries>
        <selectionEntry id="ee20-edb8-dd62-00f2" name="Estandarte de la furia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6496-d50e-61b8-fc83" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="274f-f028-ffc0-9c38" type="max"/>
          </constraints>
          <profiles>
            <profile id="1bd0-4b8d-fe49-8eb0" name="Estandarte de la furia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Furia obtiene la regla especial Furia Asesina. Sin embargo, a diferencia de otras unidades con Furia Asesina, esta unidad no puede perder esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b6bf-4260-be94-022d" name="Furia asesina (Frenzy)" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4aaa-3d8b-959a-8fad" name="Estandarte de los dioses" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="db32-8db4-2578-fd88" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b357-3eb9-2d10-9c77" type="max"/>
          </constraints>
          <profiles>
            <profile id="e5fd-60bb-5929-4622" name="Estandarte de los dioses" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleva el Estandarte de los Dioses ignora todos los modificadores negativos a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="911f-0ed9-d1f9-78ff" name="Estandarte maldito" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="42c3-2dd8-9095-5a96" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cad1-6006-a382-8d2d" type="max"/>
          </constraints>
          <profiles>
            <profile id="6aef-5f7f-7ed1-5120" name="Estandarte maldito" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte Maldito puede volver a tirar cualquier tirada de 1 natural al realizar una tirada de Salvación de Armadura contra heridas sufridas durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0d52-e744-f4c6-c27c" name="Tótem de la condenación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="91ac-95f5-16ec-a1aa" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7416-fd95-be0f-c799" type="max"/>
          </constraints>
          <profiles>
            <profile id="f93e-1198-f0dc-8c10" name="Tótem de condenación" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades enemigas que pueden trazar una línea de visión hacia la miniatura que lleva el Tótem de la Condenación sufren un modificador de -1 a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8d93-bb67-96ba-34c5" name="Icono de la oscuridad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f03-e3fb-7d16-46fe" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="79fb-4324-7b4c-e8f1" type="max"/>
          </constraints>
          <profiles>
            <profile id="1f75-c160-a281-94fc" name="Icono de la oscuridad" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier miniatura enemiga que tome como objetivo a una unidad que lleve el Icono de la Oscuridad durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
