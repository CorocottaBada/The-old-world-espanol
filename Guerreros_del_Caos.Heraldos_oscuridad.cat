            <profile id="693d-f5ee-a576-5d85" name="Pellejo del caminante de sombras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede combinarse con otra armadura. El portador del Pellejo de Caminante de Sombras mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador (y cualquier unidad a la que se haya unido) tienen Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c9b4-e012-b2bb-4d85" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4155-e30c-922c-7a78" name="La Piel de Sharggu" hidden="false" collective="false" import="true" type="upgrade">
