              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e02f-fa1a-7bb8-e285" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="23ec-3afc-f932-1f9d" type="min"/>
              </constraints>
              <profiles>
                <profile id="eb8b-fa09-3a37-2ae2" name="Explosión de fuego disforme" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">6-24&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4 (8)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-3)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Ataques flamígeros, Heridas múltiples (1D3+1).</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial Bombardeo, la plantilla de impacto de 3” . Si se obtiene un resultado de ‘Problemas’ en el dado de Artillería, esta miniatura pierde una única Herida (en vez de realizar una tirada en la Tabla de Problemas). La regla especial Heridas Múltiples (1D3+1) solo se aplica a una única m iniatura cuya base se encuentre bajo el
agujero central de la plantilla de impacto.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="446d-9fcd-67cc-89bb" name="Bombardeo (Bombardment)" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
                <infoLink id="5d32-9f56-13cf-206a" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="58b7-4993-047c-66d1" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
                <infoLink id="130e-75b8-f85d-05c2" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
