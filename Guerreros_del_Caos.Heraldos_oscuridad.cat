        </selectionEntry>
        <selectionEntry id="a2ad-dee8-3de8-afa2" name="Estandarte del mastín furioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ef69-2efa-98b8-c922" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5787-d525-cacf-9b2e" type="max"/>
          </constraints>
          <profiles>
            <profile id="8d8d-e7c4-2ab9-6a3f" name="Estandarte del mastín furioso" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">El Estandarte del mastín furioso sólo puede ser portado por una miniatura de un Ejército de Infamia de los Heraldos de la oscuridad. Una unidad que lleve el Estandarte del mastín furioso gana la regla especial Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="16f8-650d-ffcd-3ca0" name="Vanguardia" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="24df-4d94-9c2e-c8cd" name="Armas mágicas. Guerreros del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2826-8622-d9e8-3f4c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e41f-87ab-36a0-7519" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8dcf-70ef-2212-dce8" name="Azote del capataz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="843b-5a0c-c281-5d9c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7723-c22f-1ad6-4271" type="max"/>
          </constraints>
          <profiles>
            <profile id="b29f-668b-8942-f1d7" name="Azote del capataz" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques adicionales (1).</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo miniaturas con tipo de tropa «infantería». Durante la subfase de Mando de su turno, el portador del Azote del Capataz puede intentar incitar a los que le rodean a combatir con premura haciendo un chequeo de Liderazgo (usando su propio Liderazgo). Si se supera el chequeo, en tu siguiente subfase de Inicio de Turno, este personaje y cualquier unidad a la que se haya unido ganan un modificador de+1D3 a su atributo de Movimiento (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9b0f-2152-b523-e511" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0039-de92-cd1c-fd1d" name="Armas mágicas. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9c9-327f-1fb4-69e1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f294-9bc1-b401-2b80" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ffab-e4d0-8af0-1d05" name="Espada robahechizos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1c3e-83a8-b6d2-2001" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e840-d710-fc78-abbf" type="max"/>
          </constraints>
          <profiles>
            <profile id="dd75-f742-594e-c5ba" name="Espada robahechizos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier Hechicero enemigo que sufra una o más heridas no salvadas de la Espada Robahechizos olvida inmediatamente un único hechizo (determinado al azar) durante el resto de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="61cf-b447-9afb-6ccc" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="be84-ba11-5954-42fd" name="Maza de la inmundicia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="45c5-8897-a8fd-d3b2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6d4e-900f-f659-1a9f" type="max"/>
          </constraints>
          <profiles>
            <profile id="96bf-d63c-bba4-e4cc" name="Maza de la inmundicia" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier miniatura enemiga que sufra una o más heridas no salvadas por la Maza de Inmundicia debe realizar inmediatamente un chequeo de Resistencia. Si lo falla, la miniatura herida sufre un modificador de -1 a su atributo de Resistencia (hasta un mínimo de 1) hasta el final del turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="47ea-ccdc-6c35-94ee" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
