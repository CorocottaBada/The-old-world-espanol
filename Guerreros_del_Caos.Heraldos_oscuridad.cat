    <selectionEntryGroup id="bbcd-87a6-cd14-ccc3" name="Rasgos caóticos. Personajes. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="539f-ebcf-873b-5d3d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3de6-ce6e-095a-9be9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6858-cac6-9376-328b" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f923-3ffd-b118-065a" type="max"/>
          </constraints>
          <profiles>
            <profile id="afb0-4559-6423-1d1e" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2305-a77d-63b5-e1da" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3daa-8846-966a-b08c" type="max"/>
          </constraints>
          <profiles>
            <profile id="712e-53f8-e91f-3a51" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cf35-684e-567b-c4a2" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="dbe9-1723-122a-e494" name="Rasgos caóticos. Personajes. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="21e0-a703-eb79-9b57" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="721d-d24a-d7b8-70ae" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3071-b99a-4c08-b47f" name="Hambre de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fcbe-ab05-61f1-a66b" type="max"/>
          </constraints>
          <profiles>
            <profile id="a1a0-dc17-58fd-2b95" name="Hambre de batalla" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; solamente. Una unidad que consiste enteramente de miniaturas con este Rasgo Caótico aumenta su alcance de carga máximo posible en 2&quot; y, al realizar una tirada de Carga o Persecución, puede aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2004-cc97-ab39-9429" name="Rasgos caóticos. Personajes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a58-7a51-c9f2-ed31" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6109-8e27-84c0-7d13" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a13d-df9c-cdc2-6b13" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f695-f145-dcde-a155" type="max"/>
          </constraints>
          <profiles>
            <profile id="c562-ad26-df2a-b6c9" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9429-af4f-497c-eff5" name="Zancadas largas" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="increment" field="4665-ce53-541a-145e" value="1.0">
              <repeats>
                <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
              </repeats>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4665-ce53-541a-145e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ea5-77be-0358-2f57" type="max"/>
          </constraints>
          <profiles>
            <profile id="f061-8191-bc71-279b" name="Zancadas largas" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">0-1 unidad por cada 1.000 puntos. A menos que lleven armadura pesada o armadura completa, las miniaturas con este Rasgo Caótico ganan la regla especial Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9211-9465-b0d8-0e95" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fa62-938c-3b20-d7bb" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4066-e429-99b7-df3a" type="max"/>
          </constraints>
          <profiles>
            <profile id="da5e-19ab-a30b-e6b5" name="Reflejos mejorados" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén trabados en combate, las miniaturas con este Rasgo Caótico que elijan luchar con un arma de mano ganan un modificador de +2 a su atributo de Iniciativa.
Ten en cuenta que este Rasgo Caótico solo se aplica a un arma de mano única y no mágica, o a un Arma Hechizada, y no se aplica a la montura de la miniatura (si tuviera una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, este Rasgo Caótico deja de aplicarse.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7954-ffc6-1ed1-6c08" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="add1-d03b-4711-0265" type="max"/>
          </constraints>
          <profiles>
            <profile id="fb75-6795-9bbc-7ed0" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fa79-bfc0-1b0e-c737" name="Objetos hechizados. Guerreros del caos. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0766-cc84-2a14-2c88" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6e7-f441-f9d4-c532" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="eda0-e196-188e-ec2c" name="Collar de la condenación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8ecb-e094-a258-1973" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f82e-a6a8-4a45-d210" type="max"/>
          </constraints>
          <profiles>
            <profile id="6337-7eee-44a1-977b" name="Collar de la condenación" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. El portador del Collar de la Condenación obtiene un modificador de +1 a su atributo de Ataques por cada Herida que pierda.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9178-c85b-1cd3-06ac" name="Objetos hechizados. Guerreros del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9b4d-5f57-452b-cee5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a1d5-8455-e626-b515" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d5fa-9bad-33ce-7360" name="Colgante del cráneo sangriento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fd9e-7c34-952b-3a9b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b1c8-1858-d168-ce04" type="max"/>
          </constraints>
          <profiles>
            <profile id="65da-04f2-82ac-564f" name="Colgante del cráneo sangriento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Sólo miniaturas cuyo tipo de tropa sea «infantería». En lugar de atacar normalmente, el portador del Colgante de Cráneo Sangriento puede elegir infligir un único impacto de Fuerza 8 a cada miniatura enemiga con la que esté en contacto, cada uno con una PA de -1. Estos impactos tienen la regla especial Golpe Letal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8bde-8ff1-65bf-e862" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0de0-cb8e-0a15-7461" name="Objetos hechizados. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cbbe-a75f-9575-12e0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d06b-1b3a-13ed-f697" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bd55-af49-5df8-4149" name="Yelmo de incontables ojos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3f0f-ac62-5632-8851" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bf64-c6c5-dbc0-7997" type="max"/>
          </constraints>
          <profiles>
            <profile id="7f02-a748-b0fa-21da" name="Yelmo de incontables ojos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El Yelmo de Incontables ojos otorga a su portador (pero no a su montura) la regla especial Golpea primero. Sin embargo, debido a las imágenes confusas que evoca el yelmo, su portador también está sujeto a la regla especial de Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="986d-cab4-0556-3a67" name="Golpea primero" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
            <infoLink id="76a2-7017-b7ee-5bfd" name="Estupidez" hidden="false" targetId="e78e-de09-5640-bcda" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1894-dc3a-93e9-4f9e" name="Vara de los condenados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2744-e594-2b98-1a1a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cb29-5022-e86e-0528" type="max"/>
          </constraints>
          <profiles>
            <profile id="2f13-f6dd-df8d-5e2d" name="Vara de los condenados" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de la Vara de los Condenados puede lanzar el Hechizo de La Invocación del Saber de la Demonología (ver página 322 del libro de reglas de Warhammer: the Old World) como un Hechizo Vinculado con un Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5ecd-8844-da93-08de" name="Objetos hechizados muy comunes. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5726-d7e1-4ce3-4f8f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="975f-8f25-0508-95fa" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c20a-a773-da9b-1a5e" name="Favor de los dioses" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1130-4d6c-50d4-b5a5" type="max"/>
          </constraints>
          <profiles>
            <profile id="c75a-0d29-b7cb-52cf" name="Favor de los dioses" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador de un Favor de los Dioses puede volver a tirar el 1D6 cuando tire en la Tabla de la Mirada de los Dioses.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d919-d7e4-37c8-7989" name="Objetos arcanos. Guerreros del caos. Caos absoluto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c944-306c-fdc4-f4dc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e183-a427-7449-166c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="58f3-6d6e-b281-ee12" name="Tomo de los dioses oscuros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a878-6931-9af2-ae4a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf46-57de-2e0c-5c6e" type="max"/>
          </constraints>
          <profiles>
            <profile id="f73c-1068-68d4-6a6b" name="Tomo de los dioses oscuros" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Sólo miniaturas con la Marca del Caos Absoluto. Al generar sus hechizos, el portador del Tomo de los Dioses Oscuros puede descartar cualquier número de sus hechizos generados aleatoriamente. Por cada hechizo que descarte, puede elegir cualquier hechizo del Saber del Caos como si tuviera la Marca del Caos correspondiente.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="175d-ee90-57bd-528a" name="Objetos arcanos. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8023-62e2-6758-3f63" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c8cd-5e89-2a69-fe94" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4389-0df3-e4f9-560c" name="Cráneo de Katam" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d78f-5707-f0f1-86c6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1130-3153-286b-9ddd" type="max"/>
          </constraints>
          <profiles>
            <profile id="1002-bb79-b6c8-cb5c" name="Cráneo de Katam" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Cráneo de Katam y cualquier otro Hechicero en un radio de 3&quot; (amigo o enemigo) puede aplicar un modificador +1 a cualquier tirada de Lanzamiento que realice.
Ten en cuenta que esto es un modificador al resultado de una tirada, no niega una tirada de un doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2f62-e859-31dd-7e29" name="Marioneta infernal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4d82-739c-7a5b-833a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2d99-2723-546c-f533" type="max"/>
          </constraints>
          <profiles>
            <profile id="da7a-350c-c971-d5cb" name="Marioneta infernal" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">A menos que el portador de la Marioneta Infernal esté huyendo o trabado en combate, puede usarla siempre que un Hechicero enemigo que esté a 15&quot; o menos de él haga una tirada de Lanzamiento. Si lo hace, el Hechicero enemigo debe tirar un 1D6 extra y descartar el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2c99-d3ac-6ff2-b51f" name="Grimorio de Ogvold" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b0f0-6512-91fa-a9c6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="722d-3a1e-99c9-f82c" type="max"/>
          </constraints>
          <profiles>
            <profile id="62f0-9c7c-1bcf-5dd6" name="Grimorio de Ogvold" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">En lugar de generar aleatoriamente los Hechizos que conoce, e independientemente de su Nivel de Hechicería, el portador del Grimorio de Ogvold conoce los siete Hechizos del Saber de la Magia que ha elegido (incluido el Hechizo Identificativo). Sin embargo, sólo puede lanzar un número de Hechizos igual a su Nivel de Hechicería por turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f2f7-dae9-913a-d6bb" name="Cetro de poder" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4a53-eac3-526c-8564" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="990f-1867-7293-e314" type="max"/>
          </constraints>
          <profiles>
            <profile id="3fca-b0d3-bf9e-90f6" name="Cetro de poder" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Cetro de Poder puede aplicar un modificador de +1 a cualquiera de sus tiradas de Lanzamiento o Dispersión. Sin embargo, si saca un doble natural al hacer una tirada de Lanzamiento o Dispersión, el portador sufre un único impacto de Fuerza 10 con un PA de -3 después de que se hayan resuelto los efectos de la tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7254-7917-ba3a-aff2" name="Objetos arcanos muy comunes. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="812b-cf30-daab-fedf" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9daf-0ac5-cf23-b03c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9f60-ee58-997a-ce45" name="Familiar hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c2b5-f211-fa8b-8f77" type="max"/>
          </constraints>
          <profiles>
            <profile id="4484-db8a-83b1-739f" name="Familiar hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por Hechicero. El propietario de un Familiar Hechicero conoce un hechizo adicional (elegido de la forma habitual) de lo normal para su Nivel de Hechicería.
Ten en cuenta que esto no aumenta el nivel del hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1b50-5936-e8db-bbdb" name="Mutaciones del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6303-4f6d-e1d9-7b3e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9b74-c00e-8e0f-5c1a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e6c7-f726-04ff-5b8d" name="Sentidos amplificados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8f07-26a6-8e10-5437" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="51d1-43e4-0d5e-b604" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a65-aadb-17cd-4e06" name="Sentidos amplificados" hidden="false" typeId="d4c3-ba7f-f165-c66a" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c52d-71e4-a1e8-5fee">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c5c5-57f0-0908-6b09" name="Diablo de múltiples extremidades" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="664b-f8e7-7815-f32f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dc42-63c5-bd9b-7240" type="max"/>
          </constraints>
          <profiles>
            <profile id="e401-5dc4-876d-a7cd" name="Diablo de múltiples extremidades" hidden="false" typeId="d4c3-ba7f-f165-c66a" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="c52d-71e4-a1e8-5fee">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Ataques. Sin embargo, este ataque extra debe hacerse utilizando un arma de mano ordinaria.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
