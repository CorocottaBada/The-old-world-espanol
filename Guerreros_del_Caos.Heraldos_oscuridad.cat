              <selectionEntries>
                <selectionEntry id="7260-2c43-b030-6cd0" name="Zancadas largas" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="d32b-e723-54bb-b2f5" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6a10-9740-70d1-6d53" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="cd3b-e634-dfd6-2737" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b61-772f-308c-f748" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="636c-5868-0c41-62cc" name="Zancadas largas" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">0-1 unidad por cada 1.000 puntos. A menos que lleven armadura pesada o armadura completa, las miniaturas con este Rasgo Caótico ganan la regla especial Vanguardia.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="4d76-b30b-adb7-6505" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
                  </infoLinks>
                  <entryLinks>
                    <entryLink id="03ac-93ab-10f3-8e76" name="Zancadas largas" hidden="false" collective="false" import="true" targetId="9799-e3f2-912c-d957" type="selectionEntry"/>
                  </entryLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="7858-c82e-f1dd-de4c" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6027-5d2c-028c-8b33" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="1247-f639-a68e-b08f" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="c14f-bdce-f62d-4a5e" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="ff5f-a124-4e55-e2a6" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a281-a943-5e1e-3073" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8bba-e852-3bab-df93" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="b803-f7b6-35d5-1226" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="0e8d-f497-a0ec-87ba" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="d32b-e723-54bb-b2f5" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6a10-9740-70d1-6d53" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="07d5-438e-f128-e174" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="04f1-dd50-e721-3dd9" name="Reflejos mejorados" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén trabados en combate, las miniaturas con este Rasgo Caótico que elijan luchar con un arma de mano ganan un modificador de +2 a su atributo de Iniciativa.
Ten en cuenta que este Rasgo Caótico solo se aplica a un arma de mano única y no mágica, o a un Arma Hechizada, y no se aplica a la montura de la miniatura (si tuviera una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, este Rasgo Caótico deja de aplicarse.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="bafc-2421-18a0-7977" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="2.0">
                      <repeats>
                        <repeat field="selections" scope="d32b-e723-54bb-b2f5" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6a10-9740-70d1-6d53" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b317-2009-93cc-3225" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="914a-cd52-fb37-3926" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="a2ff-e949-281a-435d" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="d32b-e723-54bb-b2f5" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="6a10-9740-70d1-6d53" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6dba-5365-e402-464d" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="680b-d87a-8e14-4ab9" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
