            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="81e9-309d-6375-1ae1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7519-1bab-0353-52a4" type="max"/>
          </constraints>
          <profiles>
            <profile id="071d-8471-eb1c-7a89" name="Espada demoníaca" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1D3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques adicionales (1D3), Ataques mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cada tirada natural de 1 realizada al tirar para Impactar con esta arma da como resultado un impacto que debe resolverse contra la unidad a la que se ha unido el portador, en lugar de contra el enemigo. Si el portador no está unido a una unidad, este impacto debe resolverse contra el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="add2-e9a9-e24e-40af" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="6674-35fb-765e-d721" name="Ataques adicionales (+X)" hidden="false" targetId="93b1-1365-6161-7057" type="rule"/>
            <infoLink id="14fc-97df-ec65-ae14" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6ec8-3131-bd83-3ab8" name="Daga del panteón oscuro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ab70-f06b-4cc7-76ff" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f9f-c38f-f8fe-c6c2" type="max"/>
          </constraints>
          <profiles>
            <profile id="b932-b514-4835-5e17" name="Daga del panteón oscuro" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Por cada Herida que sufra una unidad enemiga como resultado de un ataque realizado con la Daga del Panteón Oscuro, su portador puede aplicar un modificador de +1 a su próxima tirada de Lanzamiento o Dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
