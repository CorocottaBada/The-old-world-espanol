          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5552-2e89-4a32-207c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1015-8bb0-34b2-fe7d" type="max"/>
          </constraints>
          <profiles>
            <profile id="45b6-bf9c-76d2-14bc" name="Barda de forja demoníaca" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">La Barda de forja demoníaca sólo puede ser llevada por una miniatura cuyo tipo de tropa sea &quot;caballería&quot; en un Ejército de Infamia de los Heraldos de la oscuridad. En un turno en el que el portador haya cargado, su montura y todas las monturas de cualquier unidad a la que se haya unido tienen un modificador de +1 a su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
