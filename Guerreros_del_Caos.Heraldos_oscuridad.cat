    <selectionEntryGroup id="a5d9-112c-e496-7dd3" name="Regalos del caos. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1ffc-9a97-239e-ea15" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9e0-fd24-2a24-30c6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="364e-dc39-3626-b1ee" name="Aura encantadora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0d4a-8743-90db-434d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9949-7bb9-a911-e800" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a2d-882f-d3b4-e455" name="Aura encantadora" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Sólo miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. Las unidades enemigas que estén trabadas en combate con este personaje no pueden usar la regla especial Golpea Primero. Las miniaturas enemigas que no tengan la regla especial Golpea Primero quedan sujetos a la regla especial Golpea Último.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="695b-a83b-8788-e333" name="Esplendor diabólico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="64e6-1120-b7b4-d507" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9185-c43d-8fbd-5053" type="max"/>
          </constraints>
          <profiles>
            <profile id="e814-ed0f-2983-1370" name="Esplendor diabólico" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Sólo miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la Fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="23c1-20c2-ecf9-b2b4" name="Regalos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a674-83cf-8fc3-ef5d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="611e-da6d-3310-efe7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4a4e-81dc-de0c-f25c" name="Majestad oscura" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ee5a-5de7-a564-c2eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="be5e-76ee-b2f3-84f0" type="max"/>
          </constraints>
          <profiles>
            <profile id="3e0c-9c4f-35e0-489a" name="Majestad oscura" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">A menos que este personaje esté huyendo, cualquier unidad enemiga que deba realizar un chequeo de Miedo o Terror mientras esté dentro del Aura de Mando de esta miniatura lo hará con un modificador de -1 adicional a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="987a-1494-117c-a452" name="Baba venenosa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="89b9-a385-127f-9445" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c255-d565-14d1-4d60" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb5c-2193-0a51-60c7" name="Baba venenosa" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Este personaje (pero no su montura) tiene la regla especial Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1922-9c90-533a-7a89" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="093a-5585-8d0d-7f7a" name="Aura de dolor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="60fd-4cd3-8389-b3da" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee0c-1374-8aa6-9bcf" type="max"/>
          </constraints>
          <profiles>
            <profile id="d54e-6d27-5e9b-3986" name="Aura de dolor" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Una vez por partida, cuando se elige el combate de este personaje durante el Paso 1.1 de la Subfase de Combate Elige y Lucha, una sola unidad enemiga con la que se enfrenta sufre 3 impactos de Fuerza 1D6, que no permiten tiradas de Salvación por Armadura o Regeneración (las Salvaciones Especiales se pueden realizar normalmente).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="17dc-cc97-027a-4786" name="Maestro de mortales" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d39f-b0ab-a48a-c276" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c01d-ff90-a3f6-08b7" type="max"/>
          </constraints>
          <profiles>
            <profile id="9a90-9e8d-a3b4-a1ce" name="Maestro de mortales" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">A menos que este personaje esté huyendo, las unidades amigas de Bárbaros del Caos y Jinetes Bárbaros obtienen un modificador de +1 a su atributo de Liderazgo mientras están dentro del Aura de Mando de este personaje (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5fd8-1061-7ce6-502f" name="Icor ácido" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dada-a60d-9dc8-e76e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="baf5-4aac-53be-d3d8" type="max"/>
          </constraints>
          <profiles>
            <profile id="e49d-a1db-ed54-b8de" name="Icor ácido" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Por cada Herida que este personaje pierda durante un desafío, su enemigo sufre un impacto de Fuerza 4, con un PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4e03-bc26-f68a-c621" name="Brazo extra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8f5c-2d4d-dcac-b127" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="71fd-a876-7962-c8a9" type="max"/>
          </constraints>
          <profiles>
            <profile id="9767-3558-b51b-8f85" name="Brazo extra" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Este personaje (pero no su montura) tiene un modificador +1 a su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a9ee-92d7-1986-459f" name="Carne demoníaca" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0f9d-de2d-ab9f-de0b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7682-3d35-3c87-1095" type="max"/>
          </constraints>
          <profiles>
            <profile id="b2b9-2deb-f6c2-8284" name="Carne demoníaca" hidden="false" typeId="c230-1af6-c76f-bf19" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="2492-7136-6f63-b137">Este personaje no puede ser herido por una tirada para Herir de 2, independientemente de la Fuerza del ataque.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
