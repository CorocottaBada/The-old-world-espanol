    </selectionEntryGroup>
    <selectionEntryGroup id="9455-fdcf-d212-e312" name="Armaduras mágicas muy comunes. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4bef-9017-c975-93b4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c5e1-bc46-258f-c2b1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dc63-d044-d3f9-8245" name="Armadura completa del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="891e-c359-cbb4-7198" type="max"/>
          </constraints>
          <profiles>
            <profile id="ac4c-ffbb-1f25-3de9" name="Armadura completa del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="48c8-4f2f-a4f8-53a8" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6f7e-41ad-70e3-43b1" name="Armadura pesada del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="327f-b016-161c-df51" type="max"/>
          </constraints>
          <profiles>
            <profile id="a87d-43df-ef1a-ac67" name="Armadura pesada del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
