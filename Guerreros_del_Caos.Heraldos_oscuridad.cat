            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c727-c344-8d9c-6ae7" type="max"/>
          </constraints>
          <profiles>
            <profile id="858b-c3e1-7d43-ac89" name="Espada rúnica del caos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de la Espada Rúnica del Caos tiene un modificador +1 a sus atributos de Habilidad de Arma e Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
