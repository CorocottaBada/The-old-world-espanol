              </constraints>
              <selectionEntries>
                <selectionEntry id="3731-1ae3-0378-c233" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="700f-586c-f54d-93d2" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="31b7-ba11-24b1-a81e" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e3fd-1926-d4cf-0762" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="df4a-1992-cf9f-5f30" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="093d-804c-9fd5-7c84" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5104-a893-8734-812e" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="9d1c-0fad-8919-9f75" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="6fdd-7278-9f0f-aa09" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="2e1b-ddfc-eaea-51d0" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d290-6d05-2a40-aeb1" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4ac2-6440-9751-7fb6" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="c9df-ff20-0e71-cc0d" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="df55-68ee-4be6-4b3b" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
