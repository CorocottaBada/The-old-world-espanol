    <selectionEntry id="c0ee-5013-c837-fdbf" name="Frydaal la encadenadora" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e75f-d1f8-6a56-9f76" type="max"/>
      </constraints>
      <rules>
        <rule id="4d6b-e338-24a9-d965" name="Encadenadora" hidden="false">
          <description>Cualquier estandarte enemigo capturado por Frydaal o cualquier unidad a la que se haya unido otorga 100 Puntos de Victoria
como trofeo de guerra.</description>
        </rule>
        <rule id="28ae-f53b-9069-1a05" name="Comandante y capitán" hidden="false">
          <description>A menos que esté huyendo, las unidades amigas de Bárbaros del Caos, Jinetes Bárbaros del Caos, Huscarls Bárbaros y Berserkers
Bárbaros obtienen un modificador de +1 a su atributo de Liderazgo mientras estén dentro del Rango de Mando de Frydaal (hasta
un máximo de 10).</description>
        </rule>
        <rule id="0873-2aa2-ba14-c316" name="Incursora sin igual" hidden="false">
          <description>0-1 unidad de Bárbaros del Caos o de Jinetes Bárbaros del Caos en el mismo ejército que incluya a Frydaal puede tener gratis la
regla especial Emboscadores. Además, si Frydaal es tu General, puedes además aplicar un modificador de +1 o -1 al resultado cuando tires para determinar si ella o cualquier unidad de Bárbaros del Caos o de Jinetes Bárbaros, Huscarls Bárbaros o Berserker Bárbaros con la regla especial Emboscadores que se mantiene actualmente en reserva llega este turno como refuerzo o se retrasa.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="2047-2f6b-06dd-1876" name="Emboscadores (Ambushers)" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
        <infoLink id="1e04-60f7-9161-e67d" name="Armadura del caos (X+)" hidden="false" targetId="1493-2254-51ab-179a" type="rule"/>
        <infoLink id="d8df-3476-9dd0-598e" name="Armas hechizadas" hidden="false" targetId="cc74-5dda-a0eb-528c" type="rule"/>
        <infoLink id="06b7-4837-71f8-dde8" name="Mirada de los dioses" hidden="false" targetId="bcb0-54b9-37a1-d1ac" type="rule"/>
        <infoLink id="c658-098f-51b8-96e6" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
        <infoLink id="fa19-85d9-a7c7-5a5a" name="Infantería pesada (Heavy infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
        <infoLink id="430a-cd82-fc84-cd42" name="Marca del caos Absoluto" hidden="false" targetId="1f98-6516-8af3-3fa4" type="rule"/>
