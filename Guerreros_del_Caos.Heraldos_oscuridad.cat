        <selectionEntry id="20c7-155c-c2d4-729f" name="Collar de bronce" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c76b-e153-b351-4b60" type="max"/>
          </constraints>
          <profiles>
            <profile id="8fd2-c880-d09e-7dcb" name="Collar de bronce" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de un Collar de Bronce obtiene Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8f28-f798-f0e1-2a8c" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
