    <selectionEntry id="dfab-63a9-85bc-00bc" name="Dragón de fuego disforme" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b768-0713-f089-6f7d" type="max"/>
      </constraints>
      <rules>
        <rule id="ffd9-e0ea-4477-8a3f" name="Muerte explosiva" hidden="false">
          <description>Cuando un Dragón de Fuego Disforme pierde su última Herida, antes de que la miniatura sea retirada del juego, cada unidad (amiga o enemiga) a 6» o menos de él sufre 1D6 Impactos de Fuerza 5, cada uno con una PA de-2.</description>
        </rule>
        <rule id="fffe-a711-fb30-2a5c" name="Fuego y caos" hidden="false">
          <description>Los Dragones de Fuego Disfrome tienen una salvación Especial de 5+ contra cualquier herida sufrida que haya sido causada por un ataque que tenga la regla especial Ataques Mágicos o Ataques Flamígeros.</description>
        </rule>
        <rule id="b7e5-c3a4-ebf2-5a43" name="Aura de fuego disforme" hidden="false">
          <description>Otras miniaturas (tanto amigas como enemigas) no pueden realizar salvaciones Especiales a 3&quot; o menos de esta miniatura.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="8b06-7465-884e-8ea5" name="Formación cerrada" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
        <infoLink id="4e65-b6b1-7497-1f9e" name="Coloso (Behemoths)" hidden="false" targetId="7e87-1008-0eda-9b33" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="080f-5f9b-656d-5cea" name="New CategoryLink" hidden="false" targetId="cecf-b94c-e223-2f4a" primary="true"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry id="4777-8c8a-f8c2-e79f" name="Equipo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ace-c429-b396-c56d" type="max"/>
