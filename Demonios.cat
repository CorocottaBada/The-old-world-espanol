      <rules>
        <rule id="0ce0-51e6-a9b6-cd05" name="Buscando atención" hidden="false">
          <description>Cada miniatura de una unidad de Bestias de Nurgle puede lanzar y aceptar desafíos de la misma manera que un personaje </description>
        </rule>
        <rule id="a9eb-d8d7-e359-dada" name="Rastro de babas" hidden="false">
          <description>Las unidades enemigas no pueden reclamar ningún punto de Resultado del combate adicional por enfrentarse por el flanco o por la retaguardia de esta unidad.</description>
        </rule>
      </rules>
