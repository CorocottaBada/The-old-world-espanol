        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8023-6b71-0298-3caf" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6b25-0b12-912b-0a84" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="065d-8536-8a43-2594" name="Estandarte de la victoria impía" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8574-1641-c268-73bf" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d210-858d-b2cf-f8d5" type="max"/>
          </constraints>
          <profiles>
            <profile id="fb91-58c2-4de8-1ad8" name="Estandarte de la victoria impía" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Al calcular su Resultado del combate, una unidad que lleve el Estandarte de la Victoria Impía puede reclamar una bonificación adicional de +1D3 puntos al resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5ef6-8f35-2426-5397" name="Iconos del caos. Foco demoníaco" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b2f-2919-c77b-0929" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dc88-1be0-4df2-87b4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2606-0443-b1b0-a900" name="Estandarte de la gloria del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8c7c-ff2d-0f03-4bf7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="92ab-342a-86b5-2021" type="max"/>
          </constraints>
          <profiles>
            <profile id="6cb3-bc1d-0cdd-1830" name="Estandarte de la gloria del caos" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Solo Foco Demoníaco. Las unidades demoníacas amigas obtienen un modificador de +1 a su atributo de Liderazgo mientras están dentro del Aura de Mando de este personaje (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c2f4-1a31-8728-f52b" name="Tótem de la batalla interminable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7991-ed3a-a272-b460" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="88cb-f072-3597-badd" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b33-e6db-912d-c62f" name="Tótem de la batalla interminable" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Solo Foco Demoníaco. Las unidades demoníacas amigas reducen el número de heridas sufridas debido a la regla especial Inestabilidad Demoníaca en 1D3 adicional mientras están dentro del Aura de Mando de esta miniatura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="bdec-abdf-576f-6d9e" name="Regalos del caos. Khorne" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="24e3-9957-1f7e-25a1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d5e-6e3a-594c-a276" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8cb4-44ae-6636-5bd9" name="Poder de Khorne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="93b9-4a1e-4c38-1bec" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="71b8-5aaa-9863-8bca" type="max"/>
          </constraints>
          <profiles>
            <profile id="3fc5-5a9c-1f7a-ca47" name="Poder de Khorne" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Esta miniatura tiene un modificador +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5dcb-7d42-ae89-40ff" name="Comehechizos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3b13-d8a2-3b92-7447" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c2a4-311e-ff4d-764f" type="max"/>
          </constraints>
          <profiles>
            <profile id="c2ee-6888-84d7-eb91" name="Comehechizos" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Esta miniatura puede ser designada para intentar una Dispersión Arcana, como si fuera un Hechicero. A los efectos de los intentos de Dispersión Arcana, esta miniatura cuenta como un Hechicero de nivel 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="955b-289f-0085-2269" name="Armadura de Khorne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="814f-03bc-4927-ecbb" type="max"/>
          </constraints>
          <profiles>
            <profile id="e1aa-6714-fb04-99e4" name="Armadura de Khorne" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">La Armadura de Khorne es una armadura pesada. Además, su portador tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b916-b1d7-be5c-50aa" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ab14-15ff-0796-2f3f" name="Regalos del caos muy comunes. Khorne" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="482f-800d-38ab-1ad1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5864-7ba4-08b7-6815" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3993-dcb0-0f50-786a" name="Hacha de Khorne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aab3-a2ce-726f-d7e9" type="max"/>
          </constraints>
          <profiles>
            <profile id="a2c7-9189-7980-ef45" name="Hacha de Khorne" hidden="false" typeId="4232-c79d-a3b6-800d" typeName="Regalo del caos. Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9689-3668-7ff6-3bac">Combate</characteristic>
                <characteristic name="Fuerza" typeId="8949-3484-08c0-59bf">F+1</characteristic>
                <characteristic name="PA" typeId="b096-c1f8-707f-b75e">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="eddd-17bc-14c8-af51">Golpe letal, Ataques mágicos, Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="9348-a495-df3c-3a79">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7927-d8bc-a5e7-e8e6" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
            <infoLink id="8267-6df8-fdb5-7c42" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="922a-8ec1-f3c7-a4c2" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="67a0-b181-c614-98ca" name="Collar de Khorne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a5f7-0e00-5d27-74c5" type="max"/>
          </constraints>
          <profiles>
            <profile id="9063-6a67-ae25-7c11" name="Collar de Khorne" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">El portador de un collar de Khorne mejora su Resistencia a la Magia en 1. Por ejemplo, una miniatura con Resistencia a la Magia (-2) que lleve un Collar de Khorne tendría Resistencia a la Magia (-3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e0b6-6854-e4a5-0656" name="Iconos del caos. Khorne" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ff2d-c48e-bfd5-6187" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5630-bc75-389b-8aa7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a90b-1568-5e45-6d06" name="Icono de la Guerra Eterna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1bbd-c9f0-102a-61f6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="98ea-ed5e-2ce4-f0cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a5d-ec68-01f8-edae" name="Icono de la Guerra Eterna" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Cuando una unidad que lleva el Estandarte de la Guerra Eterna declara una carga, puede volver a tirar su tirada de carga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8f1b-dae0-3e26-fc6a" name="Tótem de cráneos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d4be-7a59-135f-dd93" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f023-470c-e5a1-4ac5" type="max"/>
          </constraints>
          <profiles>
            <profile id="806f-46de-106e-1ee1" name="Tótem de cráneos" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Una unidad que lleve el Tótem de Cráneos (pero no sus monturas) obtiene la regla especial Carga Devastadora.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="75a1-ff81-6613-d4f1" name="Carga devastadora (Furious charge)" hidden="false" targetId="768a-7271-1e00-6be5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9684-72fa-d20b-9f8a" name="Gran Estandarte de la Disfuncionalidad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1229-74fe-1127-2aee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="76a9-55aa-1783-cd25" type="max"/>
          </constraints>
          <profiles>
            <profile id="483a-bf42-9c6e-ec88" name="Gran Estandarte de la Disfuncionalidad" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Cualquier Hechicero enemigo que pueda trazar una línea de visión hacia la miniatura que lleva el Gran Estandarte de la Disfuncionalidad sufre un modificador de -1 a cualquier Tirada de lanzamiento que realice.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d7a1-9876-6913-49c9" name="Regalos del caos. Nurgle. Gran inmundicia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2425-74ea-76f2-7ff5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6f08-0280-8db6-7231" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c0d8-a204-93d4-ddf0" name="Infestación de Nurgletes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b1b7-d0be-c0e1-fe70" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="febc-8532-d39d-1219" type="max"/>
          </constraints>
          <profiles>
            <profile id="0f16-9856-ea57-68f5" name="Infestación de Nurgletes" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Solo Gran Inmundicia. Mientras está en combate, esta miniatura puede realizar 1D6 ataques adicionales. Estos ataques se resuelven en la Iniciativa 2, con una Habilidad de Armas y Fuerza de 2, y con una PA de -. Además, cuando esta miniatura pierda su última herida, coloca 1D3 miniaturas de Enjambres de Nurgletes en la que cada miniatura esté a 3” o menos de esta miniatura antes de retirarla del juego.
Ten en cuenta que estos Enjambres de Nurgletes no otorgan ningún punto de victoria.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6a8e-fc9e-ada0-aeba" name="Regalos del caos. Nurgle. Heraldo demoníaco. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4fe5-1a62-d015-db14" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b0b7-f843-fe66-23a7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2ca3-7b40-943f-2413" name="Escriba plagarruina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="514d-8edb-1fbe-ea4b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="86a8-db92-3921-3bf8" type="max"/>
          </constraints>
          <profiles>
            <profile id="f011-5576-5cb5-5296" name="Escriba plagarruina" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Solo Heraldos Demoníacos cuyo tipo de tropa sea ‘infantería’. Mientras estén dentro del Aura de Mando de esta miniatura, las unidades aliadas con la regla especial Demonios de Nurgle pueden volver a tirar cualquier tirada natural para Impactar de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1e95-050c-9439-9c0e" name="Bilisgaitero chapuzas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="048b-754e-af87-22a6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="45e5-d577-8c5d-04a4" type="max"/>
          </constraints>
          <profiles>
            <profile id="378a-1ba4-a829-0add" name="Bilisgaitero chapuzas" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Solo Heraldos Demoníacos cuyo tipo de tropa sea ‘infantería’. Las unidades aliadas con la regla especial Demonios de Nurgle que comiencen su movimiento dentro del alcance de mando de esta miniatura tienen un modificador +1 a su característica de movimiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1b42-0141-bfc4-fb6a" name="Regalos del caos muy comunes. Nurgle" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="20d9-3344-4dc1-d37d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b104-6158-22d2-0eb3" type="min"/>
      </constraints>
      <selectionEntries>
