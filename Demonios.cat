        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3cac-dc1f-203f-b958" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="462e-3dbe-29ff-aedd" name="Estandarte de la transformación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8dac-6fa0-97e8-630b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e7ae-2d0b-b3da-9a90" type="max"/>
          </constraints>
          <profiles>
            <profile id="0b91-f7d2-ca2b-c827" name="Estandarte de la transformación" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Al inicio de la fase de Combate, una única unidad enemiga que participe en combate con esta miniatura sufre 2 impactos de Fuerza 3D6, cada uno con una PA de -.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e8c7-c8e0-a921-0a88" name="Pabellón de la discordia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ffd-a115-d272-3a80" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac00-5d0f-3599-5a34" type="max"/>
          </constraints>
          <profiles>
            <profile id="0304-8978-7571-774d" name="Pabellón de la discordia" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Una unidad que lleve el Pabellón de la Discordia obtiene la regla especial Resistencia a la Magia (-3). Además, las unidades amigas en un radio de 6” de la miniatura que lleva este estandarte obtienen la regla especial Resistencia a la Magia (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4f35-24d7-e5f9-9f85" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9e7c-c39d-e224-b7b7" name="Iconos del caos muy comunes. Tzeentch. Horror rosa" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d0b-4cad-291a-5553" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3570-addc-bb95-5f67" type="min"/>
