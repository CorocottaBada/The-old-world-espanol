    <selectionEntry id="9c39-6dd2-b3b2-56d6" name="Trono de sangre de Khorne" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="ab7b-93fb-2ab5-1ffb" name="Festín de sangre" hidden="false">
          <description>Por cada Herida que pierda una unidad enemiga como resultado de un Impacto por Carga causado por esta miniatura, tira 1D6. Por cada tirada de 6, esta miniatura recupera inmediatamente una única Herida perdida.</description>
        </rule>
        <rule id="de6d-fe7d-23ee-021c" name="Tótem del desangramiento eterno" hidden="false">
          <description>Las unidades amigas de Demonios de Khorne que estén dentro del Aura de Mando de esta miniatura y que hayan realizado un movimiento de Carga este turno pueden volver a tirar cualquier tirada natural de 1 para Impactar realizada durante la fase de Combate.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="de5f-fe2a-8f2b-b544" name="Carro pesado (Heavy chariots)" hidden="false" targetId="3af7-2847-d9c7-fb97" type="rule"/>
