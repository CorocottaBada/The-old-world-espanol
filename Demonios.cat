        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
      </characteristics>
    </profile>
    <profile id="5809-b062-cd74-1538" name="Garra punzante" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
