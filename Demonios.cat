      <selectionEntries>
        <selectionEntry id="d7d4-893a-58bb-3271" name="Caparazón de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a475-562f-c95c-7a3e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0a5b-71dc-53be-c205" type="max"/>
          </constraints>
          <profiles>
            <profile id="3ead-371c-8d5f-3c80" name="Caparazón de Nurgle" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">El Caparazón de Nurgle es una armadura que le da a su portador un valor de armadura de 4+ que no se puede mejorar de ninguna manera.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f924-4f89-026c-f18d" name="Iconos del caos. Nurgle" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0f89-f811-e449-12db" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9b0-4505-551f-609f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="678f-decc-54f1-b892" name="Estandarte de la decadencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0627-1548-75d3-cbd6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1dfd-0a9d-40b9-d6c3" type="max"/>
          </constraints>
          <profiles>
            <profile id="86bd-f933-dc8a-c66d" name="Estandarte de la decadencia" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Durante la fase de Combate, una unidad que lleve el Estandarte de Decadencia puede volver a tirar cualquier tirada natural para Herir de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ac09-13dd-3c6b-4311" name="Icono podrido" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7f04-3d98-227d-bab3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="23d3-56ed-5020-7495" type="max"/>
          </constraints>
          <profiles>
            <profile id="89c6-55ba-9e13-729b" name="Icono podrido" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Las unidades enemigas no pueden reclamar ningún punto de Resultado del combate adicional por enfrentarse por la retaguardia de una unidad que lleve el Icono podrido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e4ac-ef74-a42d-0a0a" name="Icono de la virulencia eterna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0e22-a9b2-6bb5-96dc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b2bc-77f4-1f55-fd2b" type="max"/>
          </constraints>
          <profiles>
            <profile id="6119-2b5e-29e4-2854" name="Icono de la virulencia eterna" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Al calcular su Resultado del combate, una unidad que lleve el Icono de Virulencia Eterna puede reclamar una bonificación adicional de +1 punto de Resultado del combate (hasta un máximo de +3) por cada herida no salvada causada por un Ataque Envenenado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e422-58f2-00cd-c8c0" name="Regalos del caos. Slaanesh. Heraldo demoníaco. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="16c7-a7cc-592f-f4b9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aa0d-d24b-8ec0-57e0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3eeb-de46-02f7-6cc5" name="Embelesadora infernal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1882-f072-8872-0e3d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="687d-a16c-0411-0f52" type="max"/>
          </constraints>
          <profiles>
            <profile id="73b6-4eab-2924-9ab0" name="Embelesadora infernal" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Solo Heraldos demoníacos cuyo tipo de tropa sea ‘infantería’. Mientras estén dentro del Aura de Mando de este personaje, los Demonios de Slaanesh amigos que también sean Hechiceros (sin incluir esta miniatura) pueden aplicar un modificador +1 a cualquier Tirada de lanzamiento que realicen. Mientras estén dentro del Aura de Mando de este personaje, los Hechiceros enemigos sufren un modificador de -1 a cualquier Tirada de lanzamiento que realicen.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9786-0436-b284-7d4e" name="Regalos del caos. Slaanesh" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1554-3e0f-0468-b952" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="802e-7031-4af7-3798" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="72ab-3104-7e1f-e494" name="Canto de sirena" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1372-f0a5-51c9-6fcc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4485-13fc-8f30-309a" type="max"/>
          </constraints>
          <profiles>
            <profile id="d37c-e331-d341-c253" name="Canto de sirena" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Un solo uso. Al comienzo de la subfase de Declarar Cargas y Reacciones de Carga de tu oponente, designa una única unidad enemiga que sea capaz de declarar una carga contra esta miniatura (o su unidad). Esa unidad enemiga debe hacer un chequeo de Liderazgo. Si se supera este chequeo, la unidad puede actuar como de costumbre. Sin embargo, si lo falla, debe declarar una carga contra esta miniatura (o su unidad).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a0e8-99ab-a564-ae81" name="Seducción de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0a72-60ff-bfd3-fb99" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f6de-8816-800c-d33d" type="max"/>
          </constraints>
          <profiles>
            <profile id="6fec-32a0-2a1f-5e23" name="Seducción de Slaanesh" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Las unidades enemigas deben hacer un chequeo de Liderazgo antes de realizar cualquier tirada para Impactar contra esta miniatura durante la fase de Combate. Si este chequeo falla, solo las tiradas para Impactar de un 6 natural tendrán éxito.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="660b-8017-05ef-27c0" name="Regalos del caos muy comunes. Slaanesh" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7dcf-8aac-974c-46b0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b8b-445d-ffa8-41aa" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="060e-feb9-d3eb-a12e" name="Almizcle soporífero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a7f7-2b75-942e-5d92" type="max"/>
          </constraints>
          <profiles>
            <profile id="13d8-6761-5b06-76fa" name="Almizcle soporífero" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Las miniaturas enemigas que entren en combate con esta miniatura no pueden usar la regla especial Golpea primero. Las miniaturas enemigas que no tienen la regla especial Golpea primero quedan sujetos a la regla especial Golpea Último.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5ca3-7536-efbf-4920" name="Mirada cautivadora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f49e-6340-f83e-b996" type="max"/>
          </constraints>
          <profiles>
            <profile id="77e9-d27a-4e5e-0e6e" name="Mirada cautivadora" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Las miniaturas enemigas que entren en combate con esta miniatura no pueden usar la regla especial Presencia Inspiradora de su General.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="55f1-d121-ee6a-784b" name="Iconos del caos. Slaanesh" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6afb-697b-12f0-ebae" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b18c-5b4e-da85-6e3e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d8a1-1eb6-3b53-0bbe" name="Estandarte arrebatador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f9a7-45cc-51ba-5a14" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7660-05d8-421f-2204" type="max"/>
          </constraints>
          <profiles>
            <profile id="360a-899b-6a3a-9810" name="Estandarte arrebatador" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Cualquier unidad enemiga que cargue el arco frontal de una unidad que lleve el Estandarte Arrebatador realiza una carga desordenada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4f03-6a10-fc5b-0493" name="Estandarte de la sirena" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="461b-0527-9172-1976" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d3fe-9159-6348-5f65" type="max"/>
          </constraints>
          <profiles>
            <profile id="fac6-a554-f9b3-d211" name="Estandarte de la sirena" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Si una unidad enemiga cargada por una unidad que lleva el Estandarte de la Sirena desea Huir (o Disparar y Huir) como reacción de carga, primero debe hacer un chequeo de Liderazgo. Si se supera este chequeo, la unidad puede Huir (o Disparar y Huir). Sin embargo, si se falla este chequeo, la unidad debe Aguantar la Posición.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cf55-4aed-49b9-bb8e" name="Estandarte de aquiescencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e294-a820-df01-3fd4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a365-4e7b-54a5-83f7" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a80-8cff-74d4-75d2" name="Estandarte de aquiescencia" hidden="false" typeId="ad65-37f5-be93-9174" typeName="Icono del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="6724-1073-f998-2c18">Una única unidad enemiga que se enfrente en combate con el portador del Estandarte de la Aquiescencia sufre un modificador de -1D3 en sus atributos de Habilidad de Armas e Iniciativa (hasta un mínimo de 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c258-d8e2-050b-8a92" name="Regalos del caos. Tzzench" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="765f-e253-e903-4103" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b28-027b-9f55-5207" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fbfe-b64b-68a1-b07b" name="Báculo del cambio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7d76-0dde-1703-a9fe" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9f74-99f9-b9f6-76de" type="max"/>
          </constraints>
          <profiles>
            <profile id="21d9-04e4-5fb6-a366" name="Báculo del cambio" hidden="false" typeId="4232-c79d-a3b6-800d" typeName="Regalo del caos. Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9689-3668-7ff6-3bac">Combate</characteristic>
                <characteristic name="Fuerza" typeId="8949-3484-08c0-59bf">F</characteristic>
                <characteristic name="PA" typeId="b096-c1f8-707f-b75e">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="eddd-17bc-14c8-af51">Ataques flamígeros, Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="9348-a495-df3c-3a79">Cualquier miniatura enemiga que sufra una o más heridas no salvadas del Bastón del Cambio debe realizar inmediatamente un chequeo de Resistencia. Si lo falla, la miniatura herida pierde todas sus heridas restantes.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7045-fd21-d81a-b25f" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="e2c3-f1e3-2ba5-2440" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="bba4-983e-69d8-1d8a" name="Voluntad de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c469-3c55-3506-9bf1" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="324a-7df1-9735-a7dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="3c4c-a738-7b30-5d4c" name="Voluntad de Tzeentch" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Una vez por ronda, esta miniatura puede volver a tirar un único Dado. Puede ser un Dado tirado por sí solo, como parte de una tirada de dados, o como parte de una tirada múltiple de dados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8b4b-d698-a37b-ad1b" name="Vórtice de poder" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9865-249f-99bb-0d77" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a407-0b0f-87a5-bcb5" type="max"/>
          </constraints>
          <profiles>
            <profile id="8a88-04f3-3498-d41d" name="Vórtice de poder" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Mientras se encuentren dentro del Alcance de Dispersión de este Hechicero, los Hechiceros enemigos sufren un modificador de -1 en sus tiradas de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="51ca-37d3-bb83-cbc6" name="Dos cabezas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee6d-b27b-c7f9-965c" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="109f-dc29-c0a5-dcbf" type="max"/>
          </constraints>
          <profiles>
            <profile id="2616-8816-682f-1ef2" name="Dos cabezas" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Esta miniatura conoce un hechizo más (elegido como de costumbre) de lo normal para su Nivel de Hechicería.
Ten en cuenta que esto no aumenta el Nivel del Hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fcba-b4a2-8d26-382e" name="Regalos del caos muy comunes. Tzeench" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5daf-30b6-3894-0a87" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="979b-56a4-cbbc-390f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a901-8239-f994-0799" name="Corona iridiscente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a2f-86d4-4a5e-9c9a" type="max"/>
          </constraints>
          <profiles>
            <profile id="08d1-a8c6-cf6d-d32a" name="Corona iridiscente" hidden="false" typeId="53a1-2555-f475-a834" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="dc99-19f4-48ac-2f1e">Cualquier miniatura enemiga que elija como objetivo a esta miniatura durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
