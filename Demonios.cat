        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Las salvaciones por Regeneración no están permitidas contra heridas causadas por esta arma (las salvaciones por armadura y las salvaciones especiales se pueden intentar como de costumbre).</characteristic>
      </characteristics>
    </profile>
    <profile id="b76d-a854-4137-9f81" name="Cabeza de muerte" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
