        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c94-5ca7-2f20-efbb" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8148-760a-fe1b-075e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c67b-c38a-245a-be9b" name="Armadura de Morko" hidden="false" collective="false" import="true" type="upgrade">
