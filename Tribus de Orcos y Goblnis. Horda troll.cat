        <selectionEntry id="6319-f337-d63d-0a04" name="Estandarte del ¡Waaagh!" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1ccd-9339-85d6-833f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d3a-24ad-d3ad-36ef" type="max"/>
          </constraints>
          <profiles>
            <profile id="b940-529d-5aff-e0fe" name="Estandarte del ¡Waaagh!" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte del ¡Waaagh! aumenta su alcance máximo posible de carga en 3” y, al realizar una tirada de Carga, puede aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="38fc-c5ad-e9e1-1c43" name="El gran trapo roñoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3cee-b21c-6ce8-043a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fee1-080c-c624-b6a8" type="max"/>
          </constraints>
          <profiles>
            <profile id="57a4-0751-de15-54b5" name="El gran trapo roñoso" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve El Gran Trapo Roñoso tiene un modificador de +1 a su atributo de Habilidad de Armas (hasta un máximo de 10). Además, al calcular su resultado de combate, la unidad puede reclamar un punto adicional de resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="acc4-a438-4e23-4bb4" name="La bandera del furiozo Ladz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e3db-72a9-7f5a-623c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b52b-293c-b149-17f0" type="max"/>
          </constraints>
