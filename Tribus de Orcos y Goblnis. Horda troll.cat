    <selectionEntry id="d8ae-2737-49b1-4235" name="Gigante" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="90cf-c9b5-94bd-1025" value="2.0">
          <conditions>
