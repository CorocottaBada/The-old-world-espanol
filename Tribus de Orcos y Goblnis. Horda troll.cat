              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve La Bandera del Furiozo Ladz obtiene la regla especial Furia Asesina.</characteristic>
              </characteristics>
