          <infoLinks>
            <infoLink id="27c9-5a70-127b-78c9" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="15f7-67e8-106b-4cd4" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0618-f056-636b-e5ff" name="El hacha de de Akrit" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="792a-aff1-9287-dbfd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f7b1-ca1c-795a-b3a0" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a76-f4b7-94a8-21eb" name="El hacha de de Akrit" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Perforacorazas (1)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador del Hacha de Akrit puede repetir cualquier tirada fallida para Impactar realizada mientras la usa. Sin embargo, el modificador de Fuerza de esta arma solo se aplica contra miniaturas enemigas a las que el portador haya cargado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bb39-125f-3e2b-0a69" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="ff0d-f83f-7486-ca14" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a2eb-f41d-654b-716d" name="Armas mágicas muy comunes. Orcos y Goblins. Goblins o Goblins nocturnos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="85d9-7583-df9e-b158" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f52-dd58-659a-454f" type="min"/>
