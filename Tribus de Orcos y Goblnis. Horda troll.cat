        <selectionEntry id="893e-2d5c-ab93-e6a9" name="El estandarte de la araña" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="325e-174e-d7dc-1ab0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b00c-cd20-a21e-4b1b" type="max"/>
