    <selectionEntryGroup id="aab1-8337-7a35-9c98" name="Talismanes. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ebb-a1a7-c215-ac90" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8406-fc51-bcae-5efe" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3f68-ecab-e098-2f75" name="Amuleto verde brillante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b52c-1d47-f075-a445" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="61da-9711-1075-154d" type="max"/>
          </constraints>
          <profiles>
            <profile id="9908-f630-9061-e410" name="Amuleto verde brillante" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Si el portador (y cualquier unidad a la que se haya unido) es el
objetivo de un hechizo enemigo, pueden usar el Amuleto Verde Brillante en lugar de intentar una dispersión arcana. Tira 1D6. Con un resultado de 2 o más, el hechizo se dispersa. Sin embargo, si se obtiene un 1, el Amuleto Verde Brillante explota. El amuleto se destruye y no se puede volver a usar, y su portador pierde una única Herida.
Ten en cuenta que el Amuleto Verde Brillante no se puede usar contra una Fuerza Irresistible.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6e18-4532-2e47-ab3a" name="El collar de Zorga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3635-7c51-e3ea-75ef" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5990-716d-1275-5e9b" type="max"/>
          </constraints>
          <profiles>
            <profile id="08c2-17dc-93de-b7ba" name="El collar de Zorga" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier ‘bestia de carga’ enemiga que dirija sus ataques contra el portador del Collar de Zorga o su unidad durante la fase de Combate sufre un modificador de -1 a sus tiradas para Impactar. Para los fines de esta regla, una bestia de carga es la montura de cualquier miniatura cuyo tipo de tropa sea ‘caballería’, la(s) bestia(s) que tire(n) de cualquier miniatura cuyo tipo de tropa sea ‘carro’, y la montura de cualquier personaje montado cuyo tipo de tropa sea ‘monstruo’.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="43b2-3da9-12c4-6963" name="Buzkador de magoz brillantez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
