    </selectionEntryGroup>
    <selectionEntryGroup id="b137-d131-36ba-a09f" name="Armaduras mágicas. Orcos y Goblins. Jefe orco negro/orco. No monstruo. Armadura" hidden="false" collective="false" import="true">
      <constraints>
