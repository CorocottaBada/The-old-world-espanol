      <selectionEntries>
        <selectionEntry id="549f-0e6f-5a2e-3293" name="Armadura endurecida de la muerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ce7f-743e-b08f-4dbb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="72c7-ce7f-4962-a4b8" type="max"/>
          </constraints>
          <profiles>
            <profile id="c247-3864-246f-adaa" name="Armadura endurecida de la muerte" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo Jefes Orcos Negros y Jefes Orcos cuyo tipo de tropa es ‘infantería’, ‘caballería’ o ‘carro’. La Armadura Endurecida de la Muerte es una armadura de placas completa. Además, su portador mejora su atributo de Resistencia en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e70b-5c45-221d-bca9" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5792-492c-36f7-d050" name="Armaduras mágicas. Orcos y Goblins. Escudo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e7c-e117-95b9-6125" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aeca-b35f-443c-92d0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="973c-9d8c-a881-1d1f" name="Escudo rencoroso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8063-69dd-2215-de37" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="14fa-3af0-e89e-e4f0" type="max"/>
          </constraints>
          <profiles>
            <profile id="e4c5-4eba-0d75-24ad" name="Escudo rencoroso" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo Rencoroso es un escudo. Además, cualquier miniatura enemiga que saque un 1 natural al hacer una tirada para Impactar o para Herir contra el portador del Escudo Rencoroso durante la fase de Combate sufre inmediatamente un impacto de Fuerza 4 con una PA de -.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d4d5-2d78-7b7b-114b" name="Escudo" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8d82-e2c3-3095-63fc" name="Armaduras mágicas. Orcos y Goblins. Armadura" hidden="false" collective="false" import="true">
