    <selectionEntryGroup id="e3f3-c86f-845a-e243" name="Armaduras mágicas muy comunes. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="91a9-d9fb-6579-bd45" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aa3e-7a20-6df1-fb47" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d2a2-b963-270e-ea4e" name="Pantalones de pellejo de troll" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4101-526c-9ddd-d94e" type="max"/>
          </constraints>
          <profiles>
            <profile id="795d-ff45-ed62-66d6" name="Pantalones de pellejo de troll" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Se pueden usar con otra armadura. El portador de los Pantalones de Pellejo de Troll mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador tiene la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5c02-d4b5-946f-bd1f" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
