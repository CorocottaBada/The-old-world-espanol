            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c6f-d2a2-80db-b5d8" type="max"/>
          </constraints>
          <profiles>
            <profile id="1e3d-4cde-7007-e969" name="Efigie de Morko (Effigy of Mork)" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura que dirija sus ataques contra el portador de la Efigie de Morko durante la fase de Combate sufre un modificador de -1 a sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ac21-e571-4533-3d0b" name="Objetos hechizados. Orcos y Goblins. Jefe orco negro/orco/goblin/goblin nocturno" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="13d1-4c9f-ed2c-d2f9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f59-e442-eb70-3d1c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6060-115d-f72f-76cb" name="Tótem espeluznante de trofeos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9850-dbc9-b25a-3d1c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="29c2-ff8e-f8a1-dd50" type="max"/>
          </constraints>
          <profiles>
            <profile id="5b4a-441a-731b-e555" name="Tótem espeluznante de trofeos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo Jefes Orcos Negros, Jefes Orcos, Jefes Goblins y Jefes Goblins Nocturnos. Todas las unidades enemigas en un radio de 6” del portador del Tótem Espeluzante de Trofeos sufren un modificador de -1 a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8248-fabd-acf8-f71f" name="Objetos hechizados. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0725-ef49-7184-ee0a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4849-a010-d348-8cb0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ffb5-05ca-a1e6-ab36" name="Kazko de jefazo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6d8e-9ca5-00a2-e0b5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a158-4dbf-2c7d-9012" type="max"/>
          </constraints>
          <profiles>
            <profile id="c98a-a033-aeac-27d5" name="Kazko de jefazo" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Durante la subfase de Comando de su turno, un personaje que lleve el Kazko de Jefazo y que no esté en combate puede deleitar a sus camaradas con palabras inspiradoras al realizar un chequeo de Liderazgo (usando su propio Liderazgo). Si se supera este chequeo, hasta la próxima subfase de Inicio de Turno de tu turno, este personaje y cualquier unidad a la que se haya unido obtienen la regla especial Indesmoralizable.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="064b-92f5-4982-f71f" name="Collar del colmillo bendito" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3eab-489d-ea31-cebc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5fa8-653a-0c68-75ee" type="max"/>
          </constraints>
          <profiles>
            <profile id="0829-877c-f4c4-e5d2" name="Collar del colmillo bendito" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Collar del Colmillo Bendito puede repetir cualquier tirada natural de 1 de cualquier Salvación por Armadura, Salvación Especial o tirada de Regeneración.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5520-8b34-57ca-0609" name="El pensar de los orcos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7b21-6eb6-c3ad-f013" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="67cd-7805-ff20-568b" type="max"/>
          </constraints>
          <profiles>
            <profile id="62e1-05b2-85b5-c0cd" name="El pensar de los orcos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de El Pensar de los Orcos mejora su atributo de Iniciativa en 1. Además, el portador y cualquier unidad a la que se haya unido no están sujetos a la regla especial de Impetuoso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c5b1-ca4e-0e39-ac5f" name="Objetos hechizados muy comunes. Orcos y Goblins. Goblins nocturnos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="65b8-c4be-409e-0a41" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54c8-5b60-4a07-d138" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8ca8-98b4-2644-bd6d" name="Vino de zetaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fdb6-adb5-4152-b3b0" type="max"/>
          </constraints>
          <profiles>
            <profile id="1dd0-dcf7-78bd-6186" name="Vino de zetaz" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo para personajes Goblins Nocturnos. Uso único. Durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar distribuir Vino de Zetas a una unidad a la que se haya unido realizando un chequeo de Liderazgo (usando su propio Liderazgo). Si supera este chequeo, hasta la próxima subfase de Inicio de Turno de tu turno, este personaje y cualquier unidad a la que se haya unido obtienen la regla especial Inmune a la Psicología.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="677e-99fb-af45-8527" name="Objetos hechizados muy comunes. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="766d-8e51-b400-17db" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66cb-f247-84fd-544b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="76c6-1550-3ad4-1720" name="Kazko kabezadura" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5caf-733e-aa83-5d61" type="max"/>
          </constraints>
          <profiles>
            <profile id="5f67-6b22-f41f-0776" name="Kazko kabezadura" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">0-1 por miniatura. Un Kazko Kabezadura otorga a su portador la regla especial Impactos por Carga (1). Este Impacto por Carga tiene un atributo de Penetración de Armadura de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a1f0-c351-6adc-8bbf" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b471-081f-1cd4-cea0" name="Objetos arcanos. Orcos y Goblins. Chamán Orco/Goblin/Goblin nocturno" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e539-704b-8a17-f211" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d8fa-ff6a-120d-0a26" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="13d3-d3d9-378b-5140" name="El brebaje de la bruja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="99ac-e768-fe20-ab7a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fdb3-87cc-69a0-203d" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb2e-b2f9-22b0-e84d" name="El brebaje de la bruja" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Solo Chamanes Orcos, Chamanes Goblins y Chamanes Goblins Nocturnos. Además de los Saberes de la Magia de los que normalmente pueden conocer hechizos, el portador del Brebaje de la Bruja puede conocer hechizos del Saber de la Magia de los Trolls (ver página 84).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="66fe-9b2c-b3dd-e8e9" name="Objetos arcanos. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="75fb-6ba0-f10c-f7a4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a25f-097e-531a-38de" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c6ba-d116-4162-e264" name="Traztoz brillantez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="20c7-0dab-ff07-d6eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1f3c-3ef5-c08e-0465" type="max"/>
          </constraints>
          <profiles>
            <profile id="9c6a-ca88-0b69-685e" name="Traztoz brillantez" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Si el portador (o su unidad) es el objetivo de un hechizo enemigo, pueden usar los Traztoz Brillantez en lugar de intentar una dispersión arcana. Tira 1D6. Con un resultado de 1-3, los Traztoz Brillantez no tienen efecto y el hechizo se lanza normalmente. Con un resultado de 4+, el hechizo se refleja de nuevo sobre el lanzador y él (y su unidad) se convierten en el objetivo del hechizo. El lanzador puede intentar una dispersión arcana.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="31a5-dd68-1b9a-b93a" name="Ídolo de Morko" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a622-6ae2-86c5-339a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0477-0e1e-8726-1648" type="max"/>
          </constraints>
          <profiles>
            <profile id="6584-4b8d-4f51-3776" name="Ídolo de Morko" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Ídolo de Morko aumenta su rango de dispersión en 3”. Además, una vez por turno, al intentar una dispersión mágica, el portador del Ídolo de Morko puede repetir la tirada de Dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1b7b-3ae6-0052-81d5" name="Bastón rugozo de Buzgob" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4d43-f9df-8a69-6164" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6b9-a7ac-0bf5-6d2a" type="max"/>
          </constraints>
          <profiles>
            <profile id="5ec9-d18b-85e3-4675" name="Bastón rugozo de Buzgob" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, el portador del Bastón Rugozo de Buzgob puede volver a realizar una tirada de Lanzamiento de Hechizo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c610-adcc-c816-75f6" name="Báculo de Baduumm" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="590c-ccd2-cded-65a1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0504-d2e0-db0f-b979" type="max"/>
          </constraints>
          <profiles>
            <profile id="d804-aa75-2d68-a3ec" name="Báculo de Baduumm" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Báculo de Baduumm aplica un modificador +1D3 al resultado de cualquier tirada de Lanzamiento que realice. Sin embargo, si saca un doble 1 natural o un doble 6 al hacer una tirada de Lanzamiento, centra una Plantilla de Área Grande de 5” sobre el portador. Cada miniatura (amiga o enemiga) cuya peana se encuentre debajo de la plantilla corre el riesgo de ser impactada y sufrir un único impacto de Fuerza 6 con una PA de -1. A continuación, el báculo se destruye y no se puede volver a utilizar.
Ten en cuenta que los efectos de este objeto se suman a los efectos de sacar un doble 1 natural o un doble 6 al hacer una Tirada de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2fe2-8190-2acd-3247" name="Ídolo de Gorko" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fb5d-e4e7-61e6-6556" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4857-c701-4dfd-8f8b" type="max"/>
          </constraints>
          <profiles>
            <profile id="a43c-1699-87b0-5fb4" name="Ídolo de Gorko" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Ídolo de Gorko aumenta el alcance de todos sus hechizos en 3”. Además, una vez por turno, el portador del Ídolo de Gorko puede volver a tirar una Tirada de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2d05-5be1-5839-1326" name="Estandartes mágicos. Orcos y Goblins" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bb2e-4f72-a580-06ce" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3cc8-6c3f-f971-aa1e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="38a1-8fc6-4ae2-3b67" name="Estandarte ventoso de Guff" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dba8-05a3-e824-a11a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="db7e-1554-e759-b91f" type="max"/>
          </constraints>
          <profiles>
            <profile id="a4b0-cf11-3531-0d00" name="Estandarte ventoso de Guff" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte Ventoso de Guff puede volver a tirar cualquier chequeo de pánico fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="92c0-6734-5bba-9930" name="Estandarte de la carnicería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="812b-b2f6-7744-3de4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a01b-15a7-4a63-2292" type="max"/>
          </constraints>
          <profiles>
            <profile id="b2ef-6f1d-b336-58d4" name="Estandarte de la carnicería" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las miniaturas en una unidad que porte el Estandarte de Carnicería tienen un modificador de +1 a su atributo de Fuerza durante un turno en el que cargan.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
