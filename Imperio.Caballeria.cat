    <selectionEntry id="01e0-269a-ae0f-2af8" name="Sacerdote de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="2d38-3887-7665-fb7d" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
