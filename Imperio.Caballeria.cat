        <selectionEntry id="2c9d-dbd5-5232-d3f4" name="Hoja de acero plateado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b6ed-bc9b-249c-0c37" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3ccc-de3e-e68a-7211" type="max"/>
          </constraints>
          <profiles>
            <profile id="4a16-ab0d-cc9f-74c9" name="Hoja de acero plateado" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Odio (miniaturas No Muertas)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Hoja de acero plateado solo puede ser adquirida por una miniatura en un Ejército de la Infamia de Órdenes Caballerescas. Las miniaturas No Muertas no pueden realizar salvaciones por Armadura o Regeneración contra una herida causada por esta arma.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
