    <selectionEntry id="23ce-e27f-3d55-5d4e" name="Altar de guerra de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2d26-36b9-ca33-462c" type="max"/>
      </constraints>
      <rules>
        <rule id="16b6-72e4-0ee2-e172" name="Fervor Sagrado" hidden="false">
          <description>Excepto si esta unidad está huyendo, unidades amigas que estén a 6” o menos de la unidad superan automáticamente cualquier Chequeo de Miedo y pueden repetir cualquier Chequeo de Pánico fallido.</description>
        </rule>
        <rule id="7407-dae8-2d9b-86cc" name="Símbolo de Poder" hidden="false">
          <description>El Aura de Mando de un Archilector de Sigmar montado en el Altar de Guerra aumenta de 8” a 12”.
Ten en cuenta que, si esta miniatura es tu General, tiene un Aura de Mando de 18” como es habitual.</description>
        </rule>
        <rule id="c26c-7b0b-5072-231a" name="Perdición de Brujas" hidden="false">
          <description>Todos los Hechiceros (amigos o enemigos) dentro del Aura de Mando de esta miniatura sufren un modificador de -2 a sus Tiradas de Lanzamiento.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="2774-c047-50d2-2d69" name="Formación cerrada" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
        <infoLink id="37eb-cf81-b553-dba4" name="Primera carga" hidden="false" targetId="19f8-c53d-60db-77c6" type="rule"/>
        <infoLink id="a622-e61b-dc8e-6f5a" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
