    </selectionEntryGroup>
    <selectionEntryGroup id="0b6a-e857-780d-7311" name="Armaduras mágicas. El Imperio. Permite hechiceros. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b76b-619c-a181-934e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fcc-8806-9ad0-d618" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a778-6906-ef4d-8332" name="Armadura de Tarnus" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d936-076e-d3ec-82eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4449-4895-e911-cf73" type="max"/>
          </constraints>
          <profiles>
            <profile id="d630-2b6a-70cc-ffa0" name="Armadura de Tarnus" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Tarnus es una armadura ligera que puede ser equipada y utilizada por un Hechicero del Imperio, incluso si no tienen opción de equipar armadura, escudo o barda, sin restricción. Además, su portador tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="50da-cb98-c603-87a2" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a1d5-fc02-7e2d-f947" name="Armaduras mágicas. El Imperio. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a892-1630-c443-ee8c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="07fd-129c-42bf-0bae" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f656-a7c7-da0d-eb24" name="Armadura de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8632-4e6a-8af4-e29c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2898-d7d0-6fb1-8e38" type="max"/>
          </constraints>
          <profiles>
            <profile id="3acb-2af6-84a2-6b85" name="Armadura de la fortuna" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de la Fortuna es una armadura pesada. Además, su portador tiene una Salvación Especial de 6+ contra cualquier herida sufrida y es inmune a la regla especial Golpe Letal. Si el portador recib un Golpe Letal, se permite Salvación por Armadura y Regeneración de manera normal. Si no se salva la herida, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="26c5-9d54-e8fe-9988" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cbbf-c810-5b66-f3eb" name="Armadura dos veces bendita" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a8d4-392c-1b34-2e32" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3f05-ad66-40cb-9de6" type="max"/>
          </constraints>
          <profiles>
            <profile id="b5d2-c9d2-aaaf-e968" name="Armadura dos veces bendita" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura Dos Veces Bendita es una armadura completa. 
Además, el portador puede lanzar el hechizo Manomartillo del Saber de la Magia de Batalla (ver página 320 del reglamento
Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6687-7793-0dbe-898f" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e89d-95c9-c7e4-548f" name="Estandartes mágicos. El Imperio. Portaestandarte de batalla Panteras" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="791e-21dd-71a9-baac" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df6f-e054-0330-1d31" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7fb1-05d3-546e-d645" name="Estandarte de los Caballeros Pantera" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6c7c-ff8c-6e47-cfd3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="15fc-e78b-7ae3-4b3f" type="max"/>
          </constraints>
          <profiles>
            <profile id="b6c6-e070-c287-4cd6" name="Estandarte de los Caballeros Pantera" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Solo Portaestandarte de Batalla de la Orden de la Orden de los Caballeros Pantera. Una unidad que porte el Estandarte de los Caballeros Pantera gana la regla especial Indesmoralizable.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fbd7-3a9b-4469-b460" name="Indesmoralizable" hidden="false" targetId="f351-e61b-a183-42e3" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="b487-62a9-b337-005a" name="Caballeros Pantera" hidden="false">
      <description>Un ejército de los Caballeros Pantera puede incluir 0-1 unidad de Órdenes de Caballería o Caballeros del Círculo Interior pertenecientes a la Orden del Lobo Blanco como una opción de Mercenarios.Esta unidad no está sujeta  alas reglas de &quot;Mala conducta de los mercenarios&quot;.</description>
    </rule>
    <rule id="ec99-ee7b-2946-31cb" name="Caballeros del Lobo Blanco" hidden="false">
      <description>Un ejército de los Caballeros del Lobo Blanco puede incluir cualquier cantidad de unidades de la Guardia Teutógena como opciones Especiales, y 0-1 unidad de Milicia de las Compañías Libres como una opción de Básica cada 1000 puntos. Sin embargo, tu ejército no puede incluir Archilectores de Sigmar, Sacerdotes de Sigmar ni Cazadores de Brujas.</description>
    </rule>
    <rule id="8c61-e599-94c6-f766" name="Caballeros del Sol Llameante" hidden="false">
      <description>Un ejército de los Caballeros del Sol Llameante puede incluir 0-2 Hechiceros de Batalla como opciones de Personajes cada 1000 puntos, y 0-1 Gran Cañón o Mortero como una opción Especial cada 1000 puntos. Sin embargo, tu ejército no puede incluir Archilectores de Sigmar ni Sumos Sacerdotes de Úlric.</description>
    </rule>
    <rule id="f244-68c7-7b09-093c" name="Caballeros de Morr" hidden="false">
      <description>Un ejército de los Caballeros de Morr puede incluir Grandes Hechiceros y Hechiceros de Batalla como opciones de Personajes. Sin embargo, tu ejército no puede incluir Archilectores de Sigmar, Sacerdotes de Sigmar, Sumos Sacerdotes de Úlric ni Sacerdotes de Úlric.</description>
    </rule>
    <rule id="f8b4-1a9d-a5b8-f29c" name="Caballeros del Corazón Ardiente" hidden="false">
      <description>Un ejército de los Caballeros del Corazón Ardiente puede incluir cualquier cantidad de unidades de Flagelantes como opciones Singulares. Sin embargo, tu ejército no puede incluir Sumos Sacerdotes de Úlric ni Sacerdotes de Úlric.</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
    <profile id="d41e-2105-1224-157b" name="Orden del Sol llameante" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las miniaturas de la Orden del Sol llameante:
- Ganan la regla especial Evasivo y Ataques flamígeros.
Además, un Gran Maestre, Maestre del capítulo o una unidad de Caballeros del Círculo interior de la Orden del Sol llameante:
- Pueden reclamar un bonificador adicional de +1 al resultado de combate durante un turno en el que haya cargado. Este bonificador no es acumulativo.</characteristic>
      </characteristics>
    </profile>
    <profile id="c4fb-6076-0a0f-f7dc" name="Orden del Lobo blanco" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las miniaturas de la Orden del Lobo blanco:
- Deben estar equipadas con armas a dos manos o alabardas, las cuales pueden reemplazar con martillos del lobo (consulta la página 39) de manera gratuita (ten en cuenta que las miniaturas que puedan adquirir armas mágicas pueden hacerlo como de costumbre).
- Ganan la regla especial Carga devastadora.
Además, un Gran Maestre, Maestre del capítulo o una unidad de Caballeros del Círculo interior de la Orden del Lobo blanco:
- Tiene una Salvación especial de 5+ contra cualquier herida sufrida causada por un ataque con la regla especial Ataques flamígeros.</characteristic>
      </characteristics>
    </profile>
    <profile id="9503-affb-7318-0833" name="Orden del Corazón ardiente" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las miniaturas de la Orden del Corazón ardiente:
- Sólo se le puede unir un Gran maestre o Maestre del capítulo de la Orden del Corazón ardiente, un Archilector de Sigmar o un Sacerdote de Sigmar.
- Ganan la regla especial Odio (Hechiceros enemigos, Orcos y Goblins).
Tienen +1 Iniciativa durante la primera ronda de cualquier combate.
Además, un Gran Maestre, Maestre del capítulo o una unidad de Caballeros del Círculo interior de la Orden del Corazón ardiente:
- Puede repetir cualquier resultado natural de 1 para Impactar o Herir realizada durante la fase de Combate.
- Ganan la regla especial Resistencia a la magia (-1).</characteristic>
      </characteristics>
    </profile>
    <profile id="0687-8805-d1d6-7a81" name="Orden de los Caballeros pantera" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las miniaturas de la Orden de los Caballeros Pantera:
- Deben estar equipadas con lanzas de caballería (ten en cuenta que las miniaturas que puedan adquirir armas mágicas pueden hacerlo como de costumbre)
- Pueden repetir un único dado que obtenga un resultado natural de 1 al realizar una tirada de Carga, antes de descartar cualquier dado que deba ser descartado.
- Ganan la regla especial Odio (Guerreros del Caos, Rebaños de Hombres Bestia y miniaturas Demoníacas).
Además, un Gran Maestre, Maestre del capítulo o una unidad de Caballeros del Círculo interior de la Orden de los Caballeros pantera:
- Ganan la regla especial Resistencia a la magia (-1).</characteristic>
      </characteristics>
    </profile>
    <profile id="1c55-69ef-eb10-9353" name="Palomas bomba" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">En vez de disparar normalmente durante la dase de Disparo, una miniatura equipada con palomas bomba puede liberar una. Elige una unidad enemiga que está a 24” o menos de la miniatura y tira en la Tabla de Paloma Bomba de abajo: 
Tabla de Paloma Bomba
1D6 Resultado
1 Cerebro de pájaro: Centra la plantilla de área pequeña (3”) sobre la miniatura que soltó la paloma. Cualquier miniatura cuya peana quede debajo de la plantilla tiene el riesgo de ser impactada y sufrir un impacto de Fuerza 4 con un PA de -1.
2-3 Vuela lejos de casa: La bomba no tiene efecto.
4-5 Defectuosa: El objetivo sufre un único impacto de Fuerza 5 con un PA de -2.
6 Entrega perfecta: Coloca la plantilla de área pequeña (3”) de modo que su orificio central esté justo sobre el centro de la unidad objetivo. Cualquier miniatura cuya peana quede debajo de la plantilla tiene el riesgo de ser impactada y sufrir un impacto de Fuerza 4 con un PA de -1.</characteristic>
      </characteristics>
    </profile>
    <profile id="c273-be79-3e55-3d6d" name="Trabuco lanzagranadas" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">24&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Aparatoso, Pesado</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Si la tirada para Impactar es exitosa, un trabuco lanzagranadas causa 1D3+1 impactos a la unidad enemigas, en vez de un impacto habitual.</characteristic>
      </characteristics>
    </profile>
    <profile id="f289-c3c2-18b8-2761" name="Rifle largo de Hochland" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">36&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Aparatoso, Pesado</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Una miniatura armada con un Rifle largo de Hochland puede declarar objetivo una miniatura específica dentro de la unidad ob jetivo, como un Campeón o un personaje.</characteristic>
      </characteristics>
    </profile>
    <profile id="1386-67fe-8c86-4715" name="Martillo del lobo" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">Combate</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F+1</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Requiere ambas manos</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Si el portador de un martillo del lobo lo utiliza durante un turno en el que haya realizado un movimiento de carga de 3&quot; o más, tendrá un modificador de +2 a su característica de Fuerza en lugar del habitual +1.</characteristic>
      </characteristics>
    </profile>
    <profile id="6f81-6062-6d9c-448f" name="Orden de los Caballeros de Morr" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
      <characteristics>
        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las miniaturas de la Orden de los Caballeros de Morr:
- Ganan la regla especial Odio (miniaturas No Muertas).
- Obtienen una Salvación especial de 6+ contra cualquier herida causada por un ataque no mágico.
Además, un Gran Maestre, Maestre del capítulo o una unidad de Caballeros del Círculo interior de la Orden de los Caballeros de Morr:
- Ganan las reglas especiales Miedo y Ataques mágicos.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
</catalogue>