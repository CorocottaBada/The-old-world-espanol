        <selectionEntry id="802f-32c0-7d56-b942" name="Anillo de Taal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="18b1-7349-ca8b-9493" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="315a-4605-054f-5f62" type="max"/>
          </constraints>
          <profiles>
            <profile id="b9dd-e79a-48d7-1039" name="Anillo de Taal" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de Taal puede lanzar el hechizo Escudo de Roble del Saber de la Magia de Batalla (ver página 321 del reglamento de Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0020-8b14-7cc1-e803" name="Objetos arcanos. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3c7d-7985-9e32-a04a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e98b-ced7-11cc-d79e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7d8e-f358-07f1-fe46" name="Libro de los Ashur" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8ee7-22e2-fa9b-6386" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="94d2-2e39-b082-6e1c" type="max"/>
          </constraints>
          <profiles>
            <profile id="1f34-a0fe-4294-e9a8" name="Libro de los Ashur" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Libro de los Ashur aumenta su Alcance de Dispersión en 3” y, excepto si obtiene algún resultado de doble natural, puede aplicar un modificador de +1 a cualquiera de sus tiradas de Lanzamiento o Dispersión. Sin embargo, si el portador obtiene un resultado de doble natural al hacer una tirada de Lanzamiento o Dispersión, resulta que el libro es una pobre reproducción, lleno de errores garrafales, y el modificador de +1 no se puede aplicar a esta tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="85.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="db16-41aa-c955-644f" name="Varita de dos colas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1a05-9851-6587-2d0e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f143-a030-bcff-c11f" type="max"/>
          </constraints>
          <profiles>
            <profile id="be96-c602-17fd-96e8" name="Varita de dos colas" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, el portador de la Varita de Dos Colas puede intentar lanzar uno de sus hechizos una segunda vez.
Sin embargo, si realiza una disfunción al lanzar el hechizo, el portador se ve abrumado por los Vientos de la Magia y, en lugar de tirar en la tabla de Disfunción Mágica, sufre 1D3 heridas sin poder hacer tiradas de salvación por Armadura o Regeneración (las tiradas de salvación Especiales se pueden intentar como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d406-d587-86d6-c429" name="Tomo de medianoche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ddee-ea44-b9c8-1d4d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f025-fe0b-ff42-1136" type="max"/>
          </constraints>
          <profiles>
            <profile id="f357-6239-9672-ba01" name="Tomo de medianoche" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Tomo de la Medianoche puede aplicar un modificador de +1 a cualquier tirada de Lanzamiento al intentar lanzar hechizos de los Saberes de Demonología, Magia Oscura o Nigromancia. Además, conoce un hechizo adicional (elegido de la manera habitual) más de lo que es normal para su Nivel de Hechicería. Sin embargo, el portador sólo puede lanzar un número de hechizos igual a su Nivel de Hechicería por turno y está sujeto a la regla especial Solitario.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="dbcf-9a41-b690-bc3a" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="da8d-6e0e-4538-8cd5" name="Bola de cristal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d17a-14a9-c9fc-57bb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3762-7238-309d-de8e" type="max"/>
          </constraints>
          <profiles>
            <profile id="4928-2b46-f940-6e10" name="Bola de cristal" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, puedes hacer que tu oponente repita una sola tirada para Impactar o Herir realizada contra una miniatura amiga que esté dentro del Aura de Mando del portador de la Bola de Cristal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a6c3-d1d3-8bdc-3a59" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="151a-7180-24e1-a346" name="Objetos arcanos muy comunes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1d4f-f768-c2a9-bd2f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3744-4a53-47fe-fa8e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6bf3-c0a6-be1d-8bc9" name="Familiar del hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d26-0de8-f26e-5f81" type="max"/>
          </constraints>
          <profiles>
            <profile id="bf48-c8e1-2fb2-18ed" name="Familiar del hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El dueño de un Familiar del hechicero puede aplicar un modificador de +1 a cualquiera de sus tiradas de Dispersión. 
Ten en cuenta que es un modificador al resultado de la tirada – no niega una tirada de doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4fbd-8918-4256-a0a9" name="Báculo de hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="128a-fd50-71aa-8741" type="max"/>
          </constraints>
          <profiles>
            <profile id="4dbc-a860-5e9c-7e10" name="Báculo de hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El portador del Báculo de Hechicero obtiene un modificador de +1 a su tirada de Lanzamiento cuando intenta lanzar un hechizo de tipo Asalto o Proyectil Mágico</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fb7d-7d69-7253-faf0" name="Estandartes mágicos. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="364d-eb59-7dce-4bc2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e891-08d1-8df4-20c4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e2ef-30be-9770-ed92" name="Estandarte imperial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e710-23b5-315c-8988" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f4b-8679-f7c5-9e85" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b3d-a997-9d5b-b9d4" name="Estandarte imperial" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades dentro del Aura de Mando de la miniatura que porta el Estandarte Imperial tiran 3D6 al hacer chequeos de Miedo, Pánico o Terror y descartan el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f604-ec5f-1076-0bb0" name="Estandarte del grifo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="208f-bdd2-29a8-f790" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9e7-6380-0ac4-c76e" type="max"/>
          </constraints>
          <profiles>
            <profile id="1c8c-e864-f3f1-efdc" name="Estandarte del grifo" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando se calcula el Resultado del combate, una unidad que porta el Estandarte del Grifo suma un Bonificador por Filas de +2 por cada fila extra tras la primera, en vez del +1 habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="aaf4-3740-d218-ff45" name="Pendón reluciente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="eae8-b4c9-fe1a-491f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="972f-2891-8823-abd2" type="max"/>
          </constraints>
          <profiles>
            <profile id="0ddc-57eb-5cee-166b" name="Pendón reluciente" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Una unidad que porta el Pendón Reluciente puede repetir un único Chequeo de Liderazgo fallado.
Ten en cuenta que Chequeo de Desmoralización no es un Chequeo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="bf2d-070f-95df-2795" name="Estandarte del deber" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="39ed-b978-3ebf-ea8b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="76d0-4ed3-d720-3684" type="max"/>
          </constraints>
          <profiles>
            <profile id="088d-bc22-3fc0-fa46" name="Estandarte del deber" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del Deber puede repetir cualquier Chequeo de Reagrupamiento fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="729f-9533-b095-0da0" name="Tapiz del triunfo de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1951-c798-b80f-56cb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="82aa-e9d5-3a51-d711" type="max"/>
          </constraints>
          <profiles>
            <profile id="3da3-6641-6dbe-ca4a" name="Tapiz del triunfo de Sigmar" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tapiz del Triunfo de Sigmar puede repetir cualquier resultado natural de 1 para Herir durante la primera ronda de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0403-d4c3-0b4e-847c" name="Icono de Morr" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="172f-3ffe-5b54-4a1f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8213-455f-9c7e-7e88" type="max"/>
          </constraints>
          <profiles>
            <profile id="a56f-da82-0988-4328" name="Icono de Morr" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Ícono de Morr gana la regla especial Miedo. Si ya tiene esta regla, en su lugar gana la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1971-9974-ac53-e5d4" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9b15-4f0c-513d-3e19" name="Armas mágicas. El Imperio. Comandante del Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0df5-deb8-85de-a6d8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f839-9487-38ff-7af2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ae33-947c-90ec-9768" name="Arco del dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="528d-145a-0784-2bee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e9b-7e65-1ab8-31cb" type="max"/>
          </constraints>
          <profiles>
            <profile id="68f1-ff7c-92ec-e97a" name="Arco del dragón" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">36&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">6</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Solo Comandantes del Imperio.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5edc-8c64-d91c-46b4" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="1c35-408b-4acd-d224" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9c53-7752-4468-2c85" name="Armas mágicas. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aae3-f6ef-7944-8a85" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ca5-74d4-8630-879c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1a50-1e61-bd94-fa90" name="Colmillo Rúnico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7bc6-507d-65c7-c4a7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b6a-6551-d10f-36d9" type="max"/>
          </constraints>
          <profiles>
            <profile id="110f-4b4f-4d3d-c334" name="Colmillo Rúnico" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cuando se tira para Herir para un impacto causado por un Colmillo Rúnico, un resultado de 2+ es siempre un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
