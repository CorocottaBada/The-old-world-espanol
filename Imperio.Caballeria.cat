          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="df7e-e5ec-3a05-65b8" name="Martillo de la rectitud" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5b5b-dd02-15fd-3c70" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d55e-f0a5-9470-bde0" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a4a-322f-acc4-49c2" name="Martillo de la rectitud" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea último, Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Las miniaturas impactadas por el Martillo de la Rectitud deben hacer un chequeo de Liderazgo por cada impacto sufrido. Si se falla el chequeo, el impacto hiere automáticamente y no se permite ninguna tirada de Salvación por Armadura (las salvaciones Especiales o Regeneración se pueden realizar de manera normal). Si se supera el chequeo, las tiradas para Herir y las tiradas de
Salvación por Armadura se realizan de manera normal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e975-44f3-e927-ee7a" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="9a6a-bd51-2dcd-6d42" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
            <infoLink id="529c-1a84-20ed-29a0" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4452-db9f-688d-f9ab" name="Dagas perladas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f3f3-696e-263e-efe5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8929-6764-6817-4958" type="max"/>
