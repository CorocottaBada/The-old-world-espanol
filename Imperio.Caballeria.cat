        <selectionEntry id="a8b4-d539-c8fd-9116" name="La maza de Helstrum" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fac6-dde5-3e80-a398" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9b47-2951-06ae-0036" type="max"/>
          </constraints>
          <profiles>
            <profile id="d4f7-0ec6-cca8-e7b6" name="La maza de Helstrum (Arma de mano)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Maza de Helsturm tiene dos perfiles. Debes elegir cuál de los dos usará el portador al inicio de cada ronda de combate. Usada a dos manos, el portador puede hacer un único ataque, ignorando su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
            <profile id="0e79-0a53-9f92-2368" name="La maza de Helstrum (Arma a dos manos)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">10</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-5</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (1D6), Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Maza de Helsturm tiene dos perfiles. Debes elegir cuál de los dos usará el portador al inicio de cada ronda de combate. Usada a dos manos, el portador puede hacer un único ataque, ignorando su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0cca-e0d9-42a2-69dc" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="7963-00d5-a9fb-a833" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
            <infoLink id="4dec-f33b-827e-8858" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c1c3-f701-99fe-8b0a" name="Espada de la justicia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="38dd-f837-aedb-db0d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8c36-af5b-20a8-463a" type="max"/>
          </constraints>
          <profiles>
            <profile id="6226-c30c-d93c-870e" name="Espada de la justicia" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos, Heridas múltiples (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de la Espada de la Justicia puede repetir las tiradas para Herir falladas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="84b7-a3b6-9c99-cea4" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="8e31-9a65-70ff-b148" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
