            <profile id="a728-815b-b3ab-0017" name="Amuleto de jade" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador es inmune a la regla especial Golpe Letal. Si el portador recibe un Golpe Letal, se permite Salvación por Armadura y Regeneración de manera normal. Si no se salva la herida, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="489c-6908-859d-5c8a" name="Protector del cazador de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4d69-2af5-6f61-0ab7" type="max"/>
          </constraints>
          <profiles>
            <profile id="c903-06ed-d5ae-2702" name="Protector del cazador de brujas" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Una miniatura que porte un Protector del Cazador de Brujas tiene la regla especial Resistencia a la Magia (-2). Además, una vez por partida, el portador de un Protector del Cazador de Brujas puede repetir una única tirada fallida de Salvación de Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1733-3ba5-5086-1094" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
