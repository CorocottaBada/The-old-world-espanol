            <profile id="9951-2fcd-c65c-e944" name="La capa blanca" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Capa Blanca tiene una Salvación Especial de 5+ contra cualquier herida sufrida, y una Salvación Especial de 3+ contra cualquier herida causada por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
