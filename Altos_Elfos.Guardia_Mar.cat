    <selectionEntryGroup id="8650-7414-c531-a140" name="Armaduras mágicas. Altos elfos. Escudo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5fde-bb2f-675a-479a" type="max"/>
