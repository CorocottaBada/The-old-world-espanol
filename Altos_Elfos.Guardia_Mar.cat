                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Capa del Señor del Conocimiento y cualquier unidad a la que se haya unido tiene una salvación de 4+ contra cualquier herida que haya sido causada por un proyectil mágico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e055-4f37-d92c-90a6" name="Brazalete de Atrazar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5b2d-ea8e-7964-744c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="20ae-cc5e-6b2d-9ce3" type="max"/>
          </constraints>
          <profiles>
            <profile id="48c7-cf90-6b50-c292" name="Brazalete de Atrazar" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Brazalete de Atrazar tiene +1 Herida en su perfil. Además, si el tipo de tropa del portador es «infantería» o «caballería», tiene un modificador +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="068f-11a4-0184-8f49" name="Incienso sagrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6985-42fa-5310-fb1a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b85-45a8-3340-f56d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7829-64be-ae47-981f" name="Incienso sagrado" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que tome como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0d4f-e0fb-f783-7841" name="Talismanes muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="652c-3112-e8ae-bb23" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4d32-a6fa-a5a5-9ab0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b12a-108f-d517-76ea" name="Amuleto de ópalo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7588-0591-1322-8588" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a18-1827-2878-8700" name="Amuleto de ópalo" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un solo uso. Un Amuleto de Ópalo da a su portador una salvación especial de 2+ contra una sola herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="73ec-657d-c88f-37f8" name="Objetos hechizados. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1012-e351-5142-13b5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ebca-4f7b-419c-245c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7299-1d9d-b7cd-378d" name="Piedra de anulación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fc8d-4755-e773-fc7d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="597d-70d9-0de1-6ae6" type="max"/>
          </constraints>
          <profiles>
            <profile id="b797-70f6-621d-a3e7" name="Piedra de anulación" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Mientras estén dentro del Aura de Mando del portador, todos los Hechiceros (amigos o enemigos) sufren un penalizador de -1 en sus tiradas de lanzamiento y dispersión.
Además, durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar utilizar la Piedra de Anulación realizando un chequeo de liderazgo (usando su propio Liderazgo sin modificar). Si se supera esta prueba, este personaje no puede ser objetivo de ningún hechizo y es inmune a los efectos de cualquier hechizo hasta tu próxima subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ae35-545c-0df4-05ef" name="Capa de las barbas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d7cb-5b20-9d70-de8c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8188-f8bb-fde1-67b5" type="max"/>
          </constraints>
          <profiles>
            <profile id="02b7-649d-1e62-2d19" name="Capa de las barbas" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de las Barbas provoca Terror. Sin embargo, el manto es tan desconcertante que otras miniaturas no pueden utilizar el Liderazgo de quien la porta.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e39b-f85c-4cf6-a049" name="Terror" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e09b-6489-38da-6624" name="Amuleto de la tempestad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6f52-05f3-0ee6-89e1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e81c-86a6-f318-69d9" type="max"/>
          </constraints>
          <profiles>
            <profile id="155e-671f-c0d5-9e2c" name="Amuleto de la tempestad" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El Amuleto de la tempestad sólo puede ser llevado por una miniatura de un Ejército de Infamia de la Guarnición del Mar. Mientras esté a 9&quot; o menos del portador del Amuleto de la tempestad, los Hechiceros enemigos no pueden sumar su nivel de Hechicería a sus Tiradas de lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b1e6-e29e-45b3-bead" name="Terror" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="198d-3207-4dc9-4baf" name="Objetos hechizados muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e6dc-4aab-f1a3-735d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e67d-937a-2de8-f2d8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="205a-34d3-bf23-27ce" name="Semilla del renacimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c128-0ad7-884d-cdfc" type="max"/>
          </constraints>
          <profiles>
            <profile id="ea74-985a-c7e6-dfed" name="Semilla del renacimiento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">La Semilla del Renacimiento otorga a su portador la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9b34-dc65-01dd-15a7" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a901-0cf3-059e-2593" name="Anillo de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="443d-34ef-ab14-df58" type="max"/>
          </constraints>
          <profiles>
            <profile id="504e-a85c-ec31-ec4b" name="Anillo de la ira" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de un Anillo de la Ira puede lanzar el hechizo Mano de Martillo del Saber de la Magia de Batalla como hechizo Vinculado, con un Nivel de Energía 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9aaf-79be-92d9-ffc3" name="Objetos arcanos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7a9d-343b-40ee-8b0e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cd3a-47ff-9a70-4fa8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="69fc-d726-8bcb-1673" name="Vara de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c6fb-0277-4957-3eb1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ea0-e365-bc90-1347" type="max"/>
          </constraints>
          <profiles>
            <profile id="5e80-0d9e-a82f-e2fd" name="Vara de plata" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador de la Vara de Plata conoce un hechizo más (elegido de la forma habitual) de lo normal para su Nivel de Magia.
Ten en cuenta que esto no aumenta el Nivel de Magia del hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4c1f-931f-2a29-b0e2" name="Cristal de las Annuli" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e63c-0374-39f3-1f42" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="622b-f6df-e68e-99c4" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b2d-39b4-0319-0cb2" name="Cristal de las Annuli" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, al lanzar con éxito un hechizo, el portador del Cristal de las Annulii puede optar por olvidar ese hechizo y generar otro(sin incluir los hechizos característicos) inmediatamente de la manera habitual.
Ten en cuenta que es posible que el Hechicero genere el hechizo que acaba de olvidar o uno olvidado en un turno anterior. Considéralo el destino.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8fbd-40c8-7dee-f03a" name="Fragmentos de vórtice" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="04a5-ee3b-2e6d-910a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01b9-e3d7-9c1d-3c23" type="max"/>
          </constraints>
          <profiles>
            <profile id="b68d-4eb5-47b4-ec7b" name="Fragmentos de vórtice" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar este objeto en lugar de hacer un intento de dispersión. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirada de dispersión. Además, se dispersan todos los hechizos en juego, incluidos los hechizos lanzados por hechiceros amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6085-b3f7-bf65-e616" name="El colgante del embaucador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8d97-59fc-3471-164b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1a2e-50e6-143b-5b6e" type="max"/>
          </constraints>
          <profiles>
            <profile id="0b27-4ab0-0b50-f26b" name="El colgante del embaucador" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar el Colgante del Embaucador cuando intente dispersar un hechizo. Si lo hace, tira 1D6 adicional al hacer la tirada de dispersión y descarta el resultado más bajo. Si el hechizo es dispersado, el hechicero que intentó lanzarlo no podrá intentar lanzar más hechizos durante el resto del turno en curso. Sin embargo, si se obtiene un doble 1 en cualquiera de los dos dados lanzados, el portador queda superado en el arte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d8f0-ab1e-d182-1e18" name="Bastón de la solidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ceb-d3ee-ab20-c556" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9054-5f40-f152-d219" type="max"/>
          </constraints>
          <profiles>
            <profile id="9a77-fa39-7a50-cef1" name="Bastón de la solidez" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Una vez por partida, cuando el portador del Bastón de la Solidez tenga que tirar en la Tabla de Disfunción, puede elegir no hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ed45-f9b6-ee6c-d225" name="Objetos arcanos muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c953-bbfa-0860-a05a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5fab-f189-42e0-f3c2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d648-0e1f-62bc-93bf" name="Selllo de Asuryan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6689-4eac-c081-ead6" type="max"/>
          </constraints>
          <profiles>
            <profile id="28eb-eac3-ceeb-c8b3" name="Selllo de Asuryan" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Hechicero puede usar este objeto en lugar de intentar dispersar. Si lo hace, el hechizo se dispersa de forma automática sin necesidad de realizar una tirada de dispersión.
Ten en cuenta que una Fuerza irresistible no se puede dispersar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="41ab-7d2a-8026-2b95" name="Honores" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d4ad-50f5-4414-2aaf" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ae4d-c3f3-10e8-4122" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="10e7-1df5-6e2c-529c" name="Acechante sombrío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de64-334f-c4d0-4e73" type="max"/>
          </constraints>
          <profiles>
            <profile id="0fab-997b-3d6c-8799" name="Acechante sombrío" hidden="false" typeId="3a24-626b-4e08-acb5" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="82f3-0fef-cdc5-c9b5">Un Personaje con el Honor Élfico Acechante Sombrío:
• No puede ir montado.
• Puede equiparse con un arco de Avelorn (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• No puede equiparse con armadura pesada o armadura completa.
• Tiene las reglas especiales Emboscador, Evasivo, Explorador, Disparar y Huir y Mover a Través de Cobertura</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6c5d-a41c-749f-d635" name="Emboscadores" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
            <infoLink id="f166-67f8-04d2-be66" name="Evasivo" hidden="false" targetId="22e4-14de-b7b8-ba59" type="rule"/>
            <infoLink id="a783-8e67-d8b0-f5c5" name="Disparar y huir" hidden="false" targetId="2024-f1cc-061a-46ec" type="rule"/>
            <infoLink id="917a-56cc-f2c6-3a1a" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
            <infoLink id="375d-1308-a114-f680" name="Exploradores" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="6e6e-1fea-3f34-5c17" name="Arco de Avelorn" hidden="false" collective="false" import="true" targetId="120f-961c-9644-7ad3" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1e1f-9784-3c31-f4fa" name="Puro de corazón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f7c1-a3c5-1027-bcda" type="max"/>
          </constraints>
          <profiles>
            <profile id="dd79-f6e1-7434-2cc8" name="Puro de corazón" hidden="false" typeId="3a24-626b-4e08-acb5" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="82f3-0fef-cdc5-c9b5">A menos que este Personaje esté huyendo, todas las unidades amigas dentro de su Aura de Mando pueden usar su Atributo de Liderazgo en lugar del suyo propio. Además, este Personaje y cualquier unidad a la que se una superan automáticamente cualquier Chequeo de Pánico que deba realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7f62-fb56-03f9-d84d" name="Guardia del mar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2d68-cde0-a773-de18" type="max"/>
          </constraints>
          <profiles>
            <profile id="487b-6076-ff51-a73d" name="Guardia del mar" hidden="false" typeId="3a24-626b-4e08-acb5" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="82f3-0fef-cdc5-c9b5">Un Personaje con el Honor Élfico Guardia del Mar:
• Solo se puede montar en un Escolta Celeste de Lothern (y no se puede elegir ninguna otra opción de montura).
• Puede estar equipado con un arco de guerra sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• Tiene las reglas especiales Disciplina Naval y Grito de Guerra</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="a511-69a6-f9db-fa1e" name="Disciplina naval" hidden="false">
              <description>Una unidad de la Guardia de Mar de Lothern puede usar esta regla especial cuando declare una reacción de Aguantar y Disparar ante una carga. Una unidad que lo haga podrá realizar la reacción de Aguantar y Disparar independientemente de la distancia a la que esté la unidad que carga. Una vez resueltos estos disparos, la unidad cargada podrá realizar una maniobra gratuita de Reorganizar filas, tras la cual mantendrá la posición y esperará a la unidad que carga.
Las unidades que están huyendo, que ya están en combate al ser cargadas, o a las que se les haya unido un Personaje sin esta regla especial no pueden usar esta regla especial.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="19da-0f3a-a8b4-14f0" name="Grito de guerra" hidden="false" targetId="98aa-28c7-f0d9-c0d9" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="d114-36a5-3e7c-1200" name="Arco de guerra" hidden="false" collective="false" import="true" targetId="f36e-05f2-ba50-ffc2" type="selectionEntry"/>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="543d-62b1-96f7-e1d7" name="Estandartes mágicos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="42fd-5b5b-dafd-a7f1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="069e-4632-3f88-77b8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c414-c605-a46f-5dfe" name="Estandarte de protección arcana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="454c-6047-e9ae-612a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9dd5-3459-153e-d443" type="max"/>
          </constraints>
          <profiles>
            <profile id="a5ca-8da3-43f9-6bf8" name="Estandarte de protección arcana" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Protección Arcana obtiene la regla especial Resistencia a la magia (-3). Además, las unidades amigas a 6&quot; o menos de la miniatura que lleve este estandarte obtienen la regla especial Resistencia Mágica (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ac9a-5257-c0c0-304c" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="97de-c45e-b7c4-4eb9" name="Estandarte del león" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fa3e-20eb-b479-99ea" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fdf3-8b47-cb9f-f439" type="max"/>
          </constraints>
          <profiles>
            <profile id="9bd3-9164-e056-f468" name="Estandarte del león" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del León supera automáticamente cualquier chequeo de miedo o terror que deba realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fd5e-0a20-7f42-37c8" name="Estandarte de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f432-2f13-fe18-2d7b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a5ee-9b96-d45f-cade" type="max"/>
          </constraints>
          <profiles>
            <profile id="4ed6-5173-ec34-d4ce" name="Estandarte de batalla" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado del combate, una unidad que lleve el Estandarte de Batalla obtiene una bonificación adicional de +1D3 puntos en el resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="da6a-66e7-2b9e-fb7d" name="Estandarte de Ellyrion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f4ce-8274-e8cb-6258" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b5d5-8c63-d99d-ba36" type="max"/>
          </constraints>
          <profiles>
            <profile id="93c3-ddc0-597e-6ce9" name="Estandarte de Ellyrion" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Ellyrion obtiene la regla especial Mover a Través de Cobertura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="83ac-dd5b-5bc1-8dc3" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0d5f-2f17-d535-158e" name="Estandarte de la resistencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="436c-ed1f-e126-199a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8b83-7f14-f52c-17c4" type="max"/>
          </constraints>
          <profiles>
            <profile id="9a12-8619-700e-7be4" name="Estandarte de la resistencia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Resistencia tiene un modificador +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0425-8f04-0ad9-419c" name="Estandarte de Lothern" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="066c-332e-cc91-0ec2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2dbe-7d9d-3878-9233" type="max"/>
          </constraints>
          <profiles>
            <profile id="2768-9af2-696c-07d1" name="Estandarte de Lothern" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad que porta el Estandarte de Lothern está equipada con lanzas arrojadizas, la mitad de las miniaturas de la tercera fila o columna (es decir, la fila o columna directamente detrás de la que normalmente puede realizar ataques de apoyo), redondeando hacia arriba, pueden realizar ataques de apoyo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="43ac-6fae-9252-e03a" name="Estandarte del equilibrio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e5b4-df53-1836-0848" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dfe3-a12d-df17-b56a" type="max"/>
          </constraints>
          <profiles>
            <profile id="5c5f-11c6-e259-ef28" name="Estandarte del equilibrio" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Mientras estén en contacto con una unidad que lleve el Estandarte del Equilibrio, las unidades enemigas no pueden repetir ninguna tirada para Impactar o para Herir. Sin embargo, la unidad que lleva el Estandarte del Equilibrio tampoco puede hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9dd0-b433-45cb-ff0e" name="Estandarte de la confianza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6e58-112b-7098-2663" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="305f-6cc1-b834-4f14" type="max"/>
          </constraints>
          <profiles>
            <profile id="10eb-d3e1-aafa-32e3" name="Estandarte de la confianza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Confianza no sufre el modificador habitual de -1 a Impactar al realizar una reacción a la carga de Aguantar y Disparar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1363-4972-30bb-ac4f" name="Armas mágicas. Altos elfos. Infantería o Carro" hidden="false" collective="false" import="true">
      <constraints>
