          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1174-88f6-97e3-a06c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66d1-be32-d0d5-a919" type="max"/>
          </constraints>
          <profiles>
            <profile id="db3b-5c55-2918-2922" name="La espada blanca" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Cazamonstruos, Golpea último, Requiere ambas manos.</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo para Miniaturas de tipo &apos;infantería&apos; o &apos;carro&apos;.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3815-dcdd-1dc9-bf70" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="d542-67ad-4299-c995" name="Cazamonstruos (Monster slayer)" hidden="false" targetId="be83-b236-0aa9-0356" type="rule"/>
            <infoLink id="fe09-0b6a-12d5-5f9e" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
            <infoLink id="c238-08a3-8405-23f6" name="Requiere ambas manos" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
