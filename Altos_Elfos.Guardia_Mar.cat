      </constraints>
      <selectionEntries>
        <selectionEntry id="a007-a404-9de7-0931" name="El escudo dorado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4ecb-d7cd-af6a-2659" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b725-33e0-1b79-32ff" type="max"/>
          </constraints>
          <profiles>
            <profile id="4062-0eba-14cd-193f" name="El escudo dorado" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo Dorado es un escudo. Además, cualquier miniatura enemiga que dirija sus ataques contra su portador durante la fase de combate debe repetir las tiradas para Impactar naturales de 6.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="32b9-ac31-3b5a-2e4c" name="Escudo" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b1a7-59c4-a2f1-d7a6" name="Armaduras mágicas. Altos elfos. Armadura. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a3d-019b-643e-d841" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d98-6a2f-77a7-362f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ea73-b04c-96e8-0479" name="Armadura de las estrellas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d79a-8133-0020-27da" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7df5-9fb1-377a-b7ce" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a19-52f1-5458-eaa3" name="Armadura de las estrellas" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Sólo miniaturas cuyo tipo de tropa es «infantería» o «caballería». La Armadura de Estrellas es una armadura pesada. Además, su portador es inmune a la regla especial «Golpe Letal». Si el portador recibe un Golpe Letal, se le permiten las salvaciones de armadura y Regeneración como de costumbre. Si la herida no se salva, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0563-5567-4fac-8298" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b350-9eec-fb90-9e71" name="Armaduras mágicas. Altos elfos. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fbdc-343e-5c59-40fc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b505-d095-a17a-2b89" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b692-69a7-d514-0efc" name="Armadura de Caledor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a228-f3ce-e3d7-18eb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a8b1-78f7-00b9-6d6c" type="max"/>
          </constraints>
          <profiles>
            <profile id="93ac-2a7e-c8a0-d648" name="Armadura de Caledor" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Caledor es una armadura completa. Además, su portador tiene una salvación especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="36e3-093a-5624-6c02" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f412-9986-9d11-0873" name="Armaduras mágicas. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="302f-b793-9c8e-2c16" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef61-74b8-f61e-9a85" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="53f5-3566-3b34-36da" name="Yelmo dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6b9a-6aaf-4b2b-b104" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a747-e6bc-ac43-f10e" type="max"/>
          </constraints>
          <profiles>
            <profile id="0be9-3296-2c19-1fde" name="Yelmo dragón" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador del Yelmo Dragón mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador tiene una salvación especial de 6+ contra cualquier herida que haya sido causada por un ataque que tenga la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="e7cc-fe8e-8f66-f028" name="Valor ancestral" hidden="false">
      <description>Una unidad con esta regla especial puede repetir cualquier chequeo de pánico fallido causado por sufrir Pérdidas Severas o por haber sido atravesada por una unidad amiga huyendo.</description>
    </rule>
    <rule id="5645-7054-d887-4572" name="Saber de Saphery" hidden="false">
      <description>Un Hechicero con la regla especial &quot;Saber de Saphery&quot; puede descartar uno de sus hechizos generados aleatoriamente de forma normal. Al hacerlo, puede seleccionar en su lugar el Hechizo Identificativo del Saber de la Magia que ha elegido o uno de los hechizos que se detallan a continuación.

Mano de Khaine
Tipo: Daño Directo
Dificultad de Lanzamiento: 7+
Alcance: Combate
Efecto: Una miniatura enemiga trabada en combate con el lanzador sufre un impacto de Fuerza 4 sin tirada de salvación por armadura (las salvaciones especiales y de regeneración se pueden realizar de la forma habitual)

Valor de Aenarion
Tipo: Potenciación
Dificultad de Lanzamiento: 10+
Alcance: 15”
Efecto: Permanece en juego. Mientras este hechizo está en juego, la unidad amiga objetivo (que puede estar en combate) obtiene la regla especial Indesmoralizable. Si se lanza este hechizo, los efectos de cualquier otra Potenciación lanzada a la unidad objetivo previamente expiran inmediatamente.

Anulación de Vaul
Tipo: Maldición
Dificultad de Lanzamiento: 11+
Alcance: 12”
Efecto: Este hechizo sólo puede lanzarse a un personaje enemigo que esté dentro del alcance y al que el lanzador pueda trazar una línea de visión, sin tener en cuenta el resto de las reglas habituales para elegir a personajes como objetivos (incluso puede lanzarse a un personaje enemigo que se haya unido a una unidad o que esté trabado en combate). 
El jugador que controla al hechicero que lanza el hechizo elige un único objeto mágico que lleve el personaje objetivo. Este objeto mágico se &quot;deshace&quot; inmediatamente, inutilizándolo completamente. El objeto mágico elegido no podrá usarse durante el resto de la partida</description>
    </rule>
    <rule id="3cd5-6e1b-3f1c-81c0" name="Reflejos élficos" hidden="false">
      <description>Una miniatura con esta regla especial (pero no su montura) obtiene un bonificador de +1 a su atributo de Iniciativa (hasta un máximo de 10) durante la primera ronda de cada combate.</description>
    </rule>
    <rule id="02e3-ad7b-f569-9d4b" name="Flechas de Isha" hidden="false">
      <description>Cualquier arco (arco largo, arco corto, arco de guerra o arco de Avelorn) usado por una miniatura con esta regla especial tiene la regla especial Perforacorazas (1) y un atributo Penetración de Armadura de -1.</description>
    </rule>
    <rule id="8499-5b1f-454f-9d7d" name="Destreza marcial" hidden="false">
      <description>Una unidad con esta regla especial puede realizar Ataques de Apoyo a sus Flancos y Retaguardia, no sólo a su frontal.</description>
    </rule>
    <rule id="a3a3-78e1-973d-5213" name="Capa de león" hidden="false">
      <description>Una miniatura con esta regla especial mejora su valor de armadura en 1 (hasta un máximo de 2+) contra ataques de disparos no mágicos.</description>
    </rule>
    <rule id="7ef4-f575-c665-cff3" name="Bendición de Lileath" hidden="false">
      <description>Una vez por turno, una miniatura con esta regla especial puede repetir una única tirada de lanzamiento fallida.</description>
    </rule>
    <rule id="ed46-c4b5-f9d0-9e76" name="Bendiciones de Asuryan" hidden="false">
      <description>Una miniatura con esta regla especial tiene una salvación especial de 5+ contra cualquier herida que haya sido causada por un ataque que tenga la regla especial Ataques flamígeros.</description>
    </rule>
    <rule id="eedd-5068-c7fb-a45b" name="Armas de Ithilmar" hidden="false">
      <description>Cuando está trabado en combate, una miniatura con esta regla especial que esté luchando con un arma de mano puede repetir cualquier resultado de 1 natural en la tirada para impactar.
Ten en cuenta que esta regla especial sólo se aplica a un arma de mano única y no mágica y no se aplica a la montura de la Miniatura (si tiene una). Si la miniatura utiliza dos armas de mano o cualquier otro tipo de arma, esta regla especial deja de aplicarse.</description>
    </rule>
    <rule id="f30b-7479-971b-3e91" name="Armadura dragón" hidden="false">
      <description>Una miniatura con esta regla especial tiene una salvación especial de 6+ contra cualquier herida sufrida. Además, un hechicero con esta regla especial puede equiparse con armadura sin penalización.</description>
    </rule>
    <rule id="5351-b016-8e02-dfa0" name="Armadura de Ithilmar/Barda de Ithilmar" hidden="false">
      <description>Una miniatura con esta regla especial puede repetir cualquier resultado de 1 al realizar chequeos de terreno peligroso. Además, un hechicero con esta regla especial puede equiparse con armadura sin penalización.</description>
    </rule>
    <rule id="7e79-86b5-bfee-0e51" name="Ejércitos del Señor de los mares" hidden="false">
      <description>Los personajes de un Ejército de Infamia de la Guarnición de la Guardia del Mar que puedan tomar un Honor Élfico sólo podrán adquirir uno de los siguientes:
Acechante sombrío
Puro de corazón
Guardia del mar</description>
    </rule>
    <rule id="77d7-d338-5c90-7db5" name="Desde la niebla" hidden="false">
      <description>Después del despliegue, pero antes de desplegar unidades con la regla especial Exploradores o mover unidades con la regla especial Vanguardia, puedes retirar inmediatamente del campo de batalla una única unidad desplegada perteneciente a tu ejército y reemplazarla en cualquier lugar dentro de tu zona de despligue.</description>
    </rule>
    <rule id="7ce5-cd73-df90-3aad" name="Desde las nubes tormentosas" hidden="false">
      <description>0-1 Escoltas celestes de Lothern cada 1000 puntos en un Ejército de Infamia de la Guarnición de la Guardia del Mar, incluyendo los Escoltas celestes adquiridos como monturas de personaje, pueden tener la regla especial Emboscadores por +10 puntos por miniatura.</description>
    </rule>
    <rule id="a590-6c3b-9325-0bfc" name="Exploradores de Viejo Mundo" hidden="false">
      <description>0-1 Unidades de Guerreros sombríos con una Potencia de unidad de 10 o menos en un Ejército de Infamia de una Guarnición de la Guardia del Mar puede tener la regla especial Emboscadores gratis.</description>
    </rule>
    <rule id="0fe6-b782-9ef0-2110" name="Orgullo de la flota" hidden="false">
      <description>Las unidades de Guardia del Mar en un Ejército de Infamia de Guarnición de la Guardia del Mar ganna la regla especial Unidad Regimental. Ademas:
0-1 Unidad de Guardia del Mar por cada 1000 puntos en un Ejército de Infamia de la Guardia del Mar puede tener la regla especial Entrenados gratis.</description>
    </rule>
  </sharedRules>
