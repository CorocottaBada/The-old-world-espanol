    <selectionEntry id="8ebd-d447-3324-51df" name="Guardia del mar de Lothern" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="b205-6d64-7da8-8c50" value="4.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="b205-6d64-7da8-8c50" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b205-6d64-7da8-8c50" type="max"/>
      </constraints>
      <rules>
        <rule id="5786-829b-0a39-88ee" name="Disciplina naval" hidden="false">
          <description>Una unidad de la Guardia de Mar de Lothern puede usar esta regla especial cuando declare una reacción de Aguantar y Disparar ante una carga. Una unidad que lo haga podrá realizar la reacción de Aguantar y Disparar independientemente de la distancia a la que esté la unidad que carga. Una vez resueltos estos disparos, la unidad cargada podrá realizar una maniobra gratuita de Reorganizar filas, tras la cual mantendrá la posición y esperará a la unidad que carga.
Las unidades que están huyendo, que ya están en combate al ser cargadas, o a las que se les haya unido un Personaje sin esta regla especial no pueden usar esta regla especial.</description>
        </rule>
      </rules>
