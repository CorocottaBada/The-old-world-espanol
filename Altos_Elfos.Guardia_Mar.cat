<catalogue id="39d4-9c30-01b3-09ad" name="Reinos de los Altos Elfos. Guarnición de la guardia del mar" revision="5" battleScribeVersion="2.03" library="false" gameSystemId="dfdc-8d68-90f9-7f0e" gameSystemRevision="36" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
