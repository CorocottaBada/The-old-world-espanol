    </selectionEntryGroup>
    <selectionEntryGroup id="1805-fe54-4f74-ce3e" name="Armas mágicas. Altos elfos. Caballería o Monstruo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e7cb-0d7f-de49-1e44" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="70c8-fbec-ee5e-036c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="642a-53f7-e50f-5864" name="Lanza estelar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="33b4-2716-9d11-29bf" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e202-b2af-9549-5bb7" type="max"/>
          </constraints>
          <profiles>
            <profile id="4584-c8bc-4c90-ded7" name="Lanza estelar" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-4</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo miniaturas cuyo tipo de tropa sea «caballería» o «monstruo». La Lanza Estelar sólo puede usarse durante un turno en el que su portador haya cargado. En turnos posteriores (o si el portador no cargó), la miniatura debe usar su arma de mano en su lugar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2b6e-b0c7-5a23-e814" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="4711-b6fe-47c2-adf3" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="eaab-e015-31e3-955b" name="Armas mágicas. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b0f-1e4d-d833-0472" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d89-e7dc-b49a-fbfd" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="61e2-7de9-4618-4f34" name="La espada de oro fulgurante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9ed8-6f2a-66ad-ba2f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e0e9-9e8e-eccd-0735" type="max"/>
          </constraints>
          <profiles>
            <profile id="0f5c-1f24-318b-f6a7" name="La espada de oro fulgurante" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques adicionales (+1D3), Ataques nágicos, Perforacorazas (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="54e9-a72d-5149-32dd" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="5608-e6ea-1522-7519" name="Ataques adicionales (+X)" hidden="false" targetId="93b1-1365-6161-7057" type="rule"/>
            <infoLink id="4172-3909-a42b-48dc" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a577-83e3-24e6-ebd4" name="Arco de Ellyrion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e966-a99f-dd5e-7096" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f2f4-128b-ab7b-0d2e" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f01-0614-ab7c-d36c" name="Arco de Ellyrion" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco de Ellyrion cuenta como un Arco de Avelorn. El portador del Arco de Ellyrion puede realizar un número de disparos igual a su atributo de Ataques, en lugar del número habitual. Esta miniatura no sufre ningún penalizador por Disparos Múltiples.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d18e-152a-e054-a2a9" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4403-8932-c56d-1162" name="Perdición de enemigos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b1f2-eefe-f2d6-2af3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4e0-9216-c8e9-f2fe" type="max"/>
          </constraints>
          <profiles>
            <profile id="fe1a-4bb3-4ed9-a740" name="Perdición de enemigos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cuando el portador de Perdición de Enemigos hace una tirada para Herir, un resultado de 4+ siempre es un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="141c-f724-b4d5-2159" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a608-4c55-e693-a789" name="Arco del navegante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2d29-c5e1-3ab1-04b4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5916-9bff-fe3b-30b8" type="max"/>
          </constraints>
          <profiles>
            <profile id="7076-1dc3-967b-e91a" name="Arco del navegante" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">5</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Aparatoso, Heridas múltiples (1D3), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco del Navegante es un Arco de Avelorn. El Arco del Navegante dispara como un Lanzavirotes, usando la regla especial «Atravesar Filas» (ver página 223 del libro de reglas de Warhammer: el Viejo Mundo).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d59a-bfee-6e02-cad6" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="fc8b-d920-58cd-2fdd" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
            <infoLink id="6ee2-0fd5-8f29-e0b1" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
            <infoLink id="8250-24c3-9311-a3ec" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="27c5-c47b-114d-9d9d" name="Arco de Avelorn" hidden="false" collective="false" import="true" targetId="120f-961c-9644-7ad3" type="selectionEntry">
              <constraints>
