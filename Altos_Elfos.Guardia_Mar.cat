                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (1D3)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo del mar Dorado sólo puede ser adquirido por miniaturas de un Ejército de Infamia de la Guarnición de la Guardia del Mar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
