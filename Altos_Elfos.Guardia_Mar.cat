          </costs>
        </selectionEntry>
        <selectionEntry id="93dc-b2b4-a258-836c" name="Filo del mar Dorado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4e83-23b3-9771-0aff" type="max"/>
