                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">36&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">6</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-3</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Aparatoso, Ataques mágicos, Mover o disparar</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Si el portador de un Jezzail saca un 1 natural al hacer una tirada para Impactar al disparar esta arma, tira inmediatamente otro 1D6. Con un resultado de 1, retíra la miniatura del portador como baja.</characteristic>
