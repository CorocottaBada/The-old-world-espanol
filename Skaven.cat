    <selectionEntry id="cf6e-85ab-94a6-3a7e" name="Rueda de muerte" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="2279-2628-0973-6c4b" type="equalTo"/>
