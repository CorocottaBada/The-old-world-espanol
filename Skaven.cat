              <profiles>
                <profile id="988b-2d15-4d55-4aa0" name="Pavés" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un pavés otorga a su portador un valor de armadura de 4+ contra ataques realizados por miniaturas enemigas que se encuentran dentro del arco frontal del portador. Sin embargo, un pavés no ofrece protección a su portador contra los ataques realizados por miniaturas enemigas que se encuentran dentro de los arcos de flanco o retaguardia del portador.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
