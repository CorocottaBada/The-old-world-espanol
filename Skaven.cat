                <profile id="158f-4be4-b0e5-9372" name="Fragmento de piedra bruja (Warpstone tokens)" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un Hechicero puede adquirir hasta tres fragmentos de piedra bruja, cada una de las cuales es de un solo uso. Antes de realizar una tirada de Lanzamiento, un Hechciero puede elegir consumir un solo Fragmento de Piedra Bruja. Por cada Fragmento consumido, pueden tirar un 1D3 adicional y añadir su resultado a su tirada de Lanzamiento. Sin embargo, por cada 1 natural que se tira, el Hechciero pierde una única Herida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
