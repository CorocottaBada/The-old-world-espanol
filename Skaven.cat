                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="cc24-a43e-c4a3-6eed" name="Mover y disparar (Move &amp; shoot)" hidden="false" targetId="2b49-fb72-106a-1e56" type="rule"/>
