    <selectionEntry id="7fcb-4d64-e682-1c3d" name="Pebetero de plaga" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="d34f-f40e-eda3-b893" name="El gran incensario" hidden="false">
          <description>Los Ataques de Golpetazo realizados por un Pebetero de Plaga representan al Gran Incensario siendo liberado para abalanzarse contra el enemigo con un efecto devastador. Cualquier Ataque de Golpetazo realizado por un Pebetero de Plaga tiene una atributo de Perforación de Armadura de -2. Además, mientras se encuentra a 3” o menos de una o más miniaturas con esta regla especial, los vapores nocivos que salen del Gran Incensario hacen que las unidades enemigas sufran un modificador de -1 en su atributo de Resistencia (hasta un mínimo de 1).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="6f1c-cc33-3c2d-6058" name="Carro pesado (Heavy chariots)" hidden="false" targetId="3af7-2847-d9c7-fb97" type="rule"/>
