                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-72&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">2 (4)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-3</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Mover o disparar</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una Catapulta, usando la regla especial ‘Bombardeo’, una plantilla de área de 5” y la Tabla de Problemas de la Catapulta. Al hacer una tirada para Herir para esta arma, una tirada natural de 6 siempre se considera un éxito, incluso si la Resistencia del objetivo es tan alta que el arma normalmente no sería capaz de herirlo.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
