          <selectionEntries>
            <selectionEntry id="6779-0308-2c7f-9fe3" name="Espada del dolor" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c879-bd4e-465d-3b6d" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="02b2-69e7-42eb-adb7" type="min"/>
              </constraints>
              <profiles>
                <profile id="53ce-f349-a8c7-e7ed" name="Espada del dolor (golpes rápidos)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques adicionales (1D6)</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Espada del Dolor tiene dos perfiles. Debes elegir cuál usará el portador al comienzo de cada ronda de combate.</characteristic>
                  </characteristics>
                </profile>
                <profile id="c0db-0117-eaba-0168" name="Espada del dolor (golpes mortales)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos (Magical attacks), Perforacorazas (1) (Armour bane), Heridas múltiples (2) (Multiple wounds).</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo Doloroso cuenta con dos perfiles. Debes escoger qué perfil usar al inicio de cada ronda de combate.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
