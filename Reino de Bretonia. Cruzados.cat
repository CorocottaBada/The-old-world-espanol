              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Cazamonstruos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Al hacer una tirada Para Herir por un impacto causado con la Espada de los Héroes, una tirada de 5+ siempre es un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
