        </selectionEntry>
        <selectionEntry id="3691-86ee-a096-d4ff" name="Virtud del ardor caballeresco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1b0d-e30b-1675-4d94" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e381-327e-b241-2c21" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f55-4e7e-9bb9-ae97" name="Virtud del ardor caballeresco" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Durante un turno en el que haya cargado, una miniatura con esta Virtud obtiene las reglas especiales Ataques Adicionales (+1D3) y Odio (a todos los enemigos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e1b9-ba7e-db13-a796" name="Ataques adicionales (+X)" hidden="false" targetId="93b1-1365-6161-7057" type="rule"/>
            <infoLink id="156a-af5e-a8e0-25a4" name="Odio (todos los enemigos) (Hatred)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="87c1-cd96-632e-b21e" name="Virtud del estoicismo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="db16-975d-bdb2-b143" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="168d-e7db-ffe2-0711" type="max"/>
          </constraints>
          <profiles>
            <profile id="57dd-7614-1470-2b35" name="Virtud del estoicismo" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud (y su unidad) puede repetir la tirada de 2D6 al realizar un chequeo de Desmoralización.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a929-1b3c-4187-93d1" name="Virtud de la justa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1389-692c-cd12-92f9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e4ff-1091-cbe5-e083" type="max"/>
          </constraints>
          <profiles>
            <profile id="3809-6be8-62f0-787a" name="Virtud de la justa" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud puede repetir cualquier tirada para Herir fallida al usar una lanza de caballería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="92b8-1620-d5f9-d183" name="Virtud del caballero impetuoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="84bc-ee93-a4cf-c4c9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="85ed-11c3-7638-9629" type="max"/>
          </constraints>
          <profiles>
            <profile id="9b93-b386-b37e-1653" name="Virtud del caballero impetuoso" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud gana la regla especial Impetuoso. Además, esta miniatura (y su unidad) aumenta su alcance máximo de carga posible en 3”. Por último, cuando esta miniatura (y su unidad) haga una tirada de Carga, puedes aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0038-15ec-108b-c4e2" name="Impetuosos (Impetuous)" hidden="false" targetId="11c7-ee78-1924-fed8" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="da9c-0cc3-1f83-8502" name="Virtud de la audacia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0a60-2a45-d3a7-f7b6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e6f0-3a60-1a71-ea20" type="max"/>
          </constraints>
          <profiles>
            <profile id="14a5-91a4-9392-b7a7" name="Virtud de la audacia" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud puede repetir cualquier tirada para Impactar fallida contra una miniatura enemiga con una Habilidad de Armas mayor que la suya.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="080f-b736-d4f7-b701" name="Virtud de la pureza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8d68-7888-775c-289a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7516-b697-8ec4-fcc4" type="max"/>
          </constraints>
          <profiles>
            <profile id="03bf-8063-e069-b2af" name="Virtud de la pureza" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud siempre se beneficia de la regla especial Bendiciones de la Dama y siempre tiene una Salvación Especial de 5+, incluso si el ejército de esta miniatura no rezó al comienzo de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bf77-f2ff-91b5-86ad" name="Bendiciones de la Dama" hidden="false" targetId="db30-ae3b-c8d8-0327" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d99f-0d5d-a9db-d930" name="Virtud de la confianza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9909-32f9-4e0c-cfe5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fbd-955e-5eea-8a89" type="max"/>
          </constraints>
          <profiles>
            <profile id="4d97-96b8-1196-2cae" name="Virtud de la confianza" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud siempre debe lanzar y aceptar desafíos (si es posible). Durante un desafío, esta miniatura puede repetir cualquier tirada para Impactar fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b34c-7084-4f3f-77eb" name="Virtud de la disciplina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6a58-d615-5fed-b654" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3c29-d44a-78ab-6e81" type="max"/>
          </constraints>
          <profiles>
            <profile id="37dc-13f9-c660-6857" name="Virtud de la disciplina" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud (y su unidad) puede marchar estando a 8” o menos de una unidad enemiga sin tener que hacer primero un chequeo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3833-b41c-15b9-3f74" name="Virtud del noble desdén" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dd74-d15d-2210-64b4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="16d5-3b0a-4105-7f0d" type="max"/>
          </constraints>
          <profiles>
            <profile id="3f09-d769-b35c-843c" name="Virtud del noble desdén" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Una miniatura con esta Virtud puede repetir las tiradas para Impactar fallidas realizadas durante la primera ronda de combate contra un enemigo equipado con armas de proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="05fd-73da-8555-46b9" name="Talismanes. Reino de Bretonia. Voto del Grial" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e8f2-a562-05a5-2f4f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b803-7db6-62d6-30c1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a748-0c64-a6fc-fa89" name="Colgante del grial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="184e-5d1f-ca02-f7f5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b8ad-2824-e75f-aa1f" type="max"/>
          </constraints>
          <profiles>
            <profile id="baa3-11fa-4d0d-80a8" name="Colgante del grial" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo miniaturas con el Voto del Grial. Un solo uso. Cuando el portador del Colgante del Grial pierda su última Herida, tira 1D6. Con una tirada de 2+, la Herida no se pierde.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="e6a2-d130-5b76-0e03" name="Talismanes. Reino de Bretonia. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f79-1cd8-50e0-93a7" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2fcc-fa6e-ab01-a00e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="adbd-06c1-d6fc-3f1c" name="Colgante de Sirienne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1ad3-28c9-4774-ecc1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0db-d039-91d1-a480" type="max"/>
          </constraints>
          <profiles>
            <profile id="3aae-5951-0362-9667" name="Colgante de Sirienne" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solamente miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. El portador es inmune a la regla especial Heridas Múltiples (X). Si el portador resulta herido por un ataque con esta regla especial, sufre una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7ffe-6538-d564-f60b" name="Talismanes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e78c-3743-27bb-3199" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b1d9-554b-9e4a-8945" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b1b8-78ad-8ffc-517d" name="Manto de la dama Elena" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2668-1826-5952-2fb1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9e12-95bb-8ad9-d93e" type="max"/>
          </constraints>
          <profiles>
            <profile id="9e81-184a-4e6f-79a4" name="Manto de la dama Elena" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador es inmune a la regla especial Ataques Envenenados. Si el portador resulta herido por un ataque con esta regla especial, el atacante debe tirar para Herir de forma normal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ce0c-d3cc-b8fd-0f87" name="Objetos hechizados. Reino de Bretonia. Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f24-9697-91b4-22cb" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf43-cae1-e7df-0017" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ecd4-3add-2570-aafb" name="Cornamenta de la gran cacería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="711b-2116-f2df-6ea9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="317d-ced9-88be-0937" type="max"/>
          </constraints>
          <profiles>
            <profile id="a8fd-3515-0912-fdc5" name="Cornamenta de la gran cacería" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Si el portador de la Cornamenta de la Gran Cacería está montado en un Caballo de Guerra con Barda o un Caballo de Guerra, él y cualquier unidad a la que se una obtienen la regla especial Mover a Través de Cobertura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cda8-321c-4625-7a1a" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c021-d5d7-527d-333d" name="Objetos hechizados. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cbf9-0ed2-3605-a60d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bff1-f312-d3a8-b364" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8c3f-386f-10f8-bef1" name="El sello de Parravon" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d487-6719-9ab8-6346" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="219c-e6a4-9e6b-c02a" type="max"/>
          </constraints>
          <profiles>
            <profile id="26cc-9835-b58d-2173" name="El sello de Parravon" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cuando el portador del Sello de Parravon hace una tirada para Impactar, una tirada de un 3+ siempre es un éxito, independientemente de la Habilidad de Armas del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0d75-303b-440a-af36" name="Cuerno de halcones de Fredemund" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8226-b491-2c8f-6c18" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c749-42a7-fac9-9630" type="max"/>
          </constraints>
          <profiles>
            <profile id="f3d5-b956-421d-9a80" name="Cuerno de halcones de Fredemund" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo Uso. Durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar usar el Cuerno de Halcones de Fredemund haciendo un chequeo de Liderazgo (usando su propio Liderazgo sin modificadores). Si pasa este chequeo, hasta la próxima subfase de Inicio del Turno, las unidades enemigas no pueden usar la regla especial de Volar (X).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="bf94-d46e-b6a2-f4fd" name="Objetos hechizados muy comunes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7468-4a9e-82cd-473b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="524f-39bd-1e5b-90f6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="95dc-9f33-c6f5-277d" name="Guantelete del desafío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6bd1-53cf-08dc-de49" type="max"/>
          </constraints>
          <profiles>
            <profile id="235a-6866-222d-d37b" name="Guantelete del desafío" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Los Desafíos lanzados por el portador de un Guantelete del Desafío no pueden ser rechazados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="790d-4ced-95f5-b975" name="Objetos arcanos. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="99a2-ab6b-e1b8-f2ce" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9a6c-b433-e09c-ca8a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6199-f6f8-270b-d72e" name="Icono de oración de Quenelles" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f6cc-1563-38f8-b71d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c090-3d1c-5fe1-cf05" type="max"/>
          </constraints>
          <profiles>
            <profile id="7a6b-9a77-8cca-3b12" name="Icono de oración de Quenelles" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Ícono de Oración de Quenelles aumenta su Alcance de Dispersión en 3”. Además, al intentar Dispersar un hechizo de Maldición, el portador del Ícono de Oración de Quenelles obtiene un modificador de +1 a su tirada para Dispersar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8424-de91-d993-60ae" name="Espejo de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="43aa-9db1-250d-5baa" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="89e3-21ff-f199-2e5d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7e07-545a-27ce-2b82" name="Espejo de plata" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. El portador del Espejo de Plata puede usarlo cuando intenta una Dispersión Arcana. Si lo hace, tira un 1D6 extra al hacer la tirada de Dispersión y descarta el resultado más bajo. Si se saca un doble 1 en dos de los dados, el portador queda Superado en Poder y el intento de Dispersar falla. Si el intento de Dispersar tiene éxito, el hechizo se disipa y el Hechicero que lo lanzó sufre un impacto de Fuerza 4 con una PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6512-66e6-f179-7a09" name="Corazón de la naturaleza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="71b7-e377-5da5-0164" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f32-e12d-7888-1fdb" type="max"/>
          </constraints>
          <profiles>
            <profile id="1cb4-4122-924e-9722" name="Corazón de la naturaleza" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Corazón de la Naturaleza puede aplicar un modificador +1 a cualquiera de sus tiradas de Lanzamiento mientras se encuentre dentro de cualquier elemento de terreno “natural”. A los efectos de esta regla, un elemento de escenografía “natural” incluye cualquier bosque o cualquier terreno difícil o peligroso (como se describe en la página 269 del reglamento Warhammer: the Old World). No incluye ninguna construcción, como muros o edificios. Antes de que comience el juego, los jugadores deben ponerse de acuerdo sobre qué características del terreno son naturales y cuáles no.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e8ad-944c-814a-3bae" name="Diadema del poder" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="adca-ba32-68c3-e1c6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01a2-7870-c52b-8c5e" type="max"/>
          </constraints>
          <profiles>
            <profile id="7b41-5fd1-ec03-0c15" name="Diadema del poder" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La Diadema de Poder solo puede ser adquirida por una miniatura en un Ejército de Infamia de Cruzados. Al intentar lanzar un Vórtice Mágico, un Proyectil Mágico o un hechizo de Asalto, el portador de la Diadema de Poder obtiene un modificador +1 a su tirada de Lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c231-8f91-7231-64e3" name="Objetos arcanos muy comunes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c032-3e4f-883a-40d6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="555c-6c6b-fbb8-2732" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6bcd-f61d-df33-5039" name="Sacramento de la Dama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b882-8d87-48ab-d38b" type="max"/>
          </constraints>
          <profiles>
            <profile id="b5e5-a917-7e55-c2fc" name="Sacramento de la Dama" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. El portador de un Sacramento de la Dama puede usarlo antes de realizar una Tirada de Lanzamiento. Si lo hace, puede aplicar un modificador de +2 a esa Tirada de Lanzamiento.
Ten en cuenta que este es un modificador al resultado de una tirada, no anula un doble natural de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="72d9-050d-896f-044b" name="Estandartes mágicos. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7eea-bbec-09f7-8e4b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5d9b-daa7-139a-d444" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d3ab-2a8b-ae5a-34df" name="Estandarte del favor de la Dama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2c6c-6170-9017-bf93" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c0d0-41ad-1028-d857" type="max"/>
          </constraints>
          <profiles>
            <profile id="b7f3-8459-bf34-63c9" name="Estandarte del favor de la Dama" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte del Favor de la Dama ignora todos los modificadores negativos a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="301a-da35-8416-a1ac" name="Estandarte de Châlons" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e944-6005-7720-8fe8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b613-a2f2-c742-3004" type="max"/>
          </constraints>
          <profiles>
            <profile id="9707-a64b-dd7c-dbf9" name="Estandarte de Châlons" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Las unidades enemigas no pueden declarar una Reacción a la Carga de Aguantar y Disparar contra una unidad que lleve el Estandarte de Châlons.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8d4b-3eae-5213-b838" name="Estandarte de la guerra honorable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1f70-d4ef-80f3-6f50" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="da4c-1d8e-07bd-a2c2" type="max"/>
          </constraints>
          <profiles>
            <profile id="0c6f-3e31-e414-b3c1" name="Estandarte de la guerra honorable" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Guerra Honorable debe repetir cualquier tirada fallida para Impactar realizada durante la primera ronda de combate cuando se enfrenta a un enemigo equipado con cualquier arma de proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b9d0-0235-74aa-c0fd" name="Estandarte de los caballeros noveles" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="99c4-3f3b-3eda-7352" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8901-1433-0668-a5dc" type="max"/>
          </constraints>
          <profiles>
            <profile id="86ca-c5ab-b88b-4535" name="Estandarte de los caballeros noveles" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las miniaturas de una unidad que lleven el Estandarte de los Caballeros Noveles tienen un modificador de +1 a su atributo de Fuerza durante el turno en el que carguen. Sin embargo, la unidad también gana la regla especial Impetuoso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4dc0-3a9c-a7e3-4988" name="Tapiz de los conquistadores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3821-72a4-1ff8-3e0f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="232a-3aec-f507-e287" type="max"/>
          </constraints>
          <profiles>
            <profile id="cf9e-3f32-3432-8ede" name="Tapiz de los conquistadores" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier estandarte enemigo capturado por una unidad que lleve el Tapiz de los Conquistadores vale 100 Puntos de Victoria como trofeo de guerra.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
