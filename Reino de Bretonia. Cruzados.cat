    <selectionEntryGroup id="df11-089f-6729-9500" name="Virtudes caballerescas. Duque, Barón o Paladín" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8a00-ed36-4b3f-4b9c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5fe6-86ed-b628-d25c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a899-042c-0df8-e0bc" name="Virtud del deber" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="09ae-812d-414c-0c77" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="96db-d581-e83b-8d2e" type="max"/>
          </constraints>
          <profiles>
            <profile id="f107-0db5-b25b-5f78" name="Virtud del deber" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Sólo Duque, Barón o Paladín. A menos que el General de tu ejército haya sido retirado del juego como baja, al calcular el Resultado del combate, este personaje puede reclamar una bonificación de +1 punto a la resolución del combate. Este personaje no puede ser General de su ejército ni unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="48fc-8c38-50f8-589e" name="Virtud del penitente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="88ef-4371-3be9-2da2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f577-a71e-26bd-238d" type="max"/>
          </constraints>
          <profiles>
            <profile id="55b2-1a39-b76c-fb3a" name="Virtud del penitente" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud obtiene la regla especial Indesmoralizable. Sin embargo, este personaje no puede unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="196d-19c9-8fe3-cb2d" name="Indesmoralizable (Unbreakable)" hidden="false" targetId="f351-e61b-a183-42e3" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1d30-e16b-4499-6df0" name="Virtud del ideal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="15c3-0599-b405-3608" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="78d1-9678-ea35-f10e" type="max"/>
          </constraints>
          <profiles>
            <profile id="ed78-f5fa-601e-5540" name="Virtud del ideal" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud tiene un modificador de +1 a su Habilidad de Armas, Iniciativa, Ataques y Liderazgo. Sin embargo, este personaje no puede ser el General de tu ejército ni unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="17cf-2272-ccca-9f00" name="Virtud de la empatía" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7bf8-dc9b-bee8-f9ac" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="72b3-aab9-ebf1-d7fa" type="max"/>
          </constraints>
          <profiles>
            <profile id="d06d-435e-2f34-572c" name="Virtud de la empatía" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud puede unirse a una unidad con la regla especial Plebeyos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
