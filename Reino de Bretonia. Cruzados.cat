        <selectionEntry id="14f7-c184-c911-ca5f" name="Estandarte de los valerosos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8b19-82ef-e440-1d05" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e257-0a63-4330-56da" type="max"/>
          </constraints>
          <profiles>
            <profile id="6d09-a322-8878-253e" name="Estandarte de los valerosos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de los Valerosos tira 3D6 cuando haga un Chequeo de Desmoralización y descarta el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8c82-498f-9899-08ef" name="Tapiz del cruzado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c26c-f30f-ee31-4768" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e32f-7d76-1089-e3dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="bb90-26f8-7eb6-b85f" name="Tapiz del cruzado" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">El Tapiz del Cruzado solo puede ser adquirido por una miniatura en un Ejército de la Infamia de los Cruzados. Una unidad que lleve el Tapiz del Cruzado obtiene la regla especial Furia Asesina.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6447-170d-d85e-762b" name="Furia asesina" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
