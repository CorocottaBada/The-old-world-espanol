            <selectionEntry id="8090-ad33-e63b-815a" name="Arma de asta" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ec44-3558-8caf-4238" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8dd8-273a-2109-1476" type="min"/>
              </constraints>
              <profiles>
                <profile id="de61-f2a6-5b9e-a696" name="Arma de asta (a una mano)" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Lucha con una fila extra</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Un Arma de Asta tiene dos perfiles. Debes elegir cuál de ellos usará la unidad al inicio de la primera Ronda de Combate (por ejemplo, la primera ronda que luche tras realizar una carga). Una miniatura que porte un Arma de Asta no puede realizar Ataques de Apoyo durante un turno en el cuál ha cargado.</characteristic>
                  </characteristics>
                </profile>
                <profile id="1ae5-2a83-babc-8058" name="Arma de asta (a dos manos)" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F+1</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Requiere ambas manos</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Un Arma de Asta tiene dos perfiles. Debes elegir cuál de ellos usará la unidad al inicio de la primera Ronda de Combate (por ejemplo, la primera ronda que luche tras realizar una carga). Una miniatura que porte un Arma de Asta no puede realizar Ataques de Apoyo durante un turno en el cuál ha cargado.</characteristic>
                  </characteristics>
                </profile>
