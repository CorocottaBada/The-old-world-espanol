                <infoLink id="5153-41a6-860a-6dcb" name="Tozudo" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
