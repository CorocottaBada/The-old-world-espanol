              <profiles>
                <profile id="3eec-e9c9-4482-b5c3" name="Cáliz de Brionne" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén dentro del Aura de Mando de esta miniatura, los personajes enemigos que intenten usar cualquier regla especial u objeto mágico que les obligue a realizar un chequeo de Liderazgo (Grito de Guerra, por ejemplo) sufren un modificador de -2 a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
