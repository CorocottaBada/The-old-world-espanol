                <characteristic name="Reglas especiales" typeId="4d01-772d-4584-b98b">Perforacorazas (2), Pellejo duro (1), Aura encantadora, Contracarga, Ataques mágicos, Golpetazo (1), Zancada veloz</characteristic>
              </characteristics>
