      <selectionEntries>
        <selectionEntry id="286a-d9cd-acc5-c985" name="Lanza del roble" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="70b5-a034-7524-5258" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f254-c0af-2011-071e" type="max"/>
          </constraints>
          <profiles>
            <profile id="6b86-28cc-e0c5-07ee" name="Lanza del roble" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Solo para miniaturas cuyo tipo de tropa es ‘caballería’ o ‘monstruo’. La Lanza del Roble solo se puede usar durante el turno en el que el portador carga. En turnos posteriores (o si el portador no cargó), la miniatura debe usar su arma de mano en su lugar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="badb-afb2-3edf-5a79" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="378c-896a-4e0e-1b4f" name="Lanza del cruzado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2b25-a701-61e3-7a16" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="168a-5193-ba8f-599e" type="max"/>
          </constraints>
          <profiles>
            <profile id="269b-447c-f5a7-a267" name="Lanza del cruzado" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (2), Carga devastadora, Odio (todos los enemigos), Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza del Cruzado solo puede ser tomada por un modelo en un Ejército de Infamia de Cruzados cuyo Tipo de Tropa sea solo ‘caballería’ o ‘monstruo’. La Lanza del Cruzado solo se puede usar durante un turno en el que el portador haya cargado. En los turnos posteriores (o si el portador no cargó), la miniatura debe usar su arma de mano en su lugar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b5dd-0cb1-3c2d-a7c8" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="a05c-81d8-b544-8160" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="d6e6-6d17-6f7a-a65a" name="Carga devastadora" hidden="false" targetId="768a-7271-1e00-6be5" type="rule"/>
            <infoLink id="6749-7701-a42c-3c09" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
