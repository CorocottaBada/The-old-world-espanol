              </constraints>
              <profiles>
                <profile id="aa9b-8c06-9c56-9022" name="Báculo de los elementos" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Si lo deseas, Lady Élisse puede descartar dos de sus hechizos generados aleatoriamente (en lugar del habitual) y en su lugar seleccionar dos hechizos identificativos del Saber del Elementalismo y/o del Saber de la Dama.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
