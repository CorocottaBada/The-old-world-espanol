                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier arma mágica equipada por una miniatura enemiga que sufra una o más heridas sin salvar por el Mangual de Fracasse es destruida y no puede ser utilizada durante el resto de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3857-7cd4-da00-0080" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0011-1aeb-0346-82cf" name="Rompeenemigos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5bde-fec7-c41f-2f10" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a3e9-9bb4-bf3a-444d" type="max"/>
          </constraints>
          <profiles>
            <profile id="f445-a9a2-4273-678a" name="Rompeenemigos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier miniatura enemiga que sufra una o más heridas no salvadas por Rompeenemigos debe hacer inmediatamente un chequeo de Resistencia. Si lo falla, la miniatura herida sufre un modificador de -1 en sus atributos de Habilidad de Armas y Ataques (hasta un mínimo de 1) hasta el final de la siguiente fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4d7f-2359-ccee-0fa0" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2014-d596-2fb7-73d9" name="Armaduras mágicas. Reino de Bretonia. Infantería o Caballería. Voto del Grial. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ba3-d675-7f1d-96a2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ae4-6e60-0ca9-7d70" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2fa9-8b57-a9c4-7d18" name="Armadura ungida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d06c-12a5-e604-e546" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f995-2cbb-4229-29f6" type="max"/>
          </constraints>
          <profiles>
            <profile id="1a09-b06d-15fb-c607" name="Armadura ungida" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas con el Voto del Grial cuyo Tipo de Tropa es ‘infantería’ o ‘caballería’. La Armadura Ungida es una armadura pesada. Además, mientras el portador tenga la Bendición de la Dama, es inmune a las reglas especiales Golpe Letal y Heridas Múltiples (X). Si el portador sufre una herida no salvada de un ataque con cualquiera de estas Reglas Especiales, pierde una única Herida. Si el portador pierde alguna vez la Bendición de la Dama, este efecto se pierde.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a2bf-e76c-5c03-813d" name="Armaduras mágicas. Reino de Bretonia. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="365c-22be-ae9e-0600" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1eca-ac80-766b-fa86" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bce8-198c-d6e6-4592" name="Coraza dorada" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="60d8-6afe-0b59-23be" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="69d4-c277-284c-0633" type="max"/>
          </constraints>
          <profiles>
            <profile id="7143-2504-1cc9-62a9" name="Coraza dorada" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Coraza Dorada es una armadura pesada. Además, su portador tiene la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0026-3e17-2725-1d4e" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
            <infoLink id="266f-add3-0acb-b318" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ab2a-eacd-443d-e58a" name="Armaduras mágicas. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4159-6f51-5628-3310" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a9d7-f349-7249-a835" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="44ff-0ede-1354-892b" name="Gran yelmo de Gromril" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c964-5c56-3e46-67f6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7dd1-2a99-b9cf-94f9" type="max"/>
          </constraints>
          <profiles>
            <profile id="f65c-028f-85d6-8cf4" name="Gran yelmo de Gromril" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador del Gran Yelmo de Gromril mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, el portador puede volver a tirar cualquier resultado natural de 1 al hacer una tirada de Salvación por Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="cc70-0304-0873-7c56" name="Objetos hechizados. Reino de Bretonia. Caballo de guerra" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e1e8-406b-50dc-64b4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="721d-def7-cf56-9445" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="673f-c098-ccda-4eab" name="Clarín del cruzado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3c8a-4a3b-8216-52e2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1f31-4bb6-356c-bedb" type="max"/>
          </constraints>
          <profiles>
            <profile id="0a50-8e70-b57d-2e05" name="Clarín del cruzado" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El Clarín del Cruzado solo puede ser adquirida por una miniatura en un Ejército de la Infamia de Cruzados que vaya montado en un Caballo de Guerra. En un turno en el que el portador del Clarín del Cruzado ha cargado, su montura y todas las monturas de la unidad a la que se ha unido tienen un modificador +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ad36-4fd2-3ddf-0634" name="Talismanes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c38-299a-2b08-e760" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d6aa-b019-451c-d78d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="461d-ada0-cc33-7133" name="La capa blanca" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1921-45c9-0941-fa02" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="202c-9afc-b6ed-b47a" type="max"/>
          </constraints>
          <profiles>
            <profile id="9c89-5068-9da7-72c3" name="La capa blanca" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Capa Blanca tiene una Salvación Especial de 5+ contra cualquier herida sufrida, y una Salvación Especial de 3+ contra cualquier herida causada por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1b5f-afee-9511-2150" name="Reloj de arena del asesino" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e21b-6c1f-fd9e-b736" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cb5f-340d-c861-3000" type="max"/>
          </constraints>
          <profiles>
            <profile id="1126-e56b-407e-ad9c" name="Reloj de arena del asesino" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Las miniaturas enemigas cuyo tipo de tropa sea ‘monstruo’ sufren un modificador de -1 a su Habilidad de Armas mientras estén en contacto peana con peana con el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4baa-ea08-2c0a-8b19" name="Talismanes muy comunes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="218a-cba8-2136-5020" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9650-dd85-6b1a-0c27" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="360e-e120-d737-7d5f" name="Amuleto de jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="481d-24fc-bc72-842b" type="max"/>
          </constraints>
          <profiles>
            <profile id="c610-eb97-6da7-1f97" name="Amuleto de jade" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador es inmune a la regla especial Golpe Letal. Si el portador recibe un Golpe Letal, se permite Salvación por Armadura y Regeneración de manera normal. Si no se salva la herida, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="af59-17a2-b7bf-8b42" name="Protector del cazador de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eb42-9484-9d47-fa09" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb6b-a7a9-027f-dd1c" name="Protector del cazador de brujas" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Una miniatura que porte un Protector del Cazador de Brujas tiene la regla especial Resistencia a la Magia (-2). Además, una vez por partida, el portador de un Protector del Cazador de Brujas puede repetir una única tirada fallida de Salvación de Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4578-fc63-ac7b-1a56" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c0e4-87cb-7010-8df1" name="Objetos hechizados. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f069-8fce-bb88-ad5c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8ab4-837f-4f8d-4dde" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="0382-08ee-066f-c63a" name="Laurel de la victoria" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b97c-e5ed-3465-5971" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ad5c-4bea-7b5b-d471" type="max"/>
          </constraints>
          <profiles>
            <profile id="98a7-436d-e933-a035" name="Laurel de la victoria" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cuando se determine el resultado de tu combate, cada herida no salvada causada por un ataque hecho por el portador del Laurel de la Victoria se cuenta como 2 puntos para el resultado del combate, en vez de 1 punto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="275d-e313-626a-fa4c" name="Manto de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0f40-169a-0432-b562" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f2c-cd61-792a-e0b4" type="max"/>
          </constraints>
          <profiles>
            <profile id="231c-5551-2e39-7adf" name="Manto de hierro" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de Hierro (y cualquier unidad a la que se haya unido) tiene una Salvación Especial de 6+ contra cualquier herida causada por una plantilla no-mágica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4ab3-1332-58ae-c080" name="Anillo de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c243-5cd5-f765-3b93" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="95d7-dfca-7cec-dc0b" type="max"/>
          </constraints>
          <profiles>
            <profile id="4cd6-2977-ec68-9ea0" name="Anillo de la fortuna" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de la Fortuna puede repetir cualquier tirada fallida para Herir realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8fd7-c723-a4e5-8aed" name="Anillo de Taal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8b18-4648-529e-af71" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8397-9b9b-ea64-afc0" type="max"/>
          </constraints>
          <profiles>
            <profile id="d475-21af-cc57-10a9" name="Anillo de Taal" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de Taal puede lanzar el hechizo Escudo de Roble del Saber de la Magia de Batalla (ver página 321 del reglamento de Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1347-3b91-3f5e-ae41" name="El cuerno de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2d98-7bef-2a02-5276" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8526-0b10-f63e-be4d" type="max"/>
          </constraints>
          <profiles>
            <profile id="0cfd-74f8-d81b-4eca" name="El cuerno de plata" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Sólo personajes con la regla especial Zancada Veloz. El portador del Cuerno de Plata (y cualquier unidad a la que se haya unido) puede repetir el 1D6 de la regla especial Zancada Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2c58-6200-99a4-c678" name="Zancada veloz" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
          </infoLinks>
