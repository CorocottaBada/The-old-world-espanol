      <selectionEntries>
        <selectionEntry id="f1cf-1813-9d73-0c41" name="Virtud de la heroicidad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="740c-0023-4f2c-9f76" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="507f-3bf1-4e97-e80a" type="max"/>
          </constraints>
          <profiles>
            <profile id="7c42-e18b-6d49-6de0" name="Virtud de la heroicidad" hidden="false" typeId="9648-dc47-9a87-0a89" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="d6df-bd6f-27e9-9338">A menos que use un arma mágica, un modelo con esta Virtud obtiene las reglas especiales Golpe Letal y Cazamonstruos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cde7-8b2f-eb42-37bb" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
