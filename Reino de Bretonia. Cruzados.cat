    <selectionEntry id="06c2-0d73-4d89-82fb" name="Profetisa" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="77d3-ce17-e7d8-32e6" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
