                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques Mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Espada de la Búsqueda tiene dos perfiles. Debes elegir cuál usará el portador al principio de cada ronda de combate.</characteristic>
              </characteristics>
            </profile>
            <profile id="546c-1782-4f3f-5673" name="Espada de la búsqueda (a dos manos)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (2), Requiere ambas manos, Golpea último</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Espada de la Búsqueda tiene dos perfiles. Debes elegir cuál usará el portador al principio de cada ronda de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
