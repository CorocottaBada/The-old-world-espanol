            <selectionEntry id="299e-4eca-449d-0824" name="Arma de asta" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="764e-f194-d4ae-3d46" type="max"/>
