            <profile id="66a5-4d62-f362-de35" name="Virtud del ideal" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud tiene un modificador de +1 a su Habilidad de Armas, Iniciativa, Ataques y Liderazgo. Sin embargo, este personaje no puede ser el General de tu ejército ni unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
