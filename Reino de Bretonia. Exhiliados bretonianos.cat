              <profiles>
                <profile id="bbd0-f0c7-14ff-8d3b" name="Bombarda" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">48&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">8</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-3</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (2), Disparo de cañón, Aparatoso, Mover o disparar, Heridas múltiples (1D3+1)</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como un cañón, usando la regla especial ‘Fuego de cañón’. Esta arma utiliza la Tabla de Problemas de la Bombarda.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="5742-14fa-978e-00bb" name="Tabla de problemas de la Bombarda" hidden="false">
                  <description>Tabla de Problemas de la Bombarda
1D6 Resultado
1 Destruida: La miniatura se destruye e inmediatamente se retira del juego.
2-3 Avería: La tripulación pierde inmediatamente una herida y la miniatura no dispara este turno.
4-5 Pffft: La miniatura no dispara esta ronda.
6 Boom!:Esta arma dispara este turno, como si se hubiera sacado un ‘2’ en los dados de Artillería, en lugar de un ‘Problema’. Sin embargo, tomará algún tiempo enderezar el arma derribada. Esta arma no puede disparar durante la siguiente ronda.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="3507-9490-7d40-100b" name="Disparo de cañón" hidden="false" targetId="82ea-9e9a-631d-9bae" type="rule"/>
