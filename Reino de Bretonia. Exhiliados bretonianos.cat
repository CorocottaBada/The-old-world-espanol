                      </constraints>
                      <rules>
                        <rule id="029d-adb2-c0ac-72b6" name="Tríptico bendecido" hidden="false">
                          <description>Una unidad que contiene una miniatura equipada con un Tríptico Bendecido obtiene la regla especial Tozudo.</description>
                        </rule>
                      </rules>
                      <infoLinks>
