            <selectionEntry id="d86b-069c-32f4-9c0a" name="Trebuchet" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cfc3-cfef-cee1-e4f6" type="min"/>
