          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ef33-6b47-bfeb-ae18" name="Virtud de la justa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1e72-ad3a-a128-6106" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="00a6-2fdc-f88f-34c5" type="max"/>
          </constraints>
          <profiles>
            <profile id="bbf9-0e8b-6c57-1df8" name="Virtud de la justa" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud puede repetir cualquier tirada para Herir fallida al usar una lanza de caballería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3e75-d6c6-da24-335a" name="Virtud del caballero impetuoso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3077-f6bf-aa98-e3cb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c7a-1ac6-c61d-f7ce" type="max"/>
          </constraints>
          <profiles>
            <profile id="8850-b743-30e7-197b" name="Virtud del caballero impetuoso" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud gana la regla especial Impetuoso. Además, esta miniatura (y su unidad) aumenta su alcance máximo de carga posible en 3”. Por último, cuando esta miniatura (y su unidad) haga una tirada de Carga, puedes aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ca9e-161a-b46f-8635" name="Impetuosos (Impetuous)" hidden="false" targetId="11c7-ee78-1924-fed8" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b74e-22a3-3137-ee95" name="Virtud de la audacia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="05e6-3749-bcaf-7e7c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2eb8-098e-d0f2-2017" type="max"/>
          </constraints>
          <profiles>
            <profile id="2686-bd2d-d6dc-8c22" name="Virtud de la audacia" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud puede repetir cualquier tirada para Impactar fallida contra una miniatura enemiga con una Habilidad de Armas mayor que la suya.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fd59-3b0a-c32d-d75e" name="Virtud de la pureza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1b67-4d7d-6cf5-53d5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="901a-36ee-82f9-aba5" type="max"/>
          </constraints>
          <profiles>
            <profile id="d1ee-8a91-6f1c-a62b" name="Virtud de la pureza" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud siempre se beneficia de la regla especial Bendiciones de la Dama y siempre tiene una Salvación Especial de 5+, incluso si el ejército de esta miniatura no rezó al comienzo de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9c13-e6ba-2698-95e5" name="Bendiciones de la Dama" hidden="false" targetId="db4f-ac8d-c5c0-835e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5efd-c61c-7bf0-b9cd" name="Virtud de la confianza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3532-3e5d-6876-161c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1c7d-100c-5753-52ce" type="max"/>
          </constraints>
          <profiles>
            <profile id="96dd-9ba6-6f1c-e04d" name="Virtud de la confianza" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud siempre debe lanzar y aceptar desafíos (si es posible). Durante un desafío, esta miniatura puede repetir cualquier tirada para Impactar fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f4dd-e9dc-59cd-080d" name="Virtud de la disciplina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ae30-183e-1193-26b1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0465-d7f8-bb37-4ad3" type="max"/>
          </constraints>
          <profiles>
            <profile id="07b4-c78f-d1ec-fdfd" name="Virtud de la disciplina" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud (y su unidad) puede marchar estando a 8” o menos de una unidad enemiga sin tener que hacer primero un chequeo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2e44-e414-9b79-7019" name="Virtud del noble desdén" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5cbd-06e7-8bd4-67ad" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="41aa-e47a-7464-be13" type="max"/>
          </constraints>
          <profiles>
            <profile id="9ec4-9bb4-e16b-45ae" name="Virtud del noble desdén" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Una miniatura con esta Virtud puede repetir las tiradas para Impactar fallidas realizadas durante la primera ronda de combate contra un enemigo equipado con armas de proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d170-05c3-3007-6bfa" name="Talismanes. Reino de Bretonia. Voto del Grial" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0964-58bb-c4d8-d9f2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef08-a586-7705-9536" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="75e5-6895-193d-7ba9" name="Colgante del grial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8fbc-05d9-eacc-5c51" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e560-28dc-4a0d-db3b" type="max"/>
          </constraints>
          <profiles>
            <profile id="8182-c2c1-e7b1-dd66" name="Colgante del grial" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo miniaturas con el Voto del Grial. Un solo uso. Cuando el portador del Colgante del Grial pierda su última Herida, tira 1D6. Con una tirada de 2+, la Herida no se pierde.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f8fc-b6d1-e3e7-8542" name="Talismanes. Reino de Bretonia. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7add-3be7-1b4a-1ae5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d9cc-eb6d-ae73-540d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ff97-5631-b39a-c2f1" name="Colgante de Sirienne" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e43c-8a13-82f1-2681" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8a4c-1214-2bd9-86a0" type="max"/>
          </constraints>
          <profiles>
            <profile id="4536-d26b-1f62-8255" name="Colgante de Sirienne" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solamente miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. El portador es inmune a la regla especial Heridas Múltiples (X). Si el portador resulta herido por un ataque con esta regla especial, sufre una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a916-74be-c3f6-bfe7" name="Talismanes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="994c-7b10-828e-befd" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="81c9-2b6c-8015-4e04" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="889f-5818-f14c-f5c7" name="Manto de la dama Elena" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8098-218e-25af-e3a2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4c55-95a3-a1c1-3af6" type="max"/>
          </constraints>
          <profiles>
            <profile id="ca0a-fb87-0c10-7d13" name="Manto de la dama Elena" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador es inmune a la regla especial Ataques Envenenados. Si el portador resulta herido por un ataque con esta regla especial, el atacante debe tirar para Herir de forma normal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="15da-485d-63cf-7ed2" name="Reliquia de la suerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8c98-c41e-c325-1936" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4a22-516b-5816-ad51" type="max"/>
          </constraints>
          <profiles>
            <profile id="e872-27d2-12bd-038f" name="Reliquia de la suerte" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Una reliquia de la suerte solo puede ser adquirida por una miniatura en un Ejército de la Infamia de Exiliados Bretonianos. Una vez por ronda, el portador de la Reliquia de la Suerte puede repetir una única tirada fallida para Impactar, para Herir, de una salvación por armadura o de una Salvación Especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="04cf-7bfb-2d8c-92e8" name="Objetos hechizados. Reino de Bretonia. Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="679e-0933-be5a-584d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9ee-27f1-580c-ad90" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="0c87-cc7c-5d4c-93a6" name="Cornamenta de la gran cacería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="691c-7f76-6a34-b1cc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="be54-a1a8-676f-8b54" type="max"/>
          </constraints>
          <profiles>
            <profile id="d6f1-efac-61a3-495a" name="Cornamenta de la gran cacería" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Si el portador de la Cornamenta de la Gran Cacería está montado en un Caballo de Guerra con Barda o un Caballo de Guerra, él y cualquier unidad a la que se una obtienen la regla especial Mover a Través de Cobertura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a375-702d-0e71-2943" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7490-2ee8-74e5-ad8e" name="Objetos hechizados. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b7f6-8c2a-88c4-9dd0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6b32-525e-fb22-abf3" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2ed7-19e5-ded0-635c" name="El sello de Parravon" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8a6c-0470-999e-7978" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d4db-55dc-8b50-01e4" type="max"/>
          </constraints>
          <profiles>
            <profile id="481b-8dd8-b5c3-b1ee" name="El sello de Parravon" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cuando el portador del Sello de Parravon hace una tirada para Impactar, una tirada de un 3+ siempre es un éxito, independientemente de la Habilidad de Armas del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dfbe-1d4c-e6a2-c304" name="Cuerno de halcones de Fredemund" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bb1a-b137-8ea2-10db" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3322-f448-bd2b-6a0f" type="max"/>
          </constraints>
          <profiles>
            <profile id="ac26-0da4-0d21-47ed" name="Cuerno de halcones de Fredemund" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo Uso. Durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar usar el Cuerno de Halcones de Fredemund haciendo un chequeo de Liderazgo (usando su propio Liderazgo sin modificadores). Si pasa este chequeo, hasta la próxima subfase de Inicio del Turno, las unidades enemigas no pueden usar la regla especial de Volar (X).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="569a-1816-4969-ccb6" name="Vial de aliento de dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9e95-369b-4742-8273" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b7f5-9496-37eb-734c" type="max"/>
          </constraints>
          <profiles>
            <profile id="52c3-d530-29b6-9b06" name="Vial de aliento de dragón" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un Vial de Aliento de Dragón solo puede ser adquirido por una miniatura en un Ejército de Infamia de Exiliados Bretonianos. Un solo uso. El Vial de Aliento de Dragón es un Arma de Aliento con el siguiente perfil:</characteristic>
              </characteristics>
            </profile>
            <profile id="e18d-8bb8-31c2-56d9" name="Vial de aliento de dragón" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">N/A</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Arma de aliento, Ataques flamígeros, Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="122a-52ee-64a1-9324" name="Arma de aliento" hidden="false" targetId="28ba-f733-cc16-d9e7" type="rule"/>
            <infoLink id="3f65-aed1-2e3d-c7ea" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="1143-abf4-c80f-8534" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4aa8-8faf-a10f-0f22" name="Objetos hechizados muy comunes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="227e-da58-4e4d-d6a4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a705-9aae-7fdd-6f6f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2447-5295-2773-ede6" name="Guantelete del desafío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d205-0896-c4fc-6009" type="max"/>
          </constraints>
          <profiles>
            <profile id="bca9-1654-6800-399f" name="Guantelete del desafío" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Los Desafíos lanzados por el portador de un Guantelete del Desafío no pueden ser rechazados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="cbce-c52a-d9e7-93fd" name="Objetos arcanos. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bc2f-196b-6957-e1a3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f9dc-feb9-2594-918d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="11f1-7823-9105-326d" name="Icono de oración de Quenelles" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7e74-96aa-c490-85ba" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0e77-ad86-c619-2576" type="max"/>
          </constraints>
          <profiles>
            <profile id="359d-7e3f-13a0-a08e" name="Icono de oración de Quenelles" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Ícono de Oración de Quenelles aumenta su Alcance de Dispersión en 3”. Además, al intentar Dispersar un hechizo de Maldición, el portador del Ícono de Oración de Quenelles obtiene un modificador de +1 a su tirada para Dispersar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5b73-34ce-7e7a-7036" name="Espejo de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="72d4-e6bf-cf03-c7cd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f5b2-94b3-f582-d81d" type="max"/>
          </constraints>
          <profiles>
            <profile id="0109-3554-f89b-b8f0" name="Espejo de plata" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. El portador del Espejo de Plata puede usarlo cuando intenta una Dispersión Arcana. Si lo hace, tira un 1D6 extra al hacer la tirada de Dispersión y descarta el resultado más bajo. Si se saca un doble 1 en dos de los dados, el portador queda Superado en Poder y el intento de Dispersar falla. Si el intento de Dispersar tiene éxito, el hechizo se disipa y el Hechicero que lo lanzó sufre un impacto de Fuerza 4 con una PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="00f0-30a5-5141-4902" name="Corazón de la naturaleza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d498-9c39-ef9d-269e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df5d-0107-f827-92dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="554e-1417-248b-f909" name="Corazón de la naturaleza" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Corazón de la Naturaleza puede aplicar un modificador +1 a cualquiera de sus tiradas de Lanzamiento mientras se encuentre dentro de cualquier elemento de terreno “natural”. A los efectos de esta regla, un elemento de escenografía “natural” incluye cualquier bosque o cualquier terreno difícil o peligroso (como se describe en la página 269 del reglamento Warhammer: the Old World). No incluye ninguna construcción, como muros o edificios. Antes de que comience el juego, los jugadores deben ponerse de acuerdo sobre qué características del terreno son naturales y cuáles no.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="920a-0846-453f-b1b2" name="Varita de fogonazos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="06a7-89b2-9380-00d1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b817-1fef-8d91-acde" type="max"/>
          </constraints>
          <profiles>
            <profile id="12f2-7d78-bdfa-4529" name="Varita de fogonazos" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La Varita de Fogonazos solo puede ser tomada por una miniatura en un Ejército de Infamia de Exiliados Bretonianos. Un solo uso. El portador de la Varita de Fogonazos puede lanzar el hechizo Bola de Fuego del Saber de la Magia de Batalla (ver página 321 del reglamento de Warhammer: the Old World) como un Hechizo Vinculado con un Nivel de Energía 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9111-810a-1cf6-c2d2" name="Objetos arcanos muy comunes. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="24b9-31a1-9c92-9bd8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01b5-b5cf-9342-c2d2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cb3a-fcd8-07a2-2f88" name="Sacramento de la Dama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9515-2fc8-52e2-4a68" type="max"/>
          </constraints>
          <profiles>
            <profile id="c4ad-807e-84c8-876f" name="Sacramento de la Dama" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. El portador de un Sacramento de la Dama puede usarlo antes de realizar una Tirada de Lanzamiento. Si lo hace, puede aplicar un modificador de +2 a esa Tirada de Lanzamiento.
Ten en cuenta que este es un modificador al resultado de una tirada, no anula un doble natural de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f578-4c9c-ad09-326e" name="Estandartes mágicos. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fb98-41a7-50a1-18cb" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e0da-cd05-19fb-ecc1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e032-3071-81fe-6289" name="Estandarte del favor de la Dama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="747d-0759-b28d-3833" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eeb3-ec42-a8fd-e0a8" type="max"/>
          </constraints>
          <profiles>
            <profile id="4050-9cc6-dce1-2849" name="Estandarte del favor de la Dama" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte del Favor de la Dama ignora todos los modificadores negativos a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a6c1-672c-9d36-5169" name="Estandarte de Châlons" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3e3c-9c76-7019-3f99" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="abf3-0d49-07c9-edb0" type="max"/>
          </constraints>
          <profiles>
            <profile id="a34b-6d08-96e3-aabc" name="Estandarte de Châlons" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Las unidades enemigas no pueden declarar una Reacción a la Carga de Aguantar y Disparar contra una unidad que lleve el Estandarte de Châlons.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="05a6-962e-3e5c-3946" name="Estandarte de la guerra honorable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6333-aa31-051d-a133" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3ab0-8fcf-d465-3ae0" type="max"/>
          </constraints>
          <profiles>
            <profile id="28c2-6168-a903-90bf" name="Estandarte de la guerra honorable" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Guerra Honorable debe repetir cualquier tirada fallida para Impactar realizada durante la primera ronda de combate cuando se enfrenta a un enemigo equipado con cualquier arma de proyectiles.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="53b5-8365-e03f-3f18" name="Estandarte de los caballeros noveles" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7831-bde5-dc90-fef8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a512-4e40-51f4-c4c8" type="max"/>
          </constraints>
          <profiles>
            <profile id="aa64-4167-4009-fc2c" name="Estandarte de los caballeros noveles" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las miniaturas de una unidad que lleven el Estandarte de los Caballeros Noveles tienen un modificador de +1 a su atributo de Fuerza durante el turno en el que carguen. Sin embargo, la unidad también gana la regla especial Impetuoso.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9fae-e992-e1bc-d45c" name="Tapiz de los conquistadores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7287-1c78-d2e6-99d2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ce2b-6592-0c8c-cf27" type="max"/>
          </constraints>
          <profiles>
            <profile id="a9a2-1639-948a-1616" name="Tapiz de los conquistadores" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier estandarte enemigo capturado por una unidad que lleve el Tapiz de los Conquistadores vale 100 Puntos de Victoria como trofeo de guerra.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="923c-4d90-4d40-b6c4" name="Estandarte de los valerosos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2e17-b8d6-f279-5554" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2c25-03d5-4138-07fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="bf0d-2534-8e00-d179" name="Estandarte de los valerosos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de los Valerosos tira 3D6 cuando haga un Chequeo de Desmoralización y descarta el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0ad0-3600-16d7-0225" name="Estandarte del caballero ferviente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7bf5-9336-93ad-e6cd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5615-04e5-c21c-ec7e" type="max"/>
          </constraints>
          <profiles>
            <profile id="9214-8986-cf24-47c5" name="Estandarte del caballero ferviente" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">El Estandarte del Caballero Ferviente solo puede ser adquirido por una miniatura en un Ejército de la Infamia de Exiliados Bretonianos. Una unidad que lleve el Estandarte del Caballero Ferviente obtiene la regla especial Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cf69-ad3c-0c29-66c8" name="Vanguardia" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="149b-e568-af7d-87e7" name="Armas mágicas. Reino de Bretonia. Caballería o Monstruo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de50-0586-6f85-5ea8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b79b-2f10-79b0-cd0a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ed22-93c5-91e4-03a1" name="Lanza del roble" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ce2-ae36-566d-e1d8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eb05-8e4c-cc9f-abb4" type="max"/>
          </constraints>
          <profiles>
            <profile id="a119-4172-d4df-18c5" name="Lanza del roble" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Solo para miniaturas cuyo tipo de tropa es ‘caballería’ o ‘monstruo’. La Lanza del Roble solo se puede usar durante el turno en el que el portador carga. En turnos posteriores (o si el portador no cargó), la miniatura debe usar su arma de mano en su lugar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7777-4202-87c3-a74e" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c0f3-0deb-919b-0dbc" name="Armas mágicas. Reino de Bretonia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fa2e-86e5-50b4-c76d" type="max"/>
