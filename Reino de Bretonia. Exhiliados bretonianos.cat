    <selectionEntryGroup id="8c4e-20ac-a9a3-4703" name="Armaduras mágicas. Reino de Bretonia. Infantería o Caballería. Voto del Grial. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2276-0483-90ba-e3a5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dac4-5d6a-c4a3-1bd8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="857c-9adb-6fa2-a975" name="Armadura ungida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="589b-ef80-4551-5162" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c84e-2763-3e58-eba5" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a53-95a5-a71f-5641" name="Armadura ungida" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas con el Voto del Grial cuyo Tipo de Tropa es ‘infantería’ o ‘caballería’. La Armadura Ungida es una armadura pesada. Además, mientras el portador tenga la Bendición de la Dama, es inmune a las reglas especiales Golpe Letal y Heridas Múltiples (X). Si el portador sufre una herida no salvada de un ataque con cualquiera de estas Reglas Especiales, pierde una única Herida. Si el portador pierde alguna vez la Bendición de la Dama, este efecto se pierde.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3522-ac99-7310-59cb" name="Armaduras mágicas. Reino de Bretonia. Armadura" hidden="false" collective="false" import="true">
