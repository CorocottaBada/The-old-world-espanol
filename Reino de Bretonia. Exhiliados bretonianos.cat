                </profile>
              </profiles>
              <rules>
                <rule id="bde8-15f2-d0dc-b33d" name="Monje del Grial" hidden="false">
                  <description>Un Monje del Grial es una miniatura de Grupo de Mando que sigue todas las reglas de un Campeón. En otras palabras, una unidad que contiene tanto a un Oficial como a un Monje del Grial contiene dos Campeones.</description>
                </rule>
              </rules>
