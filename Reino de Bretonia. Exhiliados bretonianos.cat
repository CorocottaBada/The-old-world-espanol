      </constraints>
      <rules>
        <rule id="7b51-a27e-413b-f02d" name="El Matasierpes" hidden="false">
          <description>Si Sir Cecil Gastonne mata a una miniatura enemiga cuyo Tipo de Tropa sea ‘infantería monstruosa’, ‘caballería monstruosa’, ‘criatura monstruosa’ o ‘coloso’ durante cualquier fase de Combate, gana la regla especial Terror para el resto de la partida.</description>
        </rule>
      </rules>
      <infoLinks>
