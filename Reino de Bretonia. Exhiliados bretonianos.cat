              </constraints>
              <profiles>
                <profile id="e844-e931-bb01-4131" name="Trebuchet" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-72&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5 (10)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-4)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Objeto inmóvil, Mover o disparar, Heridas múltiples (1D3+1).</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una Catapulta, usando la regla especial “Bombardeo”, la Plantilla de Área Pequeña de 3’’ y la tabla de Problemas de la Catapulta. La regla especial Heridas Múltiples (1D3+1) solamente se aplica a una única miniatura bajo el agujero central de la plantilla de área.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="40eb-84c6-eece-f043" name="Objeto inmóvil" hidden="false">
                  <description>Una vez que se ha colocado un Trebuchet en el campo de batalla durante el despliegue, su dotación no puede moverlo durante la subfase de Restos de Movimientos.
Ten en cuenta que un Trebuchet aún puede girar libremente en cualquier momento durante su turno (para enfrentarse mejor al enemigo) y puede realizar un movimiento de Presionar normalmente.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="5325-a475-f0aa-a60a" name="Bombardeo" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
                <infoLink id="34c0-9d6b-06e9-05a9" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="8f5e-6de5-54c8-d9f2" name="Mover o disparar" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="4eec-2d07-4c6b-881c" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
