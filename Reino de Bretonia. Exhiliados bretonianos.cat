      <selectionEntries>
        <selectionEntry id="ccce-3a38-6d43-9514" name="Virtud del deber" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3646-9ed0-c1ac-5840" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c103-8e83-d451-d074" type="max"/>
          </constraints>
          <profiles>
            <profile id="e9e5-64d7-0992-06e2" name="Virtud del deber" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Sólo Duque, Barón o Paladín. A menos que el General de tu ejército haya sido retirado del juego como baja, al calcular el Resultado del combate, este personaje puede reclamar una bonificación de +1 punto a la resolución del combate. Este personaje no puede ser General de su ejército ni unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f3c0-bf7c-010b-39ef" name="Virtud del penitente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6602-fe05-e67c-8b61" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d278-6af5-aadf-ffa7" type="max"/>
          </constraints>
          <profiles>
            <profile id="9057-f530-095e-8d99" name="Virtud del penitente" hidden="false" typeId="5de6-c87b-d655-f506" typeName="Virtud caballeresca">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud obtiene la regla especial Indesmoralizable. Sin embargo, este personaje no puede unirse a una unidad amiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8081-d4d2-591a-f86c" name="Indesmoralizable (Unbreakable)" hidden="false" targetId="f351-e61b-a183-42e3" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1db2-b01f-fd33-9415" name="Virtud del ideal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="788c-de3b-387b-31ec" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d649-9a6a-75fd-0758" type="max"/>
          </constraints>
