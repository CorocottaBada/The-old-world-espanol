              <characteristics>
                <characteristic name="Reglas especiales" typeId="1216-6e0e-3b9c-6e8c">Sólo para Duque, Barón o Paladín. Un personaje con esta Virtud puede unirse a una unidad con la regla especial Plebeyos.</characteristic>
