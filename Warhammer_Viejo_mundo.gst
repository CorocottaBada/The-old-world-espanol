        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Aparatoso, Mover o disparar, Necesita más clavos</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Los cañónes (de cualquier tipo) no usan la Habilidad de Proyectiles de su dotación al disparar metralla. En su lugar, disparan usando la regla especial Necesita más clavos. Esta arma utiliza la Tabla de Problemas de Armas con Pólvora.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
</gameSystem>