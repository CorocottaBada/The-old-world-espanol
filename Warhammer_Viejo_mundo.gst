          </constraints>
          <profiles>
            <profile id="0885-80dc-eb9c-f31f" name="Estandarte de guerra" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando se calcule su resultado del combate, la unidad que lleve el Estandarte de Guerra puede reclamar un bonificador adicional de +1 punto al resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
