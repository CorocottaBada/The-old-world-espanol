              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Hierro Meteórico concede al portador un valor de armadura de 5+ no mejorable por ningún medio. Sin embargo, tampoco puede reducirse este valor de armadura de ninguna forma.</characteristic>
              </characteristics>
