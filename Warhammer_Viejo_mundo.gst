    <profile id="2abc-e406-2088-d299" name="Catapulta" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-60&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4 (8)</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-3)</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Mover o disparar, Heridas múltiples (1D3+1)</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma no usa la Habilidad de Proyectiles de su dotación. En su lugar, dispara usando la regla especial Bombardeo. Esta arma utiliza una plantilla de área de 3” y la Tabla de Problemas de disparo de la Catapulta. La regla especial de Heridas Múltiples (1D3+1) se aplica solo a una única miniatura cuya peana se encuentra debajo del orificio central de la plantilla de área.</characteristic>
      </characteristics>
    </profile>
    <profile id="e29a-165c-0196-caf2" name="Cañón" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">48&quot;</characteristic>
        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">8</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (2), Disparo de cañón, Aparatoso, Mover o disparar, Heridas múltiples (1D3)</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Los cañones (de cualquier tipo) no usan la Habilidad de Proyectiles de su dotación. En lugar de ello, disparan usando la regla especial Disparo de Cañón, que usa la Tabla de Fallos de Disparos con Pólvora.</characteristic>
      </characteristics>
    </profile>
    <profile id="e5c0-930d-2bd0-017a" name="Gran cañón" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
