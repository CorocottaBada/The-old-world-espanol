            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac75-7e24-d46f-e5ab" type="max"/>
          </constraints>
          <profiles>
            <profile id="4e5b-1cc0-8b6b-b4e2" name="Tótem de la ira" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Durante un turno en el que cargó, las miniaturas dentro de una unidad que porte el Tótem de la Ira mejoran la característica de Penetración de Armadura de sus armas en 1, y pueden repetir cualquier Tirada para Herir de un 1 natural.</characteristic>
              </characteristics>
            </profile>
