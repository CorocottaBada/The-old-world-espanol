                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Plata es una armadura que concede al portador un valor de armadura de 3+ que no puede mejorarse de ningún modo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
