              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Protegetripas de las Fauces es una armadura pesada. Además, por cada herida no salvada que el portador cause durante un desafío, recupera una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
