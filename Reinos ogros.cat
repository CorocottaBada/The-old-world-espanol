                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">24&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (2), Aparatoso, Heridas múltiples (2)</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Un cañón sueltafuegos tiene dos perfiles que representan sus dos modos de disparo. Si el resultado para Impactar es exitoso cuando dispare un tiro disperso, el cañón sueltafuegos causa 1D3 impactos a la unidad enemiga objetivo en lugar del único habitual.</characteristic>
                  </characteristics>
                </profile>
                <profile id="5bc7-9d34-edbd-83ea" name="Cañón sueltafuego (Tiro disperso)" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
