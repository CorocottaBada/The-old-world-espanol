          <profiles>
            <profile id="8fb7-7a8a-1da0-4b18" name="Tumbagigantes" hidden="false" typeId="f63c-f142-d473-3a59" typeName="Sobrenombre">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="aff7-f32e-829d-c881">Este personaje (pero no su montura) tiene un bonificador de +1 a su atributo de fuerza. Sin embargo, este personaje no puede rechazar un desafío y ni él ni la unidad a la que se haya unido pueden declarar “Huir” como reacción a la carga.</characteristic>
              </characteristics>
