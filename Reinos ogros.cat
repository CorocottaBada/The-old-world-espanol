        </infoLink>
        <infoLink id="9f99-c6cf-e94b-9de1" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
        <infoLink id="815d-fcd4-8009-4628" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
        <infoLink id="7fd4-466d-6ada-2004" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
