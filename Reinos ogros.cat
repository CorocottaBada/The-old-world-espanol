          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="aa9c-bb78-cb86-952c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e28-b2ec-742e-8541" type="max"/>
          </constraints>
          <profiles>
            <profile id="5698-fbf5-5480-91ca" name="Armadura de mastodonte" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Mastodonte es una armadura pesada. Además, su portador obtiene una tirada de Salvación Especial de 6+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b598-5671-2388-19bc" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b480-a9e2-f5b5-125e" name="Talismanes. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ccb9-f5ea-dd3a-7725" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bccf-d0c6-a9c8-02c1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="1daf-cc41-cdb4-a7b3" name="Cacho de brillamucho" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f6dd-74fc-707a-d34c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9860-39c7-5cc0-3827" type="max"/>
          </constraints>
          <profiles>
            <profile id="38cc-8ea1-086e-a056" name="Cacho de brillamucho" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Cacho de Brillamucho le otorga a su portador una Salvación Especial de 4+ contra cualquier herida sufrida. Sin embargo, si se obtiene un 1 natural al tirar esta salvación, el cacho de brillamucho es destruido y no puede volver a ser usado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="23d2-e752-798c-684c" name="Talismanes muy comunes. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="74e0-14ad-a0fd-9af3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5d35-0334-891f-e125" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7802-9dc0-517e-d414" name="Azabache catayano" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="49f5-7d37-d476-c671" type="max"/>
          </constraints>
          <profiles>
            <profile id="62e7-d04e-2b9f-161c" name="Azabache catayano" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Azabache Catayano le otorga a su portador una Salvación Especial de 6+ contra cualquier herida sufrida que haya sido causada por un Proyectil Mágico, un Vórtice mágico o un hechizo de Asalto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="30a8-3ddb-b23a-1be9" name="Estandartes mágicos. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a9b6-c393-4207-c08c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5add-aeac-aa55-2921" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d758-f40e-4fa0-1997" name="Estandarte de los toros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6f51-5fdc-bab5-7cd7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf9a-ee3b-5100-fdd8" type="max"/>
          </constraints>
          <profiles>
            <profile id="fb15-d8ae-57e1-2012" name="Estandarte de los toros" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de los Toros puede repetir cualquier tirada fallida para Herir cuando resuelva los impactos por carga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dd7a-8e9b-07fd-cd43" name="Estandarte pieldedragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6f77-e26d-2cba-5aa2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2079-4a14-4476-dc57" type="max"/>
          </constraints>
          <profiles>
            <profile id="8a59-a723-912c-83f3" name="Estandarte pieldedragón" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte Pieldedragón puede repetir las tiradas para Impactar con un resultado natural de 1. Además, la unidad que porte el estandarte Pieldedragón obtiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e0cc-8fd0-07f6-b879" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="99b8-c2f9-1c22-49c7" name="Tótem caníbal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8a60-8c86-832b-5185" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4b3-596c-f84d-2d09" type="max"/>
          </constraints>
          <profiles>
            <profile id="af6f-81e3-3ea0-2c99" name="Tótem caníbal" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tótem Caníbal obtiene la regla especial regeneración (5+), pero solamente puede tirar un único 1D6 cuando haga una tirada de perseguir (en lugar de los 2D6 habituales).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="cf27-0801-ac26-b26c" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7ad5-d7fa-85c0-6e76" name="Fauces rúnicas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f47-ce0c-ca17-f8ee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dc43-d77f-205c-3dff" type="max"/>
          </constraints>
          <profiles>
            <profile id="354f-487c-ef48-5e90" name="Fauces rúnicas" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando un Hechicero enemigo elige como objetivo de su hechizo una unidad que porte las Fauces Rúnicas, tira 1D6. Con un resultado de 3+, el jugador que controle al Hechicero debe elegir otro objetivo. Si no hay ningún otro objetivo viable al alcance, el hechizo no puede ser lanzado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0f31-3195-333b-ef34" name="Objetos hechizados. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="da7b-7c70-e97f-b36a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="97ae-6e0d-a323-1be0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="025c-b6d4-5c29-de93" name="León de jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3e23-fd72-2bc4-a77e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dcb9-5e6b-3788-1686" type="max"/>
          </constraints>
          <profiles>
            <profile id="4c22-be02-688f-0836" name="León de jade" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del León de Jade y su unidad pueden repetir cualquier chequeo fallido de Miedo, Pánico o de Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="305b-f517-d177-268f" name="Objetos hechizados muy comunes. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1bf2-3081-0003-f7f3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b472-6c15-d2c2-c72d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b698-f975-76ef-7137" name="Cicatrices asustadiablos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e2dd-b241-116a-98a0" type="max"/>
          </constraints>
          <profiles>
            <profile id="0945-3986-5aa8-8343" name="Cicatrices asustadiablos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de las Cicatrices Asustadiablos obtiene la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d221-c26f-b22e-fca7" name="Terror (Terror)" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7e2d-b9e7-4ab0-c5ff" name="Ramita de laurel" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c126-c5ee-38af-2962" type="max"/>
          </constraints>
          <profiles>
            <profile id="2d90-8b05-bf0a-73ae" name="Ramita de laurel" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador de la Ramita de Laurel y su unidad pueden repetir los 2D6 cuando hagan un chequeo de desmoralización.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0e11-7247-c179-4070" name="Objetos arcanos. Reinos ogros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="afd4-4439-50e5-e032" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0688-2e3d-df82-0ff5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6c2d-fbfc-5c8a-3d8a" name="Recetario halfling" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="97d4-014e-c5cd-8ef7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="99ae-9f8c-2f2e-e8b1" type="max"/>
          </constraints>
          <profiles>
            <profile id="9554-7f71-5cfb-2864" name="Recetario halfling" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Recetario Halfling incrementa su Aura de Mando, alcance de dispersión y el alcance de un único hechizo elegido por el jugador que lo controle (sin incluir los hechizos de alcance “Lanzador” en 3”.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="afa9-cacb-5889-6dc1" name="Hoz de Grut" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="85d5-331d-2c4c-ea3e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d86e-b337-d497-fdc6" type="max"/>
          </constraints>
          <profiles>
            <profile id="7fbd-0837-3ddf-f990" name="Hoz de Grut" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Después de hacer una Tirada de lanzamiento de hechizo, el portador de la Hoz de Grut puede añadir un 1D3 adicional y añadir su resultado a su Tirada de lanzamiento. Sin embargo, una única miniatura amiga a 3” del portador pierde inmediatamente una única herida.
Ten en cuenta que el resultado de este 1D3 adicional no puede provocar una disfunción ni una Fuerza Irresistible.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ce08-43ee-8ae2-2135" name="Corazonaverno" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e8fe-7a4b-a9e0-e5ee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8fce-5824-ad9f-741b" type="max"/>
          </constraints>
          <profiles>
            <profile id="1e0a-8434-169a-c876" name="Corazonaverno" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Durante la subfase de mando de su turno, el portador del Corazonaverno puede consumirlo. Cuando lo haga, pierde inmediatamente una única herida. Sin embargo, hasta tu siguiente subfase de Inicio de Turno, si cualquier Hechicero enemigo obtiene un doble natural cuando haga una Tirada de lanzamiento de hechizo, el hechizo se desvanece.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="e703-6329-76c6-3301" name="Insignificantes" hidden="false">
      <description>Las unidades con esta regla especial nunca provocan chequeos de pánico a unidades amigas. Sin embargo, a una unidad con esta regla especial no se le puede unir un personaje que no la tenga.</description>
    </rule>
    <rule id="bc11-eb76-b899-2758" name="Gnoblar avisador" hidden="false">
      <description>Un campeón o personaje que se haya unido a una unidad con esta regla especial puede hacer una tirada de “¡Cuidado señor!” si hay dos o más miniaturas de tropa de la unidad (en lugar de las cinco habituales). Además, puedes repetir la tirada de “¡Cuidado señor!” si hay cinco o más miniaturas de tropa de la unidad.</description>
    </rule>
    <rule id="6be0-cde5-fdf6-6f5f" name="Carga de dientes martirio" hidden="false">
      <description>Los Impactos por Carga causados por una miniatura con esta regla especial tienen la regla especial Perforacorazas (1) y una Perforación de Armadura de -1.</description>
    </rule>
    <rule id="b845-6e38-9c94-5a2a" name="Aura de escarcha" hidden="false">
      <description>Mientras esté en contacto peana con peana con esta miniatura, las miniaturas enemigas sufren un penalizador de -1 a su Habilidad de Armas y su Iniciativa, hasta un mínimo de 1.</description>
    </rule>
    <rule id="872a-81aa-b121-1c9f" name="Carga de ogro" hidden="false">
      <description>La Perforación de Armadura de los Impactos por Carga causados por miniaturas con esta regla especial (pero no sus monturas) se mejora con el Bonificador por Filas actual de su unidad (o, en el caso de personajes, el Bonificador por Filas actual de la unidad a la que se hayan unido).</description>
    </rule>
    <rule id="1cb5-bd20-3423-db72" name="Esqueleto de piedra" hidden="false">
      <description>Esta miniatura es menos vulnerable a la regla especial Heridas Múltiples (X). Si sufre una herida no salvada de un ataque con esta regla especial, reduce el número de heridas perdidas en 1, hasta un mínimo de 1.</description>
    </rule>
    <rule id="b517-052d-b8cd-2335" name="Carga atronadora" hidden="false">
      <description>Los Impactos por Carga causados por esta miniatura tienen una Perforación de Armadura -2.</description>
    </rule>
    <rule id="09cd-acba-e796-5303" name="Saber de las Grandes Fauces" hidden="false">
      <description>Un mago con la regla especial Saber de las Grandes Fauces (&quot;Lore of the Great Maw&quot;) puede descartar uno de sus hechizos generados aleatoriamente de la forma habitual. Si lo hace, pueden elegir el hechizo identificativo de su Saber de la Magia o uno de los hechizos que se enumeran a continuación.
Partemuelas
Tipo: Encantamiento
Dificultad de lanzamiento: 7+/10+
Alcance: 12&quot;
Efecto: Si este hechizo se lanza con una dificultad de lanzamiento de 7 o más, la unidad amiga objetivo obtiene un bonificador de +1 a su atributo de resistencia (hasta un máximo de 10). Si este hechizo se lanza con una dificultad de lanzamiento de 10 o más, la unidad amiga objetivo obtiene un bonificador de +2 a su atributo de resistencia (hasta un máximo de 10). Este hechizo dura hasta el final de este turno.
Mondongo de Troll
Tipo: Encantamiento
Dificultad de lanzamiento: 8+/11+
Alcance: 12&quot;
Efecto: Si este hechizo se lanza con una dificultad de lanzamiento de 8 o más, la unidad amiga objetivo obtiene la regla especial Regeneración (6+) (Regeneration). Si este hechizo se lanza con una dificultad de lanzamiento de 11 o más, la unidad amiga objetivo obtiene la regla especial Regeneración (5+) (Regeneration). Este hechizo dura hasta tu próxima subfase de inicio de turno.</description>
    </rule>
  </sharedRules>
