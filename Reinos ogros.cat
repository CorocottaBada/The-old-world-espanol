      </constraints>
      <rules>
        <rule id="35e0-63ec-0194-d282" name="Perforacorazas (Cazador)" hidden="false"/>
        <rule id="38f8-205e-8c95-6a38" name="Mover a través de cobertura (Cazador)" hidden="false"/>
        <rule id="b50b-fe6b-d3cd-6bbc" name="Correr con la manada" hidden="false">
          <description>Un Cazador que se una a una unidad de Dientes de Sable obtiene la regla especial Zancada Veloz mientras permanezca unido a ella. Además, mientras el Cazador permanezca en la unidad los dientes de Sable pierden la regla especial Impetuosos.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4259-001e-3e42-caf1" name="Infantería monstruosa (Monstrous infantry)" hidden="false" targetId="5c73-876f-8ca7-1192" type="rule">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="f011-aed9-bee8-7d64" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e97c-17bb-0f51-6165" type="equalTo"/>
