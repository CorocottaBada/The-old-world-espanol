        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e39-ba58-4b31-ddb9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4573-c0b3-cc8c-0a66" name="La máscara del horno" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bc16-d046-fc97-7195" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="33ff-1c54-0acf-a4d4" type="max"/>
          </constraints>
          <profiles>
            <profile id="ba2f-46ea-6a80-ae11" name="La máscara del horno" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Se puede usar con otras armaduras. El portador de la Máscara del Horno mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, tiene una Salvación Especial de 3+ contra cualquier herida sufrida que haya sido causada por un ataque que tenga la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7a9d-6c23-5602-aa7b" name="Talismanes. Enanos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="491b-998e-b5e8-5beb" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="979e-b77e-9cf1-684a" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="20fe-129a-c48a-316b" name="Fragmento infernal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="33e7-0cd5-0424-6f79" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0838-011b-a7ee-80ea" type="max"/>
          </constraints>
          <profiles>
            <profile id="d3a6-3d36-e122-fab2" name="Fragmento infernal" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Si el portador del Fragmento Infernal pierde su última Herida por un ataque enemigo durante la fase de Combate, la unidad que realizó el ataque sufre 1D6 impactos de Fuerza 5, cada uno con una PA de -1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9120-32ee-a8a1-1a91" name="Talismanes muy comunes. Enanos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac31-46a7-d752-ff4f" type="max"/>
