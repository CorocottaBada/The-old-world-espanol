              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Morko es una armadura pesada. Además, su
portador obtiene Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
