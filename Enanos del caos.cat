        <selectionEntry id="3885-2185-3ecd-7231" name="Daga del maleficio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1d4c-b0e3-106c-529e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b768-5e0a-0819-2810" type="max"/>
          </constraints>
          <profiles>
            <profile id="8f35-a705-9ddc-c2ed" name="Daga del maleficio" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Furia asesina, Odio (todos los enemigos)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">A diferencia de otras miniaturas con Furia Asesina, el portador de la Daga de la Malicia no puede perder esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
