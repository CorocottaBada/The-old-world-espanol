            <selectionEntryGroup id="e846-d9bf-f4c4-2118" name="Armas" hidden="false" collective="false" import="true" defaultSelectionEntryId="5c6d-38de-150a-2c04">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3216-afdd-d6e5-e3f7" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="199e-3e70-1271-028e" type="min"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="5c6d-38de-150a-2c04" name="Cañón doble de vapor" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4723-e627-d72d-a9b0" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="6ae8-3d56-1ce2-c77f" name="Cañón doble de vapor" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                      <characteristics>
                        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">18&quot;</characteristic>
                        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5</characteristic>
                        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
                        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Cañón doble, Aparatoso</characteristic>
                        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">A la disparar con un cañón de vapor, siga la secuencia normal de la fase de Disparo. Esta arma no tiene 360º de línea de visión, solo puede disparar hacia el arco frontal del Demonio de Hierro.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <rules>
                    <rule id="305d-5d6c-f666-018c" name="Cañón doble" hidden="false">
                      <description>Al disparar con un cañón doble de vapor, tira dos dados de Artillería antes de hacer cualquier tirada para Impactar. El número de disparos efectuados es igual al total de ambos dados de artillería:
Si se obtiene un resultado de Problemas en uno de los dados de artillería, todos los disparos disparados desde el cañón doble de vapor este turno sufren un modificador adicional de -1 para Impactar (en lugar de Tirar en la Tabla de Problemas).
Si se obtiene un resultado de Problemas en ambos dados de artillería, no se disparan tiros y esta miniatura pierde una única herida (en lugar de Tirar en la Tabla de Problemas).
Después de determinar el número de disparos, tira para Impactar por cada uno como de costumbre, usando la Habilidad de Proyectiles de la tripulación y aplicando todos los modificadores apropiados.</description>
                    </rule>
                  </rules>
                  <infoLinks>
                    <infoLink id="fbb9-e605-9172-0e91" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                    <infoLink id="9de4-785d-881e-abfd" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="98a3-31cc-b4c7-2e9e" name="Cascacráneos" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0afc-9623-e575-1050" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="0de8-421a-d035-92d4" name="Cascacráneos" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Demonio de Hierro equipado con un Cascacráneos reemplaza la regla especial Impactos por Carga (1D6+1) por la regla especial Impactos por Carga (2D6+2) y obtiene la regla especial Perforacorazas (1).</characteristic>
