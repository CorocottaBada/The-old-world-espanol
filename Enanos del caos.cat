        <selectionEntry id="1165-3a18-4639-2fdd" name="Maza oscura" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3973-a54b-b1c2-3ed9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2808-258d-027a-0fec" type="max"/>
          </constraints>
          <profiles>
            <profile id="11de-4d3e-3816-2842" name="Maza oscura" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpe letal</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier miniatura enemiga que sufra una o más heridas no salvadas por la Maza Oscura debe realizar inmediatamente un chequeo de Fuerza. Si este chequeo falla, la miniatura enemiga pierde una Herida adicional.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
