                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques flamígeros, Heridas múltiples (1D3)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Contra miniaturas con la regla especial Inflamable, esta arma también tiene la regla especial Golpe Letal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d221-03f6-0d91-72b8" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
