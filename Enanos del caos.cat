      <selectionEntries>
        <selectionEntry id="f379-cc4c-d64d-8037" name="El cetro grabado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4273-1c45-50e5-6861" type="max"/>
