    <selectionEntry id="7388-5179-d63d-d22b" name="Demonio de hierro" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="increment" field="5714-34f7-92d6-5aed" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="false"/>
          </repeats>
        </modifier>
        <modifier type="set" field="afef-bd63-8d52-b001" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="afef-bd63-8d52-b001" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5714-34f7-92d6-5aed" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="afef-bd63-8d52-b001" type="max"/>
      </constraints>
      <rules>
        <rule id="b11a-60d4-b4eb-1f4e" name="Ruedas aplastantes" hidden="false">
          <description>Los Ataques de Golpetazo realizados por un Demonio de Hierro tienen un atributo de Perforación de Armadura de -2. Sin embargo, esta regla no se puede usar contra miniaturas cuyo tipo de tropa es “coloso”: simplemente son demasiado grandes para ser atrapados debajo de las ruedas de un Demonio de Hierro.
Además, y a diferencia de otros carros, esta miniatura trata los obstáculos lineales bajos como terreno abierto en lugar de como terreno impasable.</description>
        </rule>
        <rule id="a046-0b42-b437-8496" name="Destructor pesado" hidden="false">
          <description>Un Demonio de Hierro no puede marchar. En su lugar, puede tirar 1D6 y agregar su resultado al atributo de Movimiento de la miniatura. Sin embargo, si se saca un 1 natural al hacer esta tirada, algo ha ido mal en lo profundo de la máquina infernal, dejándola inmóvil. El Demonio de Hierro se detiene inmediatamente y no puede volver a moverse durante el resto de este turno.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="ec97-9b68-0efa-6b5a" name="Carro pesado (Heavy chariots)" hidden="false" targetId="3af7-2847-d9c7-fb97" type="rule"/>
        <infoLink id="b965-20a1-3481-d2d2" name="Formación cerrada (Close order)" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
