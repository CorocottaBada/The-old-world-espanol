      <selectionEntries>
        <selectionEntry id="eec1-6f15-4e34-cce6" name="Armadura de Bazherak el Cruel" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2357-21ea-70d0-1a98" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d38-379a-f552-0d33" type="max"/>
          </constraints>
          <profiles>
            <profile id="211a-6c63-a07b-9b5c" name="Armadura de Bazherak el Cruel" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Bazherak el Cruel es una armadura completa. Además, su portador tiene las reglas especiales Inmune a la Psicología y Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f2ad-a0b5-a571-5e29" name="Inmune a la psicología" hidden="false" targetId="acf4-8cb7-67f0-f838" type="rule"/>
            <infoLink id="1441-1ca4-bdfb-98cc" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
