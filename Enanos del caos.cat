          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4e11-e49b-d4b2-11c6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d670-32c1-58fd-53bb" type="max"/>
          </constraints>
          <profiles>
            <profile id="d924-1de1-3ad5-ad61" name="Escudo rencoroso" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo Rencoroso es un escudo. Además, cualquier miniatura enemiga que saque un 1 natural al hacer una tirada para Impactar o para Herir contra el portador del Escudo Rencoroso durante la fase de Combate sufre inmediatamente un impacto de Fuerza 4 con una PA de -.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ae02-6999-2971-c2fc" name="Escudo" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6fcc-2600-57c2-186a" name="Armadura endurecida de la muerte" hidden="false" collective="false" import="true" type="upgrade">
