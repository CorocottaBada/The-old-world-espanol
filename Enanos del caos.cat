      <rules>
        <rule id="931d-2cb4-21b5-da46" name="Evitar el pánico" hidden="false">
          <description>A menos que esta unidad esté huyendo, cualquier unidad amiga que esté a 6” o menos de esta unidad y que tenga la regla especial de Levas puede repetir un chequeo de Pánico fallido.</description>
        </rule>
      </rules>
