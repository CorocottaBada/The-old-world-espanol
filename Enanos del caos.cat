        </selectionEntry>
        <selectionEntry id="9441-d71a-b23c-dd1c" name="Sello del profeta" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="caa8-73a2-7de4-9d9e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="28c8-5fa8-b502-6fac" type="max"/>
          </constraints>
          <profiles>
            <profile id="0c42-706f-63e1-97b9" name="Sello del profeta" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Mientras que se encuentren a 9” o menos de la miniatura que porta el Sello del Profeta, las unidades amigas pierden la regla especial Levas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7253-16a3-acc0-f1aa" name="Pabellón de cenizas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a23c-5e07-5ef2-5806" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="41c2-a23f-dfe7-0530" type="max"/>
          </constraints>
          <profiles>
            <profile id="379d-f6cb-c472-193e" name="Pabellón de cenizas" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier miniatura enemiga que elija como objetivo a una unidad que lleve el Pabellón de Cenizas durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1d97-01c3-4ab9-0fea" name="La barba de lammasu" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9edb-3199-f561-04b0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4f5-3385-2e1b-6d99" type="max"/>
          </constraints>
          <profiles>
            <profile id="5658-4000-ac8d-fbd6" name="La barba de lammasu" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve la Barba de Lammasu tiene una Salvación Especial de 6+ contra cualquier herida sufrida y gana la regla especial Resistencia a la Magia (-2). Además, mientras estén a 6” o menos de la miniatura que lleva este estandarte, las unidades amigas tienen una Salvación Especial de 5+ contra cualquier herida sufrida durante la fase de Disparo y obtienen la regla especial Resistencia a la Magia (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a1a2-e7eb-3a48-cca1" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="650b-f045-6fb9-5fd9" name="Objetos hechizados. Enanos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a30-351b-f5b8-e37a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7257-b421-5d7b-8f25" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bfeb-3950-d6ef-78cf" name="Brazales de obsidiana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="34c0-52bb-e36c-5879" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c77b-14a4-b6f6-bd78" type="max"/>
          </constraints>
          <profiles>
            <profile id="8c39-41e2-4330-a1b1" name="Brazales de obsidiana" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de los Brazales de Obsidiana tiene un modificador de +1 a su atributo de Fuerza y la regla especial de Resistencia a la Magia (-1). Sin embargo, si sacas un 1 natural al hacer una tirada para Impactar durante la fase de Combate, los brazales se rompen en pedazos y ya no se pueden usar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9172-d5e9-a796-b0b1" name="Resistencia a la magia (-1) (Magic resistance)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6480-a286-24de-c0b3" name="Aliento de Hashut" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="30ef-8f41-7549-302e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="41e3-a50a-d6ee-aa77" type="max"/>
          </constraints>
          <profiles>
            <profile id="db68-186d-8288-ba1d" name="Aliento de Hashut" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El Aliento de Hashut es un Arma de Aliento con el siguiente perfil:</characteristic>
              </characteristics>
            </profile>
            <profile id="a1cd-1b19-a5c3-727d" name="Aliento de Hashut" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">N/A</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Arma de aliento, Ataques flamígeros, Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1"/>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c660-8f88-f48a-35e3" name="Arma de aliento (Breath weapon)" hidden="false" targetId="28ba-f733-cc16-d9e7" type="rule"/>
            <infoLink id="25ea-4af9-90b0-f9bc" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="cf6d-5cee-dd87-2379" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f6b0-452e-7add-33ea" name="Familiar demoníaco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4006-4b34-d53b-e2f1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9659-e00c-768a-f4e4" type="max"/>
          </constraints>
          <profiles>
            <profile id="f0c2-ea1e-1af4-13d1" name="Familiar demoníaco" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Las miniaturas enemigas que entren en combate con el propietario de un familiar demoníaco deben reducir el valor de armadura de cualquier Salvación Especial o de Regeneración que tengan en 1, hasta un mínimo de 6+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="072c-0f66-d10d-a926" name="Objetos arcanos. Enanos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1210-9bdd-76b2-a6ca" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eff0-eeef-ff31-3e89" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cd11-25c4-59c9-d5e9" name="Vial de sangre de lammasu" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="afd5-e2d6-e9e7-b715" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d7df-9a5e-1b09-7620" type="max"/>
          </constraints>
          <profiles>
            <profile id="434f-bf5b-9ffd-ecdd" name="Vial de sangre de lammasu" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Hechicero puede usar este objeto en lugar de hacer un intento de dispersión. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirar para Dispersar.
Ten en cuenta que un hechizo lanzado con Fuerza Irresistible no puede ser dispersado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="50ac-3e0e-dfe6-c538" name="Frasco demoníaco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="84e5-99fd-4c6b-65ad" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4996-b8ff-f5e5-1b85" type="max"/>
          </constraints>
          <profiles>
            <profile id="47d9-9613-44c0-ce3b" name="Frasco demoníaco" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Durante la subfase de Mando de tu turno, el portador del Frasco Demoníaco puede abrirlo. Cuando lo haga, todas las unidades enemigas que estén dentro del Aura de Mando de este personaje deben realizar un chequeo de Pánico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6b4c-bf53-35c1-46de" name="Objetos arcanos muy comunes. Enanos del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f0f4-4ca1-236a-8495" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9e8c-0fe7-b05f-5574" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5270-dced-ffd6-990b" name="Pergamino de vinculación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c478-7ab3-3d6a-e4ec" type="max"/>
          </constraints>
          <profiles>
            <profile id="4769-0c3f-df4a-13cc" name="Pergamino de vinculación" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Hechicero puede usar este pergamino cuando intente lanzar un hechizo. Si lo hace, el Hechicero tira 3D6 al hacer su Tirada de lanzamiento (en lugar de la habitual 2D6). Sin embargo, si se obtiene un doble 1 en dos de cualquiera de los dados lanzados, el Hechicero sufre una Disfunción Mágica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
