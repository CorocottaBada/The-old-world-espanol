            <selectionEntry id="fc6a-fd69-9c20-9607" name="Mortero estremecedor" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="421b-fdf2-2a2f-839d" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="753c-108c-50e3-77b6" type="min"/>
              </constraints>
              <profiles>
                <profile id="239d-a454-f98c-8426" name="Mortero estremecedor" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-72&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">3 (6)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">- (-3)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Mover o disparar, Heridas múltilples (1D6), Temblor, Recarga lenta</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una Catapulta, usando la regla especial ‘Bombardeo’, una plantilla de área de 5” y la tabla de problemas de armas de pólvora. La regla especial de Heridas Múltiples (1D6) se aplica solo a una sola miniatura cuya peana se encuentra debajo del orificio central de la plantilla de área.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="0658-12cf-ee55-7fb9" name="Temblor" hidden="false">
                  <description>Hasta tu próxima subfase de Inicio de Turno, cualquier unidad (amiga o enemiga) que estuviera a menos de 2D6” del agujero central de la plantilla de área después de dispersarse sufre un modificador de -1 a su atributo de Movimiento y no puede usar la regla especial Zancada Veloz.</description>
                </rule>
                <rule id="0f2e-c8bd-a156-97e6" name="Recarga lenta" hidden="false">
                  <description>Si esta arma disparó durante tu turno anterior, es posible que no pueda disparar durante este turno. Tira 1D6 antes de disparar con esta arma. En una tirada de 1-2, el lento y pesado proceso de recarga aún no se ha completado y el arma no dispara este turno. Si el Cañón estremecedor tiene un Cargador Ogro, puedes aplicar un modificador +1 a esta tirada.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="8b3b-e695-09f3-6fdc" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="8d1c-22b4-8655-06d1" name="Bombardeo" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
                <infoLink id="9d13-0523-be2b-b298" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
                <infoLink id="34c8-7698-dc24-2a5b" name="Mover o disparar" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="a446-f432-20c7-2517" name="Tabla de problemas de armas de pólvora" hidden="false" targetId="92b8-a4f7-bcd6-8b2c" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
