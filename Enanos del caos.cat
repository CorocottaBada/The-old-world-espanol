            <profile id="e8e8-b5f0-50c3-a153" name="Sudario del ancestro" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Sudario del Ancestro obtiene la regla especial Odio (Enanos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0443-5438-ae51-69bf" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
