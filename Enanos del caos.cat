            <selectionEntry id="535d-a378-cf88-26b5" name="Fuego infernal" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f91-4862-25e8-955a" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a045-813d-aacc-f762" type="min"/>
              </constraints>
              <profiles>
                <profile id="0f4c-e3c4-6331-4659" name="Fuego infernal" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-60&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5 (10)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2 (-5)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Mover o disparar, Heridas múltiples (1D3)</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial ‘Bombardeo’, una plantilla de área de 3” y la tabla de Problemas del Cañón Infernal. Cualquier unidad que sufra una o más heridas no salvadas por esta arma debe hacer un chequeo de Pánico como si hubiera sufrido muchas bajas.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="e934-1ff1-f35d-eb21" name="Tabla de problemas Cañón infernal" hidden="false">
                  <description>Tabla de Problemas del Cañón Infernal 
1D6 Resultado
1 ¡Libre por fin! El Demonio se libera. Cada unidad (amiga o enemiga) en un radio de 3D6” sufre 1D6 impactos de Fuerza 5, cada uno con una PA de -1. Una vez que se resuelven estos impactos, el Cañón Infernal se retira del juego como una baja.
2-4 Chomp! Retira a uno de la dotación de los enanos del caos del cañón infernal.
5-6 Saaaaangre! El Cañón Infernal rompe sus cadenas, moviéndose inmediatamente 3D6” como si estuviera sujeto a la regla especial de Movimiento Aleatorio y como si se tratara de la subfase de Movimientos Obligatorios.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="fc96-548b-0cf9-78b2" name="Bombardeo (Bombardment)" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
                <infoLink id="fee9-f2fb-b9d6-d342" name="Mover o disparar (Move or shoot)" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="e5da-9212-8714-a007" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
                <infoLink id="9ecc-d02d-a03d-9d90" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
