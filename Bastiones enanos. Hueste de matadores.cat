              </constraints>
              <profiles>
                <profile id="616b-92cf-963a-e523" name="Filo del dragón" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos. </characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo del Dragón está inscrita con una Runa de Furia y una Runa de Rencor, como se describe en la página 34 de Forces of Fantasy.</characteristic>
                  </characteristics>
                </profile>
                <profile id="4568-eebc-d0af-2be4" name="Runa de la furia" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
                  </characteristics>
                </profile>
                <profile id="53c1-bf4b-9af8-18ac" name="Runa magistral del rencor" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="9371-c580-c332-1abe" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
                <infoLink id="f083-f213-cd8a-e492" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
