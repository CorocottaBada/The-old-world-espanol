          </constraints>
          <profiles>
            <profile id="2c91-2971-75cc-7f7e" name="Runa de poder" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Por cada Runa de Poder inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Fuerza.</characteristic>
