          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="acd0-bb18-9d43-0dea" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="35e7-ee6e-1351-d696" type="max"/>
          </constraints>
          <profiles>
            <profile id="466b-d9fa-58e2-58c7" name="Runa magistral del equilibrio" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Solo Yunque Rúnico, Herrero Rúnico o Señor de las Runas. Una vez por turno, el portador de la Runa Magistral del Equilibrio puede usarla al intentar una dispersión arcana. Si lo hacen, tira 1D6 extra al intentar la tirada de dispersión y descarta el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1d29-b70c-21c3-3efc" name="Runas magistrales talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7575-6540-edf3-702f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c03-9b3b-9659-803f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b730-b57e-3b06-9577" name="Runa magistral del rencor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="88b4-e971-2938-9426" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="656e-ebe7-6a62-0174" type="max"/>
          </constraints>
          <profiles>
            <profile id="a864-126b-80bc-39dd" name="Runa magistral del rencor" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="89e4-ce94-6c3e-9827" name="Runa magistral de la calma" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3f49-0e04-eb99-ad45" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cdd3-8143-3b6e-031d" type="max"/>
          </constraints>
          <profiles>
            <profile id="dee7-4b7b-8151-4951" name="Runa magistral de la calma" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">El portador de la Runa Magistral de la Calma puede lanzar el siguiente hechizo vinculado, con un Nivel de Energía 2.
Tipo: Maldición
Dificultad de Lanzamiento: 8+ / 11+
Alcance: Personal
Efecto: Si este hechizo vinculado se lanza con un resultado de lanzamiento de 8+, los magos enemigos que se encuentren a 18” o menos de esta miniatura y que intenten lanzar un hechizo deben aumentar la Dificultad de lanzamiento de ese hechizo en 2. Si el Hechizo Vinculado se lanza con un resultado de lanzamiento de 11+, los magos enemigos que estén a 36” o menos de esta miniatura cuando intenten lanzar un hechizo deben aumentar la Dificultad de Lanzamiento del hechizo en 2. Este hechizo dura hasta tu siguiente subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="20da-e56e-f3f8-96b2" name="Runas magistrales de ingenieros. Cañón" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0dc-92fc-7cf4-59ac" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="730f-34c4-8639-089b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d1fb-4ab8-5d7e-e627" name="Runa magistral de la inmolación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="87b4-f954-bc77-a84e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4ea8-e5ec-b654-50b4" type="max"/>
          </constraints>
          <profiles>
            <profile id="7729-deff-5c24-7c2c" name="Runa magistral de la inmolación" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Sólo cañones. Un solo uso. Si un cañón que tiene inscrita la Runa Magistral de la Inmolación pierde la última herida por un ataque enemigo durante la fase de Combate, su dotación lo podrá explotar. Por cada unidad enemiga en contacto peana con peana con esta miniatura sufre 1D6 impactos de Fuerza 5 con una PA de -2. El cañón es entonces retirado del juego como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="46af-e096-a1bc-34f4" name="Runas magistrales de ingenieros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="efef-fa08-6724-609f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cc1f-8ebf-763d-168d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a7dd-06cb-e4c5-0873" name="Runa magistral del disfraz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="45c7-3293-b751-11da" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b7d1-d6ee-2562-8827" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b6f-40b6-38da-f0ad" name="Runa magistral del disfraz" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Una máquina de guerra inscrita con la Runa Magistral del Disfraz siempre se considera detrás de cobertura total.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="cd92-98ac-26c6-e800" name="Runas magistrales de estandartes. Portaestandarte de batalla" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="76eb-7690-1435-bb26" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="389f-e4f3-9ac8-1318" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b296-6a6e-5ce6-1ae7" name="Runa magistral de Grungni" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d81c-8980-14c2-5bb3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e2e8-89c0-7a35-ad1b" type="max"/>
          </constraints>
          <profiles>
            <profile id="d92d-d43d-0dd4-b791" name="Runa magistral de Grungni" hidden="false" typeId="58ae-e58d-01f9-9650" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4b70-c2f7-6537-8a18">Solo Portaestandarte de Batalla. Una unidad que lleva un estandarte inscrito con la Runa Magistral de Grungni tiene una Salvación Especial de 5+ contra todas las heridas sufridas. Además, mientras estén a 6” o menos de la miniatura que lleva este estandarte, las unidades amigas tienen una Salvación Especial de 6+ contra cualquier herida sufrida durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6614-0de2-aa3f-ae25" name="Runas magistrales de estandartes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0657-bd72-c312-c90d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0a08-4c0b-7a41-3fdf" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="21c5-aea2-6c16-c439" name="Runa magistral de la duda" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e624-e97d-ef35-e9c7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="658f-cc27-eb8f-4157" type="max"/>
          </constraints>
          <profiles>
            <profile id="7b7c-e8fe-b0f6-d888" name="Runa magistral de la duda" hidden="false" typeId="58ae-e58d-01f9-9650" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4b70-c2f7-6537-8a18">Una unidad enemiga que carga contra el arco frontal de una unidad que lleva un estandarte inscrito con la Runa Magistral de la Duda no cuenta que ha cargado para el propósito de elegir qué arma usar o cualquier regla especial que pueda tener.
Ten en cuenta que una unidad que porta esta runa todavía cuenta como que ha sido cargada por una unidad enemiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ce55-97d6-e6c8-1842" name="Runa magistral de Stromni Barbaroja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6b94-3b28-c98b-d0a5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="45c7-7b40-2444-72bf" type="max"/>
          </constraints>
          <profiles>
            <profile id="5ad5-773b-7155-be53" name="Runa magistral de Stromni Barbaroja" hidden="false" typeId="58ae-e58d-01f9-9650" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4b70-c2f7-6537-8a18"> Al calcular el resultado del combate, cualquier unidad amiga dentro del Aura de mando del portador del estandarte inscrito con la Runa Magistral de Stromni Barbaroja puede reclamar un bonificador adicional de +1 punto al resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1c02-486c-2cdf-5dca" name="Runas magistrales de armas. Arma de mano" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="412d-a65a-f02c-4ab4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fc9-080f-6e1c-4445" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="809c-9772-d2b6-e4fd" name="Runa magistral del vuelo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="cf04-7c95-878d-e7a8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="96aa-0633-928d-3c4f" type="max"/>
          </constraints>
          <profiles>
            <profile id="aa12-999c-007a-9d9c" name="Runa magistral del vuelo" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Sólo armas de mano. Una vez por turno, durante la fase de Disparo, un arma inscrita con la Runa Magistral del Vuelo podrá ser arrojada con el siguiente perfil (que podrá ser modificado por runas adicionales).</characteristic>
              </characteristics>
            </profile>
            <profile id="22f3-fbd6-56e4-3d38" name="Runa magistral del vuelo" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12&quot;</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">5</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Ataques mágicos, Mover y disparar, Disparo rápido</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="add7-cf9d-5e39-d398" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="4a50-3497-a2d3-4429" name="Mover y disparar (Move &amp; shoot)" hidden="false" targetId="2b49-fb72-106a-1e56" type="rule"/>
            <infoLink id="998c-73e7-76d1-1be9" name="Disparo rápido (Quick shot)" hidden="false" targetId="ae60-f2dc-28d3-2489" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3352-0120-9d79-5c56" name="Runas magistrales de armas de ingenieros. Ballesta, Arcabuz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ec4-bd36-e6ec-51ca" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="760a-0f4d-1f9b-10da" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cb22-c574-c523-b463" name="Runa magistral de la matanza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="de53-c209-d966-8c03" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54bc-c182-082d-32dc" type="max"/>
          </constraints>
          <profiles>
            <profile id="cd25-4422-b283-7f1c" name="Runa magistral de la matanza" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Al hacer una tirada para Herir contra un enemigo cuyo tipo de tropa es ‘coloso’ con un arma inscrita con esta runa, una tirada de 3+ siempre es un éxito, independientemente de la Resistencia del objetivo. Además, un arma inscrita con esta runa obtiene la regla especial Heridas Múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9322-2812-987d-85de" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="da95-4e59-fdae-9333" name="Runa magistral de la perforación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f885-d0e2-b156-1d2d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="179b-ad13-3862-f19b" type="max"/>
          </constraints>
          <profiles>
            <profile id="2f77-2df2-0865-5a32" name="Runa magistral de la perforación" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Un arma inscrita con esta runa tiene un modificador +1 a su atributo de Fuerza. Además, un arma inscrita con esta runa dispara como un Lanzavirotes, utilizando la regla especial ‘Atravesar Filas’ (véase la página 223 del reglamento de Warhammer: the Old World).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="73b1-ee68-d661-c92b" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fb3d-a084-2e5d-0a9e" name="Runa magistral de llamas explosivas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="57f2-4575-0830-937e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="19b5-93f6-be39-988b" type="max"/>
          </constraints>
          <profiles>
            <profile id="7e44-9c30-82b9-43b5" name="Runa magistral de llamas explosivas" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Si la tirada para Impactar tiene éxito, un arma inscrita con esta runa provoca 2D3 impactos a la unidad enemiga objetivo, en lugar del único impacto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9f35-78c2-3c0c-efb2" name="Runas magistrales de armas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="68b2-0127-0dae-7680" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="35fd-f24c-f789-a9a1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a20d-1adf-0579-316e" name="Runa magistral de la destrucción" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8415-8a34-e1b3-ad14" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e6a-0ec5-0cb2-bdbd" type="max"/>
          </constraints>
          <profiles>
            <profile id="bbac-044d-0859-0ec8" name="Runa magistral de la destrucción" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Un arma inscrita con la Runa Magistral de la Destrucción obtiene la regla especial Heridas Múltiples (1D6).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a71e-55e9-e07b-b144" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="035f-fe93-5549-ac7c" name="Runa magistral de Skalf Martillonegro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3b4c-4de1-a236-4618" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f4eb-e099-4265-acee" type="max"/>
          </constraints>
          <profiles>
            <profile id="b324-f0a5-f073-b80f" name="Runa magistral de Skalf Martillonegro" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Al realizar una tirada para Herir con un arma inscrita con la Runa Magistral de Skalf Martillonegro, un resultado de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ea42-3e5c-6f05-ca04" name="Runa magistral de la ruina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c161-023a-d810-7d49" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3204-ba7d-664f-0c7c" type="max"/>
          </constraints>
          <profiles>
            <profile id="a3bd-2f6b-fde1-d551" name="Runa magistral de la ruina" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Cualquier arma mágica equipada por una miniatura enemiga que sufra una o más heridas no salvadas de un arma inscrita con la Runa Magistral de la Ruina se destruye y no se puede utilizar durante el resto del juego.
Ten en cuenta que incluso si su arma mágica es destruida se considera que la miniatura todavía está armada con un arma de mano.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8dbf-2435-716b-6acf" name="Runa magistral de la rapidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7047-0d02-6063-5890" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d99-059e-03c6-8f17" type="max"/>
          </constraints>
          <profiles>
            <profile id="f2ea-a332-b842-e81b" name="Runa magistral de la rapidez" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">El portador de un arma inscrita con la Runa Magistral de la Rapidez gana la regla especial Golpea Primero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7627-1718-2ac6-e228" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7b8d-351d-cdc6-9c0e" name="Runa magistral matadragones" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5ea7-14e3-6d9d-dc45" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d28f-40b7-1069-1514" type="max"/>
          </constraints>
          <profiles>
            <profile id="1ee3-4440-b520-85f4" name="Runa magistral matadragones" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Al realizar una tirada para Herir contra un enemigo cuyo tipo de tropa es un “Coloso” con un arma inscrita con la Runa Magistral Matadragones, una tirada de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c69b-4768-5d1b-e3ba" name="Runa magistral de Alarik el Loco" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="755d-8da6-26d9-05fd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6c07-cc28-2713-8ea9" type="max"/>
          </constraints>
          <profiles>
            <profile id="879f-71e0-59a9-1391" name="Runa magistral de Alarik el Loco" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">No se permite ninguna tirada de Salvación por Armadura contra heridas causadas por un arma inscrita con la Runa Magistral de Alarik El Loco (las salvaciones especiales o regeneración se pueden realizar de forma normal).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
