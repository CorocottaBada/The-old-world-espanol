  <sharedSelectionEntryGroups>
    <selectionEntryGroup id="3c32-1480-64da-4648" name="Tatuajes rúnicos. Matademonios, Matadragones" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5995-ecf4-db60-d4d4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef3e-c7bf-66d5-4eff" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c644-792c-fd4d-dc20" name="Runa del deshonrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="852f-cd40-4015-5106" type="max"/>
          </constraints>
          <profiles>
            <profile id="8bdf-2f36-898a-8666" name="Runa del deshonrado" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Solo Matademonios y Matadragones. Una vez que una miniatura con este tatuaje rúnico sea reducida a su última herida, obtiene una Salvación Especial de 3+ contra cualquier otra herida sufrida. Sin embargo, al final de la batalla, una miniatura con este tatuaje rúnico que haya sido retirada como baja no otorga puntos de victoria. Si todavía está vivo, el jugador enemigo obtiene un número adicional de puntos de victoria igual al 100% de su coste de puntos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9201-0c1a-6953-f8d7" name="Tatuajes rúnicos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c28-1134-46cd-fb3f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8574-e6cc-67ad-f3c7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e71c-a738-8708-c5c0" name="Runa de la batalla interminable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5dd6-40b8-8a46-fa20" type="max"/>
          </constraints>
          <profiles>
            <profile id="6bfb-2342-355c-1b1e" name="Runa de la batalla interminable" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Durante la fase de Combate de cualquier turno en el que una miniatura con este tatuaje rúnico carga, cada ataque que haga que cause una herida no salvada le permite realizar inmediatamente un ataque adicional.
Ten en cuenta que cualquier ataque adicional que cause heridas no salvadas y cualquier herida no salvada causada por la regla especial Impactos por Carga (X) no se beneficia de esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="afe2-09ec-391e-5fae" name="Runa de los imprudentes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9d12-9659-bd0e-6813" type="max"/>
          </constraints>
          <profiles>
            <profile id="f689-93f1-f48a-c6f3" name="Runa de los imprudentes" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico obtiene la regla especial Furia Asesina y, durante la fase de Combate, tiene un modificador de +1 a sus tiradas para Impactar. Sin embargo, las miniaturas enemigas que elijan como objetivo a esta miniatura durante la fase de Combate también tienen un modificador de +1 en sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7ce7-94ba-3590-2158" name="Furia asesina" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="debf-babf-e7f9-355b" name="Runa de lo odioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7061-b34c-f6e1-599b" type="max"/>
          </constraints>
          <profiles>
            <profile id="eca8-7d2c-ddf8-7114" name="Runa de lo odioso" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico obtiene la regla especial Odio (todos los enemigos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3eff-9cc2-18d6-adce" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="68c1-f85a-7694-4367" name="Runa del valor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1f47-1934-6712-aebd" type="max"/>
          </constraints>
          <profiles>
            <profile id="fcd4-da03-bc82-f4c2" name="Runa del valor" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico tiene un modificador de +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9af1-46ff-02af-0d36" name="Runa de los intrépidos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9e6-45af-98c7-19c1" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b7f-7042-41f8-7447" name="Runa de los intrépidos" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico siempre debe lanzar y aceptar Desafíos (si es posible). Durante un Desafío, esta miniatura puede repetir cualquier tirada fallida para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0963-d925-2fb7-92eb" name="Runa de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d48-5c51-5d9f-2b4a" type="max"/>
          </constraints>
          <profiles>
            <profile id="7d2b-f4b1-e588-72f4" name="Runa de la ira" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4c27-b8d7-2259-4fd2" name="Runa de la furia ardiente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b61-ac03-a3ca-59bb" type="max"/>
          </constraints>
          <profiles>
            <profile id="7a46-3a9d-2cd2-b5a2" name="Runa de la furia ardiente" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico tiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e40b-ccc7-fc8b-b44c" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="96c9-6227-2d4b-414e" name="Runa del guerrero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="77de-3840-f2fd-3c9c" type="max"/>
          </constraints>
          <profiles>
            <profile id="e74b-648f-4f75-e02c" name="Runa del guerrero" hidden="false" typeId="2222-2a54-7356-2833" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7051-302c-ca34-d37a">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Habilidad de Armas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
