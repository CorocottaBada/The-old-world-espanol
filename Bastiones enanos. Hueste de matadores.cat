          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="63ed-c2d9-dbf1-78cc" type="max"/>
          </constraints>
          <profiles>
            <profile id="3e45-8c59-68d0-80a1" name="Runa de batalla" hidden="false" typeId="58ae-e58d-01f9-9650" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4b70-c2f7-6537-8a18">Al calcular el Resultado del combate, una unidad que lleve un estandarte inscrito con la Runa de Batalla puede reclamar una bonificación adicional de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
