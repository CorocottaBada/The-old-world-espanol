        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="066c-637d-a397-a53b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="00b6-5e94-ab68-b007" name="Runa de piedra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="816b-b4ba-affe-ef33" type="max"/>
          </constraints>
          <profiles>
            <profile id="5a6c-86f0-82f3-8a48" name="Runa de piedra" hidden="false" typeId="c019-cd95-f4ce-816e" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8cca-6c13-db66-0ad8">Un solo uso. Por cada Runa de Piedra inscrita en la armadura, el portador puede repetir una única tirada de Salvación por Armadura fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f84d-dcdb-8079-aed0" name="Runa de escudo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="41f2-4091-dd10-dc85" type="max"/>
          </constraints>
          <profiles>
            <profile id="4360-e78f-a7d5-f697" name="Runa de escudo" hidden="false" typeId="c019-cd95-f4ce-816e" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8cca-6c13-db66-0ad8">Una miniatura que lleva su armadura inscrita con una única Runa de Escudo tiene una Salvación Especial de 6+ contra todas las heridas sufridas. Por cada Runa de Escudo adicional, la Salvación Especial mejora en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="13a9-fa78-490b-24d8" name="Runa de perseveración" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d496-bab0-4475-e260" type="max"/>
          </constraints>
          <profiles>
            <profile id="d29c-d36a-5272-4244" name="Runa de perseveración" hidden="false" typeId="c019-cd95-f4ce-816e" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8cca-6c13-db66-0ad8">Una miniatura que lleva su armadura inscrita con la Runa de Preservación es inmune a las reglas especiales Golpe Letal y Heridas Múltiples (X). Si el portador sufre heridas de un ataque con cualquiera de estas reglas especiales, pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6e4f-dada-3cd6-18a7" name="Runa de fortaleza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ad0-f513-0c9b-dd10" type="max"/>
          </constraints>
          <profiles>
            <profile id="a84f-3c13-e69c-6c8f" name="Runa de fortaleza" hidden="false" typeId="c019-cd95-f4ce-816e" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8cca-6c13-db66-0ad8">Por cada Runa de Fortaleza inscrita en la Armadura del portador tiene un modificador de +1 a su atributo de Resistencia (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7366-5c70-d763-5d86" name="Runa de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fb82-1406-d353-0d79" type="max"/>
          </constraints>
          <profiles>
            <profile id="18d2-8c2b-60ea-8a15" name="Runa de hierro" hidden="false" typeId="c019-cd95-f4ce-816e" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="8cca-6c13-db66-0ad8">Una miniatura que lleva una armadura inscrita con una Runa de Hierro tiene +1 Herida en su perfil.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
