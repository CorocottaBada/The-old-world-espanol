              <characteristics>
                <characteristic name="Reglas especiales" typeId="4b70-c2f7-6537-8a18">Una unidad que lleva un estandarte con la inscripción Runa de Strollaz obtiene la regla especial Vanguardia.</characteristic>
              </characteristics>
