          </constraints>
          <profiles>
            <profile id="0419-0575-4054-45f8" name="Runa del agravio" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Por cada Runa de los Agravios inscrita en un arma, su portador puede repetir una única tirada para Impactar de un resultado natural de 1 durante la fase de Combate.</characteristic>
