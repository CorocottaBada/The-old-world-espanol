            <profile id="dccb-df4e-3a3a-f9e4" name="Runa del destierro" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Las miniaturas enemigas con la regla especial Nacidos de la Disformidad no pueden realizar salvaciones especiales contra impactos causados por un arma inscrita con la Runa del Destierro.</characteristic>
              </characteristics>
            </profile>
