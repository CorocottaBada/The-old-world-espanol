      </constraints>
      <selectionEntries>
        <selectionEntry id="3c35-b57d-f7bb-3a6e" name="Runa empaladora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ffc0-c1c3-13f2-8662" type="max"/>
          </constraints>
          <profiles>
            <profile id="3b98-f13b-ba1b-8e56" name="Runa empaladora" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Sólo lanzavirotes. Un lanzavirotes inscrito con la Runa Empaladora tiene un modificador de + 1 a su atributo de Fuerza. Además, no se permite ninguna salvación por armadura contra heridas causadas por un lanzavirotes inscrito con la Runa de Empaladora (las salvaciones especiales y regeneración se pueden intentar de forma normal).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
