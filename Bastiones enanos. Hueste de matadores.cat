        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="58dc-6579-84cc-05df" name="Runas talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac6b-9563-2a42-16ab" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d68d-41e1-8a92-5c8d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a6dc-d266-8ac2-7c48" name="Runa rompehechizos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c8fb-ce63-2910-c382" type="max"/>
          </constraints>
          <profiles>
            <profile id="b7be-de6c-0458-62a9" name="Runa rompehechizos" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Solo Yunque Rúnico, Herreros Rúnicos Enanos o Señores de las Runas. Un solo uso. El portador de la Runa Rompehechizos podrá utilizarlo en lugar de un intento de dispersión. Si lo hacen, el hechizo se disipa automáticamente sin necesidad de realizar una tirada de Dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="86be-c746-d81c-61e4" name="Runas talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c430-4cc8-6fc0-5391" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="73c8-5d71-f75d-4797" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4958-9afa-69c9-07ce" name="Runa del pasadizo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="efa8-87e1-0458-0879" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bb5d-5a8f-71b6-f73b" type="max"/>
          </constraints>
          <profiles>
            <profile id="ab84-bc5a-c860-50c4" name="Runa del pasadizo" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">El portador de una Runa del Pasadizo gana la regla especial Mover a Través de Cobertura. Cualquier unidad a la que el portador se una también gana la regla especial Mover a Través de Cobertura. Si el portador abandona la unidad por cualquier motivo, la unidad pierde esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="df08-d95e-7ea0-a87c" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9907-eeb8-4069-3f28" name="Runa ígnea" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cb0f-8aa7-c258-7520" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b4f1-8e5f-93cd-8393" type="max"/>
          </constraints>
          <profiles>
            <profile id="233a-8fb1-d79a-8d30" name="Runa ígnea" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">El portador de una Runa Ígnea tiene una Salvación Especial de 3+ contra cualquier herida sufrida por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e910-d9a7-2a92-7bc0" name="Runa de la suerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6cde-22e5-c89c-a372" type="max"/>
          </constraints>
          <profiles>
            <profile id="22d4-4753-d6af-c8eb" name="Runa de la suerte" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Un solo uso. El portador de una Runa de la Suerte puede repetir una única tirada fallida para Impactar o para Herir, o repetir una única tirada fallida de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1173-5497-3239-d1de" name="Runa de defensa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="84b9-f665-0f63-2455" type="max"/>
          </constraints>
          <profiles>
            <profile id="c12b-7ce9-4750-f407" name="Runa de defensa" hidden="false" typeId="356f-da1f-573b-1dcf" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e70b-1936-66eb-48d1">Un solo uso. Cada Runa de Defensa le da al portador una Salvación Especial de 2+ contra una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4a44-0ce0-70ac-8a76" name="Runas magistrales talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6cdc-0280-9f14-eb78" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8f4f-ae4f-0c56-2ef7" type="min"/>
      </constraints>
      <selectionEntries>
