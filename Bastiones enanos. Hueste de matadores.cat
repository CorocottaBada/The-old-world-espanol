            <profile id="5bb5-66e1-f892-4966" name="Runa de la furia" hidden="false" typeId="e76d-596d-60d2-a3ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="fd47-d322-f1a8-2806">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
