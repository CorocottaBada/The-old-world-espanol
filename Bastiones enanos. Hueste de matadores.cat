            <profile id="c858-b194-145b-1e5c" name="Runa de la firmeza" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Al calcular el Resultado del combate, una máquina de guerra inscrita con la Runa de la Firmeza puede reclamar una bonificación de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dc73-6250-9e0a-2404" name="Runa de la recarga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d868-891f-57b4-de41" type="max"/>
          </constraints>
          <profiles>
            <profile id="7703-a40c-90fe-9e65" name="Runa de la recarga" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Una máquina de guerra inscrita con una Runa de la Recarga puede disparar en cada turno, incluso si tuvo Mal Funcionamiento en su turno anterior.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e147-179c-2403-84dc" name="Runa de la forja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e0ce-b537-051f-ae62" type="max"/>
          </constraints>
          <profiles>
            <profile id="2f4b-c66a-12ce-7d40" name="Runa de la forja" hidden="false" typeId="ae92-2161-0c7b-281c" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="16f8-8f32-bc20-6e22">Un solo uso. Una máquina de guerra inscrita con una Runa de la Forja puede usarla para repetir un único fallo en el Dado de artillería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
