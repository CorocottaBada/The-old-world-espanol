              <profiles>
                <profile id="3a99-1423-c2fc-12f1" name="Cercenagoblins" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">36&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Aparatoso, Mover o disparar, Fatalidad giratoria.</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma usa la Tabla de Problemas de la Catapulta.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="fc4a-133f-9a39-631c" name="Fatalidad giratoria" hidden="false">
                  <description>Con una sola salva de hachas giratorias, un Cercenagoblins puede atravesar
varias filas de tropas. Al disparar con un Cercenagoblins, tira un dado de Artillería antes de hacer cualquier tirada para Impactar. El número de disparos disparados es igual a la tirada del dado de Artillería más un modificador de 1D3:
Por fila (incluida la fila trasera, incluso si está incompleta), si el Cercenagoblins se encuentra en el arco frontal o trasero de la unidad.
Por columna, si el Cercenagoblins se encuentra en el arco lateral de la unidad.
Sin embargo, si se obtiene un resultado de Problemas en el dado de Artillería, no se disparan hachas y se ha producido un fallo crítico. Tira inmediatamente en la Tabla de Problemas apropiada para determinar exactamente el qué.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="828f-531a-915a-44ca" name="Tabla de problemas de catapulta" hidden="false" targetId="8102-a2c7-597b-f03e" type="rule"/>
                <infoLink id="65d5-063c-16d5-8a4f" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
                <infoLink id="2422-10f9-77e5-8a52" name="Mover o disparar" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="94cf-da56-c2be-cd96" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
