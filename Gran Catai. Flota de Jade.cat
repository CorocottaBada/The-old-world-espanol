            <selectionEntry id="f9c8-eaa6-df12-12ee" name="Centinela de Jade" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="329e-f669-3f2c-19a7" type="max"/>
              </constraints>
              <profiles>
                <profile id="c147-b151-91e2-0a2d" name="Centinela de Jade" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Jade conoce un único hechizo (elegido por su jugador controlador antes de desplegar los ejércitos) del Saber de la Magia de Batalla o del Saber de Elementalismo. Puede lanzar este hechizo como un Hechizo Vinculado con un Nivel de Energía 3.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="e5dc-0d07-6547-f175" name="Centinela de Terracota" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="85cb-3e61-24c8-497f" type="max"/>
              </constraints>
              <profiles>
                <profile id="d591-8086-849d-77f9" name="Centinela de Terracota" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Terracota tiene la regla especial Regeneración (6+).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="09c3-80af-bda3-289c" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
