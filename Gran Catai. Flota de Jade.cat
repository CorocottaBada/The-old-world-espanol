            </selectionEntry>
            <selectionEntry id="cfc5-9d81-f5f3-b60c" name="Centinela de Obsidiana" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="474a-1523-9c80-16d3" type="max"/>
              </constraints>
              <profiles>
                <profile id="f522-b22e-22f2-bd7c" name="Centinela de Obsidiana" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Obsidiana tiene la regla especial Resistencia a la Magia (-2). Además, cualquier Hechicero enemigo que desee lanzar un hechizo mientras esté a 12&quot; o menos de uno o más Centinelas de Obsidiana debe primero superar un chequeo de Liderazgo. Si se falla este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -3. Si se supera este chequeo, la tirada de Lanzamiento del Hechicero sufre un modificador de -1.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="02dd-4e0f-d7c0-d12d" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="7f22-e737-5667-8193" name="Centinela de Granito" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f514-273d-342d-cbe2" type="max"/>
              </constraints>
              <profiles>
                <profile id="e741-208e-0ff4-4116" name="Centinela de Granito" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Granito mejora su valor de armadura en 1. Además, un Centinela de Granito es inmune a la regla especial Heridas Múltiples (X). Si un Centinela de Granito sufre una herida no salvada de un ataque con esta regla especial, pierde una única Herida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="a99e-2169-c2b4-9617" name="Centinela de Piedra de disformidad" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f6ff-9a24-1783-76f2" type="max"/>
              </constraints>
              <profiles>
                <profile id="fef2-e413-9cdc-1d2f" name="Centinela de Piedra de disformidad" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Un Centinela de Piedra de Disformidad tiene la regla especial Ataques Mágicos. Además, mientras esté en contacto peana con peana con uno o más Centinelas de Piedra de Disformidad, las unidades enemigas sufren un modificador de -1 a su atributo de Resistencia (hasta un mínimo de 1).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="a9cc-dc85-f02f-08f7" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
              </costs>
            </selectionEntry>
