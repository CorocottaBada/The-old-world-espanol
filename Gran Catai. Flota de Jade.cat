  <sharedSelectionEntryGroups>
    <selectionEntryGroup id="d905-4674-3242-8127" name="Talismanes. Gran Catai. Infantería o caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df40-6bc4-8550-c612" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e97d-4dee-0f35-8587" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="24db-813d-4a4c-2daa" name="El Manto del Cielo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b2c0-b1e1-9cf8-a48c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d739-308a-f1ed-d8dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="eb80-fde6-d8a2-a2c7" name="El Manto del Cielo" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. Puede llevarse con otra armadura. El portador del Manto del Cielo mejora su valor de armadura en 2 (hasta un máximo de 2+) contra ataques de disparo no mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="708e-9c2e-c42a-8cf7" name="Talismanes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e416-11f0-260c-0e30" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3249-8168-2798-c98f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cd96-3fcf-4e5c-4d6f" name="Corona de Jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b483-b123-425e-58d5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a00-5a2d-8674-2b91" type="max"/>
          </constraints>
          <profiles>
            <profile id="1f51-a569-3f63-b02f" name="Corona de Jade" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">La Corona de Jade otorga a su portador una salvación especial de 4+ contra cualquier herida sufrida que haya sido causada por un Proyectil Mágico, un Vórtice Mágico o un hechizo de Asalto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dd6e-0b26-1cac-2ead" name="Escudo de Nan-Gau" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="475c-7aa2-4186-95ee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d518-9d03-4c41-962d" type="max"/>
          </constraints>
          <profiles>
            <profile id="f84c-6c49-a226-b2d2" name="Escudo de Nan-Gau" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Escudo de Nan-Gau es un escudo. Además, durante un turno en el que su portador fue cargado, el Escudo de Nan-Gau mejora el valor de armadura de su portador en 2 (hasta un máximo de 2+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1e7e-7bab-3c5e-f3c9" name="Escudo (Shield)" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b0eb-94cb-d345-f0ad" name="Sello de Humo y Pólvora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1629-19e1-5fba-f075" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f612-18ba-2112-c95b" type="max"/>
          </constraints>
          <profiles>
            <profile id="0abd-915d-4116-f4be" name="Sello de Humo y Pólvora" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que designe como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2abd-159e-99a7-f3d1" name="Cristal de Kunlan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ce56-4952-482e-1a5e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8ce4-a4eb-9536-2f1a" type="max"/>
          </constraints>
          <profiles>
            <profile id="3571-2afa-29da-0303" name="Cristal de Kunlan" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Cristal de Kunlan otorga a su portador una salvación especial de 5+. Además, si se obtiene un 6 natural al realizar la salvación especial, cada modelo enemigo en contacto peana con peana con el portador sufre un impacto de Fuerza 3 con un PA de -. Estos ataques tienen la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8fee-0407-b407-455d" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2fcd-7026-8577-ee95" name="Talismanes muy comunes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4ed6-7a55-aaf6-c359" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7d0f-e407-a8d3-b170" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3961-e6ad-e25b-4af5" name="Plumas Bermellón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bc14-8296-9335-f95d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7102-f5cb-be7c-d9c3" name="Plumas Bermellón" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">0-1 por miniatura. Un solo uso. El portador de una Pluma Bermellón (pero no su montura) puede repetir cualquier tirada fallida para Impactar y/o para Herir realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b933-bf59-173d-a64c" name="Objetos hechizados. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="833a-e383-6404-d69b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ceb-6071-6ab5-da09" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="509a-50d2-ee17-3bb2" name="Fragmento de las Fauces" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="11aa-c722-8a8d-c87c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f8ba-291e-5700-bccc" type="max"/>
          </constraints>
          <profiles>
            <profile id="14be-b34c-9898-4022" name="Fragmento de las Fauces" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Si un Hechicero enemigo saca cualquier doble natural al hacer una tirada de Lanzamiento mientras esté a 18&quot; o menos del portador del Fragmento de las Fauces, el hechizo sufre una disfunción, independientemente del resultado de la tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="94c5-c933-c78f-5b66" name="Máscara del Alquimista" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6b8e-0b82-bfce-58d8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6369-9ad2-9ca2-750b" type="max"/>
          </constraints>
          <profiles>
            <profile id="03ae-f7b4-3b21-b528" name="Máscara del Alquimista" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de la Máscara del alquimista puede lanzar el hechizo Plaga de Óxido del saber del Elementalismo (ver página 327 del reglamento de Warhammer: the Old World) como un Hechizo Vinculado, con un Nivel de Energía de 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ca56-1fdf-3574-fa1b" name="León Dorado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9978-a89e-d22b-48a2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a93-f88f-88ae-25c6" type="max"/>
          </constraints>
          <profiles>
            <profile id="3e2b-7a68-7e42-a401" name="León Dorado" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del León Dorado y su unidad pueden repetir cualquier chequeo de Miedo, Pánico, Reagruparse o Terror fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3246-fe4d-a519-2541" name="Anillo de Azabache" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3927-7ceb-621f-e28b" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b578-4781-85cc-feab" type="max"/>
          </constraints>
          <profiles>
            <profile id="925e-0652-4dc0-0a3b" name="Anillo de Azabache" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Anillo de Azabache puede lanzar el hechizo Espíritus Inquietos del Saber de la Nigromancia (ver página 333 del reglamento de Warhammer: the Old W orld) como un Hechizo Vinculado, con un Nivel de Energía 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9654-c80c-9153-c200" name="Objetos hechizados muy comunes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3bc7-bd38-f1b8-5e23" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="301d-fb83-dff7-bca4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="d225-5292-6a56-4f06" name="Linterna Espiritual" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dc57-5f96-ffef-951c" type="max"/>
          </constraints>
          <profiles>
            <profile id="7dfb-7ace-8f5f-f869" name="Linterna Espiritual" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un modelo que porte una Linterna Espiritual causa Terror. Además, una miniatura que porte una Linterna Espiritual puede repetir cualquier tirada para Herir de un 1 natural contra miniaturas enemigas que sean &apos;Demoníacos&apos; o &apos;No Muertos&apos;.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d7aa-2084-eb63-f437" name="Terror (Terror)" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="17d2-a207-1a93-a5b2" name="Los Fuegos de Nan-Gau" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="75b9-49af-7c61-920d" type="max"/>
          </constraints>
          <profiles>
            <profile id="1e1f-b83b-b314-8330" name="Los Fuegos de Nan-Gau" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">0-1 por miniatura. Un solo uso. Los Fuegos de Nan-Gau es un arma de aliento con el siguiente perfil:</characteristic>
              </characteristics>
            </profile>
            <profile id="a519-1936-a470-6810" name="Los Fuegos de Nan-Gau" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">N/A</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4</characteristic>
                <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Arma de Aliento, Ataques Flamígeros, Ataques Mágicos</characteristic>
                <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">-</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="eaff-a48d-b02a-2afb" name="Arma de aliento (Breath weapon)" hidden="false" targetId="28ba-f733-cc16-d9e7" type="rule"/>
            <infoLink id="569b-84c7-3735-0fb1" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="6b4c-afdd-712c-ebe3" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2844-d23c-b3f4-a8cf" name="Objetos arcanos. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="645a-92a5-9d81-fd0e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0741-c03f-f1f2-511f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4c29-9a4f-23aa-efed" name="Pergaminos de Wei-jin" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7f13-d63d-ce74-236e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dbf2-cbf2-5c40-8c87" type="max"/>
          </constraints>
          <profiles>
            <profile id="fa2d-2239-409f-6f49" name="Pergaminos de Wei-jin" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador de los Pergaminos de Wei-jin conoce un hechizo más (elegido de la forma habitual) de lo normal para su Nivel de Hechicería. Sin embargo, solo puede lanzar un número de hechizos igual a su Nivel de Hechicería por turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="21b9-f0e1-54d4-46d3" name="Brújula Mecánica" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="72d3-6fcc-8d6b-96dc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3535-cbbf-a147-51d4" type="max"/>
          </constraints>
          <profiles>
            <profile id="5d03-a084-98d2-87d4" name="Brújula Mecánica" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. El portador puede usar este objeto en lugar de realizar un intento de dispersión de Hechicero. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de una tirada de Dispersión. Además, todos los hechizos de &apos;Permanece en Juego&apos; actualmente en juego son dispersados, incluyendo los hechizos lanzados por Hechiceros amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5b6a-eb6a-9d50-4e97" name="Capa de Po Mei" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7c7e-561b-bb7e-b373" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4cce-500b-cd52-f86a" type="max"/>
          </constraints>
          <profiles>
            <profile id="03ff-2113-0373-aa90" name="Capa de Po Mei" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Además de sus hechizos generados aleatoriamente, el portador de la Capa de Po Mei conoce los tres hechizos del Saber de Yin o del Saber de Yang (elegido por su jugador controlador). Sin embargo, solo puede lanzar un número de hechizos igual a su Nivel de Hechicería por turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="907f-89bb-e3b8-3d47" name="Objetos arcanos muy comunes. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3fcf-8250-4d98-9882" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d86a-98b6-ab38-6b71" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5b2a-72b1-d504-7640" name="Feng Shi Bo Erudito" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2b87-3f04-f9b3-5fd2" type="max"/>
          </constraints>
          <profiles>
            <profile id="8541-cfcf-ac83-f52f" name="Feng Shi Bo Erudito" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El dueño de un Feng Shi Bo Erudito conoce un hechizo más (elegido de la forma habitual) de lo normal para su Nivel de Hechicería.
Nota: Esto no aumenta el Nivel de Magia del Hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7477-a40e-da8e-ea92" name="Sello de Xing Po" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d7be-0163-15b4-cf6b" type="max"/>
          </constraints>
          <profiles>
            <profile id="bc26-229b-52bb-f1e7" name="Sello de Xing Po" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por miniatura. Si lo deseas, el portador de un Sello de Xing Po puede descartar dos de sus hechizos generados aleatoriamente (en lugar del habitual) y en su lugar seleccionar dos hechizos personales, ya sea del Saber de Yang o del Saber de Yin (determinado por cuál de esas dos reglas especiales tenga).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e619-66f2-d0b0-617d" name="Guardián Feng Shi Bo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f145-da12-7bcc-352f" type="max"/>
          </constraints>
          <profiles>
            <profile id="ca21-a1c6-4e22-2fd3" name="Guardián Feng Shi Bo" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Cualquier modelo enemigo que dirija sus ataques contra el dueño de un Guardián Feng Shi Bo durante la fase de Combate sufre un modificador de -1 a sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9ebf-240a-36d4-f4bd" name="Estandartes mágicos. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d78b-9b52-2536-406f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5c74-5f85-62dd-2cfb" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dd6d-3c7f-4dd7-ff8f" name="Estandarte de Wei-Jin" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="16ea-9b5e-563d-85be" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01ec-2692-6707-bc5a" type="max"/>
          </constraints>
          <profiles>
            <profile id="83b5-89c1-5526-90f6" name="Estandarte de Wei-Jin" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de Wei-jin causa Miedo. Además, todas las unidades enemigas a 12&quot; o menos de la miniatura que porta el Estandarte de Wei-jin sufren un modificador de -1 a su atributo de Liderazgo al realizar un chequeo de Miedo, Pánico o Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d192-629e-c070-a8c9" name="Icono de la Furia Celestial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="39c3-cebd-e310-7614" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1102-e8aa-f552-ae52" type="max"/>
          </constraints>
          <profiles>
            <profile id="ede1-2c49-1805-b1cf" name="Icono de la Furia Celestial" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, el portador de este estandarte puede intentar desatar su poder haciendo un chequeo de Liderazgo (utilizando su propio Liderazgo sin modificar). Si se supera este chequeo, las unidades enemigas no pueden utilizar la regla especial Volar (X) hasta tu siguiente subfase de Inicio del Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3d0c-1413-a681-571f" name="Estandarte del Ojo de Dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4508-463e-95d5-2422" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a59-96bb-481e-81be" type="max"/>
          </constraints>
          <profiles>
            <profile id="8764-b92b-54bc-40ab" name="Estandarte del Ojo de Dragón" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando un Hechicero enemigo elige como objetivo de un hechizo a una unidad que porta el Estandarte del Ojo de Dragón, tira un 1D6. Con un 4+, el jugador controlador del Hechicero debe elegir otro objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6324-4120-0727-93aa" name="Estandarte del Bastión" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4010-0705-420d-d7d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="76be-0162-821d-6510" type="max"/>
          </constraints>
          <profiles>
            <profile id="7eff-6d16-96d8-994b" name="Estandarte del Bastión" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte del Bastión gana la regla especial Muro de Escudos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6bd4-cfd1-6f52-2eaa" name="Muro de escudos (Shieldwall)" hidden="false" targetId="8782-fdac-65da-b2f9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0394-0ea5-dfb2-22dc" name="Estandarte de la Ira del Dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6bbd-db93-52a7-58a3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0fd5-0044-ea06-2898" type="max"/>
          </constraints>
          <profiles>
            <profile id="8a31-2e75-13bf-27d0" name="Estandarte de la Ira del Dragón" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de la Ira del Dragón gana las reglas especiales Ataques Flamígeros e Impactos por Carga (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0549-a7c2-2ea3-05d6" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="c240-2af7-9cf7-ecb8" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="35d7-951c-dc5e-d09a" name="El Estandarte de Jade" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="de6f-bc23-aaac-8633" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8454-70fd-590d-db46" type="max"/>
          </constraints>
          <profiles>
            <profile id="c73c-cacd-9992-bf9d" name="El Estandarte de Jade" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado de combate, una unidad que porte el Gran Estandarte de la Superioridad puede reclamar una bonificación adicional de +2 puntos al resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="897c-dd9e-ea24-6ac6" name="El Sudario de Shiyama" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="207f-9038-5238-50e4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f38e-2f1d-39c3-497f" type="max"/>
          </constraints>
          <profiles>
            <profile id="f370-aa4e-66e5-0cf2" name="El Sudario de Shiyama" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Sudario de Shiyama gana la regla especial Miedo. Si ya tienen la regla especial Miedo, en su lugar ganan la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bfd0-b092-97fa-c9bd" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6033-69e0-187e-192c" name="El Estandarte de Xen Wun" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="be9c-c382-2b8d-bc71" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f73e-af9a-3e19-df19" type="max"/>
          </constraints>
          <profiles>
            <profile id="8bd7-8779-c089-db66" name="El Estandarte de Xen Wun" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Las unidades enemigas que deseen declarar una reacción a la carga de Aguantar y Disparar o Disparar y Huir contra una unidad que porte el Estandarte de Xen Wun deben primero superar un chequeo de Liderazgo. Si se supera este chequeo, pueden declarar una reacción a la carga de Aguantar y Disparar o Disparar y Huir. Si se falla este chequeo, deben Mantener la Posición.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6801-d0a5-fa63-c764" name="Armas mágicas. Gran Catai. Caballería, Monstruo, Carro" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6dc-dfdb-8667-2854" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a793-6823-c118-b3c2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="de46-9e47-da9a-cc6d" name="Lanza del Longma Espiritual" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8f59-aefa-6e12-9b7d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3526-5019-2fb7-1641" type="max"/>
          </constraints>
          <profiles>
            <profile id="38e5-ef9f-16c7-a4a2" name="Lanza del Longma Espiritual" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques Mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Solo miniaturas cuyo tipo de tropa es &apos;caballería&apos;, &apos;monstruo&apos; o &apos;carro&apos;. Los modificadores de Fuerza y Penetración de Armadura de la Lanza del Longma Espiritual solo se aplican durante un turno en el que el portador haya cargado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c089-add8-3ca6-4e2e" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="0988-efd1-ce31-9221" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7d61-f3b0-e277-3ba4" name="Armas mágicas. Gran Catai" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7547-b67d-ca76-654b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4829-7a35-a2db-5ff8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fe3b-e832-3ace-9f83" name="La sabiduría del Rey Mono" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b0ec-bf19-1452-1d97" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="da8b-10e2-a381-a724" type="max"/>
          </constraints>
          <profiles>
            <profile id="5f76-ad91-7c92-3cbf" name="La sabiduría del Rey Mono" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">10</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-4</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques Mágicos, Heridas Múltiples (1D3), Requiere Ambas Manos, Golpea Último</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">-</characteristic>
              </characteristics>
            </profile>
