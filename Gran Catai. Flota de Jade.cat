      </constraints>
      <selectionEntries>
        <selectionEntry id="1c09-12de-acea-a5e6" name="La Armadura del Ave de Guerra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5765-bae0-21c5-87e0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1935-ff33-01e3-e9fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="e12e-6268-73e1-181d" name="La Armadura del Ave de Guerra" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa es &apos;infantería regular&apos; o &apos;infantería pesada&apos;. La Armadura del Ave de Guerra es una armadura pesada. Además, el portador gana las reglas especiales Contracarga, Volar (9) y Zancada Veloz. Sin embargo, el portador no puede unirse a una unidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d5d5-1655-e26f-2382" name="Contracarga (Counter charge)" hidden="false" targetId="4ed0-6ae1-04ef-a764" type="rule"/>
            <infoLink id="c8d3-5c45-2ad2-8335" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
            <infoLink id="ba84-6997-4c34-a9e6" name="Zancada veloz (Swiftstride)" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
