                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-48&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">3 (4)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-1)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Bombardeo, Ataques flamígeros, Mover o disparar, Espíritus aullantes</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial &apos;Bombardeo&apos;, una plantilla de área de 5&quot; y la Tabla de Problemas de la Pólvora Negra.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="7420-ddb1-f9ef-d4fe" name="Espíritus aullantes" hidden="false">
                  <description>Cualquier unidad que sufra una o más heridas no salvadas por esta arma debe hacer un chequeo de Pánico como si hubiera sufrido muchas bajas.</description>
                </rule>
              </rules>
