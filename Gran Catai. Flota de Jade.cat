    <selectionEntry id="2290-28e2-2b99-ea28" name="Matriarca Suprema de Nan-Gau Guerreros jade" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="25a6-f96e-78be-6637" type="equalTo"/>
