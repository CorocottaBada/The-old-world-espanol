    <profile id="e3ff-6e2e-112d-c118" name="Lanza catayana" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
      <characteristics>
        <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">Combate</characteristic>
