        <infoLink id="e741-5055-9ee5-57a6" name="Huída simulada (Feigned flight)" hidden="false" targetId="3337-801f-4d0f-1ea5" type="rule"/>
        <infoLink id="4c97-7763-b517-3dd4" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
