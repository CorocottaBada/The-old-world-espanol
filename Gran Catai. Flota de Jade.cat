          <profiles>
            <profile id="85aa-39fa-3fa6-c83a" name="Armadura de Jade de Beichai" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Jade de Beichai es una armadura de placas completa. Además, el portador de la Armadura de Jade tiene una salvación Especial de 5+ contra cualquier herida sufrida y gana la regla especial Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
