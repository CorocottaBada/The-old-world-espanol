        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Perforacorazas (1), Luchar con una fila extra</characteristic>
        <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Solo para miniaturas cuyo tipo de tropa sea &apos;caballería&apos;, &apos;monstruo&apos; o &apos;carro&apos;. Los modificadores de Fuerza y Perforación de Armadura de la Lanza Catayana solo se aplican contra miniaturas enemigas a las que el portador cargó ese turno.</characteristic>
      </characteristics>
    </profile>
    <profile id="5dc8-d4e2-de2c-8cd6" name="Pistola de fuego de dragón" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
