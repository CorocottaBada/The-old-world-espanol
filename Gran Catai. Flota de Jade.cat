        <selectionEntry id="daed-f5ae-ae2d-1c57" name="Protector del cazador de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e04e-0a48-2747-6ea7" type="max"/>
          </constraints>
          <profiles>
            <profile id="3814-eb7c-9ab3-7cbf" name="Protector del cazador de brujas" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Una miniatura que porte un Protector del Cazador de Brujas tiene la regla especial Resistencia a la Magia (-2). Además, una vez por partida, el portador de un Protector del Cazador de Brujas puede repetir una única tirada fallida de Salvación de Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b653-383d-a5b0-f2bb" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b358-7917-0e85-042d" name="Objetos hechizados. El Imperio. Zancada veloz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a02-7d3c-147a-27c9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="074d-ebfa-ec0e-8a54" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fe80-0cca-28ba-4669" name="El cuerno de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4bbb-4887-f988-492e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de3a-6cae-32f9-11d4" type="max"/>
          </constraints>
          <profiles>
            <profile id="6952-9959-8686-38e8" name="El cuerno de plata" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Sólo personajes con la regla especial Zancada Veloz. El portador del Cuerno de Plata (y cualquier unidad a la que se haya unido) puede repetir el 1D6 de la regla especial Zancada Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="68ae-548a-113b-9721" name="Zancada veloz" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9e61-1d8c-9f75-9021" name="Objetos hechizados. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="71d6-29ee-de25-2e3f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aa19-96f1-e22c-7fd2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a650-36de-56e5-c609" name="Laurel de la victoria" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a916-655a-9dca-2856" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="50a6-a920-bccd-8f10" type="max"/>
          </constraints>
          <profiles>
            <profile id="8b21-d079-2776-3355" name="Laurel de la victoria" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cuando se determine el resultado de tu combate, cada herida no salvada causada por un ataque hecho por el portador del Laurel de la Victoria se cuenta como 2 puntos para el resultado del combate, en vez de 1 punto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6d38-20f2-eac3-2b0b" name="Manto de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f66-ddf9-34bf-749a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="93be-15f0-71fc-a101" type="max"/>
          </constraints>
          <profiles>
            <profile id="e1a0-55d4-9bb4-720b" name="Manto de hierro" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de Hierro (y cualquier unidad a la que se haya unido) tiene una Salvación Especial de 6+ contra cualquier herida causada por una plantilla no-mágica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7e6a-a134-d49f-7892" name="Anillo de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="87ea-22fc-0ff1-b951" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="200b-4c17-6041-890c" type="max"/>
          </constraints>
          <profiles>
            <profile id="4e3b-12ee-5337-77eb" name="Anillo de la fortuna" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de la Fortuna puede repetir cualquier tirada fallida para Herir realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4bc7-5b13-bd63-3b1f" name="Anillo de Taal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c1b5-12bb-d749-e0ae" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ea4d-ac9d-0460-3659" type="max"/>
          </constraints>
          <profiles>
            <profile id="9b59-6c96-fe2e-87f9" name="Anillo de Taal" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de Taal puede lanzar el hechizo Escudo de Roble del Saber de la Magia de Batalla (ver página 321 del reglamento de Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="998c-ac0a-0b67-b5cd" name="Objetos arcanos. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aec6-350e-fd0d-0616" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5d5b-08da-ac82-0989" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8f05-0b5c-e537-dd97" name="Libro de los Ashur" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b89d-dae3-f5b8-1cb0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e09d-8c92-7e2e-d9a2" type="max"/>
          </constraints>
          <profiles>
            <profile id="1fbe-9c48-90d2-3270" name="Libro de los Ashur" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Libro de los Ashur aumenta su Alcance de Dispersión en 3” y, excepto si obtiene algún resultado de doble natural, puede aplicar un modificador de +1 a cualquiera de sus tiradas de Lanzamiento o Dispersión. Sin embargo, si el portador obtiene un resultado de doble natural al hacer una tirada de Lanzamiento o Dispersión, resulta que el libro es una pobre reproducción, lleno de errores garrafales, y el modificador de +1 no se puede aplicar a esta tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="85.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3d65-5d77-6aa3-d67c" name="Varita de dos colas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="36ae-ea43-3350-6e1e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e3d6-7b6c-89c6-2cca" type="max"/>
          </constraints>
          <profiles>
            <profile id="b5a1-4e0c-9291-252e" name="Varita de dos colas" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, el portador de la Varita de Dos Colas puede intentar lanzar uno de sus hechizos una segunda vez.
Sin embargo, si realiza una disfunción al lanzar el hechizo, el portador se ve abrumado por los Vientos de la Magia y, en lugar de tirar en la tabla de Disfunción Mágica, sufre 1D3 heridas sin poder hacer tiradas de salvación por Armadura o Regeneración (las tiradas de salvación Especiales se pueden intentar como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="28c8-98a9-a56c-c64f" name="Tomo de medianoche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="213d-6780-2b45-6bdb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c7e5-a496-44ca-392d" type="max"/>
          </constraints>
          <profiles>
            <profile id="bc10-b34c-269e-c7aa" name="Tomo de medianoche" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Tomo de la Medianoche puede aplicar un modificador de +1 a cualquier tirada de Lanzamiento al intentar lanzar hechizos de los Saberes de Demonología, Magia Oscura o Nigromancia. Además, conoce un hechizo adicional (elegido de la manera habitual) más de lo que es normal para su Nivel de Hechicería. Sin embargo, el portador sólo puede lanzar un número de hechizos igual a su Nivel de Hechicería por turno y está sujeto a la regla especial Solitario.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="bc42-4530-eae5-24e2" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="385a-ceb2-cae9-7526" name="Bola de cristal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3fdb-f2a7-1eed-7286" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ba96-8b42-3071-3875" type="max"/>
          </constraints>
          <profiles>
            <profile id="ede7-9aaf-5c18-0817" name="Bola de cristal" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, puedes hacer que tu oponente repita una sola tirada para Impactar o Herir realizada contra una miniatura amiga que esté dentro del Aura de Mando del portador de la Bola de Cristal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ae4d-5d0a-66e1-42ad" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c949-2d2a-6dc1-f4bc" name="Objetos arcanos muy comunes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c81f-ae1b-d288-500b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="158b-3828-cbdc-1a64" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5105-6a72-4c2a-c565" name="Familiar del hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="862b-c56f-42ff-df1c" type="max"/>
          </constraints>
          <profiles>
            <profile id="803e-a793-794d-3d84" name="Familiar del hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El dueño de un Familiar del hechicero puede aplicar un modificador de +1 a cualquiera de sus tiradas de Dispersión. 
Ten en cuenta que es un modificador al resultado de la tirada – no niega una tirada de doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4522-fff0-9299-7f00" name="Báculo de hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a68-a36c-e61e-a944" type="max"/>
          </constraints>
          <profiles>
            <profile id="b6f3-c3ea-b30d-2db3" name="Báculo de hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El portador del Báculo de Hechicero obtiene un modificador de +1 a su tirada de Lanzamiento cuando intenta lanzar un hechizo de tipo Asalto o Proyectil Mágico</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="05bc-7655-a56e-df99" name="Armas mágicas. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="afad-20a9-24cd-54ad" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6469-bc36-9e5d-3cdf" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="01a2-ff0a-00b3-e1d3" name="Colmillo Rúnico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0f81-292a-3aa7-bb18" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ebc4-9445-8131-c82d" type="max"/>
          </constraints>
          <profiles>
            <profile id="bdfe-7634-dbb8-bef0" name="Colmillo Rúnico" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cuando se tira para Herir para un impacto causado por un Colmillo Rúnico, un resultado de 2+ es siempre un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f2f4-04a0-6306-8aaf" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="3ccc-52d7-57fd-afba" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="100.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1ea6-9e0a-cba6-e757" name="La maza de Helstrum" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9de0-109b-c507-52b9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66a4-5ec3-5a83-7f2c" type="max"/>
          </constraints>
          <profiles>
            <profile id="2dc5-8dd9-fe7c-cc5d" name="La maza de Helstrum (Arma de mano)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Maza de Helsturm tiene dos perfiles. Debes elegir cuál de los dos usará el portador al inicio de cada ronda de combate. Usada a dos manos, el portador puede hacer un único ataque, ignorando su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
            <profile id="5ce8-1094-a9cb-a5d2" name="La maza de Helstrum (Arma a dos manos)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">10</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-5</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Heridas múltiples (1D6), Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Maza de Helsturm tiene dos perfiles. Debes elegir cuál de los dos usará el portador al inicio de cada ronda de combate. Usada a dos manos, el portador puede hacer un único ataque, ignorando su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="b02a-7d63-acf9-1c55" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="c3c0-1d37-ca69-59c6" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
            <infoLink id="1d5d-88cd-0b52-e39d" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cdb8-64e8-3649-c472" name="Espada de la justicia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bbbe-f379-4bd3-45e0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a13-cc5d-4b36-87a5" type="max"/>
          </constraints>
          <profiles>
            <profile id="f988-54ac-4a74-c1d8" name="Espada de la justicia" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos, Heridas múltiples (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de la Espada de la Justicia puede repetir las tiradas para Herir falladas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5dad-eb7f-9fd0-8c39" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="dc8e-b73d-2c26-ee8f" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="6da5-42a7-6b68-fbce" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="36c4-edc4-a6a7-2595" name="Martillo de la rectitud" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0e2d-a058-c8d1-8e00" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0faa-3238-ef7b-44a6" type="max"/>
          </constraints>
          <profiles>
            <profile id="3d49-ed88-d369-577b" name="Martillo de la rectitud" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea último, Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Las miniaturas impactadas por el Martillo de la Rectitud deben hacer un chequeo de Liderazgo por cada impacto sufrido. Si se falla el chequeo, el impacto hiere automáticamente y no se permite ninguna tirada de Salvación por Armadura (las salvaciones Especiales o Regeneración se pueden realizar de manera normal). Si se supera el chequeo, las tiradas para Herir y las tiradas de
Salvación por Armadura se realizan de manera normal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="dbfb-3876-bc08-db47" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="2e6f-6b15-7ce5-d7c0" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
            <infoLink id="2e2e-b321-4feb-4b52" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9148-86f1-81b0-1899" name="Dagas perladas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="83b3-eabd-51fe-9d80" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b07-d413-10e4-507e" type="max"/>
          </constraints>
          <profiles>
            <profile id="b3f9-6f1e-03b4-0d69" name="Dagas perladas" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques adicionales (1D3), Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de las Dagas Perladas puede repetir cualquier tirada para Impactar fallada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5f15-5c4d-941b-9f68" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="4f99-1b6b-81ac-9a80" name="Ataques adicionales (+X)" hidden="false" targetId="93b1-1365-6161-7057" type="rule"/>
            <infoLink id="e108-7788-82bc-2bdf" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ef45-9d52-e7be-3e0c" name="Armaduras mágicas. El Imperio. Permite hechiceros. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f1f-9006-5375-1c3c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b57-703f-8dcb-c027" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="21c0-bfad-6df4-a65f" name="Armadura de Tarnus" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7607-c5a4-1615-8831" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b1b0-fe85-7636-b669" type="max"/>
          </constraints>
          <profiles>
            <profile id="fbc5-23aa-b0fd-2f55" name="Armadura de Tarnus" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Tarnus es una armadura ligera que puede ser equipada y utilizada por un Hechicero del Imperio, incluso si no tienen opción de equipar armadura, escudo o barda, sin restricción. Además, su portador tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5401-aedd-69df-7b29" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="fe28-9bd2-cd53-0e0a" name="Armaduras mágicas. El Imperio. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="afe7-afc1-cf78-7d4d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="176d-5b68-679b-77a0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2002-c2c7-a690-c494" name="Armadura de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f592-ffc7-4e04-d955" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e5bc-fe49-df18-f480" type="max"/>
          </constraints>
          <profiles>
            <profile id="a561-88d4-f9e7-7c79" name="Armadura de la fortuna" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de la Fortuna es una armadura pesada. Además, su portador tiene una Salvación Especial de 6+ contra cualquier herida sufrida y es inmune a la regla especial Golpe Letal. Si el portador recib un Golpe Letal, se permite Salvación por Armadura y Regeneración de manera normal. Si no se salva la herida, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="52d2-399b-dd74-384b" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7715-fc2f-12fd-3d94" name="Armadura dos veces bendita" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d223-dcd7-f816-4c29" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f64-cc00-4bc2-24af" type="max"/>
          </constraints>
          <profiles>
            <profile id="e661-423f-eaab-f00b" name="Armadura dos veces bendita" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura Dos Veces Bendita es una armadura completa. 
Además, el portador puede lanzar el hechizo Manomartillo del Saber de la Magia de Batalla (ver página 320 del reglamento
Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7914-dc5a-09a0-6d1b" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="779c-de3e-573a-c01b" name="Estandartes mágicos. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d70-e6a4-3064-4b07" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="845d-8626-87cb-ce97" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f67c-0ca5-d46e-b2a0" name="Estandarte imperial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fe4a-32e4-64dd-1fe0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3e65-2f9d-68a7-889a" type="max"/>
          </constraints>
          <profiles>
            <profile id="c46e-f9b0-e3d5-13c5" name="Estandarte imperial" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades dentro del Aura de Mando de la miniatura que porta el Estandarte Imperial tiran 3D6 al hacer chequeos de Miedo, Pánico o Terror y descartan el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d04f-ffac-3dc7-fc2c" name="Estandarte del grifo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="061f-a9a5-421f-7164" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1d47-7548-d11e-1b7b" type="max"/>
          </constraints>
          <profiles>
            <profile id="bc69-0e79-4851-8db6" name="Estandarte del grifo" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando se calcula el Resultado del combate, una unidad que porta el Estandarte del Grifo suma un Bonificador por Filas de +2 por cada fila extra tras la primera, en vez del +1 habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2468-5c34-f3c5-1f56" name="Pendón reluciente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9eba-826d-e6af-54c8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b159-8a72-2f5c-2ec7" type="max"/>
          </constraints>
          <profiles>
            <profile id="d672-f411-e935-e985" name="Pendón reluciente" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Una unidad que porta el Pendón Reluciente puede repetir un único Chequeo de Liderazgo fallado.
Ten en cuenta que Chequeo de Desmoralización no es un Chequeo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a480-5ee8-9f1f-6a7a" name="Estandarte del deber" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ce2e-c4a8-5c9d-6a2a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5551-27a8-c35d-4e39" type="max"/>
          </constraints>
          <profiles>
            <profile id="7aea-ec3a-40f5-49d1" name="Estandarte del deber" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del Deber puede repetir cualquier Chequeo de Reagrupamiento fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f476-5c07-cc98-3d0a" name="Tapiz del triunfo de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6650-a0b3-51cd-99a7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="10c9-2b02-7add-5aa2" type="max"/>
          </constraints>
          <profiles>
            <profile id="92d0-5595-ff0b-8ec5" name="Tapiz del triunfo de Sigmar" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tapiz del Triunfo de Sigmar puede repetir cualquier resultado natural de 1 para Herir durante la primera ronda de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0767-ba90-f514-ab3a" name="Icono de Morr" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0b5c-4a0f-2cde-8bb1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="343c-98eb-eb63-d106" type="max"/>
          </constraints>
          <profiles>
            <profile id="91e5-039a-f47b-f707" name="Icono de Morr" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Ícono de Morr gana la regla especial Miedo. Si ya tiene esta regla, en su lugar gana la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2ddd-4cea-eedc-a4cd" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="afe6-7030-535b-712f" name="Voluntad de los dragones" hidden="false">
      <description>Una unidad con esta regla especial puede repetir un chequeo de Pánico fallido cuando una unidad amiga es destruida a 6&quot; o menos de ella, o cuando es atravesada en su huida por una unidad amiga.</description>
    </rule>
    <rule id="2692-a82d-43a8-dc45" name="Transformación del dragón" hidden="false">
      <description>Transformación del Dragón
Los hijos del Dragón Celestial son criaturas poderosas de una edad inimaginable y, aunque eligen vivir como humanos entre el pueblo de Gran Catai, en la batalla no dudan en revelar sus verdaderas formas y desatar su poder sobre sus enemigos.
Un Dragón Catayano puede adoptar tanto la Forma Humana como la de Dragón. Para representar esto, puedes elegir la forma de un Dragón Catayano al inicio de la partida simplemente colocando la miniatura apropiada en el campo de batalla durante el despliegue. Cada forma tiene su propio perfil de atributos.
Forma Humana
En su Forma Humana, los Dragones Catayanos son líderes sabios y queridos que caminan entre su pueblo y luchan a su lado en la batalla. Mientras esté en su Forma Humana, un Dragón Catayano sigue las reglas de un personaje cuyo tipo de tropa es &apos;infantería pesada&apos;.
Forma de Dragón
En su Forma de Dragón, los Dragones Catayanos son fuerzas de destrucción primordial que llevan la lucha directamente a sus enemigos con garras y dientes, sin preocuparse por dar órdenes y dictar el flujo de las líneas de batalla. Para representar esto, mientras esté en su Forma de Dragón, un Dragón Catayano sigue las reglas de un personaje cuyo tipo de tropa es &apos;coloso&apos;. Sin embargo, mientras estén en su Forma de Dragón, los Dragones Catayanos no tienen la regla Presencia Inspiradora, incluso si son el General de tu ejército.
Muerte de un Dragón
Cuando un Dragón Catayano pierde una Herida, esa Herida se pierde en ambos perfiles de atributos. La primera vez durante una partida que un Dragón Catayano es reducido a cero Heridas mientras está en su Forma de Dragón, inmediatamente revierte a su Forma Humana y recupera 1D3 Heridas perdidas. Una vez que esto ocurre, no puede adoptar la Forma de Dragón durante el resto de la partida. Si un Dragón Catayano es reducido a cero Heridas mientras está en su Forma Humana, es retirado del juego como una baja.
Transformación
Además de transformarse cuando es reducido a cero Heridas, un Dragón Catayano puede transformarse de su Forma Humana a su Forma de Dragón, o viceversa, durante la subfase de Mando de cualquiera de sus turnos. Para hacer esto, simplemente coloca la miniatura que representa la forma en la que el Dragón Catayano se está transformando de modo que esté:
● A 6&quot; o menos de la miniatura que representa la forma actual del Dragón Catayano.
● A más de 1&quot; de cualquier miniatura amiga.
● A más de 3&quot; de cualquier miniatura enemiga.
Una vez que se ha colocado la miniatura que representa la nueva forma del Dragón Catayano, retira del juego la miniatura que representa su forma anterior. Cuando un Dragón Catayano se transforma de esta manera, recupera inmediatamente 1D3 Heridas perdidas.
Un Dragón Catayano no puede declarar una carga durante un turno en el que se transformó y cuenta como que se ha movido a efectos de disparo, pero por lo demás puede moverse normalmente durante la subfase de Resto de Movimientos.
Nota: cuando un Dragón Catayano se transforma de su Forma Humana a su Forma de Dragón de esta manera, abandona inmediatamente cualquier unidad de la que formara parte y esa transformación le permite a un Dragón Catayano abandonar el combate.
</description>
    </rule>
    <rule id="e0a2-05b9-728e-b5da" name="Saber de Yin" hidden="false">
      <description>Un Hechicero con la regla especial &apos;Saber de Yin&apos; puede descartar uno de sus hechizos generados aleatoriamente de forma normal. Cuando lo haga, podrá seleccionar en su lugar el hechizo identificativo de su Saber de Magia elegido, o uno de los hechizos listados a continuación:
Espíritus de Viento y Sombras
Los espíritus elementales descienden sobre el enemigo, envolviéndolo en un torbellino de formas parpadeantes y vendavales fantasmales. Cuando intentan avanzar, los afectados se ven atrapados por las garras de espíritus invisibles y amortiguados por vientos espectrales.
Tipo: Maldición
Dificultad de Lanzamiento: 10+
Alcance: 15”
Efecto: Hasta tu próxima subfase de Inicio de Turno, la unidad enemiga objetivo queda sujeta a la regla especial Movimiento Aleatorio (1D6).
Espejo Maldito
El Hechicero crea una barrera mágica de oscuridad cambiante y viento aullante alrededor del enemigo. Esta barrera arrebata del aire los proyectiles del enemigo y se traga las puntas de sus lanzas, devolviendo al instante el poder letal de estas armas a sus portadores.
Tipo: Maldición
Dificultad de Lanzamiento: 9+
Alcance: 15”
Efecto: Hasta tu próxima subfase de Inicio de Turno, cualquier tirada para Impactar natural de 1 efectuada por una unidad enemiga objetivo durante la fase de Disparo o la fase de Combate resulta en un impacto de Fuerza 3 con una PA de -1 que debe resolverse contra la unidad enemiga objetivo. Este hechizo puede tener como objetivo una unidad enemiga en combate.
Guerreros Ancestrales
El Mago invoca a los ancestros de los guerreros bajo su mando convocándolos desde el inframundo para que ayuden a sus descendientes. Estos espíritus fantasmales se elevan y golpean al enemigo con un furioso asalto, antes de desvanecerse de nuevo en la tierra.
Tipo: Asalto
Dificultad de Lanzamiento: 7+/11+
Alcance: Combate
Efecto: Si este hechizo se lanza con un resultado de lanzamiento de 7 o más, una única unidad enemiga con la que el lanzador esté en combate sufre 2D3 impactos de Fuerza 2, cada uno con una PA de -. Si este hechizo se lanza con un resultado de lanzamiento de 11 o más, el enemigo objetivo sufre 2D6 impactos de Fuerza 4, cada uno con una PA de -1. Este hechizo tiene la regla especial Perforacorazas (2).</description>
    </rule>
    <rule id="98a9-412b-1a26-b46c" name="Saber de Yang" hidden="false">
      <description>Un Hechicero con la regla especial &apos;Saber de Yang&apos; puede descartar uno de sus hechizos generados aleatoriamente de forma normal. Cuando lo haga, podrá seleccionar en su lugar el hechizo identificativo de su Saber de Magia elegido, o uno de los hechizos listados a continuación:
Constelación del Dragón
De las yemas de los dedos del Hechicero brota una luz estelar resplandeciente que danza y forma un simulacro de la constelación del Emperador Dragón sobre el campo de batalla.
Tipo: Proyectil Mágico
Dificultad de Lanzamiento: 7+/11+
Alcance: 18”
Efecto: Si este hechizo se lanza con un resultado de lanzamiento de 7 o más, la unidad enemiga objetivo sufre 1D6+1 Impactos de Fuerza 4, cada uno con una PA de -. Si este hechizo se lanza con un resultado de lanzamiento de 11 o más, la unidad enemiga objetivo sufre 2D6+2 Impactos de Fuerza 4, cada uno con una PA de -1.
Gran Bastión
Con una palabra de poder del Hechicero, la tierra se agrieta y se dobla al transformarse en murallas sobre las que brillantes almenas arden con llamas celestiales.
Tipo: Potenciación
Dificultad de Lanzamiento: 9+
Alcance: 12”
Efecto: Permanece en juego. La unidad amiga objetivo obtiene una salvación Especial de 6+ contra cualquier herida sufrida. Además, cada miniatura dentro de la fila frontal de una unidad enemiga que termine su movimiento de carga en contacto con la unidad objetivo mientras este hechizo esté en juego debe efectuar un chequeo de Terreno Peligroso. Las Heridas perdidas cuentan como &quot;Heridas infligidas no salvadas&quot; al calcular el resultado del combate. Sin embargo, mientras este hechizo esté en juego, la unidad objetivo no puede marchar ni cargar. Este hechizo puede tener como objetivo una unidad amiga trabada en combate.
Poder del Cielo y la Tierra
Invocando la energía elemental de la tierra y el cielo, el Hechicero y los que le rodean se impregnan del poder puro del Yang.
Tipo: Potenciación
Dificultad de Lanzamiento: 9+/12+
Alcance: Propio
Efecto: Si este hechizo se lanza con un resultado de lanzamiento de 9 o más, el lanzador, su montura y cualquier unidad a la que se hayan unido, ganan un modificador +1 a sus atributos de Habilidad de Armas y Fuerza (hasta un máximo de 10), y ganan la regla especial Ataques Flamígeros. Si este hechizo se lanza con un resultado de lanzamiento de 12 o más, todas las unidades amigas que estén dentro del alcance de Mando del lanzador mientras se lanza este hechizo ganan un modificador +1 a sus atributos de Habilidad de Armas y Fuerza (hasta un máximo de 10), y ganan la regla especial Ataques Flamígeros. Este hechizo dura hasta el final de este turno.</description>
    </rule>
    <rule id="e10c-16fe-285e-15cd" name="Maestría de los vientos elementales" hidden="false">
      <description>Una vez por turno, un Hechicero de tu ejército que tenga esta regla especial y que esté a 6&quot; o menos de uno o más Hechiceros amigos que también tengan esta regla especial puede aplicar un modificador de +1 a una Tirada de Lanzamiento.
Ten en cuenta que este es un modificador al resultado de una tirada – no anula una tirada de un doble 1 natural.</description>
    </rule>
    <rule id="c04e-af4a-b4e0-232a" name="Los vientos elementales" hidden="false">
      <description>Durante cada una de sus subfases de Inicio de Turno, el jugador de Gran Catai tira 1D6 para determinar cuál de los Vientos Elementales sopla con más fuerza:
• Con un resultado de 1-2, los Vientos se calman y no sucede nada.
• Con un resultado de 3-4, los Vientos de Yang soplan con más fuerza.
• Con un resultado de 5-6, los Vientos de Yin soplan con más fuerza.
Vientos de Yang: Hasta tu siguiente subfase de Inicio de Turno, los Hechiceros con la regla especial Saber de Yang aumentan su Alcance de Dispersión y el alcance de cualquier hechizo de Potenciación que conozcan en 3&quot;. Además, todos los miniaturas amigos con la regla especial Voluntad de los Dragones ganan uno* de los siguientes modificadores:
● +1 al Movimiento
● +1 a la Iniciativa

Vientos de Yin: Hasta tu siguiente subfase de Inicio de Turno, los Hechiceros con la regla especial Saber de Yin aumentan el alcance de cualquier hechizo de Maldición o Proyectil Mágico que conozcan en 3&quot;. Además, todos los miniaturas amigos con la regla especial Voluntad de los Dragones ganan uno* de los siguientes modificadores:
● +1 a la Habilidad de Armas
● +1 al Liderazgo
*Ten en cuenta que todos las miniaturas elegibles ganan el mismo modificador.</description>
    </rule>
    <rule id="f40f-8807-6723-8315" name="Armonía de piedra y acero" hidden="false">
      <description>Una unidad a la que se haya unido un personaje con esta regla especial puede repetir cualquier chequeo de Liderazgo fallido al intentar reformarse tras arrollar a un enemigo, al intentar redirigir una carga, o al hacer un chequeo de Contención.</description>
    </rule>
    <rule id="5e07-8cc4-a012-4c26" name="Armadura celestial forjada (X+)" hidden="false">
      <description>Una miniatura con esta regla especial tiene una Salvación Especial contra cualquier herida sufrida. El valor de armadura de esta Salvación Especial se muestra entre paréntesis después del nombre de esta regla especial (aquí se muestra como ‘X+’). Además, un Hechicero con esta regla especial puede llevar armadura sin penalización.</description>
    </rule>
    <rule id="b8ae-2eff-a559-6bc3" name="Pólvora negra de Catai" hidden="false">
      <description>La primera vez que cualquier unidad en un ejército de la Flota de Jade que esté armada con una pistola de mano, una pistola, una ristra de pistolas, una pistola de repetición o una pistola de repetición dispare, el alcance de esa arma se incrementa en 3&quot;.</description>
    </rule>
    <rule id="18d7-0c14-9de5-1703" name="Instrucción de Armas de mano mercenarias" hidden="false">
      <description>Una vez por partida, cada unidad o destacamento de Tropas de Proyectiles Estatales en un ejército de la Flota de Jade puede disparar con una fila adicional.
</description>
    </rule>
    <rule id="e18a-133b-4bbd-a4af" name="Unidad y armonía" hidden="false">
      <description>Cualquier unidad de Guerreros de Jade o Lanceros de Jade a 3&quot; o menos de una unidad Mercenaria amiga puede repetir las tiradas para Impactar de 1 durante la fase de Combate.</description>
    </rule>
    <rule id="20ff-4f97-5140-4e8b" name="Globos de guerra" hidden="false">
      <description>0-1 Linterna Celeste por cada 1.000 puntos puede tener la regla especial Emboscadores por +15 puntos. Además, una vez por partida, una Linterna Celeste que se mantenga en reserva puede repetir la tirada de dados al determinar si llega este turno como refuerzo o se retrasa.</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
