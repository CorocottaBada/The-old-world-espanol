          <selectionEntries>
            <selectionEntry id="0faf-3b76-666c-a2d6" name="Cargador ogro" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="85da-6d43-a3f8-f089" type="max"/>
              </constraints>
              <profiles>
                <profile id="38a2-a658-4b3e-b398" name="Cargador ogro" hidden="false" typeId="4d05-969a-c2da-d376" typeName="Modelo">
                  <characteristics>
                    <characteristic name="M" typeId="aaba-08f8-2596-fc9f">4</characteristic>
                    <characteristic name="HA" typeId="983a-64b8-c41c-9267">3</characteristic>
                    <characteristic name="HP" typeId="4915-ded6-bab4-124b">3</characteristic>
                    <characteristic name="F" typeId="885a-9316-aa84-2715">4</characteristic>
                    <characteristic name="R" typeId="35d9-aa07-76fc-5df8">4</characteristic>
                    <characteristic name="H" typeId="57a0-b9e1-a78b-394e">3</characteristic>
                    <characteristic name="I" typeId="289b-8b23-92a5-50eb">2</characteristic>
                    <characteristic name="A" typeId="ce23-8368-434a-d0b1">3</characteristic>
                    <characteristic name="L" typeId="9267-3e20-0bc5-9c1d">8</characteristic>
                    <characteristic name="S" typeId="472f-789f-9d1f-641e"/>
                    <characteristic name="Tipo de tropa" typeId="0c59-b5c0-8666-35bf">Infantería monstruosa</characteristic>
                    <characteristic name="Reglas especiales" typeId="4d01-772d-4584-b98b">Suficiente para todos, Dotación de mercenarios</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="3119-d9ef-492d-9dd9" name="Suficiente para todos" hidden="false">
                  <description>Si un Cargador Ogro está equipado con bombas de pólvora, la dotación de la máquina de guerra a la que se ha unido el Cargador Ogro también está equipada con bombas de pólvora.</description>
                </rule>
                <rule id="b58f-3c7b-d547-ddf0" name="Dotación de mercenarios" hidden="false">
                  <description>Un Cargador Ogro es un miembro de la dotación adicional que puede ser tomado como una mejora para acompañar a una máquina de guerra catayana. Durante el despliegue, posiciona un Cargador Ogro con su máquina de guerra, como lo harías con cualquier otro miembro de la dotación. Una vez colocado, un Cargador Ogro no puede abandonar su máquina de guerra.
La dotación de cualquier máquina de guerra a la que se una un Cargador Ogro gana un modificador de +1 a su atributo de Movimiento y la regla especial Tozudo. Además, una vez por partida, una Batería de Cohetes Incendiarios o un Cañón Grandioso de Catai que incluya un Cargador Ogro puede disparar dos veces durante la fase de Disparo, o repetir una única tirada de Dado de Artillería.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="85d2-05d9-16dd-75bb" name="Infantería monstruosa (Monstrous infantry)" hidden="false" targetId="5c73-876f-8ca7-1192" type="rule"/>
              </infoLinks>
