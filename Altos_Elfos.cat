        <selectionEntry id="1900-54a8-2b63-6013" name="Guardián de Saphery" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0855-46b1-e4cb-0e49" type="max"/>
          </constraints>
          <profiles>
            <profile id="abbf-3afe-3745-0cd9" name="Guardián de Saphery" hidden="false" typeId="0f2a-e6d0-d444-4fe0" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="10b0-8aae-d8b2-8c02">Un Personaje con el Honor Élfico Guardián de Saphery:
• No puede ir montado.
• Puede equiparse con una Espada de Hoeth (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• Tiene las reglas especiales Armadura de Ithilmar, Desviar Disparos y Golpe Letal</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="b638-7364-4d5c-7dd4" name="Desviar disparos" hidden="false">
              <description>Una miniatura con esta regla especial tiene una Salvación especial de 6+ contra cualquier herida sufrida que haya sido causada por un ataque de disparo no mágico.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="d0e8-591e-2ec1-157d" name="Armadura/Barda de Ithilmar (Ithilmar armour/barding)" hidden="false" targetId="f5e5-f465-6aac-1af1" type="rule"/>
            <infoLink id="a490-7bd6-48f2-80f0" name="Destreza marcial (Martial prowess)" hidden="false" targetId="af5f-6dc8-6e81-229c" type="rule"/>
          </infoLinks>
          <entryLinks>
