          </costs>
        </selectionEntry>
        <selectionEntry id="73e9-5050-f1e0-525e" name="Perdición de enemigos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ed5d-a2eb-9f30-0c9f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0a01-a38a-5679-d420" type="max"/>
          </constraints>
          <profiles>
            <profile id="8fef-dbf4-b090-2e83" name="Perdición de enemigos" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cuando el portador de Perdición de Enemigos hace una tirada para Herir, un resultado de 4+ siempre es un éxito, independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a656-7589-b9cf-ce2f" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4ca9-4c86-8773-2adb" name="Arco del navegante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b8a9-d799-a6bf-3731" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5226-3b3d-84ec-d077" type="max"/>
          </constraints>
          <profiles>
            <profile id="713c-9905-229d-65da" name="Arco del navegante" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">5</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Aparatoso, Heridas múltiples (1D3), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco del Navegante es un Arco de Avelorn. El Arco del Navegante dispara como un Lanzavirotes, usando la regla especial «Atravesar Filas» (ver página 223 del libro de reglas de Warhammer: el Viejo Mundo).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9101-d9e3-d2fa-ac17" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="e3d7-65cc-101e-a523" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
            <infoLink id="e617-8ffe-778d-b1be" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
            <infoLink id="4fb4-410f-cdd7-6218" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <entryLinks>
            <entryLink id="6992-3363-a1bb-aea3" name="Arco de Avelorn" hidden="false" collective="false" import="true" targetId="0f85-0701-f847-3597" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8c10-5afc-bc87-cb12" type="min"/>
              </constraints>
            </entryLink>
          </entryLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3929-0283-710b-7e81" name="Armaduras mágicas. Altos elfos. Armadura" hidden="false" collective="false" import="true">
