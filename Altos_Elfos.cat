      <selectionEntries>
        <selectionEntry id="7fc2-f9e7-e700-4eda" name="Acechante sombrío" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f86f-dace-6ec4-1c2b" type="max"/>
          </constraints>
          <profiles>
            <profile id="7c17-9bdd-3664-02b8" name="Acechante sombrío" hidden="false" typeId="0f2a-e6d0-d444-4fe0" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="10b0-8aae-d8b2-8c02">Un Personaje con el Honor Élfico Acechante Sombrío:
• No puede ir montado.
• Puede equiparse con un arco de Avelorn (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• No puede equiparse con armadura pesada o armadura completa.
• Tiene las reglas especiales Emboscador, Evasivo, Explorador, Disparar y Huir y Mover a Través de Cobertura</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fb43-50f3-57f3-46e2" name="Emboscadores" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
            <infoLink id="cad3-dc24-dbd9-ebb0" name="Evasivo" hidden="false" targetId="22e4-14de-b7b8-ba59" type="rule"/>
            <infoLink id="230e-55cd-a374-a6a4" name="Disparar y huir" hidden="false" targetId="2024-f1cc-061a-46ec" type="rule"/>
            <infoLink id="63f5-ba44-af2a-7623" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
            <infoLink id="f811-9222-87a7-11ac" name="Exploradores" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
