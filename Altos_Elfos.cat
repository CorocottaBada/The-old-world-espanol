        </selectionEntry>
        <selectionEntry id="e0cc-57d4-518f-3f26" name="Ungido de Asuryan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f70d-f779-a7e3-a0e5" type="max"/>
          </constraints>
          <profiles>
            <profile id="011e-5360-38f2-aeb1" name="Ungido de Asuryan" hidden="false" typeId="0f2a-e6d0-d444-4fe0" typeName="Honor Alto elfo">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="10b0-8aae-d8b2-8c02">Un Personaje con el Honor Élfico Ungido de Asuryan:
• Puede montar en un Fénix Pico Llameante o un Fénix Corazón Gélido (pero no puede elegir ninguna otra opción de montura).
• Puede equiparse con una alabarda ceremonial (ver página 83) sin coste adicional. Si es así, no podrá llevar armas no mágicas adicionales.
• Tiene las reglas especiales Bendiciones de Asuryan, Miedo y Testigo del Destino
• Sustituye la regla especial Valor Ancestral por la de Veterano.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="25c2-3500-a932-4e4c" name="Testigos del destino" hidden="false">
              <description>Esta unidad tiene una salvación especial de 6+ contra cualquier herida sufrida que haya sido causada por un ataque enemigo no mágico.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="2773-4b04-5536-561a" name="Bendiciones de Asuryan" hidden="false" targetId="97c7-0394-5d50-927e" type="rule"/>
            <infoLink id="6ba7-9f0d-ebe6-4a18" name="Miedo" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
