          <profiles>
            <profile id="542b-e9ab-9d5f-b06e" name="Arco de Ellyrion" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">30&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Arco de Ellyrion cuenta como un Arco de Avelorn. El portador del Arco de Ellyrion puede realizar un número de disparos igual a su atributo de Ataques, en lugar del número habitual. Esta miniatura no sufre ningún penalizador por Disparos Múltiples.</characteristic>
              </characteristics>
            </profile>
