                <profile id="0de6-62e6-a8fd-725b" name="Cuerno de Isha" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Durante la sub-fase de Mando de su turno, este personaje puede intentar usar el Cuerno de Isha realizando un Chequeo de Liderazgo (usando su propio Liderazgo). Si este chequeo es superado, hasta tu siguiente sub-fase de Inicio de Turno, este personaje y cualquier unidad a al que se haya unido, gana un bonificador de +1 a sus tiradas para Impactar y para Herir.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
