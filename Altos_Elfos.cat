          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="75f4-e1c9-2479-5e9e" type="max"/>
      </constraints>
      <rules>
        <rule id="8ef0-400a-f7fd-36ea" name="Golpe perforante" hidden="false">
          <description>Si una miniatura con esta regla especial saca un 6 natural al hacer una tirada para Herir por un ataque realizado en combate, ha asestado un &apos;Golpe Perforante&apos;. Contra un Golpe Perforante, las miniaturas enemigas cuyo Tipo de Tropa sea &apos;infantería regular&apos;, &apos;infantería pesada&apos;, &apos;caballería ligera&apos;, &apos;caballería pesada&apos; o &apos;bestias de guerra&apos; no pueden realizar una salvación por armadura o regeneración (las salvaciones especiales se pueden intentar como de costumbre).
Ten en cuenta que si un ataque hiere automáticamente, esta regla especial no se puede usar.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="04bf-f44b-c42a-84dd" name="Bestia de guerra (War beast)" hidden="false" targetId="5e7a-fa13-70e3-775f" type="rule"/>
        <infoLink id="f891-ce23-908c-b1a5" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
        <infoLink id="d51a-1503-f4be-2d7e" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
