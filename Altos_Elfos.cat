        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3363-42ee-b4d7-240e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="203e-d5dd-b749-5d8f" name="Amuleto de ópalo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8a25-8fa5-0ee8-8b58" type="max"/>
          </constraints>
          <profiles>
            <profile id="7e0c-82ea-aa66-7414" name="Amuleto de ópalo" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un solo uso. Un Amuleto de Ópalo da a su portador una salvación especial de 2+ contra una sola herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d69a-a7c0-cb48-bcf8" name="Estandartes mágicos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dfc5-7522-84ae-a503" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e657-c01f-e335-1972" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="03ad-bdb0-2db9-d911" name="Estandarte de protección arcana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dcb9-3a83-3b8c-12ce" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="09db-e914-c54d-5aa0" type="max"/>
          </constraints>
          <profiles>
            <profile id="b9be-2415-c985-936e" name="Estandarte de protección arcana" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Protección Arcana obtiene la regla especial Resistencia a la magia (-3). Además, las unidades amigas a 6&quot; o menos de la miniatura que lleve este estandarte obtienen la regla especial Resistencia Mágica (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="605c-9629-900f-7021" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a9b2-6f62-af4c-cc03" name="Estandarte del león" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e597-c802-8dd5-d508" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b033-3d28-56c5-b7b4" type="max"/>
          </constraints>
          <profiles>
            <profile id="e52c-7147-de0b-6201" name="Estandarte del león" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del León supera automáticamente cualquier chequeo de miedo o terror que deba realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0425-eb04-86ca-12ef" name="Estandarte de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4fe7-21e8-0c28-6389" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6cbc-f553-0519-ac0a" type="max"/>
          </constraints>
          <profiles>
            <profile id="d84c-9180-42f3-af45" name="Estandarte de batalla" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular su resultado del combate, una unidad que lleve el Estandarte de Batalla obtiene una bonificación adicional de +1D3 puntos en el resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d5e4-c751-0251-d747" name="Estandarte de Ellyrion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ae80-b84a-55b5-b02d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fb86-46e5-b846-f770" type="max"/>
          </constraints>
          <profiles>
            <profile id="78bb-247d-3c5f-d340" name="Estandarte de Ellyrion" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de Ellyrion obtiene la regla especial Mover a Través de Cobertura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6e3f-6024-6f70-55ed" name="Mover a través de cobertura" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="665e-e13f-e05a-2cf7" name="Estandarte de la resistencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fe88-e282-6065-5d0b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b01-9532-67bb-18f8" type="max"/>
          </constraints>
          <profiles>
            <profile id="6383-8b09-0e6b-09c0" name="Estandarte de la resistencia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Resistencia tiene un modificador +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7871-a5e4-fe25-cf46" name="Estandarte de Lothern" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="25df-6e61-252f-d150" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d280-1a02-b26f-f3dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="4bb0-6753-ab36-1dce" name="Estandarte de Lothern" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad que porta el Estandarte de Lothern está equipada con lanzas arrojadizas, la mitad de las miniaturas de la tercera fila o columna (es decir, la fila o columna directamente detrás de la que normalmente puede realizar ataques de apoyo), redondeando hacia arriba, pueden realizar ataques de apoyo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b2bb-dd3b-153f-0a77" name="Estandarte del equilibrio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="750d-3a0e-b332-1c5f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01cf-a3aa-1d22-c2cd" type="max"/>
          </constraints>
          <profiles>
            <profile id="0eac-ff56-8b53-2daf" name="Estandarte del equilibrio" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Mientras estén en contacto con una unidad que lleve el Estandarte del Equilibrio, las unidades enemigas no pueden repetir ninguna tirada para Impactar o para Herir. Sin embargo, la unidad que lleva el Estandarte del Equilibrio tampoco puede hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="34dc-f317-fb9e-e288" name="Estandarte de la confianza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="db93-ba85-b76b-821c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1893-2139-4eb1-8e37" type="max"/>
          </constraints>
          <profiles>
            <profile id="b232-72bb-94ec-a098" name="Estandarte de la confianza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Confianza no sufre el modificador habitual de -1 a Impactar al realizar una reacción a la carga de Aguantar y Disparar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="913c-89ea-801c-69e6" name="Objetos hechizados. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="897b-5afd-f16e-228e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3709-f18d-3e46-91ca" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="80c8-7d16-23d8-584b" name="Piedra de anulación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="40ae-cbe6-bc32-d0c1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="195d-e99b-513e-9306" type="max"/>
          </constraints>
          <profiles>
            <profile id="84a4-5055-c0ee-5d6d" name="Piedra de anulación" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Mientras estén dentro del Aura de Mando del portador, todos los Hechiceros (amigos o enemigos) sufren un penalizador de -1 en sus tiradas de lanzamiento y dispersión.
Además, durante la subfase de Mando de su turno, si no está en combate, este personaje puede intentar utilizar la Piedra de Anulación realizando un chequeo de liderazgo (usando su propio Liderazgo sin modificar). Si se supera esta prueba, este personaje no puede ser objetivo de ningún hechizo y es inmune a los efectos de cualquier hechizo hasta tu próxima subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1b74-9bd8-5245-90f6" name="Capa de las barbas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3817-2978-87ba-70ba" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="615d-532a-8dc6-b711" type="max"/>
          </constraints>
          <profiles>
            <profile id="ad78-886f-9952-69fa" name="Capa de las barbas" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de las Barbas provoca Terror. Sin embargo, el manto es tan desconcertante que otras miniaturas no pueden utilizar el Liderazgo de quien la porta.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9038-6a1f-d94b-93b6" name="Terror" hidden="false" targetId="e7f4-a6ba-b7b8-3e90" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0849-3b9c-0760-6382" name="Objetos hechizados muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e8bd-7fd1-2c92-3872" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9e12-9c87-b4aa-9973" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ec4e-0985-fdc7-d492" name="Semilla del renacimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="165c-d746-954b-ad7d" type="max"/>
          </constraints>
          <profiles>
            <profile id="c2c2-a527-12b1-0fbf" name="Semilla del renacimiento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">La Semilla del Renacimiento otorga a su portador la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8337-2424-9fca-b8b7" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3af6-fe06-1ceb-6cfb" name="Anillo de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="451d-4701-b8aa-3fce" type="max"/>
          </constraints>
          <profiles>
            <profile id="8f74-2d70-18d6-de20" name="Anillo de la ira" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de un Anillo de la Ira puede lanzar el hechizo Mano de Martillo del Saber de la Magia de Batalla como hechizo Vinculado, con un Nivel de Energía 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7490-8122-9511-150a" name="Objetos arcanos muy comunes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9348-5348-1e37-6643" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="91df-b94c-26d5-3d60" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="12ee-d428-02b2-8cbf" name="Selllo de Asuryan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c725-d922-aa92-8382" type="max"/>
          </constraints>
          <profiles>
            <profile id="2ed0-5736-11be-64d7" name="Selllo de Asuryan" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Hechicero puede usar este objeto en lugar de intentar dispersar. Si lo hace, el hechizo se dispersa de forma automática sin necesidad de realizar una tirada de dispersión.
Ten en cuenta que una Fuerza irresistible no se puede dispersar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="04e0-81c3-e3e2-26d8" name="Objetos arcanos. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c940-0f09-8f24-7bc5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9e13-e648-7bd1-f06c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5df0-fd1b-4973-24da" name="Vara de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9196-b089-f463-d5b9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="789c-42da-f37a-0df5" type="max"/>
          </constraints>
          <profiles>
            <profile id="9168-0ba2-00e5-5069" name="Vara de plata" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador de la Vara de Plata conoce un hechizo más (elegido de la forma habitual) de lo normal para su Nivel de Magia.
Ten en cuenta que esto no aumenta el Nivel de Magia del hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d668-6c5a-8b16-e1f6" name="Cristal de las Annuli" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ea9f-8b08-43ae-2a2e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="899f-04dc-45aa-64dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="2026-caf3-2a4c-0c98" name="Cristal de las Annuli" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, al lanzar con éxito un hechizo, el portador del Cristal de las Annulii puede optar por olvidar ese hechizo y generar otro(sin incluir los hechizos característicos) inmediatamente de la manera habitual.
Ten en cuenta que es posible que el Hechicero genere el hechizo que acaba de olvidar o uno olvidado en un turno anterior. Considéralo el destino.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f443-7e22-c5af-6c12" name="Fragmentos de vórtice" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9dca-f738-a674-db95" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7323-dd3c-9ca4-e467" type="max"/>
          </constraints>
          <profiles>
            <profile id="5ea4-1926-0417-4ed9" name="Fragmentos de vórtice" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar este objeto en lugar de hacer un intento de dispersión. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirada de dispersión. Además, se dispersan todos los hechizos en juego, incluidos los hechizos lanzados por hechiceros amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="72f6-e109-3f0f-00e8" name="El colgante del embaucador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5eb1-179b-a66c-eb39" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="92d5-473d-176d-59ce" type="max"/>
          </constraints>
          <profiles>
            <profile id="c7f7-71be-af86-e41f" name="El colgante del embaucador" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un hechicero puede usar el Colgante del Embaucador cuando intente dispersar un hechizo. Si lo hace, tira 1D6 adicional al hacer la tirada de dispersión y descarta el resultado más bajo. Si el hechizo es dispersado, el hechicero que intentó lanzarlo no podrá intentar lanzar más hechizos durante el resto del turno en curso. Sin embargo, si se obtiene un doble 1 en cualquiera de los dos dados lanzados, el portador queda superado en el arte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="928d-2d34-8810-6da3" name="Bastón de la solidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8419-5726-4488-6738" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fae-3b32-ebb3-e782" type="max"/>
          </constraints>
          <profiles>
            <profile id="f454-78c9-c7df-dcaa" name="Bastón de la solidez" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Una vez por partida, cuando el portador del Bastón de la Solidez tenga que tirar en la Tabla de Disfunción, puede elegir no hacerlo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="769b-4cc7-3d5b-0c0f" name="Armas mágicas. Altos elfos. Caballería o Monstruo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="edf1-cf02-8d8f-a3c1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c95-f9e0-7a6e-31f4" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9752-6f35-e0f2-d3a5" name="Lanza estelar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="539b-b132-3a39-fb3e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fe51-7195-0519-c67f" type="max"/>
          </constraints>
          <profiles>
            <profile id="71b9-b4a0-c213-78a2" name="Lanza estelar" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+3</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-4</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea primero</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo miniaturas cuyo tipo de tropa sea «caballería» o «monstruo». La Lanza Estelar sólo puede usarse durante un turno en el que su portador haya cargado. En turnos posteriores (o si el portador no cargó), la miniatura debe usar su arma de mano en su lugar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8e02-6cf0-1978-5e96" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="be9c-8b9f-6426-00ae" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1a3f-6f2e-1d54-2f76" name="Armaduras mágicas. Altos elfos. Armadura. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="be59-1d74-a30f-65cd" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bcb3-515c-7a78-a275" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6b4e-78fe-364e-0ddc" name="Armadura de las estrellas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="18d6-eff7-c3f3-8c20" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cc26-d5c3-f61a-96cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="fde4-5c56-6819-32a3" name="Armadura de las estrellas" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Sólo miniaturas cuyo tipo de tropa es «infantería» o «caballería». La Armadura de Estrellas es una armadura pesada. Además, su portador es inmune a la regla especial «Golpe Letal». Si el portador recibe un Golpe Letal, se le permiten las salvaciones de armadura y Regeneración como de costumbre. Si la herida no se salva, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7b7e-b2ef-3b87-9188" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="33c6-f5ee-1224-be48" name="Armaduras mágicas. Altos elfos. Escudo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="99bd-6dd8-5879-3214" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="07ec-7e56-797f-efba" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6190-9217-5752-8cb5" name="El escudo dorado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3486-fc54-dc67-4405" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d313-968a-7bb2-ed9f" type="max"/>
          </constraints>
          <profiles>
            <profile id="3d8e-f08b-5049-f7e1" name="El escudo dorado" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo Dorado es un escudo. Además, cualquier miniatura enemiga que dirija sus ataques contra su portador durante la fase de combate debe repetir las tiradas para Impactar naturales de 6.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="e24a-c981-3787-37a5" name="Escudo" hidden="false" targetId="0568-2676-acf0-9708" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="0de7-9daf-a60e-e3e5" name="Flechas de Isha" hidden="false">
      <description>Cualquier arco (arco largo, arco corto, arco de guerra o arco de Avelorn) usado por una miniatura con esta regla especial tiene la regla especial Perforacorazas (1) y un atributo Penetración de Armadura de -1.</description>
    </rule>
    <rule id="97c7-0394-5d50-927e" name="Bendiciones de Asuryan" hidden="false">
      <description>Una miniatura con esta regla especial tiene una salvación especial de 5+ contra cualquier herida que haya sido causada por un ataque que tenga la regla especial Ataques flamígeros.</description>
    </rule>
    <rule id="c488-31cb-122f-c8af" name="Reflejos élficos" hidden="false">
      <description>Una miniatura con esta regla especial (pero no su montura) obtiene un bonificador de +1 a su atributo de Iniciativa (hasta un máximo de 10) durante la primera ronda de cada combate.</description>
    </rule>
    <rule id="f5e5-f465-6aac-1af1" name="Armadura de Ithilmar/Barda de Ithilmar" hidden="false">
      <description>Una miniatura con esta regla especial puede repetir cualquier resultado de 1 al realizar chequeos de terreno peligroso. Además, un hechicero con esta regla especial puede equiparse con armadura sin penalización.</description>
    </rule>
    <rule id="2bd1-1d92-f5ae-e503" name="Armas de Ithilmar" hidden="false">
      <description>Cuando está trabado en combate, una miniatura con esta regla especial que esté luchando con un arma de mano puede repetir cualquier resultado de 1 natural en la tirada para impactar.
Ten en cuenta que esta regla especial sólo se aplica a un arma de mano única y no mágica y no se aplica a la montura de la Miniatura (si tiene una). Si la miniatura utiliza dos armas de mano o cualquier otro tipo de arma, esta regla especial deja de aplicarse.</description>
    </rule>
    <rule id="6ec8-9292-602c-8910" name="Bendición de Lileath" hidden="false">
      <description>Una vez por turno, una miniatura con esta regla especial puede repetir una única tirada de lanzamiento fallida.</description>
    </rule>
    <rule id="af5f-6dc8-6e81-229c" name="Destreza marcial" hidden="false">
      <description>Una unidad con esta regla especial puede realizar Ataques de Apoyo a sus Flancos y Retaguardia, no sólo a su frontal.</description>
    </rule>
    <rule id="b8c2-f0f8-7532-639a" name="Valor ancestral" hidden="false">
      <description>Una unidad con esta regla especial puede repetir cualquier chequeo de pánico fallido causado por sufrir Pérdidas Severas o por haber sido atravesada por una unidad amiga huyendo.</description>
    </rule>
    <rule id="8e6f-e11c-de41-87a4" name="Saber de Saphery" hidden="false">
      <description>Un Hechicero con la regla especial &quot;Saber de Saphery&quot; puede descartar uno de sus hechizos generados aleatoriamente de forma normal. Al hacerlo, puede seleccionar en su lugar el Hechizo Identificativo del Saber de la Magia que ha elegido o uno de los hechizos que se detallan a continuación.

Mano de Khaine
Tipo: Daño Directo
Dificultad de Lanzamiento: 7+
Alcance: Combate
Efecto: Una miniatura enemiga trabada en combate con el lanzador sufre un impacto de Fuerza 4 sin tirada de salvación por armadura (las salvaciones especiales y de regeneración se pueden realizar de la forma habitual)

Valor de Aenarion
Tipo: Potenciación
Dificultad de Lanzamiento: 10+
Alcance: 15”
Efecto: Permanece en juego. Mientras este hechizo está en juego, la unidad amiga objetivo (que puede estar en combate) obtiene la regla especial Indesmoralizable. Si se lanza este hechizo, los efectos de cualquier otra Potenciación lanzada a la unidad objetivo previamente expiran inmediatamente.

Anulación de Vaul
Tipo: Maldición
Dificultad de Lanzamiento: 11+
Alcance: 12”
Efecto: Este hechizo sólo puede lanzarse a un personaje enemigo que esté dentro del alcance y al que el lanzador pueda trazar una línea de visión, sin tener en cuenta el resto de las reglas habituales para elegir a personajes como objetivos (incluso puede lanzarse a un personaje enemigo que se haya unido a una unidad o que esté trabado en combate). 
El jugador que controla al hechicero que lanza el hechizo elige un único objeto mágico que lleve el personaje objetivo. Este objeto mágico se &quot;deshace&quot; inmediatamente, inutilizándolo completamente. El objeto mágico elegido no podrá usarse durante el resto de la partida</description>
    </rule>
    <rule id="0eb9-0317-1e58-2c4d" name="Armadura dragón" hidden="false">
      <description>Una miniatura con esta regla especial tiene una salvación especial de 6+ contra cualquier herida sufrida. Además, un hechicero con esta regla especial puede equiparse con armadura sin penalización.</description>
    </rule>
    <rule id="5452-6c52-410e-2950" name="Capa de león" hidden="false">
      <description>Una miniatura con esta regla especial mejora su valor de armadura en 1 (hasta un máximo de 2+) contra ataques de disparos no mágicos.</description>
    </rule>
  </sharedRules>
  <sharedProfiles>
