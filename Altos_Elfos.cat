    <selectionEntry id="b1aa-ce69-9e7d-b78b" name="Leones de guerra" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="0383-ee73-59f8-6e28" type="equalTo"/>
          </conditions>
