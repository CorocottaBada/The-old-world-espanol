    <selectionEntry id="4776-b5e9-e5a5-2c5f" name="Fénix pico llameante" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="bf7d-bd0b-d394-ee27" value="2.0">
