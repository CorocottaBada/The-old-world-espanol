    <selectionEntry id="e6cf-e39b-25b6-9181" name="Ishaya Vess, centinela de la Isla Silenciosa" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d2e-9f06-17a7-f557" type="max"/>
      </constraints>
      <rules>
        <rule id="01e5-046b-b462-5188" name="Voz de mando" hidden="false">
          <description>El Alcance del Aura de Mando de Ishaya aumenta en 3”; en otras palabras, Ishaya Vess tiene un Aura de Mando de 12”. Si es la General de tu ejército, tiene un Aura de Mando de 15”.</description>
        </rule>
        <rule id="7bad-844f-f7d3-5c30" name="Ataques de precisión" hidden="false">
          <description>Una unidad de la Guardia del Mar de Lothern a la que se una Ishaya Vess mejora en 1 el atributo de Penetración de Armadura de sus armas.</description>
        </rule>
        <rule id="020e-f396-ea9b-66ac" name="Disciplina naval" hidden="false">
          <description>Una unidad de la Guardia de Mar de Lothern puede usar esta regla especial cuando declare una reacción de Aguantar y Disparar ante una carga. Una unidad que lo haga podrá realizar la reacción de Aguantar y Disparar independientemente de la distancia a la que esté la unidad que carga. Una vez resueltos estos disparos, la unidad cargada podrá realizar una maniobra gratuita de Reorganizar filas, tras la cual mantendrá la posición y esperará a la unidad que carga.
Las unidades que están huyendo, que ya están en combate al ser cargadas, o a las que se les haya unido un Personaje sin esta regla especial no pueden usar esta regla especial.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="ca90-eec1-a945-9116" name="Infantería ligera (Regular infantry)" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
        <infoLink id="f555-4e9b-89a4-2a5c" name="Armas de Ithilmar" hidden="false" targetId="2bd1-1d92-f5ae-e503" type="rule"/>
        <infoLink id="f586-8587-e7b0-3ac7" name="Valor ancestral (Valour of ages)" hidden="false" targetId="b8c2-f0f8-7532-639a" type="rule"/>
        <infoLink id="9ac8-dcdd-c646-272d" name="Grito de guerra (Rallying cry)" hidden="false" targetId="98aa-28c7-f0d9-c0d9" type="rule"/>
        <infoLink id="c400-6702-43c6-96bd" name="Golpea primero (Strike first)" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
      </infoLinks>
