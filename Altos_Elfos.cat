    <selectionEntry id="0c6b-7090-307a-17a4" name="Maestros de la espada de Hoeth" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="037a-cb1b-9104-8722" value="3.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="037a-cb1b-9104-8722" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="037a-cb1b-9104-8722" type="max"/>
      </constraints>
      <rules>
        <rule id="835a-4173-f7ec-f5da" name="Golpe perforante" hidden="false">
          <description>Si una miniatura con esta regla especial obtiene un 6 natural en una Tirada para Herir en un ataque de Combate, habrá conseguido un ‘Golpe Perforante’. Las miniaturas enemigas de tipo de tropa &apos;infantería regular&apos;, &apos;infantería pesada&apos;, &apos;caballería ligera&apos;, &apos;caballería pesada&apos; o &apos; bestias de guerra&apos; no pueden realizar tiradas de salvación por armadura o Regeneración contra un ‘Golpe Perforante&apos; (Las salvaciones especiales pueden hacerse normalmente).
Ten en cuenta que, si un ataque hiere automáticamente, esta regla especial no puede usarse.</description>
        </rule>
        <rule id="4e9e-72b4-976d-0fc9" name="Guerreros de la Torre Blanca" hidden="false">
          <description>A una unidad con esta regla especial solo se le puede unir un Mago Alto Elfo, o un Personaje con el Honor Élfico Guardián de Saphery o Señor del Conocimiento.</description>
        </rule>
        <rule id="3bd5-1d32-96fc-a02a" name="Desviar disparos" hidden="false">
          <description>Una miniatura con esta regla especial tiene una Salvación especial de 6+ contra cualquier herida sufrida que haya sido causada por un ataque de disparo no mágico.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="fe56-59b1-f0f7-fbb7" name="Infantería ligera" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
