        <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">F+2</characteristic>
        <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-2</characteristic>
        <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Ataques mágicos, Requiere ambas manos</characteristic>
