        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5a37-60a4-2a91-6ce5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2357-38e9-8f8e-8909" name="Armadura de Caledor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1268-86f9-c230-4d07" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f418-91d1-3a61-729f" type="max"/>
          </constraints>
          <profiles>
            <profile id="0885-a549-235a-9a12" name="Armadura de Caledor" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Caledor es una armadura completa. Además, su portador tiene una salvación especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2898-9fa8-efb5-e575" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="877d-4db3-3ff2-8496" name="Armaduras mágicas. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1ce4-1778-3022-051c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="183c-99d3-d3d9-dfa2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ec70-bbe2-638f-03f7" name="Yelmo dragón" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6563-3a21-d990-c19d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="743f-5b99-1efe-dda5" type="max"/>
          </constraints>
          <profiles>
            <profile id="03d8-6ac9-8030-9b2f" name="Yelmo dragón" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador del Yelmo Dragón mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador tiene una salvación especial de 6+ contra cualquier herida que haya sido causada por un ataque que tenga la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2065-11c8-8cce-71f5" name="Talismanes. Altos elfos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ae6-dc9b-43d3-2626" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e0d-539a-41f1-67fb" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dc5f-9e57-9ae2-944d" name="Capa del señor del conocimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6d9b-31b7-41fb-204e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9a88-8882-07a9-fb7d" type="max"/>
          </constraints>
          <profiles>
            <profile id="6f02-3f48-095a-a698" name="Capa del señor del conocimiento" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Capa del Señor del Conocimiento y cualquier unidad a la que se haya unido tiene una salvación de 4+ contra cualquier herida que haya sido causada por un proyectil mágico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7e04-8d10-003b-ea17" name="Brazalete de Atrazar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="310e-9ca4-ef2d-3240" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eb4a-48d5-4104-34d5" type="max"/>
          </constraints>
          <profiles>
            <profile id="be0e-8c52-4037-ceb2" name="Brazalete de Atrazar" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Brazalete de Atrazar tiene +1 Herida en su perfil. Además, si el tipo de tropa del portador es «infantería» o «caballería», tiene un modificador +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="06fe-5008-97d9-4893" name="Incienso sagrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e041-bc56-7441-745e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="51f0-6d36-9796-a76e" type="max"/>
          </constraints>
          <profiles>
            <profile id="e3a6-344e-26bc-1e29" name="Incienso sagrado" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que tome como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3625-628f-93a8-0e9f" name="Talismanes muy comunes. Altos elfos" hidden="false" collective="false" import="true">
