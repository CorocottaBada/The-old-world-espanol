      </constraints>
      <rules>
        <rule id="b916-5cf8-fcc7-2a50" name="Constitución poderosa" hidden="false">
          <description>Durante un turno en el que haya realizado un movimiento de carga de 3” o más, Korhil obtiene un modificador +1 a su atributo de Fuerza. Además, Korhil es inmune a la regla especial Ataques Envenenados. Si es alcanzado por un ataque con esta regla especial, el atacante debe tirar para Herir como de costumbre.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="3387-2ba5-28e9-e2e1" name="Infantería pesada (Heavy infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
