    <selectionEntry id="7c0b-b4d4-7760-1623" name="Fénix corazón gélido" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="e9e9-914f-d5da-de47" name="Aura glacial" hidden="false">
          <description>Mientras están en contacto peana con esta miniatura, las miniaturas enemigas quedan sujetas a la regla especial Golpea Último.</description>
        </rule>
      </rules>
