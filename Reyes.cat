      <rules>
        <rule id="775e-c2f3-aea5-da17" name="Protector juramentado" hidden="false">
          <description>En caso de que una miniatura de Monarca de Nehekhara sufra un impacto mientras se encuentra a 3&quot; o menos de esta miniatura, puede optar por transferir ese impacto y todos sus efectos a esta miniatura.</description>
        </rule>
      </rules>
