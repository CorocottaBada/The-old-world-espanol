          </constraints>
          <selectionEntries>
            <selectionEntry id="029a-e7e8-7eff-1da8" name="El broche de escarabajo de Usirian" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a821-d360-1874-5ee5" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2355-cbb0-ea80-5913" type="min"/>
              </constraints>
              <profiles>
                <profile id="15f5-491f-303e-000d" name="El broche de escarabajo de Usirian" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">El Broche Escarabajo de Usirian le otorga a Settra una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
                  </characteristics>
