        <infoLink id="3bf8-5456-d79d-f41e" name="Khopesh (Khopesh)" hidden="false" targetId="2b4d-7ce0-fc7e-5235" type="rule"/>
        <infoLink id="c237-355f-927f-7150" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
        <infoLink id="9e37-23b7-c8eb-cc8e" name="Muertos de Nehekhara (Nehekharan undead)" hidden="false" targetId="f7cb-1489-5a00-0c8b" type="rule"/>
        <infoLink id="7c20-ba92-a306-84aa" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
      </infoLinks>
