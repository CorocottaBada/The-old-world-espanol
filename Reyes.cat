            <selectionEntry id="bcee-8a0b-cd6e-e4e2" name="Jepesch bendecido de Ptra" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6c63-636c-2268-d23e" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9419-3611-b836-dc03" type="min"/>
              </constraints>
              <profiles>
                <profile id="0261-c260-ac15-338b" name="Jepesch bendecido de Ptra" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques flamígeros, Requiere ambas manos</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Cualquier miniatura enemiga que sufra una o más heridas no salvadas del Jepesch Bendecido de Ptra sufre un modificador de -1 en sus tiradas para Impactar, tanto al disparar como en combate, durante el resto de la partida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
