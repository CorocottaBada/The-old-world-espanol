    <selectionEntryGroup id="052a-4d08-6c05-1828" name="Talismanes. Reyes funerarios. Monarcas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="46f9-3689-0db0-4810" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54e6-15df-34ee-2d58" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ebc5-d5c6-d702-74b3" name="Corona de los Reyes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3437-8eaa-a877-7197" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e756-e251-659a-8a30" type="max"/>
          </constraints>
          <profiles>
            <profile id="d1af-9be4-96db-4e70" name="Corona de los Reyes" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Solo Monarcas de Nehekhara. Durante la subfase de Mando de su turno, si no están en combate, el portador de la Corona de los Reyes puede intentar resucitar a los caídos (ver página 76) haciendo un chequeo de Liderazgo. Si lo supera, una única unidad amiga de Guerreros Esqueleto, Arqueros Esqueleto, Jinetes Esqueleto o Arqueros Esqueleto a Caballo que esté dentro del Aura de Mando de esta miniatura recupera 1D3+1 Heridas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="bd41-9939-34f1-3314" name="Talismanes. Reyes funerarios" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aebf-80c8-a305-632c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0993-cfdb-a104-1f44" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fde6-545e-3269-66e4" name="Collar de Shapesh" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="89cb-3a3f-eef6-c78e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f57-511d-4cca-ea0f" type="max"/>
          </constraints>
          <profiles>
            <profile id="7154-5970-11df-a3a2" name="Collar de Shapesh" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un solo uso. Cuando el portador del Collar de Shapesh pierda su última Herida, tira 1D6. Con una tirada de 4+, la Herida no se
pierde. En su lugar, una única miniatura amiga dentro del Aura de Mando del portador se elimina del juego como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5ac5-b89d-45db-8255" name="Amuleto de la serpiente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c43a-21a3-e22d-0e50" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f840-dd57-73d7-9216" type="max"/>
          </constraints>
          <profiles>
            <profile id="8c55-eb7c-7d39-12b7" name="Amuleto de la serpiente" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Amuleto de la Serpiente y cualquier unidad a la que se haya unido gana la regla especial Ataques Envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f4a2-8a51-0d40-eec4" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="79a4-8302-2758-9ea9" name="Reliquia del sol del desierto" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9842-152d-14e3-9ba8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="40be-f0a8-bfd2-9dae" type="max"/>
          </constraints>
          <profiles>
            <profile id="3ffc-41dd-6ef6-7c26" name="Reliquia del sol del desierto" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Reliquia del Sol del Desierto no está sujeto a las reglas especiales de Seco Como el Polvo o Inflamable.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
