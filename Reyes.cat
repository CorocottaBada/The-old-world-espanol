        <selectionEntry id="9ef0-7283-ca5d-5b4d" name="Armadura de las eras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="67a4-d45c-d97d-c973" type="max"/>
