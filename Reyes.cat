        <selectionEntry id="1716-c258-91f6-d8e4" name="La espada del conquistador" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="279c-1b72-15a8-5399" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="66ca-8bae-569f-17e3" type="max"/>
          </constraints>
          <profiles>
            <profile id="9c90-8c3d-45ff-caa2" name="La espada del conquistador" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Golpe letal, Ataques mágicos, Golpea último, Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Mientras está involucrado en un Desafío, el portador de la Espada del Conquistador asesta un Golpe Letal si saca un 5 o 6 natural al hacer una tirada para Herir, en lugar del 6 habitual. Además, si el portador mata al General enemigo en un Desafío, ganas una bonificación de 100 puntos de victoria en el final de la partida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="be1f-75b1-04b3-1fdd" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
