        <selectionEntry id="3ed5-7d43-20fb-50a5" name="Sello de los siglos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="909a-6f2e-dc7b-98ef" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="397b-adc7-dab0-3f25" type="max"/>
          </constraints>
          <profiles>
            <profile id="1f9e-46bf-52f2-795f" name="Sello de los siglos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades enemigas en un radio de 6” de la miniatura que lleva el Sello de los Siglos sufren un modificador de -1 a su atributo de Iniciativa (hasta un mínimo de 1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="eb58-3e08-2476-46e0" name="Tapiz de las tierras conquistadas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4386-6a77-3af8-5e16" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fba4-76bd-cce3-4a87" type="max"/>
          </constraints>
          <profiles>
            <profile id="8683-761e-63d9-6782" name="Tapiz de las tierras conquistadas" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier estandarte enemigo capturado por una unidad que lleve el Tapiz de Tierras Conquistadas vale 100 Puntos de Victoria como trofeo de guerra.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="9f32-9e9c-5335-5446" name="Estandartes mágicos. Reyes funerarios. Estandarte de batalla" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d370-16c9-17d5-a796" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6ba-8ab6-5aa5-60eb" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="113d-8e53-8f4a-082b" name="Estandarte de las palabras malditas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4152-363d-3be6-bfc2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="18f6-c9e4-9469-84c9" type="max"/>
          </constraints>
          <profiles>
            <profile id="a99f-f26c-d036-589f" name="Estandarte de las palabras malditas" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Solo Portaestandarte de Batalla. Al final de cualquier fase en la que una o más miniaturas de una unidad a las que se le haya unido el portador del Estandarte de las Palabras Malditas pierdan su última Herida por un ataque enemigo, la unidad que realizó el ataque debe realizar un chequeo de Liderazgo. Si lo falla, la unidad enemiga sufre 1D3 Impactos de Fuerza 2, cada uno con una PA de -, por cada miniatura que perdió su última Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="587c-6ac4-5060-ebe8" name="Objetos hechizados. Reyes funerarios. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e03b-5657-3c2f-56a0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7f4b-7a20-928c-0072" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="82d7-8602-8059-283e" name="Manto de las dunas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6436-3d7c-8d86-2026" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="19d4-8838-3dc6-5b1d" type="max"/>
          </constraints>
          <profiles>
            <profile id="ed06-6511-df37-f2ab" name="Manto de las dunas" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo miniaturas cuyo tipo de tropa sea &apos;infantería&apos;. El portador del Manto de las Dunas obtiene la regla especial Volar (9). Además, cualquier unidad enemiga sobre la que se mueva el portador durante la subfase de Movimientos Restantes sufre 1D6 impactos de Fuerza 2, cada uno con una PA de -1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5e03-078f-4d21-c263" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
