    </selectionEntryGroup>
    <selectionEntryGroup id="3c9f-3198-3455-bff7" name="Objetos hechizados muy comunes. Reyes funerarios. Carros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="39d9-3b90-5f49-c273" type="max"/>
