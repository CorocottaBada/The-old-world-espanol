      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9146-ee2b-16ac-6a75" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="21e6-52ab-5c3b-ae9e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="81f3-b8dd-6d51-f67c" name="Broche del escarabajo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f646-ec8e-dff6-f8de" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9093-8655-9c77-2b1d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7aed-5f37-c422-d0c3" name="Broche del escarabajo" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Al usar la regla especial Surgidos de la Arena, una unidad invocada se puede colocar en cualquier punto del campo de batalla completamente a 18” o menos de un sacerdote funerario que lleve el Broche del Escarabajo, en lugar de los 12” habituales.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3f46-a89e-6ea5-93bb" name="Canope de Enkhil" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6444-d45f-5e8e-898e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8907-cd76-065a-4444" type="max"/>
          </constraints>
          <profiles>
            <profile id="40ac-e75a-3ced-1b17" name="Canope de Enkhil" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Durante la subfase de Mando de su turno, si no están en combate, el portador del Canope de Enkhil puede intentar desatar su contenido haciendo un chequeo de Liderazgo (usando su propio Liderazgo sin modificar). Si lo supera, se dispersan todos los hechizos de “Permanece en juego” actualmente en juego, incluidos los hechizos lanzados por hechiceros amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7bdb-106a-32ca-8bc8" name="Canope de Phâzerakt" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2535-27c4-3fc2-5177" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1f0a-0453-7aa8-e7ea" type="max"/>
          </constraints>
          <profiles>
            <profile id="0077-a515-5bea-3e63" name="Canope de Phâzerakt" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Durante la subfase de Mando de su turno, si no está en combate, el portador del Canope de Phâzerakt puede intentar desatar su contenido haciendo un chequeo de Liderazgo (usando su propio Liderazgo sin modificar). Si lo supera, coloca una unidad de 2D6+3 Guerreros Esqueleto Invocados en el campo de batalla en cualquier lugar completamente a 12” o menos de esta miniatura, pero a más de 1” de cualquier miniatura enemiga:</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <selectionEntries>
