            <profile id="13ac-4973-1777-a17f" name="Icono del héroe" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo miniaturas cuyo tipo de tropa sea ‘carro’. Esta miniatura duplica su Potencia de Unidad, de 3 a 6. Además, todos los Impactos causados por esta miniatura tienen un atributo de Perforación de Armadura de -2 y la regla especial de Ataques Mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4362-a3c8-27bd-6cbb" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
