    <selectionEntry id="e481-6943-a1b7-2716" name="El Príncipe Apophas, el señor maldito de los escarabajos" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1bb0-57d9-7a13-73eb" type="max"/>
      </constraints>
      <rules>
        <rule id="3b4d-611b-92ba-c92c" name="Príncipe escarabajo" hidden="false">
          <description>Si el Príncipe Apophas pierde su última Herida, antes de que su miniatura sea retirada del juego, todas las unidades enemigas en un radio de 2D6” o menos de él sufren 2D6 impactos de Fuerza 2 con una PA de -1.</description>
        </rule>
        <rule id="26ea-eaeb-f71a-7aed" name="Segador de Usirian" hidden="false">
          <description>Después del despliegue, designa a un único personaje de la lista del ejército de tu oponente. Apophas puede repetir cualquier tirada fallida para Impactar o para Herir hecha contra ese personaje. Además, cualquier impacto infligido por Apophas contra el personaje designado gana la regla especial Ataques Mágicos.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="b76b-f9d2-6441-07fe" name="Infantería ligera (Regular infantry)" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
        <infoLink id="f750-5151-6436-b778" name="Emboscadores (Ambushers)" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
        <infoLink id="ca97-463f-c6c7-d2e5" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
