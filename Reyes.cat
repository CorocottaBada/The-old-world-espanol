          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="748a-1ae4-5930-4419" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="81b2-e9ff-aec6-07b4" type="max"/>
          </constraints>
          <profiles>
            <profile id="7de4-430e-40f2-3616" name="Orbe de Ptra" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cualquier miniatura enemiga que tome como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
