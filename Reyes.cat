    <selectionEntryGroup id="aa89-8cc9-1960-d60a" name="Estandartes mágicos. Reyes funerarios" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="08cf-0821-83ec-b7fc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7815-6aa0-ca25-a5f5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6dfd-9b3d-77f6-e7a8" name="Icono del ojo sagrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3ca8-058a-800d-1bd5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="84e3-9d05-41b3-1d02" type="max"/>
          </constraints>
          <profiles>
            <profile id="7cc0-eb1e-8866-3007" name="Icono del ojo sagrado" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Icono del Ojo Sagrado tiene un modificador de +1 a su atributo de Habilidad de Armas (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="da30-0ecb-af8a-327b" name="Estandarte de los espejismos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d5e8-6fdc-1b7a-c73b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="febc-eaaa-5147-ffe7" type="max"/>
          </constraints>
          <profiles>
            <profile id="b1d8-febe-af5c-d9f9" name="Estandarte de los espejismos" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier miniatura enemiga que elija como objetivo a una unidad que lleve el Estandarte de los Espejismos durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c4c5-68cd-d40f-0dd3" name="Icono de Rakaph" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5d47-03dd-7c88-331a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f7d4-e3ea-ffcf-3ef9" type="max"/>
          </constraints>
          <profiles>
            <profile id="dc59-3198-ebd3-b546" name="Icono de Rakaph" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">A menos que realice un movimiento de carga, una unidad que lleve el Icono de Rakaph puede realizar una única reforma libre en cualquier momento durante su movimiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="786a-9c66-fd1d-522a" name="Estandarte real de Settra" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="09d4-e583-0d51-4628" type="equalTo"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="72c7-d018-adcf-92ff" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="44cc-5a3c-e272-dfa5" type="max"/>
          </constraints>
          <profiles>
            <profile id="1d33-cc6a-1027-294a" name="Estandarte real de Settra" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">El Estandarte Real de Settra solo puede ser adquirido en una lista que incluye a Settra el Imperecedero y/o a Nekaph, Emisario de Settra. Una unidad que lleve el Estandarte Real de Settra obtiene las reglas especiales Odio (personajes enemigos) y Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="808c-8456-ddb4-779d" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
