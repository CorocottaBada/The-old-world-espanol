        <selectionEntry id="10b4-a50f-eded-b4b6" name="Icono del héroe" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6c4f-75bc-b983-3cba" type="max"/>
