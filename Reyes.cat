          </constraints>
          <profiles>
            <profile id="fc6f-25e9-dee9-b981" name="Armadura de las eras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa sea ‘infantería’, ‘caballería’ o
‘carro’. La Armadura de las Eras es una armadura ligera. Además, las miniaturas enemigas deben repetir las tiradas exitosas para Herir realizadas contra el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c2e0-4ca7-3c19-c56d" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c9cc-d7dc-0f9c-d6c0" name="Armaduras mágicas. Reyes funerarios. Escudo" hidden="false" collective="false" import="true">
