            <selectionEntry id="c4e1-c849-cd3c-1c1e" name="Catapulta lanzacráneos" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf11-6f48-a607-a051" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8818-c690-f249-f26b" type="min"/>
              </constraints>
              <profiles>
                <profile id="8ea9-f27b-051b-afac" name="Catapulta lanzacráneos" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">12-60&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4 (8)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-3)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Ataques flamígeros, Ataques mágicos, Mover o disparar, Heridas múltiples (1D3+1), Cráneos aullantes.</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial “Bombardeo”, la plantilla de área de 3” y la Tabla de Problemas de la Catapulta. La regla especial de Heridas Múltiples (1D3+1) se aplica únicamente a la miniatura cuya peana se encuentra debajo del agujero central de la plantilla.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <rules>
                <rule id="afc1-f881-74f0-506d" name="Cráneos aullantes" hidden="false">
                  <description>Cualquier unidad que sufra una o más heridas no salvadas por esta arma debe hacer un chequeo de Pánico como si hubiera sufrido muchas bajas.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="c1f9-0240-cbcc-ceef" name="Aparatoso" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="9405-d29e-d5cd-8fad" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
                <infoLink id="348f-b4a7-4c88-b2b0" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
                <infoLink id="846d-b087-fc3b-a72c" name="Mover o disparar" hidden="false" targetId="cb9f-23e0-ab95-f2a8" type="rule"/>
                <infoLink id="2d3e-8d76-a546-c961" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
                <infoLink id="1743-4e3b-9ec7-d16e" name="Bombardeo" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
              </infoLinks>
