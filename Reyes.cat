          <profiles>
            <profile id="73de-e144-9a53-4773" name="Escudo de Ptra" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo de Ptra es un escudo. Además, cualquier miniatura
enemiga que dirija sus ataques contra el portador durante la fase de Combate sufre un modificador de -1 a su atributo de Habilidad de Armas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
