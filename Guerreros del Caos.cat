    <selectionEntry id="47f7-6029-5df3-6918" name="Dragón de fuego disforme" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="96a7-3621-0f37-a628" type="max"/>
      </constraints>
      <rules>
        <rule id="049b-961c-0387-a67f" name="Muerte explosiva" hidden="false">
          <description>Cuando un Dragón de Fuego Disforme pierde su última Herida, antes de que la miniatura sea retirada del juego, cada unidad (amiga o enemiga) a 6» o menos de él sufre 1D6 Impactos de Fuerza 5, cada uno con una PA de-2.</description>
        </rule>
        <rule id="0aef-6b61-59b7-2349" name="Fuego y caos" hidden="false">
          <description>Los Dragones de Fuego Disfrome tienen una salvación Especial de 5+ contra cualquier herida sufrida que haya sido causada por un ataque que tenga la regla especial Ataques Mágicos o Ataques Flamígeros.</description>
        </rule>
        <rule id="1a30-1cef-8e67-9c90" name="Aura de fuego disforme" hidden="false">
          <description>Otras miniaturas (tanto amigas como enemigas) no pueden realizar salvaciones Especiales a 3&quot; o menos de esta miniatura.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9626-aac0-0759-fa59" name="Formación cerrada (Close order)" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
        <infoLink id="b742-ff26-9a2c-ff0f" name="Coloso (Behemoths)" hidden="false" targetId="7e87-1008-0eda-9b33" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="682e-8f10-9dea-7184" name="New CategoryLink" hidden="false" targetId="cecf-b94c-e223-2f4a" primary="true"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry id="747b-dce5-0394-f709" name="Equipo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d975-07c8-bf3d-6c72" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="472e-a522-0203-14d8" type="min"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="a692-29b2-040c-9fd1" name="Explosión de fuego disforme" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d372-755b-d9a3-30b3" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="db6d-972f-5dfe-8549" type="min"/>
              </constraints>
              <profiles>
                <profile id="1d8f-9b7f-883a-e9c9" name="Explosión de fuego disforme" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
                  <characteristics>
                    <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">6-24&quot;</characteristic>
                    <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">4 (8)</characteristic>
                    <characteristic name="PA" typeId="7e92-29de-be29-1a1b">-1 (-3)</characteristic>
                    <characteristic name="Reglas especiales" typeId="534e-550c-d45e-56e0">Bombardeo, Aparatoso, Ataques flamígeros, Heridas múltiples (1D3+1).</characteristic>
                    <characteristic name="Notas" typeId="97a5-848b-e65d-91f1">Esta arma dispara como una catapulta, usando la regla especial Bombardeo, la plantilla de impacto de 3” . Si se obtiene un resultado de ‘Problemas’ en el dado de Artillería, esta miniatura pierde una única Herida (en vez de realizar una tirada en la Tabla de Problemas). La regla especial Heridas Múltiples (1D3+1) solo se aplica a una única m iniatura cuya base se encuentre bajo el
agujero central de la plantilla de impacto.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="72fe-f92b-f7d4-abbc" name="Bombardeo (Bombardment)" hidden="false" targetId="326e-f78f-0da2-fca6" type="rule"/>
                <infoLink id="edeb-d1be-22e9-9d46" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
                <infoLink id="a052-22c7-8a2e-1614" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
                <infoLink id="dae3-6abd-70d7-c6a8" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
