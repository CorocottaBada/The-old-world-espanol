    <selectionEntry id="070e-d3e9-1a45-0e16" name="Frydaal la encadenadora" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1631-0556-fb8e-097c" type="max"/>
      </constraints>
      <rules>
        <rule id="b83e-6da5-c399-a283" name="Encadenadora" hidden="false">
          <description>Cualquier estandarte enemigo capturado por Frydaal o cualquier unidad a la que se haya unido otorga 100 Puntos de Victoria
como trofeo de guerra.</description>
        </rule>
        <rule id="dcf8-d82b-071f-1c8d" name="Comandante y capitán" hidden="false">
          <description>A menos que esté huyendo, las unidades amigas de Bárbaros del Caos, Jinetes Bárbaros del Caos, Huscarls Bárbaros y Berserkers
Bárbaros obtienen un modificador de +1 a su atributo de Liderazgo mientras estén dentro del Rango de Mando de Frydaal (hasta
un máximo de 10).</description>
        </rule>
        <rule id="9166-ce27-1d65-2fff" name="Incursora sin igual" hidden="false">
          <description>0-1 unidad de Bárbaros del Caos o de Jinetes Bárbaros del Caos en el mismo ejército que incluya a Frydaal puede tener gratis la
regla especial Emboscadores. Además, si Frydaal es tu General, puedes además aplicar un modificador de +1 o -1 al resultado cuando tires para determinar si ella o cualquier unidad de Bárbaros del Caos o de Jinetes Bárbaros, Huscarls Bárbaros o Berserker Bárbaros con la regla especial Emboscadores que se mantiene actualmente en reserva llega este turno como refuerzo o se retrasa.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="30bf-f471-1e02-1bbf" name="Emboscadores (Ambushers)" hidden="false" targetId="c28f-5836-d0cf-d70f" type="rule"/>
        <infoLink id="9d12-b430-d51e-6777" name="Armadura del caos (X+)" hidden="false" targetId="e80b-d553-daa7-8ae8" type="rule"/>
        <infoLink id="971f-742f-44c2-97e2" name="Armas hechizadas (Ensorcelled weapons)" hidden="false" targetId="64ce-a3b1-e986-a65e" type="rule"/>
        <infoLink id="ceaa-5dcd-4c8a-3176" name="Mirada de los dioses (Gaze of gods)" hidden="false" targetId="325e-c67b-037a-0f0a" type="rule"/>
        <infoLink id="737b-87af-9006-d129" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
        <infoLink id="d9cb-dfe3-9628-d7b8" name="Infantería pesada (Heavy infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
        <infoLink id="b767-e2bb-64ec-82d7" name="Marca del caos Absoluto (Mark of Chaos undivided)" hidden="false" targetId="967f-90cc-d4d0-737a" type="rule"/>
        <infoLink id="b0ac-8262-7ac2-21c9" name="Grito de guerra (Rallying cry)" hidden="false" targetId="98aa-28c7-f0d9-c0d9" type="rule"/>
      </infoLinks>
