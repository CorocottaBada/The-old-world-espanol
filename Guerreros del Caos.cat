      </constraints>
      <selectionEntries>
        <selectionEntry id="12b1-5837-e381-3b87" name="Estandarte de la furia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="79b0-fb7b-43d3-4281" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4657-7078-d5cf-1173" type="max"/>
          </constraints>
          <profiles>
            <profile id="b2cc-0f49-ac27-b757" name="Estandarte de la furia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de la Furia obtiene la regla especial Furia Asesina. Sin embargo, a diferencia de otras unidades con Furia Asesina, esta unidad no puede perder esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c775-5471-3e5f-5497" name="Furia asesina (Frenzy)" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="16a9-573e-a454-fa6d" name="Estandarte de los dioses" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ccf-38ff-8ab5-8df4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fd4-106f-e681-10ac" type="max"/>
          </constraints>
          <profiles>
            <profile id="7a57-2cfa-6cfb-1de5" name="Estandarte de los dioses" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleva el Estandarte de los Dioses ignora todos los modificadores negativos a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="139a-9342-4c6b-37ba" name="Estandarte maldito" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="02cb-e656-5bc9-6d17" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d64f-fe85-7854-98e4" type="max"/>
          </constraints>
          <profiles>
            <profile id="af22-10e7-ae94-e3ca" name="Estandarte maldito" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte Maldito puede volver a tirar cualquier tirada de 1 natural al realizar una tirada de Salvación de Armadura contra heridas sufridas durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c444-b2e8-34d7-b760" name="Tótem de la condenación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2e5d-d153-3a47-aad5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e9cc-8fbe-6387-ae39" type="max"/>
          </constraints>
          <profiles>
            <profile id="fc02-3559-c4a6-1ce7" name="Tótem de condenación" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades enemigas que pueden trazar una línea de visión hacia la miniatura que lleva el Tótem de la Condenación sufren un modificador de -1 a su atributo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="082e-17ff-52eb-dc19" name="Icono de la oscuridad" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c064-9073-13f3-5909" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c73-b1b9-486d-4987" type="max"/>
          </constraints>
          <profiles>
            <profile id="33ca-1eb0-9c1d-3693" name="Icono de la oscuridad" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cualquier miniatura enemiga que tome como objetivo a una unidad que lleve el Icono de la Oscuridad durante la fase de Disparo sufre un modificador adicional de -1 para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2a59-b362-b5d4-20ec" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="19aa-1a64-1e10-b811" name="Estandarte de los poderes oscuros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8923-e69c-682d-1186" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0a3e-ea24-594a-5757" type="max"/>
          </constraints>
          <profiles>
            <profile id="4993-1fe4-70c6-af7c" name="Estandarte de los poderes oscuros" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que lleve el Estandarte de los poderes oscuros gana la regla especial Resistencia a la magia (-3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="53aa-c7c8-bc42-1365" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
