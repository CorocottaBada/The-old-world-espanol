          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7f82-0607-01cd-34fb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a90a-7818-4d02-8150" type="max"/>
          </constraints>
          <profiles>
            <profile id="b187-4d8e-65a3-9f5a" name="Corona de la conquista eterna" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Corona de la Conquista Eterna obtiene la regla especial Regeneración (5+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a5c3-4276-e32f-2492" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0afb-0e01-b9eb-cbb2" name="Talismán del águila errante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2411-780a-48f0-60d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a826-b8e3-9e7c-b148" type="max"/>
          </constraints>
          <profiles>
            <profile id="86e8-83aa-7b9c-25a7" name="Talismán del águila errante" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Talismán del Águila Errante tiene la regla especial Resistencia a la Magia (-2). Además, el portador tiene una salvación especial de 5+ contra cualquier herida sufrida que haya sido causada por un ataque que tenga la regla especial Ataques Mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4336-2759-a4de-e7cd" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="81e4-47f6-6b4a-5065" name="Talismán del cuervo carroñero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7f7f-b662-ecf3-3b64" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="08ea-d5e6-d9a2-0350" type="max"/>
          </constraints>
          <profiles>
            <profile id="402d-167d-abb7-d41e" name="Talismán del cuervo carroñero" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Talismán del Cuervo Carroñero tiene las reglas especiales Regeneración (5+) y Ataques Envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="028c-467a-2227-f205" name="Regeneración (X+)" hidden="false" targetId="aa4e-e70e-4049-680f" type="rule"/>
            <infoLink id="f5f8-c6e9-2eed-a0f1" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
