                </selectionEntry>
                <selectionEntry id="4ab6-6f7d-3490-8684" name="Hambre de batalla" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f20b-f58c-8aed-1247" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="c926-7254-a2dd-88cf" name="Hambre de batalla" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; solamente. Una unidad que consiste enteramente de miniaturas con este Rasgo Caótico aumenta su alcance de carga máximo posible en 2&quot; y, al realizar una tirada de Carga o Persecución, puede aplicar un modificador de +1D3 al resultado.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="632c-36c6-6385-9d11" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="2.0">
                      <repeats>
                        <repeat field="selections" scope="5bca-65c6-905c-1a4f" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="f3c7-fba3-27a7-ce20" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e450-6225-0608-ec5e" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="1309-fa74-9cde-21d6" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="2529-4e56-3a77-a994" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="5bca-65c6-905c-1a4f" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="f3c7-fba3-27a7-ce20" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e454-5019-645c-0dfc" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="4db9-f0bf-de9f-911f" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
