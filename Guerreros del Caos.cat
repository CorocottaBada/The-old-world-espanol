        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f721-1bdf-b125-e196" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="491f-f498-8205-e5d9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="901d-dbc6-4e2c-0cfd" name="Yelmo de incontables ojos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fdf3-59d7-f556-771a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9d85-fa4a-4aca-3670" type="max"/>
          </constraints>
          <profiles>
            <profile id="5608-b19a-8e5c-f914" name="Yelmo de incontables ojos" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El Yelmo de Incontables ojos otorga a su portador (pero no a su montura) la regla especial Golpea primero. Sin embargo, debido a las imágenes confusas que evoca el yelmo, su portador también está sujeto a la regla especial de Estupidez.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="8d71-2a46-a86a-507b" name="Golpea primero" hidden="false" targetId="5165-7d9e-0fe2-e584" type="rule"/>
            <infoLink id="ce5d-07c1-d264-c330" name="Estupidez" hidden="false" targetId="e78e-de09-5640-bcda" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="22c3-7a49-a5f7-7955" name="Vara de los condenados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e433-51d2-b5ae-91b7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ecdd-6fcd-903d-c616" type="max"/>
          </constraints>
          <profiles>
            <profile id="5606-c2c6-4c60-1e9f" name="Vara de los condenados" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador de la Vara de los Condenados puede lanzar el Hechizo de La Invocación del Saber de la Demonología (ver página 322 del libro de reglas de Warhammer: the Old World) como un Hechizo Vinculado con un Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c9af-64f5-c6cc-a5da" name="Objetos hechizados. Guerreros del caos. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9caf-3b2e-8316-12f5" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="51f9-c427-d274-19ad" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a62b-26bb-06c5-2aec" name="Collar de la condenación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4948-b945-a937-de3c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7337-f136-3393-c582" type="max"/>
          </constraints>
          <profiles>
            <profile id="cd64-4527-ed24-f951" name="Collar de la condenación" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. El portador del Collar de la Condenación obtiene un modificador de +1 a su atributo de Ataques por cada Herida que pierda.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f382-a4ba-8f29-af8e" name="Objetos hechizados muy comunes. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9653-7967-c896-f712" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="78a9-04a6-79ca-d95e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5923-8401-df69-10d9" name="Favor de los dioses" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cba7-9e6b-8c13-8949" type="max"/>
          </constraints>
          <profiles>
            <profile id="ce92-81c9-7f44-ba71" name="Favor de los dioses" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador de un Favor de los Dioses puede volver a tirar el 1D6 cuando tire en la Tabla de la Mirada de los Dioses.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="3e8a-6b5d-f33f-29c7" name="Objetos arcanos. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="df91-9476-46be-c9ac" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01ad-6ae9-111f-b0f6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4914-63f2-2c29-f3c1" name="Cráneo de Katam" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0642-0bd2-60ed-cdf8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b6e4-e1f0-c7f9-2db0" type="max"/>
          </constraints>
          <profiles>
            <profile id="a1bf-ebb8-644b-b3f0" name="Cráneo de Katam" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Cráneo de Katam y cualquier otro Hechicero en un radio de 3&quot; (amigo o enemigo) puede aplicar un modificador +1 a cualquier tirada de Lanzamiento que realice.
Ten en cuenta que esto es un modificador al resultado de una tirada, no niega una tirada de un doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4397-dc27-ff2d-cab0" name="Marioneta infernal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="047a-a28a-ee1b-c0e7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6fa0-46f3-f0b8-0fd8" type="max"/>
          </constraints>
          <profiles>
            <profile id="8f9f-094a-55eb-6d52" name="Marioneta infernal" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">A menos que el portador de la Marioneta Infernal esté huyendo o trabado en combate, puede usarla siempre que un Hechicero enemigo que esté a 15&quot; o menos de él haga una tirada de Lanzamiento. Si lo hace, el Hechicero enemigo debe tirar un 1D6 extra y descartar el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ebbd-9720-9bf9-5187" name="Grimorio de Ogvold" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bcca-a162-a038-20d2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4b91-af48-14e4-1e54" type="max"/>
          </constraints>
          <profiles>
            <profile id="9e61-d0c6-2ec4-00cb" name="Grimorio de Ogvold" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">En lugar de generar aleatoriamente los Hechizos que conoce, e independientemente de su Nivel de Hechicería, el portador del Grimorio de Ogvold conoce los siete Hechizos del Saber de la Magia que ha elegido (incluido el Hechizo Identificativo). Sin embargo, sólo puede lanzar un número de Hechizos igual a su Nivel de Hechicería por turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6489-4c43-20aa-a00e" name="Cetro de poder" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2f3c-4b35-3ffc-10db" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bd93-7b54-c0f9-015e" type="max"/>
          </constraints>
          <profiles>
            <profile id="0a81-b642-fca1-6672" name="Cetro de poder" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Cetro de Poder puede aplicar un modificador de +1 a cualquiera de sus tiradas de Lanzamiento o Dispersión. Sin embargo, si saca un doble natural al hacer una tirada de Lanzamiento o Dispersión, el portador sufre un único impacto de Fuerza 10 con un PA de -3 después de que se hayan resuelto los efectos de la tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1f7b-375c-dc83-dbb3" name="Armaduras mágicas. Guerreros del caos. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3295-9057-377e-97f7" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="89fe-7024-7db5-53c7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="870e-7bc5-40c3-9316" name="Armadura de la condenación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dc6b-06c6-d191-11d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f9c6-1665-9a20-d12c" type="max"/>
          </constraints>
          <profiles>
            <profile id="ede5-0f57-d034-0464" name="Armadura de la condenación" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de los Condenados es una Armadura Completa. Además, durante la fase de Combate, las miniaturas enemigas deben repetir las tiradas exitosas para Impactar contra el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="004a-a29e-cd59-64ea" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="70.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c892-13c2-fb85-5583" name="Armaduras mágicas. Guerreros del caos. Infantería o Caballería. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2ae3-5194-bdfe-cfe2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3884-036a-d87c-bc57" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b628-1a25-d85e-148b" name="Armadura carmesí de Dargan" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d858-58de-908f-1709" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fcf3-129d-0a09-6609" type="max"/>
          </constraints>
          <profiles>
            <profile id="f822-892a-f2fd-beb5" name="Armadura carmesí de Dargan" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa es &apos;infantería&apos; o &apos;caballería&apos;. La Armadura Carmesí de Dargan es una armadura pesada. Además, el portador es inmune a la regla especial de Heridas Múltiples (X). Si el portador sufre una herida no salvada por un ataque con esta regla especial, pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="4d97-9007-db18-e519" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c9d3-fab1-af39-567c" name="Coraza demoníaca" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6afa-10a6-9914-9231" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dd44-4860-f465-0abb" type="max"/>
          </constraints>
          <profiles>
            <profile id="235d-bddd-07d6-9019" name="Coraza demoníaca" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Sólo miniaturas cuyo tipo de tropa es «infantería» o «caballería es una armadura completa. Además, su portador mejora sus atributos de Resistencia e Iniciativa en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ae9d-15a9-d16b-4160" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
