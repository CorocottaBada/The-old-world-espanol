            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1c94-f8a9-ece2-99b2" type="max"/>
          </constraints>
          <profiles>
            <profile id="cbe2-5aca-e54b-8722" name="Majestad oscura" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">A menos que este personaje esté huyendo, cualquier unidad enemiga que deba realizar un chequeo de Miedo o Terror mientras esté dentro del Aura de Mando de esta miniatura lo hará con un modificador de -1 adicional a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="73cf-6dc9-01eb-dd5b" name="Baba venenosa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7d2c-d243-dcd9-2a2d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f451-86bc-af7d-871d" type="max"/>
          </constraints>
          <profiles>
            <profile id="5db1-f5e8-a782-a12b" name="Baba venenosa" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Este personaje (pero no su montura) tiene la regla especial Ataques envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9fff-d7af-97d2-e37f" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3667-55e0-58c6-7516" name="Aura de dolor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="de5d-9441-12e9-0694" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8584-dfae-2a1f-6a1e" type="max"/>
          </constraints>
          <profiles>
            <profile id="cec7-8d5c-795c-bd7d" name="Aura de dolor" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Una vez por partida, cuando se elige el combate de este personaje durante el Paso 1.1 de la Subfase de Combate Elige y Lucha, una sola unidad enemiga con la que se enfrenta sufre 3 impactos de Fuerza 1D6, que no permiten tiradas de Salvación por Armadura o Regeneración (las Salvaciones Especiales se pueden realizar normalmente).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f4e9-fb5f-f0ff-ed77" name="Maestro de mortales" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="44d0-1458-0c74-2b1e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="305f-cc95-2f85-2928" type="max"/>
          </constraints>
          <profiles>
            <profile id="f2e5-74a8-d954-c40c" name="Maestro de mortales" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">A menos que este personaje esté huyendo, las unidades amigas de Bárbaros del Caos y Jinetes Bárbaros obtienen un modificador de +1 a su atributo de Liderazgo mientras están dentro del Aura de Mando de este personaje (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3eb8-072d-3b58-ae20" name="Icor ácido" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1910-b060-86e1-6681" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6fc4-134d-5f3e-e59d" type="max"/>
          </constraints>
          <profiles>
            <profile id="029d-3324-8a8b-77fe" name="Icor ácido" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Por cada Herida que este personaje pierda durante un desafío, su enemigo sufre un impacto de Fuerza 4, con un PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
