              <selectionEntries>
                <selectionEntry id="c898-8760-7173-1d70" name="Zancadas largas" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="ea1b-038c-a76c-addb" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="01ea-317e-bde7-f377" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9a63-a96e-8e77-05c4" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01d8-a05a-4763-d607" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="d2b7-b871-5770-ebbf" name="Zancadas largas" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">0-1 unidad por cada 1.000 puntos. A menos que lleven armadura pesada o armadura completa, las miniaturas con este Rasgo Caótico ganan la regla especial Vanguardia.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="cc60-6c51-5f93-5c01" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
                  </infoLinks>
                  <entryLinks>
                    <entryLink id="0a1b-69a9-a413-eaec" name="Zancadas largas" hidden="false" collective="false" import="true" targetId="7171-ce62-6dbf-2866" type="selectionEntry"/>
                  </entryLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="a180-2e84-29e6-ff71" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0189-b344-f18c-b48e" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="62c4-81c4-aa61-0acc" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="5662-4e1d-31a0-a94d" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="6e94-acfe-cdc4-b2b2" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0b43-5d58-0781-a0a1" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8290-fa7c-9817-660b" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="6182-f887-56ff-dda8" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="1e7e-e14b-b955-b4fe" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="ea1b-038c-a76c-addb" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="01ea-317e-bde7-f377" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d135-b45b-1230-157c" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="e2e1-936e-b69e-9a64" name="Reflejos mejorados" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén trabados en combate, las miniaturas con este Rasgo Caótico que elijan luchar con un arma de mano ganan un modificador de +2 a su atributo de Iniciativa.
Ten en cuenta que este Rasgo Caótico solo se aplica a un arma de mano única y no mágica, o a un Arma Hechizada, y no se aplica a la montura de la miniatura (si tuviera una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, este Rasgo Caótico deja de aplicarse.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="d64a-e201-0183-4134" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="2.0">
                      <repeats>
                        <repeat field="selections" scope="ea1b-038c-a76c-addb" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="01ea-317e-bde7-f377" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d1d-95d4-edd7-b2ab" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="141f-9168-e941-e702" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="9d1e-6b42-12ba-7aae" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="ea1b-038c-a76c-addb" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="01ea-317e-bde7-f377" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6f3a-ec3e-bcd9-b9e8" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="131d-c94c-952a-f901" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
