        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ad55-4ce9-ab35-db79" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3035-ef78-ee13-2566" name="Sentidos amplificados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="beab-58e6-7ba0-278f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f8c4-e84f-af41-1262" type="max"/>
          </constraints>
          <profiles>
            <profile id="693d-2d18-4f81-67e6" name="Sentidos amplificados" hidden="false" typeId="8480-a3fb-93ec-f0d1" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7438-6592-9184-6d7a">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7fbf-d161-bec5-e2d8" name="Diablo de múltiples extremidades" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="51b5-d3bd-810f-f00c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b3cb-b564-6632-281e" type="max"/>
          </constraints>
          <profiles>
            <profile id="0955-81a6-c046-9cfb" name="Diablo de múltiples extremidades" hidden="false" typeId="8480-a3fb-93ec-f0d1" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7438-6592-9184-6d7a">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Ataques. Sin embargo, este ataque extra debe hacerse utilizando un arma de mano ordinaria.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5cbc-96ba-ab16-7b2c" name="Colmillos destripadores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e54d-dd2d-6a50-58bd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ddaf-a6e6-05a7-3a9c" type="max"/>
          </constraints>
          <profiles>
            <profile id="30f8-daae-cbb1-b87e" name="Colmillos destripadores" hidden="false" typeId="8480-a3fb-93ec-f0d1" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7438-6592-9184-6d7a">Durante la fase de Combate, el atributo de Penetración de Armadura de cualquier arma utilizada por esta miniatura (pero no su montura) es mejorada en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e561-ca72-4b1d-05db" name="Monstruosidad muscular" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="88c3-1a26-a53e-0811" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1f25-48ff-29f2-fcd5" type="max"/>
          </constraints>
          <profiles>
            <profile id="f442-a751-c323-b4c2" name="Monstruosidad muscular" hidden="false" typeId="8480-a3fb-93ec-f0d1" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7438-6592-9184-6d7a">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d406-f5e7-cc39-dbf7" name="Piel de babosa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d124-ddfa-7b87-5060" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e53f-638d-eba0-5f3a" type="max"/>
          </constraints>
          <profiles>
            <profile id="fe7b-13c7-e8ee-15ed" name="Piel de babosa" hidden="false" typeId="8480-a3fb-93ec-f0d1" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7438-6592-9184-6d7a">Cualquier miniatura enemiga que dirija sus ataques contra esta miniatura o cualquier unidad a la que se haya unido sufre un modificador de -1 a sus tiradas para Impactar durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="817f-9ed1-7d10-a5cc" name="Objetos arcanos muy comunes. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="006b-124f-c4e5-77ae" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2133-4fc5-7b06-4301" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4c14-ca5f-17d3-51d5" name="Familiar hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8a77-ac00-b05b-dc2d" type="max"/>
          </constraints>
          <profiles>
            <profile id="ed5f-165c-ef00-075d" name="Familiar hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por Hechicero. El propietario de un Familiar Hechicero conoce un hechizo adicional (elegido de la forma habitual) de lo normal para su Nivel de Hechicería.
Ten en cuenta que esto no aumenta el nivel del hechicero.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="03e3-410b-116f-2e45" name="Objetos hechizados. Guerreros del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a4be-29fc-8e66-8b33" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cc96-d0ff-0360-3198" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5c14-9e72-d2d1-3300" name="Colgante del cráneo sangriento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ac20-9a56-7b67-40c7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7c04-eabe-c207-d837" type="max"/>
          </constraints>
          <profiles>
            <profile id="3bc2-31bf-15d9-1d70" name="Colgante del cráneo sangriento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Sólo miniaturas cuyo tipo de tropa sea «infantería». En lugar de atacar normalmente, el portador del Colgante de Cráneo Sangriento puede elegir infligir un único impacto de Fuerza 8 a cada miniatura enemiga con la que esté en contacto, cada uno con una PA de -1. Estos impactos tienen la regla especial Golpe Letal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="457c-10d0-b140-1ef4" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="54f5-b2a0-f4f7-cb70" name="Objetos arcanos. Guerreros del caos. Caos absoluto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5209-5416-1a72-505e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c88c-7e3b-0b47-e549" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="97d9-9775-b6e9-aeda" name="Tomo de los dioses oscuros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="527f-71db-2114-ea0f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="dde6-e0ab-87be-869e" type="max"/>
          </constraints>
          <profiles>
            <profile id="8dfa-b74d-108c-8133" name="Tomo de los dioses oscuros" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Sólo miniaturas con la Marca del Caos Absoluto. Al generar sus hechizos, el portador del Tomo de los Dioses Oscuros puede descartar cualquier número de sus hechizos generados aleatoriamente. Por cada hechizo que descarte, puede elegir cualquier hechizo del Saber del Caos como si tuviera la Marca del Caos correspondiente.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b58a-6e98-e219-ebfc" name="Armas mágicas. Guerreros del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="18e1-3299-342b-df0a" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6a01-df73-c883-cd62" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="fe7d-0a57-bbd5-75ee" name="Azote del capataz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1ff4-3461-a13f-54ba" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e664-a48c-466c-db66" type="max"/>
          </constraints>
          <profiles>
            <profile id="3c62-c680-6501-6c92" name="Azote del capataz" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques adicionales (1).</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Sólo miniaturas con tipo de tropa «infantería». Durante la subfase de Mando de su turno, el portador del Azote del Capataz puede intentar incitar a los que le rodean a combatir con premura haciendo un chequeo de Liderazgo (usando su propio Liderazgo). Si se supera el chequeo, en tu siguiente subfase de Inicio de Turno, este personaje y cualquier unidad a la que se haya unido ganan un modificador de+1D3 a su atributo de Movimiento (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="3e59-56a5-4205-989f" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="d2b3-659f-2882-c4eb" name="Regalos del caos. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="91f0-3eec-1bf9-04c4" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ab1b-40fa-d90b-90e9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b98d-2493-8314-ead8" name="Aura encantadora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d8ed-9933-e579-16e8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="078a-7364-38c8-40ac" type="max"/>
          </constraints>
          <profiles>
            <profile id="c591-3f19-ebe3-5c59" name="Aura encantadora" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Sólo miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. Las unidades enemigas que estén trabadas en combate con este personaje no pueden usar la regla especial Golpea Primero. Las miniaturas enemigas que no tengan la regla especial Golpea Primero quedan sujetos a la regla especial Golpea Último.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5865-8439-317b-3c63" name="Esplendor diabólico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b745-e374-a9fb-1a1f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6532-5a87-3058-e483" type="max"/>
          </constraints>
          <profiles>
            <profile id="17d8-4ffe-37d0-d722" name="Esplendor diabólico" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Sólo miniaturas cuyo tipo de tropa es ‘infantería’ o ‘caballería’. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la Fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4cd0-e756-ccbd-c7ec" name="Rasgos caóticos. Personajes. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d326-ddcb-146a-88e9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c02-5231-dca2-c10d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="cab1-fa34-11d2-685c" name="Hambre de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="db22-138a-5e9c-ed07" type="max"/>
          </constraints>
          <profiles>
            <profile id="3af6-f446-553e-c174" name="Hambre de batalla" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; solamente. Una unidad que consiste enteramente de miniaturas con este Rasgo Caótico aumenta su alcance de carga máximo posible en 2&quot; y, al realizar una tirada de Carga o Persecución, puede aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8869-4952-ffa0-08c0" name="Rasgos caóticos. Personajes. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ae25-b7a7-783d-99a8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8874-5775-c0e9-d0d9" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="b7bb-f20b-027c-b12d" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c6a7-7abe-e70b-e9b1" type="max"/>
          </constraints>
          <profiles>
            <profile id="96e6-1a87-b7bb-9f83" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="ff1e-a916-d731-44e5" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="facb-480a-e4f2-84ef" type="max"/>
          </constraints>
          <profiles>
            <profile id="2046-6e28-f4cb-75d0" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0298-68f8-f179-160f" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="56f9-8cc5-3302-cdb1" name="Rasgos caóticos. Personajes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="414d-6132-13c6-fbd0" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4a95-73bc-94af-3e9c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8c4e-d77b-96fc-b5e4" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3646-87fe-f025-1699" type="max"/>
          </constraints>
          <profiles>
            <profile id="43b1-cedb-aa8e-1943" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a321-b225-0f9e-34de" name="Zancadas largas" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="increment" field="4f98-6fa3-6792-62e9" value="1.0">
              <repeats>
                <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
              </repeats>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f98-6fa3-6792-62e9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5c16-9b8b-4fbf-0bf2" type="max"/>
          </constraints>
          <profiles>
            <profile id="68a0-93b6-29e6-7c27" name="Zancadas largas" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">0-1 unidad por cada 1.000 puntos. A menos que lleven armadura pesada o armadura completa, las miniaturas con este Rasgo Caótico ganan la regla especial Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7f79-0758-61c5-1b09" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1491-0541-e5ac-01d9" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1477-7446-52a3-a026" type="max"/>
          </constraints>
          <profiles>
            <profile id="feed-eb88-3b41-4ca4" name="Reflejos mejorados" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén trabados en combate, las miniaturas con este Rasgo Caótico que elijan luchar con un arma de mano ganan un modificador de +2 a su atributo de Iniciativa.
Ten en cuenta que este Rasgo Caótico solo se aplica a un arma de mano única y no mágica, o a un Arma Hechizada, y no se aplica a la montura de la miniatura (si tuviera una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, este Rasgo Caótico deja de aplicarse.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d693-4626-997d-c5f7" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="091c-592b-e017-d8c0" type="max"/>
          </constraints>
          <profiles>
            <profile id="69d5-bdb6-210c-7d08" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
  <sharedRules>
    <rule id="e80b-d553-daa7-8ae8" name="Armadura del caos (X+)" hidden="false">
      <description>Una miniatura con esta regla especial tiene una Salvación Especial contra cualquier herida sufrida. El valor de armadura de esta Salvación Especial se muestra entre paréntesis después del nombre de esta regla especial (que se muestra aquí como &apos;X+&apos;). Además, un Hechicero con esta regla especial puede usar armadura sin penalización.</description>
    </rule>
    <rule id="64ce-a3b1-e986-a65e" name="Armas hechizadas" hidden="false">
      <description>Un arma de mano portada por una miniatura con esta regla especial tiene la regla especial Ataques Mágicos y un atributo de Penetración de Armadura de -1.
Ten en cuenta que esta regla especial solo se aplica a una sola arma de mano no mágica y no se aplica a la montura de la miniatura (si tiene una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, esta regla especial deja de aplicarse.</description>
    </rule>
    <rule id="325e-c67b-037a-0f0a" name="Mirada de los dioses" hidden="false">
      <description>Durante la subfase de Mando de su turno, un personaje con esta regla especial puede elegir tirar en la Tabla de la Mirada de los Dioses:
Tabla de la Mirada de los Dioses
1D6 Resultado
1 Maldito por el Caos: Esta miniatura queda sujeto a la regla especial Estupidez durante el resto de la partida. Si ya tiene esta regla especial, sufre un modificador de -1 a su Liderazgo (hasta un mínimo de 2).
2 Rapidez antinatural: Hasta tu próxima subfase de Inicio de Turno, esta miniatura obtiene un modificador +1 a su atributo de Iniciativa (hasta un máximo de 10).
3 Piel férrea: Hasta tu próxima subfase de Inicio de Turno, esta miniatura obtiene un modificador de +1 a su atributo de Resistencia (hasta un máximo de 10).
4 Mutación homicida: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a su atributo de Habilidad de Armas (hasta un máximo de 10).
5 Furia oscura: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a su atributo de Ataques (hasta un máximo de 10).
6 Apoteosis: Durante el resto de la partida, esta miniatura obtiene un modificador de +1 a sus atributos de Fuerza y Liderazgo (hasta un máximo de 10).
Ten en cuenta que los beneficios otorgados por la Mirada de los Dioses solo se aplican al Campeón, no a su montura (si tiene una).</description>
    </rule>
    <rule id="967f-90cc-d4d0-737a" name="Marca del caos Absoluto" hidden="false">
      <description>Las miniaturas con la Marca del Caos Absoluto pueden repetir cualquier chequeo fallido de Miedo, Pánico o Terror.</description>
    </rule>
    <rule id="86e0-caa6-5924-8b96" name="Marca de Khorne" hidden="false">
      <description>Las miniaturas con la Marca de Khorne tienen la regla especial Furia Asesina.</description>
    </rule>
    <rule id="b96f-ad4b-564d-8195" name="Marca de Nurgle" hidden="false">
      <description>Cualquier miniatura enemiga que dirija sus ataques contra una miniatura con la Marca de Nurgle durante la fase de Combate debe repetir cualquier tirada para Impactar natural de 6.</description>
    </rule>
    <rule id="3714-0777-75d2-23c9" name="Marca de Slaanesh" hidden="false">
      <description>Las miniaturas con la Marca de Slaanesh tienen +1 a su atributo de Iniciativa durante la primera ronda de cualquier combate. Además, si la mayoría de las miniaturas de una unidad tienen la Marca de Slaanesh, la unidad supera automáticamente cualquier chequeo de Pánico que deba realizar.</description>
    </rule>
    <rule id="326c-0825-11ad-6cbf" name="Marca de Tzeentch" hidden="false">
      <description>Las miniaturas con la Marca de Tzeentch tienen las reglas especiales Ataques Flamígeros y Resistencia a la Magia (-1). Además, si un Hechicero con la Marca de Tzeentch se ha unido a una unidad con la Marca de Tzeentch que tiene una Potencia de Unidad de 10 o más, puede aplicar un modificador +1 a cualquier tirada de Lanzamiento que realice. Si abandona la unidad por cualquier motivo, o si la Potencia de Unidad cae por debajo de 10, este modificador se pierde.</description>
    </rule>
    <rule id="39db-f5b5-c95d-c1ef" name="Saber del caos" hidden="false">
      <description>Un hechicero con la regla especial &quot;Saber del Caos&quot; puede descartar uno de sus hechizos generados al azar como es habitual. Cuando lo haga, puede seleccionar en su lugar el hechizo identificativo de su Saber de Magia elegido o bien el hechizo que corresponda a su marca del Caos enumerados a continuación.

Vientos del Caos (Marca del Caos Absoluto)
Tipo: Maldición
Dificultad de Lanzamiento: 7+/9+
Alcance: 21”
Efecto: Si este hechizo se lanza con un resultado de lanzamiento de 7 o más, la unidad enemiga objetivo sufre un modificador de -1 a su atributo de Movimiento (hasta un mínimo de 1). Si este hechizo se lanza con un resultado de lanzamiento de 9 o más, la unidad enemiga objetivo sufre un modificador de –2a su atributo de Movimiento (hasta un mínimo de 1). Este hechizo dura hasta tu próxima subfase de Inicio de Turno.

Aquiescencia (Marca de Slaanesh)
Tipo: Maldición
Dificultad de Lanzamiento: 6+
Alcance: 12”
Efecto: Hasta el final de la fase de combate, la unidad enemiga objetivo queda sujeta a la regla especial Golpea Último.

Abundancia Carnosa (Marca de Nurgle)
Tipo: Potenciación
Dificultad de Lanzamiento: 7+
Alcance: Lanzador
Efecto: Permanece en juego. Mientras este hechizo está en juego, el lanzador y cualquier unidad a la que se haya unido obtienen un modificador de +1 a su atributo de Resistencia (hasta un máximo de 7).

Fuego Azul (Marca de Tzeentch)
Tipo: Proyectil Mágico
Dificultad de Lanzamiento: 9+
Alcance: 18”
Efecto: La unidad enemiga objetivo sufre 1D6+3 Impactos de Fuerza 4, cada uno con una PA de -2 y con la regla especial Ataques Flamígeros.</description>
    </rule>
    <rule id="b89f-4cec-fe24-0f59" name="Culto del Cuervo carroñero" hidden="false">
      <description>Una vez por partida, durante la subfase de Mando de su turno, una unidad perteneciente a un Culto Caótico puede implorar la bendición de su patrón realizando un chequeo de Liderazgo. Si se pasa este chequeo, hasta su próxima subfase de Inicio del Turno, todas las miniaturas del Culto Caótico dentro de la unidad obtienen el siguiente beneficio. Si se falla este chequeo, las imploraciones de la unidad no son escuchadas:
Las miniaturas pertenecientes a este Culto Caótico obtienen un modificador de +1 a su atributo de Resistencia.</description>
    </rule>
    <rule id="bb85-b7a5-37b5-c631" name="Culto del Rapaz siniestro" hidden="false">
      <description>Una vez por partida, durante la subfase de Mando de su turno, una unidad perteneciente a un Culto Caótico puede implorar la bendición de su patrón realizando un chequeo de Liderazgo. Si se pasa este chequeo, hasta su próxima subfase de Inicio del Turno, todas las miniaturas del Culto Caótico dentro de la unidad obtienen el siguiente beneficio. Si se falla este chequeo, las imploraciones de la unidad no son escuchadas:
Las miniaturas pertenecientes a este Culto Caótico obtienen una Salvación Especial de 6+ contra cualquier herida sufrida que haya sido causada por un ataque enemigo no mágico.</description>
    </rule>
    <rule id="ea15-2055-95b1-b27c" name="Culto de la Serpiente reptante" hidden="false">
      <description>Una vez por partida, durante la subfase de Mando de su turno, una unidad perteneciente a un Culto Caótico puede implorar la bendición de su patrón realizando un chequeo de Liderazgo. Si se pasa este chequeo, hasta su próxima subfase de Inicio del Turno, todas las miniaturas del Culto Caótico dentro de la unidad obtienen el siguiente beneficio. Si se falla este chequeo, las imploraciones de la unidad no son escuchadas:
Las miniaturas pertenecientes a este Culto Caótico obtienen la regla especial Ataques Envenenados.</description>
    </rule>
    <rule id="aa2c-95e4-a132-eb24" name="Culto del sabueso ensangrentado" hidden="false">
      <description>Una vez por partida, durante la subfase de Mando de su turno, una unidad perteneciente a un Culto Caótico puede implorar la bendición de su patrón realizando un chequeo de Liderazgo. Si se pasa este chequeo, hasta su próxima subfase de Inicio del Turno, todas las miniaturas del Culto Caótico dentro de la unidad obtienen el siguiente beneficio. Si se falla este chequeo, las imploraciones de la unidad no son escuchadas:
Las miniaturas pertenecientes a este Culto Caótico obtienen un modificador de +1 a su atributo de Habilidad de Armas.</description>
    </rule>
    <rule id="d8f5-77b3-a9cd-3aa7" name="Cólera de la tormenta" hidden="false">
      <description>Una miniatura con esta regla especial tiene una Tirada de salvación especial de 5+ para cualquier herida sufrida a causa de hechizos de Proyectil mágico o Vórtice mágico. Además, si una miniatura con esta regla especial, o la unidad a la que pertenezca, sufre uno o más impactos por Llamada a la tormenta, (ver págica 74), se vuelve &quot;Encolerizada&quot;. Una miniatura &quot;Encolerizada&quot; tiene un modificador de +1 a sus atributos de Iniciativa y Ataques. Esta &quot;Encolerizada&quot; dura hasta su siguiente subfase de Inicio del Turno.</description>
    </rule>
  </sharedRules>
</catalogue>