            <selectionEntryGroup id="d6d2-66dc-aa51-22d0" name="Ragos caóticos" hidden="false" collective="false" import="true">
              <constraints>
                <constraint field="selections" scope="parent" value="2.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b79e-8ace-c8e6-7049" type="max"/>
              </constraints>
              <selectionEntries>
                <selectionEntry id="7e94-76ff-c9dc-62b9" name="Corazones oscuros" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="9fcb-d148-bc1d-fb7b" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="c075-83cd-95d8-2c95" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1a98-9f12-7377-7eb7" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="7140-1040-30cb-dc24" name="Corazones oscuros" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa sea &apos;infantería&apos; o &apos;caballería&apos; solamente. Si el bando ganador de un combate incluye una o más unidades en las que la mayoría de las miniaturas tienen este Rasgo Caótico, cada unidad que pertenezca al bando perdedor sufre un modificador de -1 a su atributo de Liderazgo al realizar su Chequeo de Desmoralización. Las miniaturas que tienen este Rasgo Caótico, que causan Terror, o que son Inmunes a la Psicología no se ven afectadas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="2502-db4c-ce56-a700" name="Voluntad de bronce" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8903-18f8-27cc-a3ea" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="134b-52a3-807a-bfee" name="Voluntad de bronce" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Miniaturas cuyo Tipo de Tropa es &apos;infantería&apos; o &apos;caballería&apos; solamente. Una unidad con este Rasgo Caótico gana la regla especial Resistencia a la Magia (-1).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="b2b4-1872-6b05-205e" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="ac37-8564-6ce8-28f2" name="Visión profética" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="786c-f6ea-0cb5-e799" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef90-5ebd-6e35-ebf8" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="fe19-1b37-1207-c9be" name="Visión profética" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Las unidades enemigas que desplieguen usando la regla especial Exploradores no pueden ser desplegadas a menos de 18&quot; de una unidad en la que cada miniatura tenga este Rasgo Caótico (en lugar de las 12&quot; habituales). Además, las unidades enemigas que desplieguen usando la regla especial Emboscadores no pueden ser colocadas a menos de 12&quot; (en lugar de las 8&quot; habituales) de una unidad en la que cada miniatura tenga este Rasgo Caótico.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="1e8f-c0de-4b22-dc9b" name="Reflejos mejorados" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="1.0">
                      <repeats>
                        <repeat field="selections" scope="9fcb-d148-bc1d-fb7b" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="c075-83cd-95d8-2c95" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ad5-53e0-d3e6-10e6" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="2789-7ced-6016-a9f2" name="Reflejos mejorados" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Mientras estén trabados en combate, las miniaturas con este Rasgo Caótico que elijan luchar con un arma de mano ganan un modificador de +2 a su atributo de Iniciativa.
Ten en cuenta que este Rasgo Caótico solo se aplica a un arma de mano única y no mágica, o a un Arma Hechizada, y no se aplica a la montura de la miniatura (si tuviera una). Si la miniatura está usando dos armas de mano o cualquier otro tipo de arma, este Rasgo Caótico deja de aplicarse.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="63da-a185-bff2-882b" name="Fortaleza antinatural" hidden="false" collective="false" import="true" type="upgrade">
                  <modifiers>
                    <modifier type="increment" field="33c0-92bb-bf87-74d4" value="2.0">
                      <repeats>
                        <repeat field="selections" scope="9fcb-d148-bc1d-fb7b" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="c075-83cd-95d8-2c95" repeats="1" roundUp="false"/>
                      </repeats>
                    </modifier>
                  </modifiers>
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="576e-ffa4-ec5a-ea9e" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="030a-ff1e-5352-425f" name="Fortaleza antinatural" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">A menos que lleven armadura pesada o armadura de placas completa, las miniaturas con este Rasgo Caótico mejoran su atributo de Resistencia en 1 (hasta un máximo de 10).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
