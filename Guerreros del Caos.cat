    <selectionEntryGroup id="9719-0f29-4ece-288d" name="Estandartes mágicos. Guerreros del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="50a4-6071-f9dd-8039" type="max"/>
