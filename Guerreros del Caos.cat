            <profile id="edfa-41ff-f1c4-dfdb" name="Brazo extra" hidden="false" typeId="1623-b517-650d-568a" typeName="Regalo del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="adaa-a956-3d52-ba7a">Este personaje (pero no su montura) tiene un modificador +1 a su atributo de Ataques.</characteristic>
              </characteristics>
