      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="20db-600b-d86c-f332" type="max"/>
      </constraints>
      <rules>
        <rule id="e797-7e0e-9fbe-04f8" name="Padre de las bestias" hidden="false">
          <description>Mientras estén dentro del Aura de Mando de Ghorros Warhoof, las Manadas de Centigors amigas pueden repetir la tirada de 1D6 al tirar en la tabla de Borracho .</description>
        </rule>
        <rule id="0809-4bf1-ee83-58f1" name="Los hijos de Ghorros" hidden="false">
          <description>0-1 Manada de Centigors en la misma lista de ejército que Ghorros puede ser mejorada a Hijos de Ghorros por +2 puntos por miniatura. Los Hijos de Ghorros tienen un modificador de +1 a su atributo de Habilidad de Armas y Liderazgo (hasta un máximo de 10) y obtienen la regla especial Perforacorazas (1).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="6f54-c42f-e3db-6c4e" name="Mirada de los dioses" hidden="false" targetId="e43e-2e96-1b91-a6dc" type="rule"/>
        <infoLink id="f2dc-f018-c02e-0019" name="Caballería pesada (Heavy cavalry)" hidden="false" targetId="f079-4c2e-a239-014c" type="rule"/>
        <infoLink id="57a8-fe1b-43d9-814d" name="Marca del caos Absoluto" hidden="false" targetId="3d61-886a-c0e2-3841" type="rule"/>
        <infoLink id="d2de-ed90-7b0c-ae1f" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
        <infoLink id="8c29-1e09-3921-ea9e" name="Furia primitiva" hidden="false" targetId="a5b9-7b69-a4cf-f3ce" type="rule"/>
        <infoLink id="d574-95d0-49f8-9a1e" name="Golpetazo (X)" hidden="false" targetId="c3fc-6bee-83fd-5186" type="rule"/>
