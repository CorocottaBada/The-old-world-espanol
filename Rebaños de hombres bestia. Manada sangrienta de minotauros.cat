            <profile id="c61c-f888-293f-5e71" name="Sentidos amplificados" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Iniciativa.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
