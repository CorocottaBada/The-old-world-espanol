    <selectionEntryGroup id="afaa-82b2-83eb-d19a" name="Estandartes mágicos. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1243-be6e-999e-aa59" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a544-3808-f134-b08c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="936c-e6f8-b903-2f47" name="Estandarte de la vergüenza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0000-9ee8-830f-260f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="61df-573a-6156-cfda" type="max"/>
          </constraints>
          <profiles>
            <profile id="41f4-4223-331f-92d8" name="Estandarte de la vergüenza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de la Vergüenza puede repetir su chequeo de Liderazgo cuando chequea para Furia Primitiva.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5ca7-3d96-05e2-4ddc" name="Tótem herrumbroso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b19f-c9fb-b786-2190" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0b51-7807-3e6f-a9f3" type="max"/>
          </constraints>
          <profiles>
            <profile id="93cd-af64-b483-98b5" name="Tótem herrumbroso" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cada miniatura (amiga o enemiga) que está a 6” o menos de la miniatura que porte el Tótem Herrumbroso sufre un modificador de -1 a sus tiradas de Salvación por Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="470a-0673-3711-90e1" name="Tótem virulento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="605f-cf44-fcb1-683d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2941-62d5-6e15-c0fd" type="max"/>
          </constraints>
          <profiles>
            <profile id="ff35-6810-3d63-8f50" name="Tótem virulento" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tótem Virulento obtiene la regla especial Ataques Envenenados.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ae0f-640a-33a2-2ff1" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cea0-4b3d-e2ec-67b0" name="Estandarte de la perdición humana" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3106-437b-7104-fde9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3116-f35e-f6c8-bdb0" type="max"/>
          </constraints>
          <profiles>
            <profile id="6b28-7910-57a9-f0b7" name="Estandarte de la perdición humana" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades enemigas que están a 6” o menos de la miniatura que porte el Estandarte de la Perdición Humana sufren un modificador de -1 a su atributo de Liderazgo (hasta un mínimo de 2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a41d-bef3-37f1-dcd1" name="El Estandarte de la Carnicería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="e128-6409-ba46-4698" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee91-c72b-b3dd-6259" type="max"/>
          </constraints>
          <profiles>
            <profile id="c13e-22b6-fcc2-2dab" name="El Estandarte de la Carnicería" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Si una unidad desea declarar una carga contra una unidad que porta el Estandarte de la Carnicería, debe primero superar un chequeo de Liderazgo. Si este chequeo se falla, la unidad no puede cargar. No se mueve y se considera que ha realizado una carga fallida. Si este chequeo se supera, la unidad puede cargar con normalidad.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c8c7-a934-b4e7-b885" name="Estandarte de la Luna Retorcida" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="081f-8e2b-b9c3-123a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7d36-1fd7-f12a-1637" type="max"/>
          </constraints>
          <profiles>
            <profile id="64f4-0a63-7703-4361" name="Estandarte de la Luna Retorcida" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Durante la subfase de Mando de su turno, si no están trabados en combate, el portador de este estandarte puede intentar desatar su poder realizando un chequeo de Liderazgo (usando su propio Liderazgo sin modificar). Si este chequeo se supera, hasta tu siguiente subfase de Inicio del Turno las unidades enemigas no pueden usar la regla especial Volar (X).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="649a-7a67-830c-c024" name="El Estandarte de la Bestia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bc56-be77-03ce-22cb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ccc3-d55f-5af6-11ee" type="max"/>
          </constraints>
          <profiles>
            <profile id="5aab-d3da-674b-316f" name="El Estandarte de la Bestia" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte de la Bestia aumenta su alcance de carga máximo posible en 3” y, cuando realiza una tirada de Carga, puede aplicar un modificador de +1D3 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cd82-781d-8809-86ca" name="El Tapiz Profanado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="de74-8eb5-967b-d0a2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cb66-e2a5-ebc6-926e" type="max"/>
          </constraints>
          <profiles>
            <profile id="a352-6ce1-83f6-7bdf" name="El Tapiz Profanado" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Tapiz Profanado obtiene la regla especial Odio (todos los enemigos). Sin embargo, todas las miniaturas enemigas Odian a la unidad que porta este estandarte.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ec3c-e555-aae9-9c83" name="Odio (todos los enemigos) (Hatred)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="feeb-fc16-7dee-9510" name="Armas mágicas. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d82-93f0-f40a-d9e2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f0ed-c34c-38f6-9a44" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e140-0477-82af-103a" name="Hacha de los hombres" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ffc6-6e62-5886-c119" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="31f9-919f-9be7-89f9" type="max"/>
          </constraints>
          <profiles>
            <profile id="dbee-668a-c053-8150" name="Hacha de los hombres" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Golpe letal, Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Si el portador del Hacha de los Hombres mata un personaje enemigo (incluidos campeones) en un desafío, obtiene la regla especial Terror para el resto de la batalla.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f2a8-c7fb-1f9a-a190" name="Golpe letal (Killing blow)" hidden="false" targetId="b925-a41b-6f43-8851" type="rule"/>
            <infoLink id="0bbf-2519-7be6-8d3a" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="abf7-3c0b-b028-5475" name="Lanza de caza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5248-d9a0-9408-140f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c25-46d0-e002-3f72" type="max"/>
          </constraints>
          <profiles>
            <profile id="bb95-6f8a-bbef-ef4b" name="Lanza de caza" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">24&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">6</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Aparatoso, Ataques mágicos, Heridas múltiples (2), Atravesar filas</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">La Lanza de Caza dispara como un lanzavirotes, usando la regla especial Atravesar Filas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="db49-0da6-cb51-3f1c" name="Aparatoso (Cumbersome)" hidden="false" targetId="f595-9274-a126-f21e" type="rule"/>
