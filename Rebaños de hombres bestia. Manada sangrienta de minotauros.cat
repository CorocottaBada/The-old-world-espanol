            <selectionEntry id="07b4-5aeb-46c2-83ac" name="Marca de Tzeentch" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="a090-7e2b-4639-9f98" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a8d6-3481-53fb-4914" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d8fa-d63c-abc7-b605" type="max"/>
              </constraints>
              <rules>
                <rule id="c715-2125-fdb2-db53" name="Marca de Tzeentch (Mark of Tzeentch)" hidden="false">
                  <description>Las miniaturas con la Marca de Tzeentch tienen las reglas especiales Ataques Flamígeros y Resistencia Mágica (+1). Adicionalmente, si un Hechicero con la Marca de Tzeentch se une a una unidad con la Marca de Tzeentch con una Fuerza de Unidad de 10 o más, obtendrán un bonificador de +1 a cualquier tirada de Lanzamiento de Hechizos. Si abandonara esa unidad o si la Fuerza de Unidad de dicha unidad bajara de 10, este bonificador se pierde.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="7cbe-5aed-a7e1-35af" name="Marca de Nurgle" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="a090-7e2b-4639-9f98" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a8d6-3481-53fb-4914" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c15-f0e3-749b-b7d2" type="max"/>
              </constraints>
              <rules>
                <rule id="8f07-c6b5-3581-32e3" name="Marca de Nurgle (Mark of Nurgle)" hidden="false">
                  <description>Cualquier miniaturas enemiga que dirija un ataque a una miniatura con la Marca de Nurgle durante la Fase de Combate, deberá repetir cualquier tirada natural de 6 para Impactar.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="1b4d-e34a-92b8-d965" name="Marca de Slaanesh" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
                  <repeats>
                    <repeat field="selections" scope="a090-7e2b-4639-9f98" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="a8d6-3481-53fb-4914" repeats="1" roundUp="false"/>
