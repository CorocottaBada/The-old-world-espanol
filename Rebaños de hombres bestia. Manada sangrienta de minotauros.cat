          <profiles>
            <profile id="7f32-fc85-f655-4cfb" name="Runa de la bestia verdadera" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Miniaturas enemigas cuyo tipo de tropa sean ‘monstruo’ sufren un modificador de -1 a su atributo de Habilidad de Armas mientras estén a 6” o menos del portador de la Runa de la Bestia Verdadera.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c556-5f3a-d394-07d5" name="Cáliz de la Lluvia Negra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dff0-9939-22d1-81bb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e49-877f-6b37-3eed" type="max"/>
          </constraints>
          <profiles>
            <profile id="f08f-c9b9-7bc2-553b" name="Cáliz de la Lluvia Negra" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, el portador del Cáliz de la Lluvia Negra puede beber de él. Hasta tu siguiente subfase de Inicio del Turno, el alcance de todas las armas de proyectiles enemigas se reduce a la mitad (redondeando fracciones hacia arriba) y las máquinas de guerra enemigas no pueden disparar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="15de-96bc-81ed-cc27" name="Cornucopia de Corpulencia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4466-e4f9-1152-5d01" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="da2f-fff7-0d34-fa17" type="max"/>
          </constraints>
          <profiles>
            <profile id="0d80-1072-b7d4-79b3" name="Cornucopia de Corpulencia" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cuando se elige el combate del portador durante el Paso 1.1 de cualquier subfase de Elegir Combate y Luchar, las miniaturas enemigas en contacto peana con peana con el portador de la Cornucopia de Corpulencia deben realizar un chequeo de Resistencia. Si este chequeo se falla, pierden una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
