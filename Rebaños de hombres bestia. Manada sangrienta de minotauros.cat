        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6ae5-a6b0-e3a6-71ff" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f577-eada-9580-6116" name="Placas oscuras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dbcf-02b4-319e-d431" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f22c-76eb-94cf-ded2" type="max"/>
          </constraints>
          <profiles>
            <profile id="296f-dbc2-efbc-f6fa" name="Placas oscuras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Las Placas Oscuras son un conjunto de armadura completa. Además, su portador tiene una Salvación Especial de 3+ contra cualquier herida causada por un ataque que tenga la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="855f-09f6-aff1-2c39" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
            <infoLink id="1886-a82f-35f3-660a" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="884a-16ed-1435-5ebb" name="Armaduras mágicas. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8e14-4880-faee-5f2b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="79e1-2f42-a001-7cd6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bc0d-1580-6ed6-58b3" name="Pellejo del caminante de sombras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c78f-f76b-cc1f-feee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f74-5f2e-53df-877a" type="max"/>
          </constraints>
          <profiles>
            <profile id="9ac2-0965-e629-c281" name="Pellejo del caminante de sombras" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede combinarse con otra armadura. El portador del Pellejo de Caminante de Sombras mejora su valor de armadura en 1 (hasta un máximo de 2+). Además, su portador (y cualquier unidad a la que se haya unido) tienen Resistencia a la Magia (-2).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ccb2-eba0-37cb-7365" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f546-fadf-3171-168e" name="La Piel de Sharggu" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3374-1c0f-d7f8-b2f3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="56d7-07f0-0e03-e504" type="max"/>
          </constraints>
          <profiles>
            <profile id="3770-1da2-e7b0-d755" name="La Piel de Sharggu" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a"/>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otra armadura. El portador de La Piel de Sharggu mejora su valor de armadura en 2 (hasta un máximo de 2+) contra ataques de proyectiles no mágicos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5e6c-5689-d79e-c298" name="Armaduras mágicas muy comunes. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d7ce-f2c3-e6bd-6bf1" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="da17-620c-c8d8-db63" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e322-3103-b488-ad6e" name="Armadura completa del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8087-e1b0-d0b9-480e" type="max"/>
          </constraints>
          <profiles>
            <profile id="022a-06d5-1243-459b" name="Armadura completa del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1f7f-679e-f383-547d" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="37be-7bb7-54de-ead5" name="Armadura pesada del caos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="62cf-09ea-8175-a640" type="max"/>
          </constraints>
          <profiles>
            <profile id="60b4-e47d-1dce-3aba" name="Armadura pesada del caos" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura completa del Caos es una armadura completa. La Armadura Pesada del Caos es una armadura pesada. Ambas pueden ser adquiridas y llevadas por un Mago, incluso si no tiene la opción de equiparse con armadura, escudo o barda, sin penalización. Además, el portador de una Armadura del Caos tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="77b2-a1e0-28c1-fe37" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
