            <profile id="7748-2097-0a38-602d" name="Piel humana" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Solo Caudillos Hombres Bestia y Chamanes Hombres Bestia cuyo tipo de tropa es ‘infantería’. El portador de la Piel Humana obtiene las reglas especiales Exploradores y Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="0bea-6483-fdd9-4b1f" name="Exploradores (Scouts)" hidden="false" targetId="e8e4-c7cf-ab65-c419" type="rule"/>
            <infoLink id="b42f-029c-0760-9f76" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b772-c717-184c-e6c4" name="Objetos hechizados. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="752b-54da-431c-a0d8" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ec7e-db1d-fdec-f4f2" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7f86-eb6c-0eee-8cb2" name="Piedra del resentimiento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5c89-2041-98e5-c1a7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d67e-a5d8-fb3e-e291" type="max"/>
          </constraints>
          <profiles>
            <profile id="1d8a-5a42-288a-eca5" name="Piedra del resentimiento" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Durante la subfase de Mando de su turno, si no está trabado en combate, este personaje puede usar la Piedra del Resentimiento. Hasta tu siguiente subfase de Inicio del Turno, todos los Hechiceros (amigos o enemigos) sufren un modificador de -2 a sus tiradas de Lanzamiento.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="33c2-05d7-ad22-0017" name="Cuerno de la primera bestia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2a79-3db1-f8f0-c3e9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ed2d-6598-18d1-1bd1" type="max"/>
          </constraints>
          <profiles>
            <profile id="692d-4174-084c-1a1e" name="Cuerno de la primera bestia" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Excepto si el portador del Cuerno de la Primera Bestia está huyendo, cualquier unidad amiga que esté a 18” o menos de esta miniatura puede usar su atributo de Liderazgo cuando chequean por Furia Primitiva.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="47ef-ced6-2964-1f64" name="Azote de los Agobiados" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c6dc-20e8-6893-2003" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4dac-933c-ac80-1d9a" type="max"/>
          </constraints>
          <profiles>
            <profile id="14d1-6de0-9e60-ecfe" name="Azote de los Agobiados" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Azote de los Agobiados puede lanzar el hechizo Llamada de lo Salvaje del Saber de la Magia Primigenia como un Hechizo Vinculado, con un Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9422-8ded-af0e-5a3e" name="Tonada Cacofónica" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2f2a-8cd5-b825-f058" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0c63-6530-562b-fac8" type="max"/>
          </constraints>
          <profiles>
            <profile id="9fb9-9902-5b1c-79e1" name="Tonada Cacofónica" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Mientras su unidad esté a 18” o menos del portador de la Tonada Cacofónica, los músicos enemigos no pueden usar sus reglas de “¡Adelante hacia la Victoria!”, Ritmo Constante o Toque Rápido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dacb-3a93-a5de-8049" name="Cuerno de la Gran Cacería" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5f47-f951-8d91-e5e7" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6d1b-f709-954f-1c2a" type="max"/>
          </constraints>
          <profiles>
            <profile id="8fde-e23b-986c-bdc8" name="Cuerno de la Gran Cacería" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Una vez por turno, después de tirar para determinar si una unidad con la regla especial Emboscadores que actualmente se mantiene en reserva como refuerzo llega, y si el portador del Cuerno de la Gran Cacería está en el campo de batalla y no está huyendo, puedes aplicar un modificador de +1 o -1 al resultado.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8085-c7ce-4689-ca8e" name="Objetos arcanos. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0ae3-9c12-f419-4b95" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d74-701c-3603-de80" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="660d-2858-d730-b480" name="Cáliz de la plaga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1b6e-cafe-bc73-553d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a298-cc09-a782-ab09" type="max"/>
          </constraints>
          <profiles>
            <profile id="d35a-37c2-4bac-d73b" name="Cáliz de la plaga" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Si el portador del Cáliz de la Plaga obtiene cualquier resultado doble natural al realizar una tirada de Lanzamiento (sin incluir tiradas naturales de doble 1), el hechizo es lanzado con Fuerza Irresistible independientemente de su valor de lanzamiento o cualquier otro
modificador. Sin embargo, cada vez que el portador lanza con Fuerza
Irresistible, sufre un impacto de Fuerza 4 sin tirada de salvación por armadura (se permite Salvación Especial y Regeneración como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1240-1810-4070-2f30" name="Daga ritual" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c2fd-b2e1-658d-c6bf" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1dcc-443c-bb9e-a01a" type="max"/>
          </constraints>
          <profiles>
            <profile id="2884-0c57-6a42-1d21" name="Daga ritual" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La Daga Ritual solo puede ser usada por un Hechicero que se haya unido a una unidad. Antes de hacer una tirada de Lanzamiento, el portador de la Daga Ritual puede hacer un sacrificio. Una miniatura perteneciente a la unidad es retirada como baja inmediatamente. El portador puede entonces modificar su tirada de Lanzamiento añadiendo al resultado el atributo de Heridas de la miniatura sacrificada.
Ten en cuenta que esto es un modificador al resultado de la tirada no niega un resultado de doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="814d-1476-2b7e-97ec" name="Fetiche del árbol de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4963-03c9-0153-211d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4256-0b11-813d-a7d2" type="max"/>
          </constraints>
          <profiles>
            <profile id="4bf0-11eb-0f49-31ba" name="Fetiche del árbol de brujas" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Siempre que el portador del Fetiche del Árbol de Brujas lanza exitosamente un Proyectil Mágico, puede repetir cualquier tirada fallida para Herir.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1cc5-5e60-a9fd-0f69" name="Corazón de Demonio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c76a-4e08-dfef-fabb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="62eb-030c-c986-f80b" type="max"/>
          </constraints>
          <profiles>
            <profile id="c269-2da4-6b63-6895" name="Corazón de Demonio" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Dispersión Mágica, el portador del Corazón de Demonio cuenta su Nivel de Mago como uno superior al del Mago cuyo hechizo está dispersando o, en el caso de Hechizos Vinculados, uno superior al Nivel de Hechicería de ese hechizo.
Ten en cuenta que esto se aplica incluso si significara que el portador cuenta su Nivel de Mago como inferior al que realmente es.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="5627-1fbb-5ac0-91ba" name="Objetos arcanos muy comunes. Hombres bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="23dc-d38b-6286-9b66" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cd4b-6a06-e8aa-ac95" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2f0e-42d7-fd8a-e962" name="Colmillo Sangriento" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="964f-3fdf-049d-0f29" type="max"/>
          </constraints>
          <profiles>
            <profile id="7f6b-11af-5d9d-bab7" name="Colmillo Sangriento" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Además de los Saberes de la Magia que normalmente puedan conocer, el portador de un Colmillo Sangriento puede conocer hechizos del Saber de la Magia Primigenia (ver página 92).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="6135-cbd1-1909-d6f9" name="Sangre del Entregador de Sombras" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1cde-26d6-b0f2-a9dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="2a26-25ca-ba15-a61e" name="Sangre del Entregador de Sombras" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un sólo uso. Un Mago puede usar este objeto en lugar de realizar un intento de dispersión Mágica. Si lo hace, el hechizo se dispersa automáticamente sin necesidad de tirada de Dispersión. Ten en cuenta que una invocación perfecta no puede ser dispersada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ae20-a447-2eb1-dccb" name="Mutaciones del caos. Personajes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="091b-2d52-1faa-3dcc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8245-606f-6e87-fc93" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="05a4-cd5a-86ed-6b20" name="Corona de cuernos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="274f-36d3-95e3-8a4d" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0da1-7514-5328-d895" type="max"/>
          </constraints>
          <profiles>
            <profile id="87b3-0820-5314-916f" name="Corona de cuernos" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Sólo personajes. Este personaje y cualquier unidad a la que se haya unido obtienen la regla especial Tozudo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7602-d475-e8a2-6be5" name="Tozudo (Stubborn)" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1505-78f6-a4d7-e0d4" name="Piel sombría" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7cd5-564c-65f5-554e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5a31-5dff-fb0f-052d" type="max"/>
          </constraints>
          <profiles>
            <profile id="1c42-6524-92c5-da77" name="Piel sombría" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Sólo personajes. Cualquier miniatura enemiga que elija como objetivo a este personaje o a cualquier unidad a la que se haya unido durante la fase de Disparo sufre un modificador adicional de -1 a Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="6c09-4b0e-53ab-3897" name="Mutaciones del caos. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1e39-434a-950a-346d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="12ff-ea59-9503-5c8d" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c8f2-21a8-4039-8d6f" name="Pellejo endurecido" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3558-9814-8d1b-dc73" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ac84-2c6a-1bfb-488d" type="max"/>
          </constraints>
          <profiles>
            <profile id="fd32-3dfe-aba8-086c" name="Pellejo endurecido" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Solo miniaturas cuyo tipo de tropa es ‘infantería’. Esta miniatura obtiene la regla especial Pellejo Duro (1).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1231-777e-9257-4244" name="Pellejo duro (X)" hidden="false" targetId="1dce-aa57-3693-62ae" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7223-919f-c2c1-1147" name="Mutaciones del caos. Caudillo hombre bestia" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4e2e-1073-0f65-a6a3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c255-a749-d893-4fa3" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bd01-fe55-3ef6-4ea9" name="Runa de la bestia ascendente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4358-4326-5a81-e9a1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="85c0-a369-fecd-53ce" type="max"/>
          </constraints>
          <profiles>
            <profile id="4718-70d7-d093-3bc1" name="Runa de la bestia ascendente" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Solo Caudillos Hombres Bestia. Excepto si este personaje está huyendo, Rebaños de Bestigors, Gors y Ungors amigos obtienen un modificador de +1 a su atributo de Liderazgo mientras estén dentro del Aura de Mando de este personaje (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="52d2-c801-0e52-ae07" name="Mutaciones del caos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3dac-b174-8613-a2c2" type="max"/>
