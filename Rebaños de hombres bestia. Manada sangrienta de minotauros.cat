              </modifiers>
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7301-faa3-54db-9965" type="max"/>
              </constraints>
              <rules>
                <rule id="456f-a07b-2f6e-6a25" name="Marca de Slaanesh (Mark of Slaanesh)" hidden="false">
                  <description>Las miniaturas con la Marca de Slaanesh tienen +1 a la Iniciativa durante la primera ronda de cualquier combate. Adicionalmente, si la mayoría de miniaturas en esa unidad tienen la Marca de Slaanesh, esa unidad supera automáticamente cualquier chequeo de Pánico que estén obligados a realizar.</description>
                </rule>
              </rules>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="38ab-a978-30e0-e559" name="Marca de Khorne" hidden="false" collective="false" import="true" type="upgrade">
              <modifiers>
                <modifier type="increment" field="33c0-92bb-bf87-74d4" value="3.0">
