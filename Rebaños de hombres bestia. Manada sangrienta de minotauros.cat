          <profiles>
            <profile id="7d45-1e73-fcf5-4a63" name="Monstruosidad muscular" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="cdd9-60b7-02d0-3eab" name="Colmillos destripadores" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fab4-ac0b-7d02-0d26" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fb2c-3037-16f4-993b" type="max"/>
          </constraints>
          <profiles>
            <profile id="4214-3485-7d56-8d0b" name="Colmillos destripadores" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Durante la fase de Combate, el atributo de Penetración de Armadura de cualquier arma utilizada por esta miniatura (pero no su montura) es mejorada en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="96f0-29df-18ee-b440" name="Diablo de múltiples extremidades" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="57a8-ed6a-2895-067a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="822b-d2b3-50bc-7244" type="max"/>
          </constraints>
          <profiles>
            <profile id="dd7e-104f-2461-ebe6" name="Diablo de múltiples extremidades" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Esta miniatura (pero no su montura) tiene un modificador de +1 a su atributo de Ataques. Sin embargo, este ataque extra debe hacerse utilizando un arma de mano ordinaria.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4743-aa52-ce19-4990" name="Piel de babosa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="a664-c625-4a76-3564" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a999-3a54-ed5e-2ecb" type="max"/>
          </constraints>
          <profiles>
            <profile id="28c2-2644-ac7d-c4fe" name="Piel de babosa" hidden="false" typeId="a8ed-296c-6778-1f44" typeName="Mutación del caos">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="9f34-1c29-0bc6-3f17">Cualquier miniatura enemiga que dirija sus ataques contra esta miniatura o cualquier unidad a la que se haya unido sufre un modificador de -1 a sus tiradas para Impactar durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5f7c-d861-bff3-058d" name="Sentidos amplificados" hidden="false" collective="false" import="true" type="upgrade">
