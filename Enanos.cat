    <selectionEntry id="79cf-418c-4429-7875" name="Ungrim Puñohierro, Rey matador de Karak Kadrin" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e3de-83b9-4319-9c10" type="max"/>
      </constraints>
      <rules>
        <rule id="6570-f379-1270-0526" name="Rey del bastión de matadores" hidden="false">
          <description>Ungrim Ironfist puede unirse a una unidad de Martilladores o a una unidad de Matadores (aunque no tenga la regla especial de Solitario). Una unidad de Martilladores a la que se une Ungrim obtiene las reglas especiales Inmune a la Psicología e Indesmoralizable mientras permanezca en la unidad. Además, si Ungrim Puñohierro es elegido como el General de un ejército de un Clan Real:
Los Matademonios y los Matadragones pueden ser elegidos como opción de Personaje.
0-1 unidad de Matadores cada 1.000 puntos pueden ser elegidas como opción Básica.
0-4 Buscamuertes cada 1.000 puntos pueden ser elegidos como opción Especial.</description>
        </rule>
        <rule id="7951-2b04-a1c5-71a3" name="Matador" hidden="false">
          <description>Cuando este personaje hace una tirada para Herir, una tirada de 4+ siempre es un éxito independientemente de la Resistencia del objetivo.</description>
        </rule>
        <rule id="67a0-9aeb-4270-8656" name="Resistencia a la magia (-2)" hidden="false"/>
      </rules>
      <infoLinks>
        <infoLink id="0b2e-b7f3-0aeb-9dbd" name="Infantería pesada (Heavy infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
