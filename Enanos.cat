            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dc2a-de79-cf31-0dff" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="742b-f704-9584-7713" type="max"/>
          </constraints>
          <profiles>
            <profile id="8030-4bdb-4ce4-3fa5" name="Runa magistral de Skalf Martillonegro" hidden="false" typeId="cf70-4c6f-5b60-14ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ba50-fe8c-ab52-047b">Al realizar una tirada para Herir con un arma inscrita con la Runa Magistral de Skalf Martillonegro, un resultado de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a88c-46df-8e92-0686" name="Runa magistral de la ruina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="492c-fa62-6ba9-bee8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="394e-a9c3-34e2-aa8b" type="max"/>
          </constraints>
          <profiles>
            <profile id="d14c-8f86-bf7e-cbd5" name="Runa magistral de la ruina" hidden="false" typeId="cf70-4c6f-5b60-14ce" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ba50-fe8c-ab52-047b">Cualquier arma mágica equipada por una miniatura enemiga que sufra una o más heridas no salvadas de un arma inscrita con la Runa Magistral de la Ruina se destruye y no se puede utilizar durante el resto del juego.
Ten en cuenta que incluso si su arma mágica es destruida se considera que la miniatura todavía está armada con un arma de mano.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="2951-c28b-1a7a-5c6d" name="Runa magistral de la rapidez" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bbe4-5f99-ebd7-37df" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="11e9-7fe6-f713-e2e6" type="max"/>
