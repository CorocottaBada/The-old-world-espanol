    <selectionEntry id="d2fb-9d99-6352-4712" name="Girobombardero" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="increment" field="ff12-3c40-36fb-5a0e" value="1.0">
          <repeats>
