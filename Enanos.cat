              <profiles>
                <profile id="80ad-68a9-0927-5814" name="La corona de los matadores" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">El portador de la Corona de los Matadores mejora el valor de su armadura en 2. Además, su portador tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
