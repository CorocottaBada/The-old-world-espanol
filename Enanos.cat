              </constraints>
              <profiles>
                <profile id="87a2-a875-0e34-1397" name="Filo del dragón" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos. </characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo del Dragón está inscrita con una Runa de Furia y una Runa de Rencor, como se describe en la página 34 de Forces of Fantasy.</characteristic>
                  </characteristics>
                </profile>
                <profile id="5891-2c56-058d-e15e" name="Runa de la furia" hidden="false" typeId="cf70-4c6f-5b60-14ce" typeName="Runa de arma">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="ba50-fe8c-ab52-047b">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
                  </characteristics>
                </profile>
                <profile id="539e-5e04-f58b-8575" name="Runa magistral del rencor" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="82ba-2ef5-4784-62b6" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
                <infoLink id="127c-25bb-0755-5b61" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
              </infoLinks>
