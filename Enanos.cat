        <selectionEntry id="9347-2911-7436-e553" name="Equipo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b027-1782-51e5-ed40" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f12f-6734-95ee-ec78" type="min"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="d4f4-07b4-bc2d-00f2" name="Colono del rencor" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6422-3cfb-be08-e4e8" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0053-da3a-819f-4329" type="min"/>
              </constraints>
              <profiles>
                <profile id="d29e-6ca6-1ef3-40dd" name="Colono del rencor" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
                  <characteristics>
                    <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos.</characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Colono del Rencor está inscrito con la Runa Magistral de la Destrucción y la Runa de la Parada, como se describe en las páginas 33 y 34 de Fuerzas de Fantasía.</characteristic>
                  </characteristics>
                </profile>
                <profile id="ac5c-7b32-d655-9fdf" name="Runa magistral del rencor" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
                  </characteristics>
                </profile>
                <profile id="b83f-1671-864e-0bb7" name="Runa de la parada" hidden="false" typeId="cf70-4c6f-5b60-14ce" typeName="Runa de arma">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="ba50-fe8c-ab52-047b">Cualquier miniatura enemiga cuyos ataques sean dirigidos contra una miniatura que empuña un arma inscrita con una Runa de Parada durante la fase de Combate sufre un modificador de -1 a las tiradas de Impactar.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="8838-5a5a-b89d-2985" name="Armadura de Skaldour" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6924-f4f6-49f1-44d6" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d5b2-3d08-6324-15a1" type="min"/>
              </constraints>
              <profiles>
                <profile id="dd34-de07-a9da-cf4e" name="Armadura de Skaldour" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
                  <characteristics>
                    <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                    <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Skaldour es una armadura pesada. Además, su portador tiene una Salvación Especial de 4+ contra un Golpe Letal, o contra cualquier herida sufrida que haya sido causada por un ataque que tenga la regla especial de Heridas Múltiples (X).</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="57af-2001-8350-9a35" name="Armadura pesada (Heavy armour)" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="17da-c0db-1277-37d3" name="La piedra de los agravios" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4132-805e-2521-2b34" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cdaf-28bc-dd16-5726" type="min"/>
              </constraints>
              <profiles>
                <profile id="0ae5-078b-9af1-59e1" name="La piedra de los agravios" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Durante cualquier subfase de Inicio de Turno, Thorgrim puede colocar la Piedra de los Agravios. Una vez colocada, Thorgrim y cualquier unidad a la que se haya unido obtienen la regla especial Indesmoralizable y pasan automáticamente cualquier chequeo de Pánico que deban realizar. Sin embargo, una vez que la Piedra de los Agravios ha sido colocada Thorgrim y su unidad no pueden elegir Huir como reacción a la carga y no pueden moverse más que para Ceder Terreno, para hacer un movimiento de presionar o para reformarse.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="bcb9-42fd-7258-624c" name="Indesmoralizable (Unbreakable)" hidden="false" targetId="f351-e61b-a183-42e3" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
              </costs>
            </selectionEntry>
            <selectionEntry id="c0d3-28c0-0e68-2e73" name="Escudo" hidden="false" collective="false" import="true" type="upgrade">
              <constraints>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4a9d-8c84-757f-f57f" type="max"/>
                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aaa8-fc28-b14d-a681" type="min"/>
