      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9628-45a8-3581-69e9" type="max"/>
      </constraints>
      <rules>
        <rule id="a859-126b-65e3-9c8f" name="Maestría del rencor" hidden="false">
          <description>Una vez que Thorgrim ha colocado la Piedra de los Agravios (ver más abajo), tanto él como cualquier unidad a la que se haya unido reemplazan la regla especial de Odio (Orcos y Goblins) con la regla especial de Odio (todos los enemigos).</description>
        </rule>
        <rule id="5afb-4218-0efa-9df0" name="Resistencia a la magia (-1)" hidden="false"/>
      </rules>
      <infoLinks>
        <infoLink id="f35f-f3e5-d201-b8a7" name="Infantería pesada (Heavy infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
