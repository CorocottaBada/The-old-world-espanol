    <selectionEntry id="9557-cea3-87bb-75e5" name="Porteadores de escudo" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="ea4e-4e16-1bae-ba4e" name="Llevar en volandas" hidden="false">
          <description>Una miniatura con Porteadores de escudo no contiene solo una, sino cuatro miniaturas (el personaje y tres vasallos leales) que ocupa una sola base y actúan juntos como una sola entidad. Para representar esto, una miniatura con Porteadores de escudo tiene un perfil combinado y sigue la regla Perfil Combinado (Caballería). En todos los demás aspectos esta miniatura es infantería pesada.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="8084-dd2b-ddfb-52f3" name="Infantería pesada (Heavy Infantry)" hidden="false" targetId="7bf4-f7e6-75b8-7218" type="rule"/>
