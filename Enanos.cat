              <characteristics>
                <characteristic name="Reglas especiales" typeId="ba50-fe8c-ab52-047b">El portador de un arma inscrita con la Runa Magistral de la Rapidez gana la regla especial Golpea Primero.</characteristic>
              </characteristics>
