          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="b06e-1ce3-2bf9-4c88" name="Runas de armaduras" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="031a-b0c3-d3c9-6f59" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d345-0a4f-b37b-4797" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="de25-0ba4-8e72-23c3" name="Runa de piedra" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="71e1-cba5-70c1-08b9" type="max"/>
          </constraints>
          <profiles>
            <profile id="0d5f-6d79-a0fe-7c5a" name="Runa de piedra" hidden="false" typeId="c217-b8c7-e97d-1b0b" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e170-d79b-afc0-a41a">Un solo uso. Por cada Runa de Piedra inscrita en la armadura, el portador puede repetir una única tirada de Salvación por Armadura fallida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="454b-684b-af8b-138b" name="Runa de escudo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bd59-3939-9b74-ba3d" type="max"/>
          </constraints>
          <profiles>
            <profile id="c48b-5c69-f9d2-9d8d" name="Runa de escudo" hidden="false" typeId="c217-b8c7-e97d-1b0b" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e170-d79b-afc0-a41a">Una miniatura que lleva su armadura inscrita con una única Runa de Escudo tiene una Salvación Especial de 6+ contra todas las heridas sufridas. Por cada Runa de Escudo adicional, la Salvación Especial mejora en 1.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9d72-a6ee-b778-fae1" name="Runa de perseveración" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9efe-a8c7-ab0b-3f05" type="max"/>
          </constraints>
          <profiles>
            <profile id="d32a-2f08-bbe3-c209" name="Runa de perseveración" hidden="false" typeId="c217-b8c7-e97d-1b0b" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e170-d79b-afc0-a41a">Una miniatura que lleva su armadura inscrita con la Runa de Preservación es inmune a las reglas especiales Golpe Letal y Heridas Múltiples (X). Si el portador sufre heridas de un ataque con cualquiera de estas reglas especiales, pierde una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="09b6-e7ff-af36-1ba1" name="Runa de fortaleza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f671-e8a1-32a1-0ebb" type="max"/>
          </constraints>
          <profiles>
            <profile id="ca55-014d-dc71-ee37" name="Runa de fortaleza" hidden="false" typeId="c217-b8c7-e97d-1b0b" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e170-d79b-afc0-a41a">Por cada Runa de Fortaleza inscrita en la Armadura del portador tiene un modificador de +1 a su atributo de Resistencia (hasta un máximo de 10).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4d02-1dd1-2f48-c767" name="Runa de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5bde-b6d3-6b41-5000" type="max"/>
          </constraints>
          <profiles>
            <profile id="cb09-926e-53b2-ffec" name="Runa de hierro" hidden="false" typeId="c217-b8c7-e97d-1b0b" typeName="Runa de armadura">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="e170-d79b-afc0-a41a">Una miniatura que lleva una armadura inscrita con una Runa de Hierro tiene +1 Herida en su perfil.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="850f-7c7b-8992-4b22" name="Runas talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e6a2-1596-b036-3793" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4e79-8802-0852-9ea1" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ac6d-9c04-4c99-0ba1" name="Runa del pasadizo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2895-dfd4-6fe5-10f4" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="82da-f5f5-2c81-385b" type="max"/>
          </constraints>
          <profiles>
            <profile id="49c8-0a98-f6fc-0679" name="Runa del pasadizo" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">El portador de una Runa del Pasadizo gana la regla especial Mover a Través de Cobertura. Cualquier unidad a la que el portador se una también gana la regla especial Mover a Través de Cobertura. Si el portador abandona la unidad por cualquier motivo, la unidad pierde esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d98d-712a-4210-5ab7" name="Mover a través de cobertura (Move thorugh cover)" hidden="false" targetId="cd5d-9dfe-b655-6a83" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3694-c1b6-6429-cf13" name="Runa ígnea" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e10d-d89c-a6bf-b865" type="max"/>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="5e11-279e-6264-b704" type="max"/>
          </constraints>
          <profiles>
            <profile id="1bdb-a883-7ebe-c7d3" name="Runa ígnea" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">El portador de una Runa Ígnea tiene una Salvación Especial de 3+ contra cualquier herida sufrida por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0afc-ea5a-14fa-9e7f" name="Runa de la suerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="32a5-cef3-a569-6265" type="max"/>
          </constraints>
          <profiles>
            <profile id="c447-20df-0d69-5122" name="Runa de la suerte" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Un solo uso. El portador de una Runa de la Suerte puede repetir una única tirada fallida para Impactar o para Herir, o repetir una única tirada fallida de salvación por armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dc1c-5806-7f6c-8609" name="Runa de defensa" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="becd-83ab-2a1a-9d79" type="max"/>
          </constraints>
          <profiles>
            <profile id="9791-76c7-d6b9-155f" name="Runa de defensa" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Un solo uso. Cada Runa de Defensa le da al portador una Salvación Especial de 2+ contra una única herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a7b5-d2a1-e0e0-0686" name="Runas magistrales talismánicas" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="33a9-a9d6-4b21-b90d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7ef3-656c-08d1-af12" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9855-c150-7ff4-9cfb" name="Runa magistral del rencor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="de23-546f-809e-abf5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c75e-e795-c545-d55b" type="max"/>
          </constraints>
          <profiles>
            <profile id="873f-37f0-8236-1013" name="Runa magistral del rencor" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="880c-d87c-f6f3-a9d1" name="Runa magistral de la calma" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1215-3524-9a47-9aaa" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ec07-e74f-af8d-5e62" type="max"/>
          </constraints>
          <profiles>
            <profile id="45d9-4e4b-2736-228c" name="Runa magistral de la calma" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">El portador de la Runa Magistral de la Calma puede lanzar el siguiente hechizo vinculado, con un Nivel de Energía 2.
Tipo: Maldición
Dificultad de Lanzamiento: 8+ / 11+
Alcance: Personal
Efecto: Si este hechizo vinculado se lanza con un resultado de lanzamiento de 8+, los magos enemigos que se encuentren a 18” o menos de esta miniatura y que intenten lanzar un hechizo deben aumentar la Dificultad de lanzamiento de ese hechizo en 2. Si el Hechizo Vinculado se lanza con un resultado de lanzamiento de 11+, los magos enemigos que estén a 36” o menos de esta miniatura cuando intenten lanzar un hechizo deben aumentar la Dificultad de Lanzamiento del hechizo en 2. Este hechizo dura hasta tu siguiente subfase de Inicio de Turno.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f9bb-49e1-d389-8f11" name="Runas magistrales talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3da0-f491-718a-f09f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b80f-2b5a-a32f-61d5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2a59-c37d-dabd-0ac0" name="Runa magistral del equilibrio" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="eb77-19d9-9052-a4bc" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4f63-0399-030d-d871" type="max"/>
          </constraints>
          <profiles>
            <profile id="36dd-599c-ee9e-5186" name="Runa magistral del equilibrio" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Solo Yunque Rúnico, Herrero Rúnico o Señor de las Runas. Una vez por turno, el portador de la Runa Magistral del Equilibrio puede usarla al intentar una dispersión arcana. Si lo hacen, tira 1D6 extra al intentar la tirada de dispersión y descarta el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="401f-c861-a304-d4a8" name="Runas talismánicas. Yunque rúnico o Herrero rúnico" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5503-6f18-6998-78cd" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6642-2344-71c8-f80f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="a000-15da-904d-3614" name="Runa rompehechizos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1cc1-368d-ddf4-46bd" type="max"/>
          </constraints>
          <profiles>
            <profile id="36c3-fc6b-e83e-1bbd" name="Runa rompehechizos" hidden="false" typeId="af53-8df6-3d8f-0f7d" typeName="Runa talismánica">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="f976-96a3-21eb-e0ae">Solo Yunque Rúnico, Herreros Rúnicos Enanos o Señores de las Runas. Un solo uso. El portador de la Runa Rompehechizos podrá utilizarlo en lugar de un intento de dispersión. Si lo hacen, el hechizo se disipa automáticamente sin necesidad de realizar una tirada de Dispersión.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ef08-6774-e86e-8ab6" name="Runas de estandartes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a4af-f994-380c-a46c" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="167b-50ac-0691-391b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="0adb-7322-1df3-d34b" name="Runa del coraje" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5145-3725-0292-6eda" type="max"/>
          </constraints>
          <profiles>
            <profile id="6e19-8978-ea73-698d" name="Runa del coraje" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Una unidad que lleva un estandarte inscrito con la Runa del Coraje pasa automáticamente todos los chequeos de Miedo o Terror que debe realizar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8bbe-6b28-a6fd-80b5" name="Runa de Strollaz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ca51-5988-b127-888c" type="max"/>
          </constraints>
          <profiles>
            <profile id="7a85-8f6b-c555-9d1f" name="Runa de Strollaz" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Una unidad que lleva un estandarte con la inscripción Runa de Strollaz obtiene la regla especial Vanguardia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a6e7-f667-9dcc-862e" name="Vanguardia (Vanguard)" hidden="false" targetId="d540-6e53-4883-9bb5" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0c1e-a432-c824-6927" name="Runa de batalla" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4adb-44fd-59ff-fd3f" type="max"/>
          </constraints>
          <profiles>
            <profile id="6dfd-706f-d75d-0d21" name="Runa de batalla" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Al calcular el Resultado del combate, una unidad que lleve un estandarte inscrito con la Runa de Batalla puede reclamar una bonificación adicional de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0c99-f6f5-c831-569d" name="Runa del miedo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7777-d430-8faa-ea70" type="max"/>
          </constraints>
          <profiles>
            <profile id="6955-488a-9f52-04fb" name="Runa del miedo" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Una unidad que lleva un estandarte con la Runa del Miedo gana la regla especial Miedo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5ce3-58a5-8412-814a" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1950-f5fc-07fc-c073" name="Runa de la confusión" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b5e5-24ce-c1ff-edc8" type="max"/>
          </constraints>
          <profiles>
            <profile id="5637-f19c-1f3c-d34a" name="Runa de la confusión" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Cualquier unidad enemiga que carga contra el arco frontal de una unidad que lleva un estandarte inscrito con la Runa de la Confusión realiza una carga desordenada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="38a4-c78c-94a6-92c0" name="Runas magistrales de estandartes. Portaestandarte de batalla" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e599-34ab-4ff4-b392" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1679-1856-a082-d0a6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9cc2-31a6-d2c9-2508" name="Runa magistral de Grungni" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bd76-eae0-0857-df46" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3e31-3aee-9e3f-176d" type="max"/>
          </constraints>
          <profiles>
            <profile id="afc1-3257-7894-e978" name="Runa magistral de Grungni" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Solo Portaestandarte de Batalla. Una unidad que lleva un estandarte inscrito con la Runa Magistral de Grungni tiene una Salvación Especial de 5+ contra todas las heridas sufridas. Además, mientras estén a 6” o menos de la miniatura que lleva este estandarte, las unidades amigas tienen una Salvación Especial de 6+ contra cualquier herida sufrida durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="80.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ff7b-fa92-171e-dc8f" name="Runas magistrales de estandartes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8ad0-2473-b454-fe56" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d063-b3bb-93c5-abeb" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="bd57-35ae-c7c4-a9bf" name="Runa magistral de la duda" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1309-0813-7d6b-733a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef61-204f-eefa-a5c1" type="max"/>
          </constraints>
          <profiles>
            <profile id="5b11-e32d-79af-16ed" name="Runa magistral de la duda" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd">Una unidad enemiga que carga contra el arco frontal de una unidad que lleva un estandarte inscrito con la Runa Magistral de la Duda no cuenta que ha cargado para el propósito de elegir qué arma usar o cualquier regla especial que pueda tener.
Ten en cuenta que una unidad que porta esta runa todavía cuenta como que ha sido cargada por una unidad enemiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7a6e-e1c8-ec98-64ae" name="Runa magistral de Stromni Barbaroja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="53ec-c313-70f9-297a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="67f4-213f-0aa7-4b05" type="max"/>
          </constraints>
          <profiles>
            <profile id="d312-63bb-4c28-edfc" name="Runa magistral de Stromni Barbaroja" hidden="false" typeId="83ac-da84-2a20-d3a0" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="434b-5b71-9f7a-33cd"> Al calcular el resultado del combate, cualquier unidad amiga dentro del Aura de mando del portador del estandarte inscrito con la Runa Magistral de Stromni Barbaroja puede reclamar un bonificador adicional de +1 punto al resultado de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="75.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a69c-5bf9-3bf0-8ee4" name="Runas magistrales de ingenieros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d548-cf8e-8ab7-3d18" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e5ad-44b2-2070-c755" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="af87-71ed-3fcb-4b02" name="Runa magistral del disfraz" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1efe-4988-bf77-a545" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="954a-1d7a-149b-89a0" type="max"/>
          </constraints>
          <profiles>
            <profile id="f2b0-9865-0b35-b01b" name="Runa magistral del disfraz" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Una máquina de guerra inscrita con la Runa Magistral del Disfraz siempre se considera detrás de cobertura total.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f0c3-6573-3b37-bb38" name="Runas magistrales de ingenieros. Cañón" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1352-a135-a7b7-9fee" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c5b4-c98b-9c16-4ea6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="8ab4-777c-a6a9-e988" name="Runa magistral de la inmolación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="dc0d-46e3-6cf8-d964" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e604-f2ce-839d-b0dd" type="max"/>
          </constraints>
          <profiles>
            <profile id="c191-5b5e-45c1-9c4b" name="Runa magistral de la inmolación" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Sólo cañones. Un solo uso. Si un cañón que tiene inscrita la Runa Magistral de la Inmolación pierde la última herida por un ataque enemigo durante la fase de Combate, su dotación lo podrá explotar. Por cada unidad enemiga en contacto peana con peana con esta miniatura sufre 1D6 impactos de Fuerza 5 con una PA de -2. El cañón es entonces retirado del juego como baja.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="a9b2-2142-f0c8-9388" name="Runas de ingenieros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4a70-16f0-3b0f-7ee9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9182-8483-a614-dd62" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ca83-bd8c-234a-2c8b" name="Runa de la firmeza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d0c3-5b48-6722-683a" type="max"/>
          </constraints>
          <profiles>
            <profile id="fe10-5c33-bfd2-23ef" name="Runa de la firmeza" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Al calcular el Resultado del combate, una máquina de guerra inscrita con la Runa de la Firmeza puede reclamar una bonificación de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0ade-c4d7-8800-c243" name="Runa de la recarga" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a499-93c1-acfe-46fb" type="max"/>
          </constraints>
          <profiles>
            <profile id="0415-133f-7793-1434" name="Runa de la recarga" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Una máquina de guerra inscrita con una Runa de la Recarga puede disparar en cada turno, incluso si tuvo Mal Funcionamiento en su turno anterior.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="aae0-3c1a-3f8c-9981" name="Runa de la forja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bc02-4781-0740-0b02" type="max"/>
          </constraints>
          <profiles>
            <profile id="c146-0a2b-9cb5-8afd" name="Runa de la forja" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Un solo uso. Una máquina de guerra inscrita con una Runa de la Forja puede usarla para repetir un único fallo en el Dado de artillería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="02b2-8133-2eaa-e174" name="Runa incendiaria" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b62f-2901-11b6-0f67" type="max"/>
          </constraints>
          <profiles>
            <profile id="a6e3-3e52-44b7-1c87" name="Runa incendiaria" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Una máquina de guerra inscrita con una Runa Incendiaria obtiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1494-19db-072c-d753" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="1d04-c66f-7a0a-a22c" name="Runas de ingenieros. Lanzavirotes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ab2e-75ef-a8b5-20b9" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7914-e92e-28da-1fc0" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9d5e-58e1-6e73-3d76" name="Runa empaladora" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a79-abbe-d703-0476" type="max"/>
          </constraints>
          <profiles>
            <profile id="f0ec-7ec5-9822-db66" name="Runa empaladora" hidden="false" typeId="0085-e889-294d-263a" typeName="Runa de ingeniería">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="a777-0656-7fb0-0565">Sólo lanzavirotes. Un lanzavirotes inscrito con la Runa Empaladora tiene un modificador de + 1 a su atributo de Fuerza. Además, no se permite ninguna salvación por armadura contra heridas causadas por un lanzavirotes inscrito con la Runa de Empaladora (las salvaciones especiales y regeneración se pueden intentar de forma normal).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="045c-23ed-6eda-e524" name="Tatuajes rúnicos. Matademonios, Matadragones" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9d58-2b97-28e9-addc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7bec-2869-4ff4-6489" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f773-d317-c740-bdd4" name="Runa del deshonrado" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf90-3245-5cc0-2441" type="max"/>
          </constraints>
          <profiles>
            <profile id="6e27-b549-fa9b-0a91" name="Runa del deshonrado" hidden="false" typeId="371d-5436-9fc1-3b7b" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="44c7-7386-bc25-5d80">Solo Matademonios y Matadragones. Una vez que una miniatura con este tatuaje rúnico sea reducida a su última herida, obtiene una Salvación Especial de 3+ contra cualquier otra herida sufrida. Sin embargo, al final de la batalla, una miniatura con este tatuaje rúnico que haya sido retirada como baja no otorga puntos de victoria. Si todavía está vivo, el jugador enemigo obtiene un número adicional de puntos de victoria igual al 100% de su coste de puntos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="7d4c-8dcf-e28a-4a03" name="Tatuajes rúnicos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="37f2-68f6-bbfd-f768" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="12e4-7e5e-e1f2-5b37" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5d90-659e-0867-c150" name="Runa de la batalla interminable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="37a8-0b9b-0d6a-8191" type="max"/>
          </constraints>
          <profiles>
            <profile id="65d9-b8d5-0546-64d6" name="Runa de la batalla interminable" hidden="false" typeId="371d-5436-9fc1-3b7b" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="44c7-7386-bc25-5d80">Durante la fase de Combate de cualquier turno en el que una miniatura con este tatuaje rúnico carga, cada ataque que haga que cause una herida no salvada le permite realizar inmediatamente un ataque adicional.
Ten en cuenta que cualquier ataque adicional que cause heridas no salvadas y cualquier herida no salvada causada por la regla especial Impactos por Carga (X) no se beneficia de esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e539-5303-5e6e-a6f5" name="Runa de los imprudentes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9678-c690-4ed2-a76d" type="max"/>
          </constraints>
          <profiles>
            <profile id="7810-eaeb-b378-8d1b" name="Runa de los imprudentes" hidden="false" typeId="371d-5436-9fc1-3b7b" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="44c7-7386-bc25-5d80">Una miniatura con este tatuaje rúnico obtiene la regla especial Furia Asesina y, durante la fase de Combate, tiene un modificador de +1 a sus tiradas para Impactar. Sin embargo, las miniaturas enemigas que elijan como objetivo a esta miniatura durante la fase de Combate también tienen un modificador de +1 en sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="ed67-ce80-a2a4-f631" name="Furia asesina (Frenzy)" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c8d2-67d5-4b3d-5aae" name="Runa de lo odioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c354-67a9-5f09-3582" type="max"/>
          </constraints>
          <profiles>
            <profile id="cfcc-bfdb-5ba8-d4dc" name="Runa de lo odioso" hidden="false" typeId="371d-5436-9fc1-3b7b" typeName="Tatuaje rúnico">
              <characteristics>
