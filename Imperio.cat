          <profiles>
            <profile id="eb2f-eaed-b10c-656f" name="Runa encantada" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Un arma inscrita con esta runa obtiene la regla especial Ataques Mágicos.</characteristic>
