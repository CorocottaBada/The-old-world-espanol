        <selectionEntry id="d533-7141-d4e4-e204" name="Runa magistral de la ruina" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ca22-4c72-5585-cddd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e942-ac89-a8d6-2246" type="max"/>
          </constraints>
          <profiles>
            <profile id="9f34-05ad-2158-4f05" name="Runa magistral de la ruina" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Cualquier arma mágica equipada por una miniatura enemiga que sufra una o más heridas no salvadas de un arma inscrita con la Runa Magistral de la Ruina se destruye y no se puede utilizar durante el resto del juego.
Ten en cuenta que incluso si su arma mágica es destruida se considera que la miniatura todavía está armada con un arma de mano.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
