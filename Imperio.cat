          </constraints>
          <profiles>
            <profile id="0e07-a859-34f9-2b71" name="Runa de acero fundido" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Un arma inscrita con esta runa obtiene la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="95e8-bd84-faa6-f4d7" name="Ataques flamígeros" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
