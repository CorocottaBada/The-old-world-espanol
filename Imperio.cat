      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8032-8b84-76a6-3dbf" type="max"/>
      </constraints>
      <rules>
        <rule id="0874-debb-1161-4c03" name="Comandante mercenario" hidden="false">
          <description>Si Hans es el General del ejército, las unidades amigas con la regla especial Mercenarios pueden beneficiarse de su regla de Presencia Inspiradora y puede unirse a dichas unidades. Además, las unidades amigas de Mercenarios no están sujetas a las reglas de “Mala Conducta de los Mercenarios”.</description>
        </rule>
        <rule id="ccf5-b554-aa13-a179" name="Maestría estratégica" hidden="false">
          <description>En los escenarios donde los jugadores tiran para determinar quién toma el primer turno, puedes aplicar un modificador de +1 o -1 al resultado de tu tirada.</description>
        </rule>
        <rule id="bf63-38f3-c528-9ddf" name="&quot;¡Aguantad la línea&quot;!" hidden="false">
          <description>Este personaje y cualquier unidad a la que se haya unido superan automáticamente cualquier Chequeo de Pánico que tengan que hacer.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4167-da35-b38d-7cc0" name="Grito de guerra (Rallying cry)" hidden="false" targetId="98aa-28c7-f0d9-c0d9" type="rule"/>
        <infoLink id="5418-cc21-f4e6-e577" name="Tozudo (Stubborn)" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
        <infoLink id="dc62-aea6-b86b-5c69" name="Infantería ligera (Regular infantry)" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
      </infoLinks>
