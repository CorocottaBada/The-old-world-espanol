          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="70f8-6e01-4115-8dd1" type="max"/>
          </constraints>
          <profiles>
            <profile id="31db-4dd2-3c66-8554" name="Runa del agravio" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Por cada Runa de los Agravios inscrita en un arma, su portador puede repetir una única tirada para Impactar de un resultado natural de 1 durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e126-cfa7-7da5-cc0d" name="Runa de la furia" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="53d0-6a11-2151-4b47" type="max"/>
          </constraints>
          <profiles>
            <profile id="994c-82cf-3a05-2a3e" name="Runa de la furia" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
