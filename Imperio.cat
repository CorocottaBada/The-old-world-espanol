            <profile id="907f-43f4-38ae-7609" name="Espada de la justicia" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos, Heridas múltiples (2)</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de la Espada de la Justicia puede repetir las tiradas para Herir falladas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="2906-3457-9b60-a960" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
            <infoLink id="0a4e-74a8-174c-42da" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="2c79-48be-7d54-c795" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="303e-5c19-2704-53de" name="Martillo de la rectitud" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7705-ee65-96a9-9c18" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b38-1ad6-fb9a-b52d" type="max"/>
          </constraints>
          <profiles>
            <profile id="9dd1-4a0a-0906-343f" name="Martillo de la rectitud" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Golpea último, Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Las miniaturas impactadas por el Martillo de la Rectitud deben hacer un chequeo de Liderazgo por cada impacto sufrido. Si se falla el chequeo, el impacto hiere automáticamente y no se permite ninguna tirada de Salvación por Armadura (las salvaciones Especiales o Regeneración se pueden realizar de manera normal). Si se supera el chequeo, las tiradas para Herir y las tiradas de
Salvación por Armadura se realizan de manera normal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="77e2-a744-5697-a096" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
            <infoLink id="e4ef-b082-701c-7f25" name="Golpea en último lugar (Strike last)" hidden="false" targetId="221b-8e57-e839-4d0d" type="rule"/>
            <infoLink id="a5d3-c47b-383d-a7e1" name="Requiere ambas manos (Requires two hands)" hidden="false" targetId="0cd9-76c6-0ab1-df74" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="e57d-1a44-3ff4-e1ed" name="Dagas perladas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d510-79ae-cb23-4664" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6203-0d9b-b62c-0527" type="max"/>
          </constraints>
          <profiles>
            <profile id="4b8a-af04-67c2-41a0" name="Dagas perladas" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+1</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Ataques adicionales (1D3), Requiere ambas manos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El portador de las Dagas Perladas puede repetir cualquier tirada para Impactar fallada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5e7c-8073-b8d8-60e3" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
