      <selectionEntries>
        <selectionEntry id="9672-e4ec-d3ad-fbf6" name="La capa blanca" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f2ac-79bb-86cc-1844" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8af5-7ab7-28fd-83e3" type="max"/>
          </constraints>
          <profiles>
            <profile id="d873-b873-8063-28cd" name="La capa blanca" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Capa Blanca tiene una Salvación Especial de 5+ contra cualquier herida sufrida, y una Salvación Especial de 3+ contra cualquier herida causada por un ataque con la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="769e-0618-3aa0-3156" name="Reloj de arena del asesino" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="704f-7f6f-a46b-7909" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="408e-712a-078f-10cf" type="max"/>
          </constraints>
          <profiles>
            <profile id="04dc-85a0-9417-85a7" name="Reloj de arena del asesino" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Las miniaturas enemigas cuyo tipo de tropa sea ‘monstruo’ sufren un modificador de -1 a su Habilidad de Armas mientras estén en contacto peana con peana con el portador.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4300-34ca-0550-6cce" name="Talismanes muy comunes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b1b0-6a38-da67-b08b" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f37d-2a22-c43e-55f9" type="min"/>
