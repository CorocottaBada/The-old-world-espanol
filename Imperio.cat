    <selectionEntryGroup id="2dbe-a672-81ae-d6f3" name="Runas magistrales de armas de ingenieros. Ballesta, Arcabuz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1257-0bc8-d84c-5a1f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="43be-df9c-27b9-26e8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="4ab8-2ce4-1fd0-0487" name="Runa magistral de la matanza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6c51-ca76-047d-cdd1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0733-92e7-1384-954a" type="max"/>
          </constraints>
          <profiles>
            <profile id="1362-a51e-9832-3ba6" name="Runa magistral de la matanza" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Al hacer una tirada para Herir contra un enemigo cuyo tipo de tropa es ‘coloso’ con un arma inscrita con esta runa, una tirada de 3+ siempre es un éxito, independientemente de la Resistencia del objetivo. Además, un arma inscrita con esta runa obtiene la regla especial Heridas Múltiples (1D3).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6d79-2da1-2264-e6f2" name="Heridas múltiples (X)" hidden="false" targetId="b8ec-eacf-b8ff-d8cc" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="563d-9638-4670-ff24" name="Runa magistral de la perforación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7ed8-9342-c80b-f7e2" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b3a9-88e5-df87-4d9d" type="max"/>
          </constraints>
          <profiles>
            <profile id="b9c4-f00d-2f3f-792f" name="Runa magistral de la perforación" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Un arma inscrita con esta runa tiene un modificador +1 a su atributo de Fuerza. Además, un arma inscrita con esta runa dispara como un Lanzavirotes, utilizando la regla especial ‘Atravesar Filas’ (véase la página 223 del reglamento de Warhammer: the Old World).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="dfd4-505f-0a76-f03a" name="Atravesar filas" hidden="false" targetId="15a5-2dad-511c-7ded" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="a0b2-baee-7043-7cc6" name="Runa magistral de llamas explosivas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2ebb-6e1f-e7d9-ab2f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e119-ffab-987d-d604" type="max"/>
          </constraints>
          <profiles>
            <profile id="f9dc-7adc-22a0-7aa9" name="Runa magistral de llamas explosivas" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Si la tirada para Impactar tiene éxito, un arma inscrita con esta runa provoca 2D3 impactos a la unidad enemiga objetivo, en lugar del único impacto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="366c-5476-2a96-68aa" name="Tatuajes rúnicos" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de96-34f3-224a-4fa6" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8af1-e8c9-d375-7104" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c967-a0eb-6f64-d77b" name="Runa de la batalla interminable" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e32b-e2a7-2d9c-2c0e" type="max"/>
          </constraints>
          <profiles>
            <profile id="4707-c19a-cc2a-ca0a" name="Runa de la batalla interminable" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Durante la fase de Combate de cualquier turno en el que una miniatura con este tatuaje rúnico carga, cada ataque que haga que cause una herida no salvada le permite realizar inmediatamente un ataque adicional.
Ten en cuenta que cualquier ataque adicional que cause heridas no salvadas y cualquier herida no salvada causada por la regla especial Impactos por Carga (X) no se beneficia de esta regla especial.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5f88-64d3-bd52-48b5" name="Runa de los imprudentes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fbae-9946-e571-5b0a" type="max"/>
          </constraints>
          <profiles>
            <profile id="f861-2086-3ae3-2e18" name="Runa de los imprudentes" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico obtiene la regla especial Furia Asesina y, durante la fase de Combate, tiene un modificador de +1 a sus tiradas para Impactar. Sin embargo, las miniaturas enemigas que elijan como objetivo a esta miniatura durante la fase de Combate también tienen un modificador de +1 en sus tiradas para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="6eee-b500-3d2f-464a" name="Furia asesina (Frenzy)" hidden="false" targetId="9f2b-ac7d-e603-ea44" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8f24-65c2-1958-4604" name="Runa de lo odioso" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5c83-c888-bb29-fc7f" type="max"/>
          </constraints>
          <profiles>
            <profile id="8bdc-7a65-ce89-c517" name="Runa de lo odioso" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico obtiene la regla especial Odio (todos los enemigos).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="a3ab-bb96-652e-3d58" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="93e7-728c-2c15-fd97" name="Runa del valor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2be2-32b8-b59f-9499" type="max"/>
          </constraints>
          <profiles>
            <profile id="fce6-be37-b918-057a" name="Runa del valor" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico tiene un modificador de +1 a su atributo de Resistencia.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5024-eb52-6b32-5f5c" name="Runa de los intrépidos" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3d09-812e-64a2-5b4a" type="max"/>
          </constraints>
          <profiles>
            <profile id="a41a-f76a-591b-d5aa" name="Runa de los intrépidos" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico siempre debe lanzar y aceptar Desafíos (si es posible). Durante un Desafío, esta miniatura puede repetir cualquier tirada fallida para Impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c066-9396-1955-40b9" name="Runa de la ira" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="30d5-0349-b31c-1404" type="max"/>
          </constraints>
          <profiles>
            <profile id="38ed-bac0-b2ab-b534" name="Runa de la ira" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Ataques.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="98f0-5412-8d1b-47a6" name="Runa de la furia ardiente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b524-431c-94c4-55b6" type="max"/>
          </constraints>
          <profiles>
            <profile id="ee4a-1bed-ca45-ef86" name="Runa de la furia ardiente" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico tiene la regla especial Ataques Flamígeros.</characteristic>
