        <selectionEntry id="f56b-75f8-b13a-e140" name="Colmillo Rúnico" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="cd56-0fbb-74bd-372e" type="max"/>
