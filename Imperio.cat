    <selectionEntry id="bfad-aeca-0f0b-28ad" name="Altar de guerra de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
      <constraints>
        <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9368-3e94-29f2-3b12" type="max"/>
      </constraints>
      <rules>
        <rule id="273b-1a1f-ff08-3799" name="Fervor Sagrado" hidden="false">
          <description>Excepto si esta unidad está huyendo, unidades amigas que estén a 6” o menos de la unidad superan automáticamente cualquier Chequeo de Miedo y pueden repetir cualquier Chequeo de Pánico fallido.</description>
        </rule>
        <rule id="8f65-c20a-db68-2911" name="Símbolo de Poder" hidden="false">
          <description>El Aura de Mando de un Archilector de Sigmar montado en el Altar de Guerra aumenta de 8” a 12”.
Ten en cuenta que, si esta miniatura es tu General, tiene un Aura de Mando de 18” como es habitual.</description>
        </rule>
        <rule id="6213-00a0-b0f3-68ab" name="Perdición de Brujas" hidden="false">
          <description>Todos los Hechiceros (amigos o enemigos) dentro del Aura de Mando de esta miniatura sufren un modificador de -2 a sus Tiradas de Lanzamiento.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="dd3c-cd4a-986f-4e54" name="Formación cerrada" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
        <infoLink id="2acb-f45c-137c-cd00" name="Primera carga" hidden="false" targetId="19f8-c53d-60db-77c6" type="rule"/>
        <infoLink id="295f-1334-2892-cec5" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
