    <selectionEntry id="b775-4a46-df29-9ec3" name="Carro de guerra" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="increment" field="0c02-26c7-f910-f781" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="false"/>
          </repeats>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="d230-2ac6-2801-86e8" value="2.0">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="increment" field="d230-2ac6-2801-86e8" value="1.0">
          <repeats>
            <repeat field="limit::33c0-92bb-bf87-74d4" scope="roster" value="1000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="model" repeats="1" roundUp="true"/>
          </repeats>
          <conditions>
            <condition field="limit::33c0-92bb-bf87-74d4" scope="roster" value="2000.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="greaterThan"/>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="aae2-4bd2-d7f3-5bc9" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="roster" value="0.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0c02-26c7-f910-f781" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d230-2ac6-2801-86e8" type="max"/>
      </constraints>
      <rules>
        <rule id="edfa-7cce-8586-f201" name="Peso aplastante" hidden="false">
          <description>Los Golpetazos realizados por un Carro de Guerra tienen una Penetración de Armadura de -1. Además, y a diferencia de otros carros, esta miniatura trata los obstáculos lineales bajos como terreno peligroso  en lugar de como terreno impasable.</description>
        </rule>
        <rule id="a0ce-80ff-eb74-0975" name="Plataforma de disparo estable" hidden="false">
          <description>Para reflejar la estabilidad de un Carro de Guerra, cualquier arma de proyectiles que porte la tripulación puede utilizarse en la fase de Disparo, incluso si el Carro de Guerra marchó este turno.</description>
        </rule>
        <rule id="80b7-cebc-35f6-cc93" name="Armas variadas" hidden="false">
          <description>Además de su arma de mano, cada miembro de la tripulación de un Carro de Guerra está
armado de forma diferente, llevando una de las siguientes seis armas únicas:
Carro
• Trabuco
• Rifle largo
• Rifle de repetición
• Bola con cadena
• Alabarda con gancho
• Atrapahombres
Durante la fase de Disparo, cada miembro de la tripulación equipado con un arma de proyectiles puede disparar con esa arma. Durante la fase de Combate, cada miembro de la tripulación puede elegir utilizar su arma única o su arma de mano. En ambos casos, el jugador controlador debe tirar dados en grupos separados para las diferentes armas, dejando claro al oponente qué ataques representan a cada miembro de la tripulación y hacia dónde están
dirigidos.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="6e86-f29c-33cc-1121" name="Carro pesado (Heavy chariots)" hidden="false" targetId="3af7-2847-d9c7-fb97" type="rule"/>
        <infoLink id="2a0b-4dd1-468b-f1a7" name="Formación cerrada (Close order)" hidden="false" targetId="bf0e-448e-d554-8f02" type="rule"/>
        <infoLink id="dde3-582a-6779-86d5" name="Impactos por carga (X)" hidden="false" targetId="d0ca-db48-cd27-f123" type="rule"/>
        <infoLink id="1f3c-0ad5-de1d-7799" name="Objetivo grande (Large target)" hidden="false" targetId="c023-414d-0ecd-5837" type="rule"/>
        <infoLink id="386a-7881-be8b-e21d" name="Golpetazo (X)" hidden="false" targetId="c3fc-6bee-83fd-5186" type="rule"/>
