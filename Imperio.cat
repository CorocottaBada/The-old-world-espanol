        <selectionEntry id="bfc7-cbd2-69c1-af2f" name="Runa de precisión" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b17-1740-0887-f509" type="max"/>
          </constraints>
          <profiles>
