    <selectionEntry id="196a-6032-9bca-07ae" name="Heraldo de la perdición" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="d5d2-501a-5983-3295" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="0c3e-7baa-6942-cb14" type="atLeast"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2e69-c1f0-78de-f561" type="max"/>
      </constraints>
      <rules>
        <rule id="962a-08a0-66ad-bf34" name="No hay dolor" hidden="false">
          <description> Una miniatura con esta regla especial tiene:
Una Salvación Especial de 6+ contra heridas sufridas por un ataque enemigo no-mágico.
Una Salvación Especial de 5+ contra heridas sufridas por un ataque enemigo no-mágico de Fuerza 5 o superior.</description>
        </rule>
        <rule id="9277-b6b0-b9f4-9790" name="Plegaria de los condenados" hidden="false">
          <description>Durante la subfase de Mando de tu turno, este personaje puede intentar entonar la Plegaria de los Condenados realizando un chequeo de Liderazgo (utilizando su propio atributo de Liderazgo). Si el chequeo tiene éxito, hasta la subfase de Inicio del Turno de tu próximo turno, este personaje y cualquier unidad a la que se haya unido ganan:
• Salvación Especial de 6+ contra cualquier herida sufrida.
• Salvación especial de 5+ contra cualquier herida sufrida causada en combate por un enemigo con las reglas especiales Miedo o Terror.</description>
        </rule>
        <rule id="3cc5-a6d8-26a1-5fd7" name="Celote" hidden="false">
          <description>Un personaje con esta regla especial solo puede unirse a una unidad con la regla especial Fervor Fanático.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4bcd-b684-6c5a-e64b" name="Infantería ligera (Regular infantry)" hidden="false" targetId="05da-ff1b-7967-58ec" type="rule"/>
        <infoLink id="6769-6488-71c8-6b00" name="Carga devastadora (Furious charge)" hidden="false" targetId="768a-7271-1e00-6be5" type="rule"/>
        <infoLink id="00cc-feff-7c7b-d3b5" name="Inmune a la psicología (Immune to psychology)" hidden="false" targetId="acf4-8cb7-67f0-f838" type="rule"/>
        <infoLink id="45ad-e02e-c895-6206" name="Impetuosos (Impetuous)" hidden="false" targetId="11c7-ee78-1924-fed8" type="rule"/>
        <infoLink id="7406-45ed-e94c-b8ca" name="Odio (todos los enemigos) (Hatred)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
        <infoLink id="49d6-14d9-b748-cdc3" name="Indesmoralizable (Unbreakable)" hidden="false" targetId="f351-e61b-a183-42e3" type="rule"/>
