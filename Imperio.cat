                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">El Cazador de Brujas y cualquiera unidad a la que se haya unido obtienen las reglas especiales Odio (miniaturas No Muertas) y Ataques Flamígeros.</characteristic>
                      </characteristics>
                    </profile>
