    <selectionEntryGroup id="483a-d0c0-f4d6-7407" name="Runas magistrales de estandartes" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aae8-64b4-ce55-89ff" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="396c-7779-27ae-4fe8" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f161-4d26-d005-a1a9" name="Runa magistral de la duda" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8dd4-6309-3538-88d0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9d94-1eb6-c5e1-b59f" type="max"/>
          </constraints>
          <profiles>
            <profile id="1441-8f55-cb91-21a4" name="Runa magistral de la duda" hidden="false" typeId="e704-bfaf-a21f-bee4" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="b06b-5df0-760b-c3be">Una unidad enemiga que carga contra el arco frontal de una unidad que lleva un estandarte inscrito con la Runa Magistral de la Duda no cuenta que ha cargado para el propósito de elegir qué arma usar o cualquier regla especial que pueda tener.
Ten en cuenta que una unidad que porta esta runa todavía cuenta como que ha sido cargada por una unidad enemiga.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7fef-7373-10a3-6268" name="Runa magistral de Stromni Barbaroja" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="342d-21e9-f785-c04b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e776-1fe4-b436-402e" type="max"/>
          </constraints>
          <profiles>
            <profile id="a86f-b163-dbe8-d115" name="Runa magistral de Stromni Barbaroja" hidden="false" typeId="e704-bfaf-a21f-bee4" typeName="Runa de estandarte">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="b06b-5df0-760b-c3be"> Al calcular el resultado del combate, cualquier unidad amiga dentro del Aura de mando del portador del estandarte inscrito con la Runa Magistral de Stromni Barbaroja puede reclamar un bonificador adicional de +1 punto al resultado de combate.</characteristic>
