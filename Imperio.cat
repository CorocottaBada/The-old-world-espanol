          <profiles>
            <profile id="95da-4667-7f36-e3c0" name="Runa de fuego rápido" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Un arma inscrita con esta runa obtiene las reglas especiales Disparos múltiples (2) y Disparo Rápido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
