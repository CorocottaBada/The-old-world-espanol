          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="5.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="65a7-155e-83d9-9b61" name="Runa del guerrero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5130-4a13-07fa-178f" type="max"/>
          </constraints>
          <profiles>
            <profile id="7ef2-14d7-0426-b15b" name="Runa del guerrero" hidden="false" typeId="3257-a4e1-1c47-57c1" typeName="Tatuaje rúnico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="7c1d-1a04-afd2-2035">Una miniatura con este tatuaje rúnico tiene un modificador +1 a su atributo de Habilidad de Armas.</characteristic>
