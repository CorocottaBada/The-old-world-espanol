              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Al realizar una tirada para Herir con un arma inscrita con la Runa Magistral de Skalf Martillonegro, un resultado de 2+ siempre es un éxito independientemente de la Resistencia del objetivo.</characteristic>
              </characteristics>
