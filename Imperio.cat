          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c5b8-1827-48b7-358f" type="max"/>
          </constraints>
          <profiles>
            <profile id="29da-78b4-8fa1-1622" name="Runa del destierro" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Las miniaturas enemigas con la regla especial Nacidos de la Disformidad no pueden realizar salvaciones especiales contra impactos causados por un arma inscrita con la Runa del Destierro.</characteristic>
              </characteristics>
            </profile>
