                <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1d79-234c-90da-f371" type="min"/>
              </constraints>
              <rules>
                <rule id="ae7c-d209-ca04-30fe" name="Acusación" hidden="false">
                  <description>Cada Cazador de Brujas de tu ejército debe tener una de las siguientes ‘especializaciones’, elegidas al redactar la lista de ejército. Tal especialización indica a cuál de los diversos enemigos de la humanidad da caza. Debes indicarle a tu oponente que especialización tiene cada Cazador de Brujas al desplegar tu ejército:</description>
                </rule>
              </rules>
              <selectionEntries>
                <selectionEntry id="0715-7e12-67d5-0740" name="La bruja" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3a20-8e5e-2c08-aca3" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="01d9-a93d-cd83-284a" name="La bruja" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">El Cazador de Brujas y cualquiera unidad a la que se haya unido obtienen las reglas especiales Odio (Hechiceros enemigos) y Resistencia a la Magia (-2).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <infoLinks>
                    <infoLink id="3b27-fb3a-5b62-deff" name="Odio (X)" hidden="false" targetId="761c-24c3-ec93-521b" type="rule"/>
                    <infoLink id="d965-3cb0-2de0-7aa5" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
                  </infoLinks>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
