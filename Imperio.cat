      <selectionEntries>
        <selectionEntry id="6dc2-c443-5ac8-7f72" name="Runa de la fuerza conmocionante" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e3d-4dde-72ca-b285" type="max"/>
          </constraints>
          <profiles>
            <profile id="00f6-f9bb-ade2-9262" name="Runa de la fuerza conmocionante" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Una unidad impactada con un ataque realizado por un arma inscrita con esta runa gana la regla especial Estupidez hasta tu próxima subfase de Inicio de Turno.</characteristic>
