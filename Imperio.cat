              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Por cada Runa de Poder inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Fuerza.</characteristic>
              </characteristics>
            </profile>
