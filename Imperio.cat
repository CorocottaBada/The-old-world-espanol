            <profile id="c88c-e382-25e9-5742" name="Runa del fuego" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">El portador de un arma inscrita con la Runa del Fuego gana la regla especial Ataques Flamígeros.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="c320-957c-ab3c-2545" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="d1cd-2b64-27e1-219b" name="Runa de ataque" hidden="false" collective="false" import="true" type="upgrade">
