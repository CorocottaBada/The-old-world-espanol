        <selectionEntry id="0234-33e5-2580-91c6" name="Protector del cazador de brujas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="580b-0dcf-be62-b9f2" type="max"/>
          </constraints>
          <profiles>
            <profile id="8173-b336-4294-49b1" name="Protector del cazador de brujas" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Una miniatura que porte un Protector del Cazador de Brujas tiene la regla especial Resistencia a la Magia (-2). Además, una vez por partida, el portador de un Protector del Cazador de Brujas puede repetir una única tirada fallida de Salvación de Armadura.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="5dec-19ff-7034-2485" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
