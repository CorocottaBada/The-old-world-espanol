    <selectionEntryGroup id="5b5f-9b98-f8c9-b979" name="Armaduras mágicas. El Imperio. Armadura" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a087-e135-0fb3-47ba" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9e91-b28b-19d1-6d72" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="946b-67e1-1082-943e" name="Armadura de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="eef1-51a9-70ad-062a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0cae-afd3-5042-fe92" type="max"/>
          </constraints>
          <profiles>
            <profile id="69e1-0d0a-e6cc-7669" name="Armadura de la fortuna" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de la Fortuna es una armadura pesada. Además, su portador tiene una Salvación Especial de 6+ contra cualquier herida sufrida y es inmune a la regla especial Golpe Letal. Si el portador recib un Golpe Letal, se permite Salvación por Armadura y Regeneración de manera normal. Si no se salva la herida, pierde una única Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1853-6353-91a6-88f5" name="Armadura pesada" hidden="false" targetId="2dfa-2e0a-7b31-48f1" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="45.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5025-00c0-2d82-85ca" name="Armadura dos veces bendita" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="110a-a9b5-9c5e-911e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="077c-78c0-cb3e-b8d1" type="max"/>
          </constraints>
          <profiles>
            <profile id="3fc0-85b9-f3af-1843" name="Armadura dos veces bendita" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">4+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura Dos Veces Bendita es una armadura completa. 
Además, el portador puede lanzar el hechizo Manomartillo del Saber de la Magia de Batalla (ver página 320 del reglamento
Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="fb0e-226e-e152-6ea5" name="Armadura completa" hidden="false" targetId="610a-e0ce-0272-9fdc" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
