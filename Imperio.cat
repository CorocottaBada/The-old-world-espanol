      </constraints>
      <selectionEntries>
        <selectionEntry id="ae72-c85d-84e1-29aa" name="Armadura de Tarnus" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="70a3-70b0-8728-806c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c428-f5ca-962b-75d1" type="max"/>
          </constraints>
          <profiles>
            <profile id="1bf1-7086-cb5d-2995" name="Armadura de Tarnus" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">La Armadura de Tarnus es una armadura ligera que puede ser equipada y utilizada por un Hechicero del Imperio, incluso si no tienen opción de equipar armadura, escudo o barda, sin restricción. Además, su portador tiene una Salvación Especial de 5+ contra cualquier herida sufrida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="1549-071c-a5ab-1111" name="Armadura ligera" hidden="false" targetId="6636-8cd5-1710-4312" type="profile"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
