                    <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F+2</characteristic>
                    <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-2</characteristic>
                    <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Perforacorazas (1), Ataques mágicos. </characteristic>
                    <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">El Filo del Dragón está inscrita con una Runa de Furia y una Runa de Rencor, como se describe en la página 34 de Forces of Fantasy.</characteristic>
                  </characteristics>
                </profile>
                <profile id="e70a-16f3-0c6b-968b" name="Runa de la furia" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Por cada Runa de la Furia inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Ataques.</characteristic>
                  </characteristics>
                </profile>
                <profile id="ae39-cd8b-5ff2-a060" name="Runa magistral del rencor" hidden="false" typeId="6688-7006-60f6-ef0e" typeName="Runa talismánica">
                  <characteristics>
                    <characteristic name="Reglas especiales" typeId="64d0-4e43-a301-0f53">Cada vez que el portador de la Runa Magistral del Rencor pierde una herida por un ataque enemigo durante la fase de Combate, la unidad que realizó ese ataque sufre un impacto de Fuerza 5 con una PA de -2.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="4798-693a-9349-1e4b" name="Ataques mágicos" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
                <infoLink id="d5da-985a-0ac2-a89f" name="Perforacorazas (X)" hidden="false" targetId="cfd0-c88b-8c52-5b6c" type="rule"/>
              </infoLinks>
