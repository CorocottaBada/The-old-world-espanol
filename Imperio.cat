          </constraints>
          <profiles>
            <profile id="af11-5099-e69f-d4ac" name="Runa de ataque" hidden="false" typeId="0275-9069-bdfc-5d34" typeName="Runa de arma">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="ea5f-8997-17ce-8e25">Por cada Runa de Ataque inscrita en un arma, su portador tiene un modificador de +1 a su atributo de Habilidad de Armas.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
