      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cdda-0ad4-4d76-5e66" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4b9-d446-7337-3bfe" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="3ffe-768b-eb87-91eb" name="Estandarte imperial" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0e3f-a83f-5d77-63d1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4513-b437-ba20-69e2" type="max"/>
          </constraints>
          <profiles>
            <profile id="2e7e-8ee9-560a-edc7" name="Estandarte imperial" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Todas las unidades dentro del Aura de Mando de la miniatura que porta el Estandarte Imperial tiran 3D6 al hacer chequeos de Miedo, Pánico o Terror y descartan el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="60.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="8659-7ff4-a961-adf6" name="Estandarte del grifo" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ecaf-a96f-6708-0d65" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5b61-3584-21d3-879b" type="max"/>
          </constraints>
          <profiles>
            <profile id="769d-a32e-9e7e-6d89" name="Estandarte del grifo" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando se calcula el Resultado del combate, una unidad que porta el Estandarte del Grifo suma un Bonificador por Filas de +2 por cada fila extra tras la primera, en vez del +1 habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dbee-bc0e-6baf-41e4" name="Pendón reluciente" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1ed9-cdfc-3ae0-4f24" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8cfa-c789-2cff-27a1" type="max"/>
          </constraints>
          <profiles>
            <profile id="e7ff-f81e-0ae9-6dbc" name="Pendón reluciente" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Una unidad que porta el Pendón Reluciente puede repetir un único Chequeo de Liderazgo fallado.
Ten en cuenta que Chequeo de Desmoralización no es un Chequeo de Liderazgo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="784e-e1d3-7a69-9dfb" name="Estandarte del deber" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d9a7-3b01-034b-20e4" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b905-1461-142d-04f4" type="max"/>
          </constraints>
          <profiles>
            <profile id="0952-3e1e-cfd3-6c15" name="Estandarte del deber" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porta el Estandarte del Deber puede repetir cualquier Chequeo de Reagrupamiento fallido.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="fa1e-414d-ac1d-05ae" name="Tapiz del triunfo de Sigmar" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="38e1-b312-38a5-aa1c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3b7d-a780-39f9-645a" type="max"/>
          </constraints>
          <profiles>
            <profile id="e787-b6fc-1fbe-aad9" name="Tapiz del triunfo de Sigmar" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Tapiz del Triunfo de Sigmar puede repetir cualquier resultado natural de 1 para Herir durante la primera ronda de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="daa1-f822-12b4-2553" name="Icono de Morr" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="0d21-d1c7-bf87-5ab5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="33b7-9f35-b669-7b2d" type="max"/>
          </constraints>
          <profiles>
            <profile id="93bb-0433-aa26-71d8" name="Icono de Morr" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Ícono de Morr gana la regla especial Miedo. Si ya tiene esta regla, en su lugar gana la regla especial Terror.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f369-7629-97de-7304" name="Miedo (Fear)" hidden="false" targetId="130d-c528-a7f6-ed8e" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="70e6-e754-d88a-d9da" name="Objetos hechizados. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="650b-fffa-5b52-330e" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7083-d164-8713-d16b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="ef39-45dc-5868-a2a1" name="Laurel de la victoria" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="6165-706f-17b3-d5b6" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b49d-92fa-30ad-3810" type="max"/>
          </constraints>
          <profiles>
            <profile id="2eb5-6674-b777-91ee" name="Laurel de la victoria" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Cuando se determine el resultado de tu combate, cada herida no salvada causada por un ataque hecho por el portador del Laurel de la Victoria se cuenta como 2 puntos para el resultado del combate, en vez de 1 punto habitual.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4fab-71a0-aa42-316d" name="Manto de hierro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="1efb-9346-7f22-17e5" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="80ad-2818-d3c8-1e3f" type="max"/>
          </constraints>
          <profiles>
            <profile id="efc4-39c5-0898-a759" name="Manto de hierro" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">El portador del Manto de Hierro (y cualquier unidad a la que se haya unido) tiene una Salvación Especial de 6+ contra cualquier herida causada por una plantilla no-mágica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="938c-2f51-3c03-5126" name="Anillo de la fortuna" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4c8e-394b-8cee-5e21" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="eaa6-0178-0e6c-3e46" type="max"/>
          </constraints>
          <profiles>
            <profile id="3d20-839f-3791-38dd" name="Anillo de la fortuna" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de la Fortuna puede repetir cualquier tirada fallida para Herir realizada durante la fase de Combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="50ed-52b3-4bd0-856f" name="Anillo de Taal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="67d7-f46e-9d55-3f6e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2954-372e-5022-d9c8" type="max"/>
          </constraints>
          <profiles>
            <profile id="98f8-7a13-3674-9372" name="Anillo de Taal" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Anillo de Taal puede lanzar el hechizo Escudo de Roble del Saber de la Magia de Batalla (ver página 321 del reglamento de Warhammer: the Old World) como Hechizo Vinculado, con Nivel de Energía 3.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="62d0-67f8-af13-f4d9" name="Objetos hechizados. El Imperio. Zancada veloz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="86ef-5623-3fea-d574" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2884-a679-02c8-b667" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="2fb5-255a-c37f-d9e9" name="El cuerno de plata" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c982-9de9-3816-32d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a9fe-dedd-f0e3-a236" type="max"/>
          </constraints>
          <profiles>
            <profile id="1688-2c92-2af7-1ff7" name="El cuerno de plata" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Sólo personajes con la regla especial Zancada Veloz. El portador del Cuerno de Plata (y cualquier unidad a la que se haya unido) puede repetir el 1D6 de la regla especial Zancada Veloz.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="9594-ec6d-66af-30e9" name="Zancada veloz" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="2fdb-068f-2ed5-8048" name="Objetos arcanos. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4636-f8d2-751d-506f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fdd0-5a88-2d8d-3fd6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="e345-a33b-caa4-617b" name="Libro de los Ashur" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="3d64-447b-fa52-24d3" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9e0-f6d5-d479-dfbd" type="max"/>
          </constraints>
          <profiles>
            <profile id="43a5-d4d8-b0ff-57a4" name="Libro de los Ashur" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Libro de los Ashur aumenta su Alcance de Dispersión en 3” y, excepto si obtiene algún resultado de doble natural, puede aplicar un modificador de +1 a cualquiera de sus tiradas de Lanzamiento o Dispersión. Sin embargo, si el portador obtiene un resultado de doble natural al hacer una tirada de Lanzamiento o Dispersión, resulta que el libro es una pobre reproducción, lleno de errores garrafales, y el modificador de +1 no se puede aplicar a esta tirada.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="85.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="b69a-aa49-0727-e34c" name="Varita de dos colas" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="8637-ddf2-f904-8f68" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="26fa-9940-29c2-078b" type="max"/>
          </constraints>
          <profiles>
            <profile id="bacc-9587-47ce-276f" name="Varita de dos colas" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, el portador de la Varita de Dos Colas puede intentar lanzar uno de sus hechizos una segunda vez.
Sin embargo, si realiza una disfunción al lanzar el hechizo, el portador se ve abrumado por los Vientos de la Magia y, en lugar de tirar en la tabla de Disfunción Mágica, sufre 1D3 heridas sin poder hacer tiradas de salvación por Armadura o Regeneración (las tiradas de salvación Especiales se pueden intentar como de costumbre).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="1f92-40a6-d27d-20b1" name="Tomo de medianoche" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ea09-8cfe-37cb-80f1" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0d77-441c-e0e1-04b0" type="max"/>
          </constraints>
          <profiles>
            <profile id="1412-17d9-526d-bd1d" name="Tomo de medianoche" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">El portador del Tomo de la Medianoche puede aplicar un modificador de +1 a cualquier tirada de Lanzamiento al intentar lanzar hechizos de los Saberes de Demonología, Magia Oscura o Nigromancia. Además, conoce un hechizo adicional (elegido de la manera habitual) más de lo que es normal para su Nivel de Hechicería. Sin embargo, el portador sólo puede lanzar un número de hechizos igual a su Nivel de Hechicería por turno y está sujeto a la regla especial Solitario.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="87a7-a3f4-4a6a-7471" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0198-7472-d61a-cc4e" name="Bola de cristal" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="7a6b-b8bc-c711-496a" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9c9b-5774-7981-02c6" type="max"/>
          </constraints>
          <profiles>
            <profile id="a9c1-a8da-3ecb-7e05" name="Bola de cristal" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Una vez por turno, puedes hacer que tu oponente repita una sola tirada para Impactar o Herir realizada contra una miniatura amiga que esté dentro del Aura de Mando del portador de la Bola de Cristal.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="95ae-c498-e1bd-115d" name="Solitario (Loner)" hidden="false" targetId="6abd-8468-abaf-eb56" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ecd5-4850-f21d-50e9" name="Objetos arcanos muy comunes. El Imperio" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3138-e66b-05bf-00c3" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ee44-4e34-a936-d90c" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="dcff-d497-cc56-89ba" name="Familiar del hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c9e7-5020-cb84-c1a7" type="max"/>
          </constraints>
          <profiles>
            <profile id="e15f-0bdf-e913-f7f1" name="Familiar del hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El dueño de un Familiar del hechicero puede aplicar un modificador de +1 a cualquiera de sus tiradas de Dispersión. 
Ten en cuenta que es un modificador al resultado de la tirada – no niega una tirada de doble 1 natural.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="35.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5443-243a-aff2-94ed" name="Báculo de hechicero" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="34e7-6057-cdbc-119f" type="max"/>
          </constraints>
          <profiles>
            <profile id="a50e-c044-ee97-1c41" name="Báculo de hechicero" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">0-1 por cada Hechicero. El portador del Báculo de Hechicero obtiene un modificador de +1 a su tirada de Lanzamiento cuando intenta lanzar un hechizo de tipo Asalto o Proyectil Mágico</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="f96a-3d2a-f12e-7b6c" name="Runas de armas de ingenieros. Ballesta, Arcabuz" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3bb4-cd46-2f59-3e8b" type="max"/>
