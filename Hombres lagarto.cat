              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">Cualquier miniatura enemiga que dirija sus ataques contra el portador del Aura de Quetzl en la fase de combate sufre un modificador de -1 a sus tiradas para impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
