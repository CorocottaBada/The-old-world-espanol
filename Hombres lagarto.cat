              <selectionEntries>
                <selectionEntry id="2666-4ab3-fec0-64eb" name="Artilugio solar" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="40da-f4dc-cb93-58ba" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="fbd3-54f4-5ea2-25aa" name="Artilugio solar (Solar engine)" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Resplandor Solar: Mientras estén a 6” de uno o más Artilugios solares, las unidades amigas con la regla especial Sangre Fría (Cold blooded)obtienen un modificador de +1 a su Iniciativa.
Rayo de Chotec: Esta miniatura puede lanzar el siguiente Hechizo vinculado con un poder de 2
- Tipo: Proyectil Mágico
- Valor del lanzamineto: 9+
- Alcance: 24”
- Efecto: La unidad enemiga objetivo sufre 3D3 impactos de Fuerza 5, cada uno con un AP de -2. Este hechizo vinculado tiene la regla especial Ataques Flamígeros (Flaming Attacks).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="8a68-df1d-e839-988b" name="Arca de Sotek" hidden="false" collective="false" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b101-b5e3-031c-cf40" type="max"/>
                  </constraints>
                  <profiles>
                    <profile id="6ff4-476d-4e46-cc5e" name="Arca de Sotek (Ark of Sotek)" hidden="false" typeId="9f78-29a2-5818-670f" typeName="Objeto">
                      <characteristics>
                        <characteristic name="Reglas especiales" typeId="4d20-e592-9954-386f">Serpientes Deslizantes: Durante la subfase de Comando de su turno, cada unidad enemiga dentro de D6” de este modelo sufre 2D6 impactos de Fuerza 2, sin PA.
Descendencia de Sotek: Durante la subfase de Comando de su turno, tira 1D6. Con un resultado de 4 o más, un unico Enjambre de la Jungla dentro de 6” de este modelo recupera 1D3 Heridas perdidas.</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
