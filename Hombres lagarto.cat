              </characteristics>
            </profile>
            <profile id="b4ff-b35f-d106-57e0" name="Báculo del sol perdido (Staff of the lost sun) (Distancia)" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
