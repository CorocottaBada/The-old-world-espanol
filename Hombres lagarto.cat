          </constraints>
          <profiles>
            <profile id="334d-5d20-1b0e-8240" name="Deliberaciones introspectivas (Wandering deliberation)" hidden="false" typeId="d21a-3a43-f476-2dc3" typeName="Disciplina de los Ancestrales">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="685c-0e30-6412-66b4">En lugar de generar conjuros normalmente, este personaje conoce cuatro hechizos Identificativos, elegidos entre los siguientes Saberes de Magia: Magia de Batalla (Battle Magic), Demonología (Daemonology), Magia Oscura (Dark Magic), Elementalismo (Elementalism), Alta Magia (High Magic), Ilusionismo (Illusion) y Nigromancia (Necromancy).
El personaje puede descartar uno de estos hechizos en favor de un hechizo del Saber de Lustria (Lore of Lustria).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="3d90-5e3d-6bfc-b000" name="Meditación apaciguada (Becalming cogitation)" hidden="false" collective="false" import="true" type="upgrade">
