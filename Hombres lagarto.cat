                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos (Magical attacks), Disparos múltiples (3) (Multiple shots).</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">-</characteristic>
