              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador del Gargantilla de los glifos tiene una salvación especial de 5+ contra cualquier herida sufrida y gana la regla especial Resistencia a la magia (-2) (Magic Resistance).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="d684-5b77-116d-cc86" name="Resistencia a la magia (-X)" hidden="false" targetId="7cb2-1d7d-5d97-e41c" type="rule"/>
