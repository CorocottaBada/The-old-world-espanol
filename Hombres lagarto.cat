    <selectionEntryGroup id="14d5-96f0-bde2-1257" name="Armaduras mágicas. Hombres lagarto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8e14-5c8f-9ff7-73ee" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8030-6ce6-4245-1e32" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f2e9-a448-6d88-6080" name="Piel de gélido (Hide of the cold ones)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="c085-e4a1-9a56-009c" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1d2d-d139-ca18-bdb1" type="max"/>
          </constraints>
          <profiles>
            <profile id="966a-0378-9a22-202b" name="Piel de gélido (Hide of the cold ones)" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Puede llevarse con otras armaduras. El portador de la Piel de gélido obtiene +1 a su Armadura (hasta un máximo de 2+). Sin embargo, su portador también está sujeto a la regla especial Estupidez (Stupidity).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="f727-48eb-4965-de6a" name="Estupidez (Stupidity)" hidden="false" targetId="e78e-de09-5640-bcda" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c408-418b-7883-febc" name="Armaduras mágicas. Hombres lagarto. Escudo" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="31b9-137a-2c94-d972" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bfea-94df-0d70-a73b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="f3b4-c803-a04b-d6a2" name="Escudo del estanque cristalino (Shield of the mirror pool)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="ab11-b76b-70d1-44ee" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="839c-1ea9-468e-974d" type="max"/>
          </constraints>
          <profiles>
            <profile id="4498-6a2e-26dc-bf37" name="Escudo del estanque cristalino (Shield of the mirror pool)" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">6+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">El Escudo del Estanque Cristalino es un Escudo. Además, cada vez que el portador pierde una o más Heridas por un Proyectil Mágico, el lanzador sufre un único impacto de Fuerza 5 con un PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="351a-d5eb-d07a-4bed" name="Objetos hechizados. Hombres lagarto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1cd3-9f4d-3638-5a68" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ebfd-a763-67cc-7a6f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="5182-7bdf-7f89-a8f1" name="Veneno de la rana luciérnaga (Venom of the firefly frog)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="fb36-034c-14b8-342b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4440-2209-8a7e-7422" type="max"/>
          </constraints>
          <profiles>
            <profile id="10d6-c672-da07-86dd" name="Veneno de la rana luciérnaga (Venom of the firefly frog)" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Todos los ataques efectuados durante la fase de combate por el portador del Veneno de la rana de lu tienen las reglas especiales Ataques envenenados (Poisoned Attacks) y Ataques Flamigeros (Flaming Attacks). 
Ten en cuenta que esto solo se aplica a las armas no mágicas y no se aplica a la montura (en caso de que tenga una).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="7f3e-bb0f-7c26-feed" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
            <infoLink id="08c8-843d-c70a-6b71" name="Ataques flamígeros (Flaming attacks)" hidden="false" targetId="8ec0-f4b0-6a6f-9a94" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="583b-a4a2-1c97-305e" name="Objetos hechizados. Hombres lagarto. Héroe eslizon. Infantería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7a0f-ec2d-8fbb-d4be" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="973c-6d31-008a-f8b5" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="6c77-8de1-ff3e-88e5" name="Capa de plumas de águila (Cloak of feathers)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="2e2f-04d9-74c2-bce9" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d8e-f308-b84d-8ea0" type="max"/>
          </constraints>
          <profiles>
            <profile id="6508-21f7-5eb2-faa7" name="Capa de plumas de águila (Cloak of feathers)" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Héroes Eslizón cuyo tipo de tropa es sólo “infantería”. El portador dea Capa De Plumas de Águila gana las reglas especiales Volar (10) (Fly) y Zancada velóz (Swiftstride).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="37ef-719c-dfde-6a75" name="Volar (X)" hidden="false" targetId="bb53-86f7-9f3c-4cd1" type="rule"/>
            <infoLink id="8604-bc28-f9d7-03ad" name="Zancada veloz (Swiftstride)" hidden="false" targetId="474c-d22f-3b09-6ee9" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ee1f-0d01-6f22-8328" name="Objetos hechizados muy comunes. Hombres lagarto. Héroe saurio. Gélido" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c2cd-2dd9-e4e4-4b8f" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="108a-42bf-d22d-1168" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="229e-ef55-b148-de32" name="Gélido cornudo (Horned one)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7fca-0f4a-205e-d255" type="max"/>
          </constraints>
          <profiles>
            <profile id="e756-6afa-e904-b0dc" name="Gélido cornudo (Horned one)" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Este objeto mágico sólo puede ser cogido por un Heroe Saurio montado en Gelido. La montura de este personaje pierde la regla especial Estupidez (Stupidity) y tiene una característica de Movimiento de 8.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="10.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="285f-fc77-cd21-5b34" name="Objetos arcanos. Hombres lagarto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4fc3-7c86-ee5a-9493" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d6b8-4c15-3cea-7c95" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="7c3f-e177-b4f4-846d" name="Manos de los Ancestrales (Cupped hands of the Old ones)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b894-1824-53c2-8060" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f3af-5c32-1865-5a7a" type="max"/>
          </constraints>
          <profiles>
            <profile id="156e-472c-a941-bc9b" name="Manos de los Ancestrales (Cupped hands of the Old ones)" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Si el portador de las Manos de Los Ancestrales falla el lanzamiento de un hechizo, tira un 1D6. Con un 1, el portador hace una tirada normal en la tabla de Disfunciones. Con una tirada de 2+, el portador nombra a un personaje enemigo. Centra una plantilla de Área pequeña (3”) sobre este personaje. Cada miniatura cuya base se encuentre bajo la plantilla se arriesga a ser alcanzado y sufrir un único impacto de fuerza 6 con un PA de -2.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="8d94-3762-9694-513f" name="Objetos arcanos muy comunes. Hombres lagarto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ece4-ebf7-99bb-29dc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="0095-10a4-38dc-508b" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="660d-e2eb-9c15-79f2" name="Comida de Itxi (Itxi grub)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c94a-7822-4ea9-3e11" type="max"/>
          </constraints>
          <profiles>
            <profile id="30a8-5bd3-e4cc-6c58" name="Comida de Itxi (Itxi grub)" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Antes de hacer una tirada de lanzamiento, el portador puede intentar consumir una Comida de Itxi haciendo un chequeo de resistencia. Si se supera la prueba, el portador puede aplicar un modificador de +3 a la tirada de lanzamiento. Sin embargo, si la prueba es fallida, el portador pierde inmediatamente una Herida.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="927d-a38f-95c5-fbf7" name="Cubo de la oscuridad (Cube of darkness)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="938f-b4bf-0c22-54e0" type="max"/>
          </constraints>
          <profiles>
            <profile id="838d-c429-8760-f31d" name="Cubo de la oscuridad (Cube of darkness)" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">Un solo uso. Un Mago puede usar este objeto en lugar de hacer un intento de disipación. Si lo hace, el hechizo se disipa automáticamente sin necesidad de tirada de Disipar. Además, todos los hechizos “permanecen en juego “ actualmente en juego se disipan, incluyendo los hechizos lanzados por Magos amigos.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="50.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="0699-b40a-6270-a9d2" name="Estandartes mágicos. Hombres lagarto" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="2a0b-6d2c-2da7-bdb2" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f1ab-c620-2200-e34e" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="866e-15f0-fbd4-f716" name="Estandarte del jaguar (Jaguar standard)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="cd21-58b9-1b62-28fb" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="1426-855c-2cb6-9f06" type="max"/>
          </constraints>
          <profiles>
            <profile id="d84b-5010-0e85-ef07" name="Estandarte del jaguar (Jaguar standard)" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Cuando una unidad que lleva el Estandarte Jaguar hace una tirada de Persecución puede tirar 1D6 extra y descartar el resultado más bajo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="0b36-0e1a-6ae2-91bf" name="Estandarte del sol de Chotec (Sun standard of Chotec)" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="4f4b-ffac-9d4b-d05b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de4b-ae63-721c-0146" type="max"/>
          </constraints>
          <profiles>
            <profile id="36b8-d4c6-d3bb-f26b" name="Estandarte del sol de Chotec (Sun standard of Chotec)" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Las unidades enemigas no pueden declarar una reacción de carga de Aguantar y Disparar (Stand &amp; Shoot) contra una unidad que lleve el Estandarte del Sol de Chotec. Además, cualquier miniatura enemiga que haga objetivo a una unidad que lleve este estandarte durante la fase de disparo sufre un modificador adicional de -1 a impactar.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
