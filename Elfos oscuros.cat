                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-1</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Perforacorazas (1), Ataques envenenados, DIsparos múltiples (1D3+1)</characteristic>
