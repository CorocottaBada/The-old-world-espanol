    <selectionEntryGroup id="db54-fcd5-9540-4cc2" name="Armaduras mágicas. Elfos oscuros. Infantería o Caballería" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6de2-4d8f-5d3e-351d" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e6f8-fce7-8841-50e6" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="39fc-470d-fdfa-a930" name="Armadura sangrienta" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="f821-b5bb-0403-bf5e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="db51-f5dc-4920-a2d8" type="max"/>
          </constraints>
          <profiles>
            <profile id="986e-baaa-2e4d-2f27" name="Armadura sangrienta" hidden="false" typeId="a5e2-0a90-194d-07a3" typeName="Armadura mágica">
              <characteristics>
                <characteristic name="Salvación" typeId="12f6-1232-c5c9-e54a">5+</characteristic>
                <characteristic name="Reglas especiales" typeId="2e5e-d42c-3188-c248">Solo miniaturas cuyo tipo de tropa es “infantería” o “caballería”. La Armadura Sangrienta es una armadura que le da a su portador un Valor de Armadura de 5+. Por cada Herida no Salvada que inflige el portador, este Valor de Armadura mejora en 1, hasta un máximo de 2+.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="30.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="ee2d-08c8-25ed-061a" name="Armaduras mágicas. Elfos oscuros. Escudo" hidden="false" collective="false" import="true">
