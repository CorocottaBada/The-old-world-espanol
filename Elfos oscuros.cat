        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="39f8-7fad-5c36-fb36" type="max"/>
      </constraints>
      <rules>
        <rule id="7021-c638-5c82-e715" name="Aquelarre maldito" hidden="false">
          <description>Una unidad de Brujos Fuegoletal conoce un único hechizo (elegido por el jugador que los controla antes de que los ejércitos desplieguen) de los Saberes de Magia Oscura o Demonología. La unidad podrá lanzar este hechizo como un Hechizo Vinculado:
Si la unidad tiene Potencia de Unidad de 10 o más e incluye un Maestre, lanzará su Hechizo Vinculado con un Nivel de Energía 2.
Si la unidad contiene un Maestre, pero tiene una Potencia de Unidad de 9 o menos, entonces lanzará su Hechizo Vinculado con un Nivel de Energía 1.
En cualquier otro caso, la unidad lanzará su Hechizo Vinculado con un Nivel de Energía 0.</description>
        </rule>
        <rule id="6150-585b-89ee-8952" name="Runas oscuras" hidden="false">
          <description>Esta unidad tiene una Salvación Especial de 5+ contra cualquier Herida causada por ataques no mágicos.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="8e35-1f8f-afdd-7545" name="Ataques envenenados (Poisoned attacks)" hidden="false" targetId="5501-acd0-b3b2-3d48" type="rule"/>
