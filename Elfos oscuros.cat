            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7a29-5c55-a35f-ffdd" type="max"/>
          </constraints>
          <profiles>
            <profile id="d9bc-33fc-ccc2-cbe4" name="Espada de la ruina" hidden="false" typeId="6493-e737-ded4-9e61" typeName="Arma mágica">
              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">Combate</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">*</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">No se permiten tiradas de salvación por armadura, especiales o regeneración contra Heridas causadas por la Espada de la Ruina.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="16e2-f67b-194c-e6ba" name="Ataques mágicos (Magical attacks)" hidden="false" targetId="4829-1312-9809-b543" type="rule"/>
