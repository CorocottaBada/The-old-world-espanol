          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="acb9-1581-00bc-0aeb" name="Talismanes. Elfos oscuros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="72c7-09af-ecfe-15dc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a5cc-a5bc-357e-1d85" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="c41c-3d88-aef0-472c" name="Colgante de Khaeleth" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="bb27-f589-f42e-132b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="83b3-f6ad-5e46-0c7b" type="max"/>
          </constraints>
          <profiles>
            <profile id="7394-9403-559d-ea81" name="Colgante de Khaeleth" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El Colgante de Khaeleth le da a su portador una Salvación Especial de 5+ contra cualquier herida sufrida que fue causada por un ataque con una Fuerza de 4 o menos, y una Salvación Especial de 4+ contra cualquier herida sufrida que fue causada por un ataque con una Fuerza de 5 o superior.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4d5a-073d-88d1-9017" name="Perla infinita de la desolación" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d1ee-def6-26d8-e0d0" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9480-5b0a-02cc-cdf8" type="max"/>
          </constraints>
          <profiles>
            <profile id="d67f-836e-2b92-d53e" name="Perla infinita de la desolación" hidden="false" typeId="bcd6-e5db-3243-896c" typeName="Talismán">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="57d8-87cc-3044-9dcd">El portador de la Perla de la Infinita Desolación y cualquier unidad a la que se una obtienen la regla especial Inmune a la Psicología.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="081e-8f68-66b1-ab88" name="Inmune a la psicología (Immune to psychology)" hidden="false" targetId="acf4-8cb7-67f0-f838" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="4bd2-7be8-861b-1c6a" name="Estandartes mágicos. Elfos oscuros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="67e0-5e53-08c5-5d62" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8d9e-1cc0-5f63-84f7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="88ee-a834-b466-a364" name="Estandarte de Har Ganeth" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b1b2-df0f-b205-0f77" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="21a8-d2b0-4155-3324" type="max"/>
          </constraints>
          <profiles>
            <profile id="61a0-7600-3a34-c25e" name="Estandarte de Har Ganeth" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de Har Ganeth mejora en 1 el Atributo de Penetración de Armadura de sus armas de combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="25.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7780-9d8c-64d8-b7e1" name="Estandarte de la matanza" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="d984-6e3a-68c1-7236" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6e0f-77dd-9095-67f2" type="max"/>
          </constraints>
          <profiles>
            <profile id="1e45-e72c-ea09-be13" name="Estandarte de la matanza" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Al calcular el Resultado del combate del turno en el que cargó, una unidad que lleve el Estandarte de la Matanza puede reclamar una bonificación adicional de +1D3 puntos al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="40.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9574-ab3a-416d-a022" name="Estandarte de Nagarythe" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="438f-2dbb-bbb2-3477" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="de29-ee60-c805-81c1" type="max"/>
          </constraints>
          <profiles>
            <profile id="24af-a752-bb96-f118" name="Estandarte de Nagarythe" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Una unidad que porte el Estandarte de Nagarythe obtiene la regla especial Tozudo. Además, al calcular el Resultado del combate, la unidad obtiene un bonificador de +1 punto al Resultado del combate.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink id="05e3-4862-5848-85cc" name="Tozudo (Stubborn)" hidden="false" targetId="5699-8276-5dfe-92a1" type="rule"/>
          </infoLinks>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="65.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="5dad-dce1-2cd8-c2f6" name="Estandarte de la sangre fría" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="effd-667b-990c-eb25" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b611-0717-e57f-4645" type="max"/>
          </constraints>
          <profiles>
            <profile id="ec4d-57c5-3744-c557" name="Estandarte de la sangre fría" hidden="false" typeId="32ad-74c6-6310-b5bf" typeName="Estandarte mágico">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="74d9-a2d0-7db5-d1c6">Un solo uso. Una unidad que porte el Estandarte de la Sangre fría puede usarlo al realizar cualquier chequeo de Liderazgo, incluido un Chequeo de Desmoralización. Cuando lo haga, puede tirar un 1D6 adicional y descartar el resultado más alto.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="20.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="044b-0533-a8bb-f958" name="Objetos hechizados. Elfos oscuros" hidden="false" collective="false" import="true">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3eef-1806-52de-32cc" type="max"/>
        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="5222-bbe4-e1c7-061f" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="715b-a486-42f2-51c9" name="El ojo guía" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="b9ed-caf6-17fd-0a0e" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8b35-2584-1d96-b620" type="max"/>
          </constraints>
          <profiles>
            <profile id="c754-9eb9-cebc-30c9" name="El ojo guía" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. El portador del Ojo Guía y cualquier unidad a la que se haya unido pueden repetir cualquier tirada para Impactar fallida realizada durante la fase de Disparo.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
