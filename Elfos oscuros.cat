              <characteristics>
                <characteristic name="Rango" typeId="6168-8fed-a913-cb21">9&quot;</characteristic>
                <characteristic name="Fuerza" typeId="359a-36f5-017d-23c2">F</characteristic>
                <characteristic name="PA" typeId="f69d-e565-b765-c1aa">-3</characteristic>
                <characteristic name="Reglas especiales" typeId="81fc-c27b-3dac-726e">Ataques mágicos, Disparo rápido, Mover y disparar</characteristic>
                <characteristic name="Notas" typeId="3ba6-81f2-086f-214d">Esta arma puede lanzarse contra una miniatura específica dentro de la Unidad Objetivo, como un campeón o un personaje.</characteristic>
              </characteristics>
            </profile>
            <profile id="38e6-2000-d5a6-e906" name="Diente de hidra" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un Diente de Hidra es un arma de proyectiles con el siguiente perfil:</characteristic>
