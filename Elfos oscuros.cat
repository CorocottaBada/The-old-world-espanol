        <constraint field="selections" scope="parent" value="-1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="21e7-cd38-1f5d-0cb7" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="74e5-3708-1a20-f4b8" name="Tomo de Furion" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="9aa0-1ab3-4b49-dc68" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a5f8-811a-d1b5-cf19" type="max"/>
          </constraints>
          <profiles>
            <profile id="5d64-2936-1c07-b8a6" name="Tomo de Furion" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La portadora del Tomo de Furion conoce un hechizo más de lo normal (elegido como de costumbre) de los que corresponden a su Nivel de Hechicería.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4f98-4d32-dffd-c1e8" name="Báculo negro" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="roster" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" id="485e-2bb7-597a-f385" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="a3ea-67d0-b127-1938" type="max"/>
          </constraints>
          <profiles>
            <profile id="923e-ff09-caa3-6ab8" name="Báculo negro" hidden="false" typeId="3085-8165-bef9-c73d" typeName="Objeto arcano">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="1f81-b7cd-bad8-3944">La portadora del Báculo Negro puede usarlo al lanzar un hechizo. Si lo hace, en la Tirada de lanzamiento tira 1D6 adicional y descarta el resultado más bajo. Sin embargo, si se obtiene un doble 1 en dos dados cualesquiera, se obtiene una Disfunción Mágica.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="Puntos" typeId="33c0-92bb-bf87-74d4" value="55.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
    </selectionEntryGroup>
    <selectionEntryGroup id="c755-2d2f-a76b-8097" name="Objetos arcanos muy comunes. Elfos oscuros" hidden="false" collective="false" import="true">
