            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3ccf-7615-91b7-29ad" type="max"/>
          </constraints>
          <profiles>
            <profile id="cbe3-447d-04f4-8ca0" name="Huevo de dragón negro" hidden="false" typeId="50b5-2b19-1a82-0d69" typeName="Objeto hechizado">
              <characteristics>
                <characteristic name="Reglas especiales" typeId="4064-eb02-0f73-8788">Un solo uso. Durante la subfase de Mando de su turno, el portador de un Huevo de Dragón Negro puede consumirlo. Hasta el final de ese turno, la miniatura tiene un Atributo de Resistencia de 6 (que no se puede mejorar más) y adquiere el Aliento Pestilente (ver página 77).</characteristic>
              </characteristics>
            </profile>
            <profile id="5979-ae07-a6ba-18e5" name="Aliento pestilente" hidden="false" typeId="359d-698d-6873-7a3a" typeName="Arma">
              <characteristics>
                <characteristic name="Rango" typeId="9bcb-26f1-5d7c-3649">N/A</characteristic>
                <characteristic name="Fuerza" typeId="c557-04d7-ef13-1d29">2</characteristic>
